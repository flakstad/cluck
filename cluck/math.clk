;; Small math namespace for require/ns smoke coverage.

(ns cluck.math)

(defn square "Return x squared." [x]
  (* x x))

(defn sum-of-squares "Return the sum of the squares in XS." [xs]
  (reduce + 0 (mapv square xs)))

(defn report "Return a summary map for XS." [xs]
  {:count (count xs)
   :sum (reduce + 0 xs)
   :sum-of-squares (sum-of-squares xs)})
