;; Small application namespace that depends on cluck.math.

(ns cluck.examples.app
  (:require [cluck.math :as math]))

(defn report [xs]
  (let [first-value (first xs)]
    {:count (count xs)
     :sum (reduce + 0 xs)
     :sum-of-squares (math/sum-of-squares xs)
     :first-square (math/square first-value)
     :alias-square (math/square first-value)}))
