(defn draw-preview-segment-budget
  "Return the maximum number of new stroke points to preview in one frame."
  []
  24)

(defn draw-heartbeat-interval-ms
  "Return the minimum spacing between heartbeat file writes."
  []
  250)

(defn draw-watchdog-stale-ms
  "Return how long the heartbeat may stay stale before a stall is recorded."
  []
  5000)

(defn draw-watchdog-poll-ms
  "Return how often the external stall watcher checks the heartbeat."
  []
  500)

(defn draw-state-sync-interval-ms
  "Return the minimum spacing between full state-file writes."
  []
  250)

(defn draw-supervisor-poll-ms
  "Return how often the parent supervisor checks the child."
  []
  1000)

(defn init-video!
  []
  (sdl/init-video!))

(defn shutdown!
  []
  (sdl/shutdown! #f))

(defn last-error
  []
  (sdl/last-error #f))

(defn quit-requested?
  []
  (sdl/quit-requested? #f))

(defn delay-ms
  [ms]
  (sdl/delay-ms ms))

(defn draw-with-lock
  "Run THUNK while holding the draw I/O mutex."
  [thunk]
  (mutex-lock! *draw-io-lock*)
  (dynamic-wind
    (lambda () false)
    (lambda () (thunk))
    (lambda () (mutex-unlock! *draw-io-lock*))))

(defn draw-log-file-path
  "Return the path used for the draw session log."
  []
  (draw-runtime/draw-log-file-path (current-directory) *draw-log-path*))

(defn draw-crash-file-path
  "Return the path used for the latest crash snapshot."
  []
  (draw-runtime/draw-crash-file-path (current-directory) *draw-crash-path*))

(defn draw-heartbeat-file-path
  "Return the path used for draw loop heartbeats."
  []
  (draw-runtime/draw-heartbeat-file-path (current-directory) *draw-heartbeat-path*))

(defn draw-stall-file-path
  "Return the path used for detected draw stalls."
  []
  (draw-runtime/draw-stall-file-path (current-directory) *draw-stall-path*))

(defn draw-stall-sample-file-path
  "Return the path used for detected draw stall samples."
  []
  (draw-runtime/draw-stall-sample-file-path (current-directory) *draw-stall-sample-path*))

(defn draw-watchdog-script-path
  "Return the watchdog script used to capture draw stalls."
  []
  (draw-runtime/draw-watchdog-script-path (current-directory)))

(defn draw-child-runner-path
  "Return the child-runner script used by the supervisor process."
  []
  (draw-runtime/draw-child-runner-path (current-directory)))

(defn draw-control-file-path
  "Return the control file used by the supervised child."
  []
  (draw-runtime/draw-control-file-path (current-directory)))

(defn draw-child-stdout-path
  "Return the file used for child stdout/stderr capture."
  []
  (draw-runtime/draw-child-stdout-path (current-directory)))

(defn draw-process-id
  "Return the current process id."
  []
  (draw-runtime/draw-process-id))

(defn draw-wall-clock-ms
  "Return the current wall clock in milliseconds."
  []
  (draw-runtime/draw-wall-clock-ms))

(defn draw-ensure-parent-directory!
  "Ensure PATH's parent directory exists before writing a save file."
  [path]
  (draw-runtime/draw-ensure-parent-directory! path))

(defn draw-write-file-atomic!
  "Write TEXT to PATH using a temporary file and rename."
  [path text]
  (draw-runtime/draw-write-file-atomic! path text))

(defn draw-enable-logging!
  "Enable draw session logging."
  []
  (set! *draw-log-enabled?* true))

(defn draw-disable-logging!
  "Disable draw session logging."
  []
  (set! *draw-log-enabled?* false))

(defn draw-reset-preview-sync!
  "Forget any cached active-stroke preview progress."
  []
  (set! *draw-preview-point-count* 0))

(defn draw-set-log-path!
  "Override the draw session log path."
  [path]
  (set! *draw-log-path* (fs/path path)))

(defn draw-set-crash-path!
  "Override the draw crash snapshot path."
  [path]
  (set! *draw-crash-path* (fs/path path)))

(defn draw-enable-watchdog!
  "Enable the external draw watchdog."
  []
  (set! *draw-watchdog-enabled?* true))

(defn draw-disable-watchdog!
  "Disable the external draw watchdog."
  []
  (set! *draw-watchdog-enabled?* false))

(defn draw-watchdog-status
  "Return the current watchdog configuration and paths."
  []
  (draw-runtime/draw-watchdog-status *draw-watchdog-enabled?*
                                     *draw-watchdog-pid*
                                     (draw-heartbeat-file-path)
                                     (draw-stall-file-path)
                                     (draw-stall-sample-file-path)
                                     (draw-watchdog-stale-ms)
                                     (draw-watchdog-poll-ms)))

(defn draw-enable-supervision!
  "Enable the supervised child-process development mode."
  []
  (set! *draw-supervision-enabled?* true))

(defn draw-disable-supervision!
  "Disable the supervised child-process development mode."
  []
  (set! *draw-supervision-enabled?* false))

(defn draw-supervised-mode?
  "Return true when the current process should supervise a child draw window."
  []
  (draw-runtime/draw-supervised-mode? *draw-supervision-enabled?*
                                      *draw-child-mode?*))

(defn draw-supervisor-status
  "Return the current supervised-child status."
  []
  (draw-runtime/draw-supervisor-status (draw-supervised-mode?)
                                       *draw-child-mode?*
                                       *draw-child-pid*
                                       (if *draw-supervisor-thread* true false)
                                       *draw-control-seq*
                                       *draw-last-control-seq*
                                       (draw-state-file-path)
                                       (draw-control-file-path)
                                       (draw-child-stdout-path)
                                       (draw-heartbeat-file-path)))

(defn draw-clear-log!
  "Delete the current draw log file when it exists."
  []
  (draw-runtime/draw-clear-log! (draw-log-file-path)))

(defn draw-clear-watchdog-files!
  "Delete prior heartbeat and stall artifacts."
  []
  (draw-runtime/draw-clear-watchdog-files! (draw-heartbeat-file-path)
                                           (draw-stall-file-path)
                                           (draw-stall-sample-file-path)))

(defn draw-clear-control-file!
  "Delete any prior supervised-child control file."
  []
  (draw-runtime/draw-clear-control-file! (draw-control-file-path)))

(defn draw-log-lines
  "Return all current draw log lines."
  []
  (draw-runtime/draw-log-lines (draw-log-file-path)))

(defn draw-log-tail
  "Return the last COUNT draw log lines."
  [n]
  (draw-runtime/draw-log-tail (draw-log-file-path) n))

(defn draw-read-state-file
  "Read the latest full draw state from disk when available."
  []
  (draw-runtime/draw-read-state-file (draw-state-file-path)
                                     draw-normalize-state))

(defn draw-heartbeat-payload
  "Return the external heartbeat payload for STATE at PHASE."
  [phase state]
  (draw-runtime/draw-heartbeat-payload phase
                                       state
                                       *draw-running?*
                                       *draw-watchdog-enabled?*
                                       draw-state-snapshot))

(defn draw-write-heartbeat!
  "Write a heartbeat for PHASE and STATE when enough time has elapsed."
  [phase state]
  (let [now (draw-wall-clock-ms)
        force? (or (equal? phase :start)
                   (equal? phase :stop)
                   (equal? phase :crash))
        due? (or force?
                 (= *draw-last-heartbeat-at* 0)
                 (>= (- now *draw-last-heartbeat-at*)
                     (draw-heartbeat-interval-ms)))]
    (if due?
      (let [path (draw-heartbeat-file-path)
            payload (draw-heartbeat-payload phase state)]
        (draw-write-file-atomic! path (pr-str payload))
        (set! *draw-last-heartbeat-at* now)
        payload)
      false)))

(defn draw-write-state-file!
  "Write STATE to the shared state file when enough time has elapsed."
  [state force?]
  (let [now (draw-wall-clock-ms)
        due? (or force?
                 (= *draw-last-state-sync-at* 0)
                 (>= (- now *draw-last-state-sync-at*)
                     (draw-state-sync-interval-ms)))]
    (if due?
      (let [path (draw-state-file-path)]
        (draw-write-file-atomic! path (pr-str state))
        (set! *draw-last-state-sync-at* now)
        path)
      false)))

(defn draw-log-entry!
  "Append a diagnostic KIND/PAYLOAD entry to the draw session log."
  [kind payload]
  (draw-runtime/draw-log-entry! *draw-log-enabled?*
                                (draw-log-file-path)
                                kind
                                payload))

(defn draw-write-crash-report!
  "Write a full crash report for EXN."
  [exn]
  (draw-runtime/draw-write-crash-report! (draw-crash-file-path)
                                         exn
                                         *draw-state*
                                         *draw-last-error*
                                         draw-state-snapshot))

(defn draw-stop-watchdog!
  "Stop the external draw watchdog when one is running."
  []
  (let [pid *draw-watchdog-pid*]
    (set! *draw-watchdog-pid* false)
    (draw-runtime/draw-stop-watchdog! pid)
    nil))

(defn draw-child-alive?
  "Return true when PID still exists."
  [pid]
  (draw-runtime/draw-child-alive? pid))

(defn draw-write-control-command!
  "Write an OP/PAYLOAD command for the supervised child."
  [op payload]
  (let [result (draw-runtime/draw-write-control-command! *draw-control-seq*
                                                         (draw-control-file-path)
                                                         op
                                                         payload)]
    (set! *draw-control-seq* (get result :seq))
    (get result :command)))

(defn draw-read-control-command
  "Read the latest supervised-child control command when present."
  []
  (draw-runtime/draw-read-control-command (draw-control-file-path)))

(defn draw-control-command-pending
  "Return the next unprocessed control command when present."
  []
  (draw-runtime/draw-control-command-pending (draw-read-control-command)
                                             *draw-last-control-seq*))

(defn draw-start-watchdog!
  "Start the external draw watchdog if it is enabled."
  []
  (let [pid (draw-runtime/draw-start-watchdog! *draw-watchdog-enabled?*
                                               (draw-watchdog-script-path)
                                               (draw-process-id)
                                               (draw-heartbeat-file-path)
                                               (draw-stall-file-path)
                                               (draw-stall-sample-file-path)
                                               (draw-log-file-path)
                                               (draw-watchdog-stale-ms)
                                               (draw-watchdog-poll-ms)
                                               draw-stop-watchdog!)]
    (if pid
      (begin
        (set! *draw-watchdog-pid* pid)
        pid)
      nil)))

(defn draw-dump-state!
  "Write the current full draw state to PATH, or the default state file."
  [path]
  (draw-session/draw-dump-state! path
                                 (draw-state-file-path)
                                 current-state
                                 draw-write-file-atomic!))

(defn dump-current-state!
  "Write the current full draw state to the default dump file."
  []
  (draw-dump-state! false))

(defn draw-set-state-core!
  "Install STATE and refresh the cached canvas if needed."
  [state]
  (draw-session/draw-set-state-core! state
                                     draw-normalize-state
                                     draw-supervised-mode?
                                     (lambda (next-state)
                                       (set! *draw-state* next-state))
                                     draw-write-control-command!
                                     draw-reset-preview-sync!
                                     draw-clear-preview!
                                     draw-state-snapshot
                                     draw-log-entry!
                                     (lambda () *draw-running?*)
                                     draw-render-current!))

(defn draw-load-state-core!
  "Install STATE after loading it from disk."
  [state]
  (draw-set-state-core! state))

(defn draw-save-canvas-core!
  "Write STATE to the default draw save file and return STATE."
  [state]
  (draw-session/draw-save-canvas-core! state
                                       (draw-state-file-path)
                                       draw-ensure-parent-directory!
                                       draw-state-snapshot
                                       draw-log-entry!))

(defn draw-load-canvas-core!
  "Load draw state from the default save file and return the next state."
  [state]
  (draw-session/draw-load-canvas-core! state
                                       (draw-state-file-path)
                                       draw-normalize-state
                                       draw-state-snapshot
                                       draw-log-entry!))

(defn draw-refresh!
  "Render the current draw state immediately when the window is live."
  []
  (draw-with-lock
    (lambda ()
      (if (draw-supervised-mode?)
        (draw-write-control-command! :redraw {:reason :repl})
        (draw-render-current!)))))

(defn draw-render-current!
  "Render the current state if the draw context is live."
  []
  (if (and *draw-running?* *draw-context* *draw-state*)
    (let [state (draw-sync-canvas! *draw-state*)]
      (set! *draw-state* state)
      (draw-ensure-preview! state)
      (draw-sync-cursor! state)
      (sync-window-title!)
      (render-frame *draw-context* state)
      *draw-state*)
    nil))

(defn current-state
  "Return the current draw state."
  []
  (draw-session/current-state draw-supervised-mode?
                              draw-child-alive?
                              *draw-child-pid*
                              draw-read-state-file
                              *draw-state*))

(defn reset-state!
  "Reset the current draw state to the default."
  []
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! (default-state)))))

(defn set-state!
  "Replace the current draw state with STATE."
  [state]
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! state))))

(defn draw-save-state-to!
  "Write the current draw state to PATH."
  [path]
  (draw-with-lock
    (lambda ()
      (let [save-path (fs/path path)]
        (draw-ensure-parent-directory! save-path)
        (io/spit save-path (pr-str (current-state)))
        save-path))))

(defn save-canvas!
  "Write the current draw state to the default save file."
  []
  (draw-save-state-to! (draw-state-file-path)))

(defn save-canvas-to!
  "Write the current draw state to PATH."
  [path]
  (draw-save-state-to! path))

(defn draw-load-state-from!
  "Load a draw state from PATH."
  [path]
  (draw-with-lock
    (lambda ()
      (draw-load-state-core!
       (edn/read-string (io/slurp (fs/path path))))
      (fs/path path))))

(defn load-canvas!
  "Load the current draw state from the default save file."
  []
  (draw-load-state-from! (draw-state-file-path)))

(defn load-canvas-from!
  "Load a draw state from PATH."
  [path]
  (draw-load-state-from! path))

(defn set-title!
  "Update the current window title."
  [title]
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! (assoc (or (current-state) (default-state))
                                   :title title)))))

(defn set-background!
  "Update the current background color to a [R G B] vector."
  [color]
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! (assoc (or (current-state) (default-state))
                                   :background color)))))

(defn set-render-fn!
  "Install a custom render function of (lambda [ctx state] ...)."
  [render-fn]
  (set! *draw-render-fn* render-fn)
  *draw-render-fn*)

(defn clear-render-fn!
  "Restore the built-in clear-screen renderer."
  []
  (set! *draw-render-fn* nil)
  nil)

(def draw-mark-canvas-dirty! draw-canvas/draw-mark-canvas-dirty!)

(defn draw-sync-canvas!
  "Rebuild the cached canvas when STATE says it is dirty."
  [state]
  (draw-canvas/draw-sync-canvas! state
                                 draw-canvas-ready?
                                 draw-rebuild-canvas!))

(defn draw-clear-error!
  "Clear the last recorded draw error."
  []
  (set! *draw-last-error* false)
  (draw-log-entry! :clear-error {:state (draw-state-snapshot *draw-state*)})
  false)

(defn draw-with-stroke-color
  "Run THUNK while binding the current stroke color."
  [color thunk]
  (let [saved *draw-current-stroke-color*]
    (dynamic-wind
      (lambda () false)
      (lambda ()
        (set! *draw-current-stroke-color* color)
        (thunk))
      (lambda ()
        (set! *draw-current-stroke-color* saved)))))

(defn draw-canvas
  "Return the cached canvas texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :canvas)
    false))

(defn draw-canvas-ready?
  "Return true when the cached canvas texture is available."
  []
  (and *draw-canvas-ready?*
       (sdl/pointer-ready? (draw-canvas))))

(defn draw-preview
  "Return the active-stroke preview texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :preview)
    false))

(defn draw-preview-ready?
  "Return true when the active-stroke preview texture is available."
  []
  (and *draw-preview-ready?*
       (sdl/pointer-ready? (draw-preview))))

(defn draw-brush-texture
  "Return the cached brush texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :brush-texture)
    false))

(defn draw-brush-texture-ready?
  "Return true when the cached brush texture is available."
  []
  (and *draw-brush-ready?*
       (sdl/pointer-ready? (draw-brush-texture))))

(defn draw-strip-texture
  "Return the cached strip texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :strip-texture)
    false))

(defn draw-strip-texture-ready?
  "Return true when the cached strip texture is available."
  []
  (and *draw-strip-ready?*
       (sdl/pointer-ready? (draw-strip-texture))))

(defn draw-brush-texture-diameter
  "Return the canonical brush stamp diameter."
  []
  (draw-resources/draw-brush-texture-diameter))

(defn draw-brush-hardness
  "Return the default brush hardness used by the stamp texture."
  []
  (draw-resources/draw-brush-hardness))

(defn draw-strip-texture-width
  "Return the canonical width for the soft strip texture."
  []
  (draw-resources/draw-strip-texture-width))

(defn draw-strip-texture-height
  "Return the canonical height for the soft strip texture."
  []
  (draw-resources/draw-strip-texture-height))

(defn draw-strip-hardness
  "Return the default strip hardness used by the segment body texture."
  []
  (draw-resources/draw-strip-hardness))

(defn draw-ensure-brush-texture!
  "Create or refresh the brush stamp texture."
  [state]
  (let [result (draw-resources/draw-ensure-brush-texture! *draw-context*
                                                          (draw-brush-texture-ready?))]
    (set! *draw-context* (get result :context))
    (set! *draw-brush-ready?* (if (get result :ready?) true false))
    *draw-context*))

(defn draw-release-brush-texture!
  "Destroy the cached brush stamp texture and clear it from the draw context."
  []
  (let [result (draw-resources/draw-release-brush-texture! *draw-context*
                                                           (draw-brush-texture-ready?))]
    (set! *draw-context* (get result :context))
    (set! *draw-brush-ready?* false)
    nil))

(defn draw-ensure-strip-texture!
  "Create or refresh the strip texture used for stroke bodies."
  [state]
  (let [result (draw-resources/draw-ensure-strip-texture! *draw-context*
                                                          (draw-strip-texture-ready?))]
    (set! *draw-context* (get result :context))
    (set! *draw-strip-ready?* (if (get result :ready?) true false))
    *draw-context*))

(defn draw-release-strip-texture!
  "Destroy the cached strip texture and clear it from the draw context."
  []
  (let [result (draw-resources/draw-release-strip-texture! *draw-context*
                                                           (draw-strip-texture-ready?))]
    (set! *draw-context* (get result :context))
    (set! *draw-strip-ready?* false)
    nil))

(defn draw-release-cursors!
  "Destroy cached system cursors and clear them from the draw context."
  []
  (set! *draw-context* (draw-resources/draw-release-cursors! *draw-context*))
  nil)

(defn draw-ensure-canvas!
  "Create or resize the cached canvas texture to match STATE."
  [state]
  (let [result (draw-resources/draw-ensure-canvas! *draw-context*
                                                   (draw-canvas-ready?)
                                                   (get state :width)
                                                   (get state :height))]
    (set! *draw-context* (get result :context))
    (set! *draw-canvas-ready?* (if (get result :ready?) true false))
    *draw-context*))

(defn draw-ensure-preview!
  "Create or resize the active-stroke preview texture to match STATE."
  [state]
  (let [result (draw-resources/draw-ensure-preview! *draw-context*
                                                    (draw-preview-ready?)
                                                    (get state :width)
                                                    (get state :height))]
    (set! *draw-context* (get result :context))
    (set! *draw-preview-ready?* (if (get result :ready?) true false))
    *draw-context*))

(defn draw-with-canvas!
  "Run THUNK with the canvas texture bound as the SDL render target."
  [thunk]
  (draw-resources/draw-resource-with-canvas! *draw-context*
                                             (draw-canvas-ready?)
                                             thunk))

(defn draw-with-preview!
  "Run THUNK with the preview texture bound as the SDL render target."
  [thunk]
  (draw-resources/draw-resource-with-preview! *draw-context*
                                              (draw-preview-ready?)
                                              thunk))

(defn draw-release-canvas!
  "Destroy the cached canvas texture and clear it from the draw context."
  []
  (let [result (draw-resources/draw-release-canvas! *draw-context*
                                                    (draw-canvas-ready?))]
    (set! *draw-context* (get result :context))
    (set! *draw-canvas-ready?* false)
    nil))

(defn draw-release-preview!
  "Destroy the active-stroke preview texture and clear it from the draw context."
  []
  (let [result (draw-resources/draw-release-preview! *draw-context*
                                                     (draw-preview-ready?))]
    (set! *draw-context* (get result :context))
    (set! *draw-preview-ready?* false)
    (draw-reset-preview-sync!)
    nil))

(defn draw-clear-canvas!
  "Clear the cached canvas texture."
  []
  (draw-resources/draw-clear-canvas! *draw-context*
                                     (draw-canvas-ready?)))

(defn draw-clear-preview!
  "Clear the active-stroke preview texture."
  []
  (draw-resources/draw-clear-preview! *draw-context*
                                      (draw-preview-ready?)))

(defn draw-commit-stroke!
  "Render a single stroke into the cached canvas texture."
  [state stroke]
  (draw-with-canvas!
    (lambda (renderer)
      (draw-render-stroke! renderer state stroke)
      nil)))

(defn draw-commit-element!
  "Render a single committed element into the cached canvas texture."
  [state element]
  (draw-with-canvas!
    (lambda (renderer)
      (draw-render-element! renderer state element)
      nil)))

(defn draw-rebuild-canvas!
  "Rebuild the cached canvas texture from STATE."
  [state]
  (draw-with-canvas!
    (lambda (renderer)
      (sdl/set-draw-color! renderer 0 0 0 0)
      (sdl/render-clear! renderer)
      (reduce (lambda (acc element)
                (begin
                  (draw-render-element! renderer state element)
                  acc))
              nil
              (get state :elements))
      nil)))

(defn draw-set-brush-size-core!
  "Set the brush size and return to brush mode, recording undo history."
  [state size]
  (draw-actions/draw-set-brush-size-core! state
                                          size
                                          draw-push-history!
                                          draw-state-snapshot
                                          draw-log-entry!))

(defn draw-set-brush-size!
  "Set the brush size and return to brush mode, recording undo history."
  [state size]
  (draw-with-lock
    (lambda ()
      (let [state (draw-set-brush-size-core! state size)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-toggle-eraser-core!
  "Toggle eraser mode for STATE and record undo history."
  [state]
  (draw-actions/draw-toggle-eraser-core! state
                                         draw-push-history!
                                         draw-state-snapshot
                                         draw-log-entry!))

(defn draw-toggle-eraser!
  "Toggle eraser mode for STATE and record undo history."
  [state]
  (draw-with-lock
    (lambda ()
      (let [state (draw-toggle-eraser-core! state)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-clear-strokes-core!
  "Clear all finished and active strokes from STATE and record undo history."
  [state]
  (draw-actions/draw-clear-strokes-core! state
                                         draw-push-history!
                                         draw-clear-preview!
                                         draw-sync-elements
                                         draw-state-snapshot
                                         draw-log-entry!))

(defn draw-clear-strokes!
  "Clear all finished and active strokes from STATE and record undo history."
  [state]
  (draw-with-lock
    (lambda ()
      (let [state (draw-clear-strokes-core! state)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-undo-stroke-core!
  "Undo the most recent draw action."
  [state]
  (draw-actions/draw-undo-stroke-core! state
                                       draw-clear-preview!
                                       draw-restore-history!
                                       draw-state-snapshot
                                       draw-log-entry!))

(defn draw-undo-stroke!
  "Undo the most recent draw action."
  [state]
  (draw-with-lock
    (lambda ()
      (let [state (draw-undo-stroke-core! state)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-handle-tool-key!
  "Apply draw tool shortcuts for KEY to STATE."
  [state key]
  (draw-commands/draw-handle-tool-key! state
                                       key
                                       draw-clear-strokes-core!
                                       draw-undo-stroke-core!
                                       draw-set-tool-core!
                                       draw-toggle-eraser-core!
                                       draw-set-brush-size-core!))

(defn draw-handle-view-key!
  "Apply zoom and pan shortcuts for KEY to STATE."
  [state key]
  (draw-handle-view-key-base! state key))

(defn draw-handle-wheel!
  "Apply mouse-wheel zoom to STATE."
  [state]
  (draw-handle-wheel-base! state))

(defn draw-crash!
  "Record EXN as the last draw error and stop the background loop."
  [exn]
  (set! *draw-last-error* exn)
  (set! *draw-running?* false)
  (set! *draw-thread* nil)
  (draw-write-state-file! *draw-state* true)
  (draw-write-heartbeat! :crash *draw-state*)
  (draw-stop-watchdog!)
  (draw-log-entry! :crash
                   {:error (format "%s" exn)
                    :state (draw-state-snapshot *draw-state*)})
  (draw-write-crash-report! exn)
  (println (format "Cluck Draw crashed: %s" exn))
  exn)

(defn draw-cancel-active-stroke-core!
  "Cancel the active stroke without recording history."
  [state]
  (draw-reset-preview-sync!)
  (draw-clear-preview!)
    (let [state (assoc state
                     :pointer-down? false
                     :pointer-source false
                     :active-selection-drag false
                     :active-selection-resize false
                     :active-selection-rotate false
                     :active-selection-marquee false
                     :active-stroke false
                     :active-box false
                     :active-arrow false
                     :active-frame false
                     :active-text false
                     :panning? false
                     :pen-pressure 1.0
                     :canvas-dirty? true)]
    state))

(defn draw-focus-lost-core!
  "Record that the window lost focus and cancel any active stroke."
  [state]
  (let [next-state (draw-cancel-active-stroke-core!
                     (assoc state
                            :window-focused? false
                            :space-down? false
                            :ctrl-down? false
                            :canvas-dirty? true))]
    (draw-log-entry! :focus-lost {:state (draw-state-snapshot next-state)})
    next-state))

(defn draw-focus-gained-core!
  "Record that the window regained focus."
  [state]
  (let [next-state (assoc state
                          :window-focused? true
                          :canvas-dirty? true
                          :space-down? false
                          :ctrl-down? false
                          :pen-pressure 1.0)]
    (draw-log-entry! :focus-gained {:state (draw-state-snapshot next-state)})
    next-state))

(defn draw-mouse-leave-core!
  "Handle the pointer leaving the window without changing focus state."
  [state]
  (draw-cancel-active-stroke-core! state))

(defn draw-mouse-enter-core!
  "Handle the pointer entering the window without changing focus state."
  [state]
  state)

(defn draw-stroke-record
  "Build a fresh stroke map."
  [points color size]
  {:points points
   :color color
   :size size})

(defn draw-ensure-system-cursor!
  "Return a cached system cursor pointer for KIND, creating it when needed."
  [kind]
  (let [result (draw-resources/draw-ensure-system-cursor! *draw-context* kind)]
    (set! *draw-context* (get result :context))
    (get result :cursor)))

(defn draw-sync-cursor!
  "Apply the desired cursor for STATE when the live context is available."
  [state]
  (let [result (draw-resources/draw-sync-cursor! *draw-context*
                                                 (draw-desired-cursor-kind state))]
    (set! *draw-context* (get result :context))
    (get result :kind)))

(defn draw-apply-tool-panel-button
  "Apply BUTTON from the tool panel to STATE."
  [state button point screen-point]
  (let [kind (get button :kind)
        base-state (draw-sync-pointer-state
                     (draw-clear-active-interactions state)
                     point
                     screen-point)]
    (cond
      (draw-kind=? kind :tool)
      (draw-set-tool-core! base-state (get button :tool))

      (draw-kind=? kind :save)
      (draw-save-canvas-core! base-state)

      (draw-kind=? kind :load)
      (draw-sync-pointer-state
        (draw-load-canvas-core! base-state)
        point
        screen-point)

      :else base-state)))

(defn draw-start-stroke
  "Start a new stroke from WORLD-POINT and SCREEN-POINT."
  [state point screen-point pointer-source]
  (let [state (draw-push-history! state)
        stroke (draw-stroke-record [point]
                                   (draw-stroke-color state)
                                   (get state :brush-size))
        next-state (draw-sync-pointer-state
                     (assoc state
                            :pointer-down? true
                            :pointer-source pointer-source
                            :active-selection-drag false
                            :active-selection-resize false
                            :active-selection-rotate false
                            :active-selection-marquee false
                            :active-box false
                            :active-arrow false
                            :active-frame false
                            :active-text false
                            :active-stroke stroke)
                     point
                     screen-point)]
    (draw-reset-preview-sync!)
    (draw-clear-preview!)
    (draw-preview-stroke! next-state stroke)
    (draw-log-entry! :stroke-start
                     {:point point
                      :state (draw-state-snapshot next-state)})
    next-state))

(defn draw-extend-stroke
  "Add WORLD-POINT at SCREEN-POINT to the active stroke."
  [state point screen-point]
  (let [stroke (get state :active-stroke)]
    (if stroke
      (let [points (get stroke :points)
            next-points (draw-append-stroke-point state stroke point)
            appended? (> (count next-points) (count points))
            previous (if (empty? points) nil (last points))
            next-stroke (draw-stroke-record next-points
                                            (get stroke :color)
                                            (get stroke :size))
            next-state (draw-sync-pointer-state
                         (assoc state
                                :active-stroke next-stroke)
                         point
                         screen-point)]
        (if (and appended? previous)
          (draw-preview-segment! next-state
                                 previous
                                 point
                                 (get stroke :size)
                                 (get stroke :color))
          nil)
        next-state)
      (draw-start-stroke state point screen-point :mouse))))

(defn draw-finish-stroke
  "Finish the active stroke using WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [stroke (get state :active-stroke)]
    (if stroke
        (let [points (get stroke :points)
              finished-points (draw-append-stroke-point state stroke point)
              finished (draw-stroke-record finished-points
                                           (get stroke :color)
                                           (get stroke :size))
              next-state (draw-sync-pointer-state
                           (assoc state
                                  :pointer-down? false
                                  :pointer-source false
                                  :active-stroke false)
                           point
                           screen-point)
              next-state (draw-append-element next-state
                                              (assoc finished :kind :ink))]
          (draw-log-entry! :stroke-finish
                           {:point point
                            :points (count (get finished :points))
                            :state (draw-state-snapshot next-state)})
          (if (and (draw-preview-ready?)
                   (draw-canvas-ready?))
            (begin
              (draw-with-canvas!
                (lambda (renderer)
                  (sdl/render-texture! renderer (draw-preview))
                  nil))
              (draw-clear-preview!))
            (if (draw-canvas-ready?)
              (draw-commit-stroke! next-state finished)
              nil))
          (draw-reset-preview-sync!)
          next-state)
      (draw-sync-pointer-state
        (assoc state
               :pointer-down? false
               :pointer-source false
               :active-stroke false)
        point
        screen-point))))

(defn draw-bump-frame!
  "Advance the frame counter in STATE."
  [state]
  (assoc state
         :frame (+ (get state :frame) 1)))
(defn draw-apply-and-log-input-event!
  "Apply EVENT to STATE and emit a diagnostic log entry when relevant."
  [state event source]
  (if (draw-ignorable-input-event? event)
    state
    (let [next-state (draw-apply-input-event! state event)]
      (if (draw-loggable-event? event)
        (draw-log-entry! :input
                         {:source source
                          :kind (get event :kind)
                          :desc (or (get event :desc) "")
                          :key (or (get event :key) "")
                          :text (or (get event :text) "")
                          :pressure (or (get event :pressure) 1.0)
                          :shift? (get event :shift?)
                          :state (draw-state-snapshot next-state)})
        nil)
      next-state)))

(defn draw-handle-wheel-event!
  "Apply mouse-wheel zoom from EVENT to STATE."
  [state event]
  (let [delta (or (get event :wheel-y) 0.0)]
    (if (= delta 0.0)
      state
      (draw-zoom-at-core! state
                          delta
                          (or (get event :wheel-mouse-x) 0.0)
                          (or (get event :wheel-mouse-y) 0.0)))))

(defn draw-apply-input-event!
  "Apply a synthetic or live EVENT map to STATE."
  [state event]
  (let [kind (get event :kind)
        desc (or (get event :desc) "")
        events (conj (get state :recent-events) desc)
        recent (draw-trim-events events)
        state (assoc state
                     :recent-events recent
                     :last-event desc)]
    (cond
      (or (draw-kind=? kind :key-down)
          (draw-kind=? kind :key-up))
      (let [key-label (or (get event :key) "")
            state (assoc state
                         :last-key key-label
                         :last-key-desc desc)
            state (draw-apply-key-modifier-state state event)]
        (if (draw-kind=? kind :key-down)
          (let [state (if (and (get state :ctrl-down?)
                               (draw-save-shortcut-key? key-label))
                        (draw-save-canvas-core! state)
                        (if (and (get state :ctrl-down?)
                                 (draw-load-shortcut-key? key-label))
                          (draw-load-canvas-core! state)
                          state))
                state (draw-handle-view-key! state key-label)
                state (draw-handle-tool-key! state key-label)
                state (if (draw-toggle-debug-panel-key? key-label)
                        (draw-toggle-debug-panel! state)
                        state)]
            (if (draw-toggle-tool-panel-key? key-label)
              (draw-toggle-tool-panel! state)
              state))
          (if (and (draw-space-key? key-label)
                   (get state :panning?))
            (draw-finish-pan-core! state)
            state)))

      (draw-kind=? kind :mouse-wheel)
      (draw-handle-wheel-event! state event)

      (draw-kind=? kind :focus-lost)
      (draw-focus-lost-core! state)

      (draw-kind=? kind :focus-gained)
      (draw-focus-gained-core! state)

      (draw-kind=? kind :mouse-leave)
      (draw-mouse-leave-core! state)

      (draw-kind=? kind :mouse-enter)
      (draw-mouse-enter-core! state)

      (draw-kind=? kind :text-input)
      (assoc state
             :last-text (draw-nonblank (or (get event :text) desc) desc)
             :last-key (or (get event :key) desc))

      (or (draw-kind=? kind :mouse-motion)
          (draw-kind=? kind :mouse-down)
          (draw-kind=? kind :mouse-up))
      (if (draw-pen-owned-pointer? state)
        state
        (let [state (assoc state :pen-pressure 1.0)]
          (cond
            (and (draw-kind=? kind :mouse-down)
                 (get state :space-down?))
            (draw-start-pan-core! state (draw-input-event-screen-point event))

            (draw-kind=? kind :mouse-down)
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)
                  panel-button (draw-find-tool-panel-button state screen-point)
                  resize-handle (if (draw-selection-tool? state)
                                  (draw-find-selection-handle state screen-point)
                                  false)]
                (if panel-button
                  (draw-apply-tool-panel-button state panel-button point screen-point)
                (if (draw-tool-panel-hit? state screen-point)
                  (draw-sync-pointer-state state point screen-point)
                (if (draw-selection-tool? state)
                (if resize-handle
                  (if (draw-kind=? resize-handle :rotate)
                    (draw-start-selection-rotate state
                                                 point
                                                 screen-point
                                                 :mouse)
                    (draw-start-selection-resize state
                                                 point
                                                 screen-point
                                                 :mouse
                                                 resize-handle))
                  (draw-start-selection-interaction state
                                                   point
                                                   screen-point
                                                   :mouse
                                                   (if (get event :shift?) true false)))
                (if (draw-box-tool? state)
                  (draw-start-box state point screen-point)
                  (if (draw-arrow-tool? state)
                    (draw-start-arrow state point screen-point)
                    (if (draw-frame-tool? state)
                      (draw-start-frame state point screen-point)
                      (if (draw-text-tool? state)
                        (draw-start-text state point screen-point)
                        (draw-start-stroke state point screen-point :mouse)))))))))

            (and (draw-kind=? kind :mouse-up)
                 (get state :panning?))
            (draw-finish-pan-core! state)

            (draw-kind=? kind :mouse-up)
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)]
              (if (get state :active-selection-rotate)
                (draw-finish-selection-rotate state point screen-point)
                (if (get state :active-selection-resize)
                (draw-finish-selection-resize state point screen-point)
                (if (get state :active-selection-marquee)
                (draw-finish-selection-marquee state point screen-point)
                (if (get state :active-selection-drag)
                (draw-finish-selection-drag state point screen-point)
                (if (get state :active-box)
                  (draw-finish-box state point screen-point)
                  (if (get state :active-arrow)
                    (draw-finish-arrow state point screen-point)
                    (if (get state :active-frame)
                      (draw-finish-frame state point screen-point)
                      (if (get state :active-text)
                        (draw-finish-text state point screen-point)
                        (draw-finish-stroke state point screen-point))))))))))

            (get state :panning?)
            (draw-pan-core! state (draw-input-event-screen-point event))

            (get state :pointer-down?)
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)]
              (if (get state :active-selection-rotate)
                (draw-extend-selection-rotate state point screen-point)
                (if (get state :active-selection-resize)
                (draw-extend-selection-resize state point screen-point)
                (if (get state :active-selection-marquee)
                (draw-extend-selection-marquee state point screen-point)
                (if (get state :active-selection-drag)
                (draw-extend-selection-drag state point screen-point)
                (if (get state :active-box)
                  (draw-extend-box state point screen-point)
                  (if (get state :active-arrow)
                    (draw-extend-arrow state point screen-point)
                    (if (get state :active-frame)
                      (draw-extend-frame state point screen-point)
                      (if (get state :active-text)
                        (draw-extend-text state point screen-point)
                        (draw-extend-stroke state point screen-point))))))))))

            :else
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)]
              (draw-sync-pointer-state state point screen-point)))))

      (or (draw-kind=? kind :pen-motion)
          (draw-kind=? kind :pen-down)
          (draw-kind=? kind :pen-up)
          (draw-kind=? kind :pen-button-down)
          (draw-kind=? kind :pen-button-up))
      (let [state (assoc state
                         :pen-pressure (or (get event :pressure) 1.0))]
        (cond
          (and (draw-kind=? kind :pen-down)
               (get state :space-down?))
          (draw-start-pan-core! state (draw-input-event-screen-point event))

          (draw-kind=? kind :pen-down)
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)
                panel-button (draw-find-tool-panel-button state screen-point)
                resize-handle (if (draw-selection-tool? state)
                                (draw-find-selection-handle state screen-point)
                                false)]
              (if panel-button
                (draw-apply-tool-panel-button state panel-button point screen-point)
              (if (draw-tool-panel-hit? state screen-point)
                (draw-sync-pointer-state state point screen-point)
              (if (draw-selection-tool? state)
              (if resize-handle
                (if (draw-kind=? resize-handle :rotate)
                  (draw-start-selection-rotate state
                                               point
                                               screen-point
                                               :pen)
                  (draw-start-selection-resize state
                                               point
                                               screen-point
                                               :pen
                                               resize-handle))
                (draw-start-selection-interaction state
                                                 point
                                                 screen-point
                                                 :pen
                                                 (if (get event :shift?) true false)))
              (if (draw-box-tool? state)
                (draw-start-box state point screen-point)
                (if (draw-arrow-tool? state)
                  (draw-start-arrow state point screen-point)
                  (if (draw-frame-tool? state)
                    (draw-start-frame state point screen-point)
                    (if (draw-text-tool? state)
                      (draw-start-text state point screen-point)
                      (draw-start-stroke state point screen-point :pen)))))))))

          (and (or (draw-kind=? kind :pen-up)
                   (draw-kind=? kind :pen-button-up))
               (get state :panning?))
          (draw-finish-pan-core! state)

          (or (draw-kind=? kind :pen-up)
              (draw-kind=? kind :pen-button-up))
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)]
            (if (get state :active-selection-rotate)
              (draw-finish-selection-rotate state point screen-point)
              (if (get state :active-selection-resize)
              (draw-finish-selection-resize state point screen-point)
              (if (get state :active-selection-marquee)
              (draw-finish-selection-marquee state point screen-point)
              (if (get state :active-selection-drag)
              (draw-finish-selection-drag state point screen-point)
              (if (get state :active-box)
                (draw-finish-box state point screen-point)
                (if (get state :active-arrow)
                  (draw-finish-arrow state point screen-point)
                  (if (get state :active-frame)
                    (draw-finish-frame state point screen-point)
                    (if (get state :active-text)
                      (draw-finish-text state point screen-point)
                      (draw-finish-stroke state point screen-point))))))))))

          (get state :panning?)
          (draw-pan-core! state (draw-input-event-screen-point event))

          (get state :pointer-down?)
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)]
            (if (get state :active-selection-rotate)
              (draw-extend-selection-rotate state point screen-point)
              (if (get state :active-selection-resize)
              (draw-extend-selection-resize state point screen-point)
              (if (get state :active-selection-marquee)
              (draw-extend-selection-marquee state point screen-point)
              (if (get state :active-selection-drag)
              (draw-extend-selection-drag state point screen-point)
              (if (get state :active-box)
                (draw-extend-box state point screen-point)
                (if (get state :active-arrow)
                  (draw-extend-arrow state point screen-point)
                  (if (get state :active-frame)
                    (draw-extend-frame state point screen-point)
                    (if (get state :active-text)
                      (draw-extend-text state point screen-point)
                      (draw-extend-stroke state point screen-point))))))))))

          :else
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)]
            (draw-sync-pointer-state state point screen-point))))

      (draw-kind=? kind :pen-axis)
      (let [point (draw-input-event-point state event)
            screen-point (draw-input-event-screen-point event)]
        (draw-sync-pointer-state
          (assoc state
                 :pen-pressure (or (get event :pressure) 1.0))
          point
          screen-point))

      (draw-kind=? kind :text-editing)
      (assoc state
             :last-text (draw-nonblank (or (get event :text-edit) desc) desc)
             :last-key (or (get event :key) desc))

      :else
      state)))

(defn draw-record-input!
  "Record the latest SDL event description in STATE."
  [state desc]
  (draw-apply-and-log-input-event! state
                                   (draw-build-input-event state desc)
                                   :sdl))

(defn draw-simulate-input!
  "Apply a synthetic input EVENT to the current draw state."
  [event]
  (draw-with-lock
    (lambda ()
      (set! *draw-state*
            (draw-apply-and-log-input-event! (or *draw-state* (default-state))
                                             event
                                             :simulated))
      (if *draw-running?*
        (draw-render-current!)
        nil)
      *draw-state*)))

(defn draw-replay-events!
  "Apply EVENTS in order to the current draw state."
  [events]
  (draw-with-lock
    (lambda ()
      (set! *draw-state*
            (reduce (lambda (state event)
                      (draw-apply-and-log-input-event! state event :replay))
                    (or *draw-state* (default-state))
                    events))
      (if *draw-running?*
        (draw-render-current!)
        nil)
      *draw-state*)))

(defn draw-repeat-events!
  "Replay EVENTS ROUNDS times starting from STATE."
  [state events rounds]
  (draw-repeat-events-base! state
                            events
                            rounds
                            draw-apply-input-event!))

(defn draw-replay-benchmark!
  "Replay EVENTS and print the elapsed wall-clock time."
  [events rounds]
  (draw-replay-benchmark-base! (or *draw-state* (default-state))
                               events
                               rounds
                               draw-apply-input-event!
                               current-process-milliseconds
                               describe-state))

(defn draw-replay-live!
  "Replay EVENTS in the live window, pausing PAUSE-MS milliseconds between events."
  [events pause-ms]
  (let [pause (if (> (or pause-ms 0) 0)
                pause-ms
                0)]
    (reduce (lambda (state event)
              (let [next-state (draw-simulate-input! event)]
                (if (> pause 0)
                  (delay-ms pause)
                  nil)
                next-state))
            (or *draw-state* (default-state))
            events)))

(defn draw-repeat-live-events!
  "Replay EVENTS ROUNDS times in the live window."
  [events rounds pause-ms]
  (draw-repeat-live-events-base! (or *draw-state* (default-state))
                                 events
                                 rounds
                                 pause-ms
                                 draw-replay-live!))

(defn draw-replay-live-benchmark!
  "Replay EVENTS live and print the elapsed wall-clock time."
  [events rounds pause-ms]
  (draw-replay-live-benchmark-base! (or *draw-state* (default-state))
                                    events
                                    rounds
                                    pause-ms
                                    (lambda (state events rounds pause-ms)
                                      (draw-repeat-live-events-base! state
                                                                     events
                                                                     rounds
                                                                     pause-ms
                                                                     draw-replay-live!))
                                    current-process-milliseconds
                                    describe-state))

(defn mouse-position
  "Return the current mouse position from the draw state."
  []
  (let [state (or (current-state) (default-state))]
    {:x (get state :mouse-x)
     :y (get state :mouse-y)}))

(defn recent-events
  "Return the recent SDL event log."
  []
  (get (or (current-state) (default-state)) :recent-events))

(defn last-key-event
  "Return the last key event description."
  []
  (get (or (current-state) (default-state)) :last-key))

(defn last-input-event
  "Return the last SDL event description."
  []
  (get (or (current-state) (default-state)) :last-event))

(defn input-summary
  "Return a short textual summary of the current input state."
  []
  (draw-input-summary (or (current-state) (default-state))))

(defn sync-window-title!
  "Update the SDL window title from the current state."
  []
  (if *draw-context*
    (sdl/set-window-title! (get *draw-context* :window)
                           (describe-state *draw-state*))
    nil))

(defn draw-drain-input-batch!
  "Drain at most REMAINING SDL input events into the current state."
  [remaining quit?]
  (if (<= remaining 0)
    quit?
    (if (sdl/poll-event!)
      (let [desc (sdl/event-description)
            event (draw-build-input-event *draw-state* desc)
            kind (get event :kind)]
        (if (draw-ignorable-input-event? event)
          (draw-drain-input-batch! remaining quit?)
          (begin
            (set! *draw-state*
                  (draw-apply-and-log-input-event! *draw-state* event :sdl))
            (if (draw-kind=? kind :quit)
              (begin
                (set! *draw-running?* false)
                (draw-drain-input-batch! (- remaining 1) true))
              (draw-drain-input-batch! (- remaining 1) quit?)))))
      quit?)))

(defn draw-poll-input!
  "Drain pending SDL input events into the current state."
  []
  (let [quit? (draw-drain-input-batch! (draw-input-batch-limit) false)]
    (set! *draw-state* (draw-bump-frame! *draw-state*))
    (sync-window-title!)
    quit?))

(defn draw-apply-control-command!
  "Apply a supervisor control COMMAND to STATE inside the child process."
  [state command]
  (let [op (get command :op)
        payload (get command :payload)
        next-state
          (cond
            (equal? op :set-state)
            (assoc payload :canvas-dirty? true)

            (equal? op :redraw)
            (assoc state :canvas-dirty? true)

            (equal? op :stop)
            (begin
              (set! *draw-running?* false)
              state)

            :else
            state)]
    (draw-log-entry! :control
                     {:op op
                      :state (draw-state-snapshot next-state)})
    next-state))

(defn draw-poll-control!
  "Apply the latest pending supervisor control command in child mode."
  []
  (if *draw-child-mode?*
    (let [command (draw-control-command-pending)]
      (if command
        (begin
          (set! *draw-last-control-seq* (or (get command :seq) *draw-last-control-seq*))
          (set! *draw-state* (draw-apply-control-command! *draw-state* command))
          command)
        false))
    false))

(defn draw-brush-radius
  "Return the brush radius for SIZE."
  [size]
  (if (> size 0)
    (draw-exact-int size)
    1))

(defn draw-point-alpha
  "Scale the stroke alpha by POINT pressure."
  [point]
  (let [pressure (draw-normalize-pressure (draw-point-pressure point))
        alpha (draw-exact-int (math/ceiling (+ 72 (* 183 pressure))))]
    (if (> alpha 255)
      255
      alpha)))

(defn draw-stroke-color-value
  "Return the current stroke color, defaulting to white."
  []
  (if *draw-current-stroke-color*
    *draw-current-stroke-color*
    [255 255 255]))

(defn draw-set-stroke-color!
  "Set the draw color for the current stroke with ALPHA."
  [renderer alpha]
  (let [color (draw-stroke-color-value)]
    (sdl/set-draw-color! renderer
                         (nth color 0)
                         (nth color 1)
                         (nth color 2)
                         alpha)))

(defn draw-render-soft-brush!
  "Render the soft brush texture at POINT with SIZE."
  [renderer state point size]
  (let [brush (draw-brush-texture)
        color (draw-stroke-color-value)
        screen-point (draw-world-point->screen-point state point)
        stamp-size (draw-point-screen-size state point size)
        alpha (draw-point-alpha point)]
    (if (draw-brush-texture-ready?)
      (begin
        (sdl/set-texture-color-mod! brush
                                    (nth color 0)
                                    (nth color 1)
                                    (nth color 2))
        (sdl/set-texture-alpha-mod! brush alpha)
        (sdl/render-texture-at! renderer
                                brush
                                (- (nth screen-point 0) (/ stamp-size 2.0))
                                (- (nth screen-point 1) (/ stamp-size 2.0))
                                stamp-size
                                stamp-size)
        true)
      (begin
        (draw-set-stroke-color! renderer alpha)
        (sdl/render-fill-rect! renderer
                               (- (nth screen-point 0) (/ stamp-size 2.0))
                               (- (nth screen-point 1) (/ stamp-size 2.0))
                               stamp-size
                               stamp-size)
        false))))

(defn draw-render-stroke-point!
  "Render a single stroke sample at POINT."
  [renderer state point size]
  (draw-render-soft-brush! renderer state point size))

(defn draw-render-soft-segment!
  "Render a smooth segment from A to B using the compiled SDL helper."
  [renderer state a b size]
  (let [brush (draw-brush-texture)
        strip (draw-strip-texture)
        color (draw-stroke-color-value)
        screen-a (draw-world-point->screen-point state a)
        screen-b (draw-world-point->screen-point state b)
        size-a (draw-point-screen-size state a size)
        size-b (draw-point-screen-size state b size)
        alpha-a (draw-point-alpha a)
        alpha-b (draw-point-alpha b)]
    (if (and (draw-brush-texture-ready?)
             (draw-strip-texture-ready?))
      (sdl/render-soft-segment! renderer
                                strip
                                brush
                                (nth screen-a 0)
                                (nth screen-a 1)
                                size-a
                                alpha-a
                                (nth screen-b 0)
                                (nth screen-b 1)
                                size-b
                                alpha-b
                                (nth color 0)
                                (nth color 1)
                                (nth color 2))
      (begin
        (draw-set-stroke-color! renderer (if (> alpha-a alpha-b) alpha-a alpha-b))
        (sdl/render-line! renderer
                          (nth screen-a 0)
                          (nth screen-a 1)
                          (nth screen-b 0)
                          (nth screen-b 1))
        (draw-render-soft-brush! renderer state a size)
        (draw-render-soft-brush! renderer state b size)
        true))))

(defn draw-render-stroke-segment!
  "Render a line segment from A to B."
  [renderer state a b size]
  (draw-render-soft-segment! renderer state a b size))

(defn draw-render-stroke-segments!
  "Render a line strip from POINTS."
  [renderer state points size]
  (let [total (count points)]
    (if (<= total 1)
      nil
      (reduce (fn [previous point]
                (begin
                  (draw-render-stroke-segment! renderer state previous point size)
                  point))
              (first points)
              (rest points)))))

(defn draw-render-stroke!
  "Render a stroke map."
  [renderer state stroke]
  (let [points (get stroke :points)
        color (get stroke :color)
        size (get stroke :size)]
    (if (empty? points)
      nil
      (draw-with-stroke-color color
        (lambda ()
          (if (<= (count points) 1)
            (draw-render-stroke-point! renderer state (first points) size)
            (draw-render-stroke-segments! renderer state points size)))))))

(defn draw-render-box-edge!
  "Render one edge of a box from A to B."
  [renderer state color size a b]
  (draw-with-stroke-color color
    (lambda ()
      (draw-render-stroke-segment! renderer
                                   state
                                   [(nth a 0) (nth a 1) 1.0]
                                   [(nth b 0) (nth b 1) 1.0]
                                   size))))

(defn draw-render-screen-soft-segment!
  "Render a soft segment directly in screen coordinates."
  [renderer color size x1 y1 x2 y2]
  (let [brush (draw-brush-texture)
        strip (draw-strip-texture)
        alpha 255]
    (draw-with-stroke-color color
      (lambda ()
        (if (and (draw-brush-texture-ready?)
                 (draw-strip-texture-ready?))
          (sdl/render-soft-segment! renderer
                                    strip
                                    brush
                                    x1
                                    y1
                                    size
                                    alpha
                                    x2
                                    y2
                                    size
                                    alpha
                                    (nth color 0)
                                    (nth color 1)
                                    (nth color 2))
          (begin
            (draw-set-stroke-color! renderer alpha)
            (sdl/render-line! renderer x1 y1 x2 y2)
            (sdl/render-fill-rect! renderer
                                   (- x1 (/ size 2.0))
                                   (- y1 (/ size 2.0))
                                   size
                                   size)
            (sdl/render-fill-rect! renderer
                                   (- x2 (/ size 2.0))
                                   (- y2 (/ size 2.0))
                                   size
                                   size)
            true))))))

(defn draw-render-screen-rect!
  "Render a rectangle outline directly in screen coordinates."
  [renderer x y width height color size]
  (let [left x
        top y
        right (+ x width)
        bottom (+ y height)]
    (draw-render-screen-soft-segment! renderer color size left top right top)
    (draw-render-screen-soft-segment! renderer color size right top right bottom)
    (draw-render-screen-soft-segment! renderer color size right bottom left bottom)
    (draw-render-screen-soft-segment! renderer color size left bottom left top)))

(defn draw-render-box!
  "Render a rectangle element."
  [renderer state box]
  (draw-render/draw-render-box! renderer
                                state
                                box
                                draw-render-screen-soft-segment!))

(defn draw-render-frame!
  "Render a legacy frame/container element."
  [renderer state frame]
  (draw-render/draw-render-frame! renderer
                                  state
                                  frame
                                  draw-render-screen-rect!
                                  draw-render-box-edge!))

(defn draw-render-text!
  "Render a text element using the built-in SDL debug font."
  [renderer state text-element]
  (draw-render/draw-render-text! renderer state text-element))

(defn draw-render-arrow-segment!
  "Render an arrow segment using COLOR as the active stroke color."
  [renderer state a b size color]
  (draw-with-stroke-color color
    (lambda ()
      (draw-render-stroke-segment! renderer state a b size))))

(defn draw-render-arrow-point!
  "Render an arrow endpoint using COLOR as the active stroke color."
  [renderer state point size color]
  (draw-with-stroke-color color
    (lambda ()
      (draw-render-stroke-point! renderer state point size))))

(defn draw-render-arrow!
  "Render an arrow element."
  [renderer state arrow]
  (draw-render/draw-render-arrow! renderer
                                  state
                                  arrow
                                  draw-render-arrow-point!
                                  draw-render-arrow-segment!))

(defn draw-render-element!
  "Render a committed canvas element."
  [renderer state element]
  (draw-render/draw-render-element! renderer
                                    state
                                    element
                                    draw-render-box!
                                    draw-render-arrow!
                                    draw-render-frame!
                                    draw-render-text!
                                    draw-render-stroke!))

(defn draw-render-active-box!
  "Render the current active rectangle preview."
  [renderer state active-box]
  (draw-render/draw-render-active-box! renderer
                                       state
                                       active-box
                                       draw-render-box!))

(defn draw-render-active-arrow!
  "Render the current active arrow preview."
  [renderer state active-arrow]
  (draw-render/draw-render-active-arrow! renderer
                                         state
                                         active-arrow
                                         draw-render-arrow!))

(defn draw-render-active-frame!
  "Render the current active legacy frame preview."
  [renderer state active-frame]
  (draw-render/draw-render-active-frame! renderer
                                         state
                                         active-frame
                                         draw-render-frame!))

(defn draw-render-active-text!
  "Render the current active text preview."
  [renderer state active-text]
  (draw-render/draw-render-active-text! renderer
                                        state
                                        active-text
                                        draw-render-text!))

(defn draw-render-selection-handles!
  "Render editing handles for the currently selected editable element."
  [renderer state]
  (draw-render/draw-render-selection-handles! renderer
                                              state
                                              draw-render-screen-soft-segment!))

(defn draw-render-selection!
  "Render selection bounds and handles for the current selection."
  [renderer state]
  (draw-render/draw-render-selection! renderer
                                      state
                                      draw-render-box!
                                      draw-render-selection-handles!))

(defn draw-preview-stroke!
  "Render STROKE into the preview texture."
  [state stroke]
  (draw-canvas/draw-preview-stroke! state
                                    stroke
                                    draw-with-preview!
                                    draw-render-stroke!))

(defn draw-preview-segment!
  "Render just the newest segment from PREVIOUS to POINT into the preview texture."
  [state previous point size color]
  (draw-canvas/draw-preview-segment! state
                                     previous
                                     point
                                     size
                                     color
                                     draw-with-preview!
                                     draw-with-stroke-color
                                     draw-render-stroke-segment!))

(defn draw-preview-batch-render!
  "Render active stroke points from START-INDEX up to END-INDEX."
  [renderer state points start-index end-index size]
  (draw-canvas/draw-preview-batch-render! renderer
                                          state
                                          points
                                          start-index
                                          end-index
                                          size
                                          draw-render-stroke-segment!))

(defn draw-sync-preview!
  "Render only the missing active-stroke segments into the preview texture."
  [state]
  (let [active (get state :active-stroke)]
    (if (and active (draw-preview-ready?))
      (let [points (get active :points)
            total (count points)
            rendered (if (and (integer? *draw-preview-point-count*)
                              (>= *draw-preview-point-count* 0)
                              (<= *draw-preview-point-count* total))
                       *draw-preview-point-count*
                       0)]
        (if (= rendered 0)
          (begin
            (draw-clear-preview!)
            (if (> total 0)
              (draw-with-preview!
                (lambda (renderer)
                  (draw-with-stroke-color (get active :color)
                    (lambda ()
                      (draw-render-stroke-point! renderer
                                                 state
                                                 (first points)
                                                 (get active :size))))))
              nil)
            (set! *draw-preview-point-count* (if (> total 0) 1 0)))
          nil)
        (if (< *draw-preview-point-count* total)
          (let [end-index (if (> (+ *draw-preview-point-count*
                                    (draw-preview-segment-budget))
                                 total)
                            total
                            (+ *draw-preview-point-count*
                               (draw-preview-segment-budget)))
                batch-count (- end-index *draw-preview-point-count*)]
            (if (> batch-count 0)
              (draw-with-preview!
                (lambda (renderer)
                  (draw-with-stroke-color (get active :color)
                    (lambda ()
                      (draw-preview-batch-render! renderer
                                                  state
                                                  points
                                                  *draw-preview-point-count*
                                                  end-index
                                                  (get active :size))))))
              nil)
            (set! *draw-preview-point-count* end-index))
          nil)
        true)
      (begin
        (if (> *draw-preview-point-count* 0)
          (draw-clear-preview!)
          nil)
        (draw-reset-preview-sync!)
        false))))

(defn draw-render-elements!
  "Render all committed elements plus active previews."
  [ctx state]
  (draw-render/draw-render-elements! ctx
                                     state
                                     draw-render-element!
                                     draw-render-stroke!
                                     draw-render-active-box!
                                     draw-render-active-arrow!
                                     draw-render-active-frame!
                                     draw-render-active-text!
                                     draw-render-selection!))

(defn draw-render-canvas!
  "Render the cached canvas texture, or fall back to stroke replay."
  [ctx state]
  (draw-canvas/draw-render-canvas! ctx
                                   state
                                   draw-canvas-ready?
                                   draw-preview-ready?
                                   draw-render-elements!
                                   draw-render-stroke!
                                   draw-render-active-box!
                                   draw-render-active-arrow!
                                   draw-render-active-frame!
                                   draw-render-active-text!
                                   draw-render-selection!))

(defn draw-render-tool-panel-button!
  "Render BUTTON from the in-window tool panel."
  [renderer button]
  (draw-render-tool-panel-button-base! renderer button))

(defn draw-render-tool-panel!
  "Render the toggleable in-window tool panel."
  [renderer state]
  (draw-render-tool-panel-base! renderer state))

(defn draw-render-debug-panel!
  "Render the on-demand debug panel."
  [renderer state]
  (draw-status/draw-render-debug-panel! renderer
                                        state
                                        draw-render-stroke-point!
                                        draw-desired-cursor-kind
                                        *draw-last-error*))

(defn draw-render-status!
  "Render the text overlay and mouse marker for STATE."
  [ctx state]
  (draw-status/draw-render-status! ctx
                                   state
                                   draw-render-stroke-point!
                                   draw-desired-cursor-kind
                                   *draw-last-error*))

(defn draw-loop-step!
  "Drain input and render once when the window is active."
  []
  (draw-with-lock
    (lambda ()
      (draw-write-heartbeat! :poll *draw-state*)
      (draw-poll-control!)
      (draw-poll-input!)
      (draw-write-heartbeat! :render *draw-state*)
      (if *draw-state*
        (let [state (draw-render-current!)]
          (draw-write-state-file! state false)
          (draw-write-heartbeat! :idle state)
          state)
        *draw-state*))))

(defn default-render-frame
  "Clear and present one frame using STATE."
  [ctx state]
  (let [renderer (get ctx :renderer)
        background (get state :background)]
    (sdl/set-draw-color!
      renderer
      (nth background 0)
      (nth background 1)
      (nth background 2)
      255)
    (sdl/render-clear! renderer)
    (draw-render-canvas! ctx state)
    (draw-render-status! ctx state)
    (sdl/render-present! renderer)
    nil))

(defn render-frame
  "Clear and present one frame."
  [ctx state]
  (if *draw-render-fn*
    (*draw-render-fn* ctx state)
    (default-render-frame ctx state)))

(defn render-now!
  "Render one frame from the current state."
  []
  (draw-with-lock
    (lambda ()
      (if (draw-supervised-mode?)
        (draw-write-control-command! :redraw {:reason :manual})
        (begin
          (draw-poll-input!)
          (draw-render-current!))))))

(defn draw-loop
  "Render until the window is closed or the loop is stopped."
  []
  (handle-exceptions exn
    (draw-crash! exn)
    (if *draw-running?*
      (begin
        (draw-loop-step!)
        (if *draw-running?*
          (begin
            (thread-sleep! 0.016)
            (draw-loop))
          nil))
      nil)))

(defn start!
  "Open the SDL window and prepare the draw state."
  []
  (draw-with-lock
    (lambda ()
      (if (and *draw-running?* *draw-context*)
        *draw-context*
        (begin
          (if *draw-child-mode?*
            (draw-log-entry! :child-start-enter
                             {:state (draw-state-snapshot *draw-state*)})
            nil)
          (if (not (init-video!))
            (begin
              (if *draw-child-mode?*
                (draw-log-entry! :child-init-video-failed {:error (last-error)})
                nil)
              (println (format "SDL init failed: %s" (last-error)))
              nil)
            (let [state (if *draw-state*
                          (assoc *draw-state*
                                 :window-focused? true
                                 :pen-pressure 1.0)
                          (default-state))
                  ctx (sdl/open-context (get state :title)
                                        (get state :width)
                                        (get state :height))]
              (if (nil? ctx)
                (begin
                  (if *draw-child-mode?*
                    (draw-log-entry! :child-open-context-failed {:error (last-error)})
                    nil)
                  (println (format "SDL window failed: %s" (last-error)))
                  (shutdown!)
                  nil)
                (begin
                  (if *draw-child-mode?*
                    (draw-log-entry! :child-open-context-ok {:title (get state :title)})
                    nil)
                  (set! *draw-state* state)
                  (set! *draw-context* (assoc ctx :cursor-cache {} :cursor-kind false))
                  (set! *draw-running?* true)
                  (set! *draw-last-heartbeat-at* 0)
                  (draw-clear-watchdog-files!)
                  (draw-log-entry! :start
                                   {:state (draw-state-snapshot state)
                                    :log (draw-log-file-path)
                                    :crash (draw-crash-file-path)
                                    :heartbeat (draw-heartbeat-file-path)
                                    :stall (draw-stall-file-path)})
                  (draw-ensure-canvas! state)
                  (draw-ensure-preview! state)
                  (draw-ensure-brush-texture! state)
                  (draw-ensure-strip-texture! state)
                  (if (draw-canvas-ready?)
                    (draw-rebuild-canvas! state)
                    nil)
                  (draw-reset-preview-sync!)
                  (draw-clear-preview!)
                  (draw-write-state-file! state true)
                  (draw-write-heartbeat! :start state)
                  (draw-start-watchdog!)
                  (sync-window-title!)
                  ctx)))))))))

(defn draw-stop-local!
  "Stop the local draw loop and close the SDL context."
  []
  (draw-with-lock
    (lambda ()
      (draw-write-state-file! *draw-state* true)
      (draw-write-heartbeat! :stop *draw-state*)
      (draw-log-entry! :stop {:state (draw-state-snapshot *draw-state*)})
      (set! *draw-running?* false)
      (draw-stop-watchdog!)
      (draw-release-canvas!)
      (draw-release-preview!)
      (draw-release-brush-texture!)
      (draw-release-strip-texture!)
      (draw-release-cursors!)
      (if *draw-context*
        (begin
          (sdl/close-context! *draw-context*)
          (set! *draw-context* nil)))
      (set! *draw-thread* nil)
      (set! *draw-last-heartbeat-at* 0)
      (shutdown!)
      nil)))

(defn draw-start-local-dev!
  "Start the SDL window and background loop in the current process."
  []
  (if (and *draw-running?* *draw-context*)
    *draw-context*
    (begin
      (when *draw-context*
        (draw-stop-local!))
      (draw-clear-error!)
      (let [ctx (start!)]
      (if ctx
        (begin
          (render-now!)
          (set! *draw-thread*
                (make-thread
                  (lambda ()
                    (draw-loop))
                  "cluck-draw"))
          (thread-start! *draw-thread*)
          ctx)
        nil)))))

(defn draw-supervisor-launch-child!
  "Start the child draw process and return its pid."
  []
  (let [pid (draw-supervision/draw-supervisor-launch-child-base! (current-directory)
                                                                 (draw-child-runner-path)
                                                                 (draw-child-stdout-path))]
    (set! *draw-child-pid* pid)
    pid))

(defn draw-supervisor-stop-child!
  "Stop the supervised child process when it is running."
  []
  (let [pid *draw-child-pid*]
    (set! *draw-child-pid* false)
    (draw-supervision/draw-supervisor-stop-child-base! pid)
    nil))

(defn draw-heartbeat-age-ms
  "Return the age of the child heartbeat in milliseconds, or false."
  []
  (draw-runtime/draw-heartbeat-age-ms (draw-heartbeat-file-path)))

(defn draw-wait-for-child-ready!
  "Wait until the supervised child writes its first heartbeat, or time out."
  [deadline-ms]
  (draw-supervision/draw-wait-for-child-ready-base! (draw-heartbeat-file-path)
                                                    (lambda () *draw-running?*)
                                                    *draw-child-pid*
                                                    draw-child-alive?
                                                    draw-wall-clock-ms
                                                    deadline-ms))

(defn draw-start-supervisor-loop!
  "Start the parent-side thread that restarts a dead or stale child."
  []
  (set! *draw-thread* nil)
  (set! *draw-supervisor-thread*
        (draw-supervision/draw-start-supervisor-loop-base! draw-supervised-mode?
                                                           (lambda () *draw-child-pid*)
                                                           draw-heartbeat-age-ms
                                                           draw-child-alive?
                                                           draw-log-entry!
                                                           draw-supervisor-launch-child!
                                                           draw-supervisor-stop-child!
                                                           (draw-watchdog-stale-ms)
                                                           (draw-supervisor-poll-ms)
                                                           draw-state-snapshot
                                                           current-state))
  (thread-start! *draw-supervisor-thread*)
  *draw-supervisor-thread*)

(defn draw-stop-supervisor-loop!
  "Stop the parent-side supervisor thread."
  []
  (let [thread *draw-supervisor-thread*]
    (set! *draw-supervisor-thread* nil)
    (draw-supervision/draw-stop-supervisor-loop-base! thread)
    nil))

(defn draw-start-supervised-dev!
  "Start the draw child process and the parent supervisor thread."
  []
  (draw-with-lock
    (lambda ()
      (set! *draw-state* (or *draw-state* (default-state)))
      (set! *draw-running?* true)
      (set! *draw-control-seq* 0)
      (set! *draw-last-control-seq* 0)
      (set! *draw-last-heartbeat-at* 0)
      (set! *draw-last-state-sync-at* 0)
      (draw-clear-error!)
      (draw-clear-control-file!)
      (draw-clear-watchdog-files!)
      (draw-write-state-file! *draw-state* true)
      (draw-log-entry! :supervised-start
                       {:state (draw-state-snapshot *draw-state*)
                        :child-log (draw-child-stdout-path)
                        :control (draw-control-file-path)})
      (let [pid (draw-supervisor-launch-child!)]
        (if pid
          (let [deadline (+ (draw-wall-clock-ms) 15000)]
            (begin
              (draw-start-supervisor-loop!)
              (if (draw-wait-for-child-ready! deadline)
                {:pid pid :mode :supervised}
                (begin
                  (draw-log-entry! :supervised-start-failed
                                   {:pid pid
                                    :child-log (draw-child-stdout-path)
                                    :heartbeat (draw-heartbeat-file-path)})
                  (set! *draw-running?* false)
                  (draw-stop-supervisor-loop!)
                  (draw-supervisor-stop-child!)
                  false))))
          (begin
            (set! *draw-running?* false)
            false))))))

(defn stop!
  "Stop the supervised child or the local draw loop."
  []
  (if (draw-supervised-mode?)
    (draw-with-lock
      (lambda ()
        (draw-log-entry! :supervised-stop {:state (draw-state-snapshot (current-state))})
        (set! *draw-running?* false)
        (draw-write-control-command! :stop {})
        (draw-stop-supervisor-loop!)
        (draw-supervisor-stop-child!)
        nil))
    (draw-stop-local!)))

(defn start-dev!
  "Start the draw app in supervised mode, or locally when supervision is disabled."
  []
  (if (draw-supervised-mode?)
    (draw-start-supervised-dev!)
    (draw-start-local-dev!)))

(defn restart-dev!
  "Restart the development window after a crash or reset."
  []
  (draw-log-entry! :restart {:state (draw-state-snapshot *draw-state*)})
  (stop!)
  (reset-state!)
  (draw-clear-error!)
  (start-dev!))

(defn run-loop
  "Run until SDL asks us to quit."
  [ctx state]
  (if *draw-running?*
    (begin
      (draw-loop-step!)
      (if *draw-running?*
        (begin
          (delay-ms 16)
          (run-loop ctx state))
        nil))
    nil))

(defn draw-child-main
  "Run the draw window in child-process mode."
  []
  (set! *draw-child-mode?* true)
  (set! *draw-supervision-enabled?* false)
  (draw-log-entry! :child-main-enter {:cwd (current-directory)})
  (set! *draw-state* (or (draw-read-state-file)
                         *draw-state*
                         (default-state)))
  (set! *draw-last-control-seq* 0)
  (draw-clear-error!)
  (let [ctx (start!)]
    (if ctx
      (handle-exceptions exn
        (begin
          (draw-log-entry! :child-main-crash-before-loop
                           {:error (format "%s" exn)
                            :state (draw-state-snapshot *draw-state*)})
          (draw-crash! exn)
          nil)
        (begin
          (draw-log-entry! :child-main-started {:state (draw-state-snapshot *draw-state*)})
          (render-now!)
          (run-loop ctx *draw-state*)
          (draw-stop-local!)))
      (begin
        (draw-log-entry! :child-main-start-returned-nil {:error (last-error)})
        nil))))

(defn main
  "Open a window and run the minimal SDL3 loop."
  [args]
  (set! *draw-state* (default-state))
  (if (member "--repl" args)
    (begin
      (if (start-dev!)
        (begin
          (println (format "Opened %s" (describe-state *draw-state*)))
          (println (format "Hint: %s" (str/upper-case "use the repl to change state")))
          (println (format "Hint: %s" (str/upper-case "call (stop!) or close the window to quit")))
          (cluck-repl)
          (stop!))
        nil))
    (let [state (current-state)]
      (if (not (init-video!))
        (begin
          (println (format "SDL init failed: %s" (last-error)))
          nil)
        (let [ctx (sdl/open-context (get state :title)
                                    (get state :width)
                                    (get state :height))]
          (if (nil? ctx)
            (begin
              (println (format "SDL window failed: %s" (last-error)))
              (shutdown!)
              nil)
            (begin
              (println (format "Opened %s" (describe-state state)))
              (println (format "Hint: %s" (str/upper-case "close the window to quit")))
              (run-loop ctx state)
              (sdl/close-context! ctx)
              (shutdown!)
              nil)))))))

(comment
  
  (load-file "examples/cluck/draw/dev.clk")
  (draw-clear-log!)
  (draw-clear-watchdog-files!)
  (start-dev!)

  (draw-log-tail 50)
  (dump-current-state!)
  (draw-watchdog-status)

  (default-state)
  (describe-state (default-state))
  (draw-clear-strokes! (default-state))
  (draw-undo-stroke! (default-state))
  (draw-set-brush-size! (default-state) 6)
  (draw-toggle-eraser! (default-state))
  (restart-dev!)
  (draw-toggle-debug-panel! (current-state))
  (main ["--help"]))
