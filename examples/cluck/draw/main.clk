;; SDL3 drawing app spike for Cluck.
;;
;; The app stays in Cluck syntax. The SDL3 bindings live in cluck.sdl3, which
;; is the direct C-interop boundary.

(ns cluck.examples.draw
  (:require [cluck.sdl3 :as sdl]
            [cluck.fs :as fs]
            [cluck.io :as io]
            [cluck.process :as proc]
            [cluck.edn :as edn]
            [cluck.math :as math]
            [cluck.string :as str]))

(import srfi-18
        (prefix (chicken file) cfile:)
        (chicken time)
        (prefix (chicken process) cproc:)
        (prefix (chicken process-context posix) posix:))

(def *draw-state* nil)
(def *draw-context* nil)
(def *draw-running?* false)
(def *draw-thread* nil)
(def *draw-render-fn* nil)
(def *draw-last-error* false)
(def *draw-log-enabled?* true)
(def *draw-log-path* false)
(def *draw-crash-path* false)
(def *draw-heartbeat-path* false)
(def *draw-stall-path* false)
(def *draw-stall-sample-path* false)
(def *draw-watchdog-enabled?* true)
(def *draw-watchdog-pid* false)
(def *draw-last-heartbeat-at* 0)
(def *draw-last-state-sync-at* 0)
(def *draw-child-mode?* false)
(def *draw-supervision-enabled?* true)
(def *draw-supervisor-thread* nil)
(def *draw-child-pid* false)
(def *draw-control-seq* 0)
(def *draw-last-control-seq* 0)
(def *draw-canvas-ready?* false)
(def *draw-preview-ready?* false)
(def *draw-brush-ready?* false)
(def *draw-strip-ready?* false)
(def *draw-preview-point-count* 0)
(def *draw-io-lock* (make-mutex 'cluck-draw-io))
(def *draw-current-stroke-color* false)

(defn draw-recent-events-limit
  []
  8)

(defn draw-debug-event-lines-limit
  []
  4)

(defn draw-preview-segment-budget
  "Return the maximum number of new stroke points to preview in one frame."
  []
  24)

(defn draw-heartbeat-interval-ms
  "Return the minimum spacing between heartbeat file writes."
  []
  250)

(defn draw-watchdog-stale-ms
  "Return how long the heartbeat may stay stale before a stall is recorded."
  []
  5000)

(defn draw-watchdog-poll-ms
  "Return how often the external stall watcher checks the heartbeat."
  []
  500)

(defn draw-state-sync-interval-ms
  "Return the minimum spacing between full state-file writes."
  []
  250)

(defn draw-supervisor-poll-ms
  "Return how often the parent supervisor checks the child."
  []
  1000)

(defn init-video!
  []
  (sdl/init-video!))

(defn shutdown!
  []
  (sdl/shutdown! #f))

(defn last-error
  []
  (sdl/last-error #f))

(defn quit-requested?
  []
  (sdl/quit-requested? #f))

(defn delay-ms
  [ms]
  (sdl/delay-ms ms))

(defn draw-with-lock
  "Run THUNK while holding the draw I/O mutex."
  [thunk]
  (mutex-lock! *draw-io-lock*)
  (dynamic-wind
    (lambda () false)
    (lambda () (thunk))
    (lambda () (mutex-unlock! *draw-io-lock*))))

(defn default-state
  "Return the starter app state."
  []
  {:title "Cluck Draw"
   :width 1280
   :height 720
   :background [24 24 28]
   :brush-color [245 245 245]
   :brush-size 2
   :pen-pressure 1.0
   :window-focused? true
   :view-x 0.0
   :view-y 0.0
   :zoom 1.0
   :running? true
   :frame 0
   :mouse-x 0
   :mouse-y 0
   :mouse-screen-x 0.0
   :mouse-screen-y 0.0
   :pointer-down? false
   :pointer-source false
   :panning? false
   :pan-last-x 0
   :pan-last-y 0
   :space-down? false
   :ctrl-down? false
   :canvas-dirty? false
   :debug-panel? false
   :tool-panel? false
   :history []
   :elements []
   :next-element-id 1
   :selection []
   :active-selection-drag false
   :active-selection-resize false
   :strokes []
   :active-stroke false
   :active-box false
   :active-arrow false
   :active-frame false
   :active-text false
   :last-key ""
   :last-text ""
   :last-event ""
   :recent-events []})

(defn draw-state-file-path
  "Return the default path used for saving and loading the canvas state."
  []
  (fs/path (current-directory) "build" "cluck-draw-state.edn"))

(defn draw-log-file-path
  "Return the path used for the draw session log."
  []
  (or *draw-log-path*
      (fs/path (current-directory) "build" "cluck-draw.log")))

(defn draw-crash-file-path
  "Return the path used for the latest crash snapshot."
  []
  (or *draw-crash-path*
      (fs/path (current-directory) "build" "cluck-draw-crash.edn")))

(defn draw-heartbeat-file-path
  "Return the path used for draw loop heartbeats."
  []
  (or *draw-heartbeat-path*
      (fs/path (current-directory) "build" "cluck-draw-heartbeat.edn")))

(defn draw-stall-file-path
  "Return the path used for detected draw stalls."
  []
  (or *draw-stall-path*
      (fs/path (current-directory) "build" "cluck-draw-stall.edn")))

(defn draw-stall-sample-file-path
  "Return the path used for detected draw stall samples."
  []
  (or *draw-stall-sample-path*
      (fs/path (current-directory) "build" "cluck-draw-stall.sample")))

(defn draw-watchdog-script-path
  "Return the watchdog script used to capture draw stalls."
  []
  (fs/path (current-directory) "examples" "cluck" "draw" "watchdog.sh"))

(defn draw-child-runner-path
  "Return the child-runner script used by the supervisor process."
  []
  (fs/path (current-directory) "examples" "cluck" "draw" "run-dev-child.scm"))

(defn draw-control-file-path
  "Return the control file used by the supervised child."
  []
  (fs/path (current-directory) "build" "cluck-draw-control.edn"))

(defn draw-child-stdout-path
  "Return the file used for child stdout/stderr capture."
  []
  (fs/path (current-directory) "build" "cluck-draw-child.log"))

(defn draw-process-id
  "Return the current process id."
  []
  (posix:current-process-id))

(defn draw-wall-clock-ms
  "Return the current wall clock in milliseconds."
  []
  (* (current-seconds) 1000))

(defn draw-ensure-parent-directory!
  "Ensure PATH's parent directory exists before writing a save file."
  [path]
  (let [dir (fs/dirname path)]
    (if (and dir (not (fs/directory? dir)))
      (create-directory dir)
      dir)))

(defn draw-write-file-atomic!
  "Write TEXT to PATH using a temporary file and rename."
  [path text]
  (let [target (fs/path path)
        temp (str target ".tmp")]
    (draw-ensure-parent-directory! target)
    (io/spit temp text)
    (cfile:rename-file temp target true)
    target))

(defn draw-enable-logging!
  "Enable draw session logging."
  []
  (set! *draw-log-enabled?* true))

(defn draw-disable-logging!
  "Disable draw session logging."
  []
  (set! *draw-log-enabled?* false))

(defn draw-reset-preview-sync!
  "Forget any cached active-stroke preview progress."
  []
  (set! *draw-preview-point-count* 0))

(defn draw-set-log-path!
  "Override the draw session log path."
  [path]
  (set! *draw-log-path* (fs/path path)))

(defn draw-set-crash-path!
  "Override the draw crash snapshot path."
  [path]
  (set! *draw-crash-path* (fs/path path)))

(defn draw-enable-watchdog!
  "Enable the external draw watchdog."
  []
  (set! *draw-watchdog-enabled?* true))

(defn draw-disable-watchdog!
  "Disable the external draw watchdog."
  []
  (set! *draw-watchdog-enabled?* false))

(defn draw-watchdog-status
  "Return the current watchdog configuration and paths."
  []
  {:enabled? *draw-watchdog-enabled?*
   :pid *draw-watchdog-pid*
   :heartbeat (draw-heartbeat-file-path)
   :stall (draw-stall-file-path)
   :sample (draw-stall-sample-file-path)
   :stale-ms (draw-watchdog-stale-ms)
   :poll-ms (draw-watchdog-poll-ms)})

(defn draw-enable-supervision!
  "Enable the supervised child-process development mode."
  []
  (set! *draw-supervision-enabled?* true))

(defn draw-disable-supervision!
  "Disable the supervised child-process development mode."
  []
  (set! *draw-supervision-enabled?* false))

(defn draw-supervised-mode?
  "Return true when the current process should supervise a child draw window."
  []
  (and *draw-supervision-enabled?*
       (not *draw-child-mode?*)))

(defn draw-supervisor-status
  "Return the current supervised-child status."
  []
  {:enabled? (draw-supervised-mode?)
   :child-mode? *draw-child-mode?*
   :child-pid *draw-child-pid*
   :supervisor-thread? (if *draw-supervisor-thread* true false)
   :control-seq *draw-control-seq*
   :last-control-seq *draw-last-control-seq*
   :state-path (draw-state-file-path)
   :control-path (draw-control-file-path)
   :child-log (draw-child-stdout-path)
   :heartbeat (draw-heartbeat-file-path)})

(defn draw-clear-log!
  "Delete the current draw log file when it exists."
  []
  (let [path (draw-log-file-path)]
    (if (fs/file? path)
      (fs/delete! path)
      false)
    path))

(defn draw-clear-watchdog-files!
  "Delete prior heartbeat and stall artifacts."
  []
  (let [paths [(draw-heartbeat-file-path)
               (draw-stall-file-path)
               (draw-stall-sample-file-path)]]
    (let [heartbeat (first paths)
          stall (nth paths 1)
          sample (nth paths 2)]
      (if (fs/file? heartbeat)
        (fs/delete! heartbeat)
        false)
      (if (fs/file? stall)
        (fs/delete! stall)
        false)
      (if (fs/file? sample)
        (fs/delete! sample)
        false))
    paths))

(defn draw-clear-control-file!
  "Delete any prior supervised-child control file."
  []
  (let [path (draw-control-file-path)]
    (if (fs/file? path)
      (fs/delete! path)
      false)
    path))

(defn draw-log-lines
  "Return all current draw log lines."
  []
  (let [path (draw-log-file-path)]
    (if (fs/file? path)
      (io/read-lines path)
      [])))

(defn draw-log-tail
  "Return the last COUNT draw log lines."
  [n]
  (let [lines (draw-log-lines)
        total (count lines)
        limit (if (and n (> n 0)) n 0)]
    (if (> total limit)
      (vec (drop (- total limit) lines))
      (vec lines))))

(defn draw-state-snapshot
  "Return a compact diagnostic snapshot for STATE."
  [state]
  (if state
    {:frame (get state :frame)
     :mouse-x (or (get state :mouse-x) 0.0)
     :mouse-y (or (get state :mouse-y) 0.0)
     :mouse-screen-x (or (get state :mouse-screen-x) 0.0)
     :mouse-screen-y (or (get state :mouse-screen-y) 0.0)
     :view-x (draw-view-x state)
     :view-y (draw-view-y state)
     :zoom (draw-view-zoom state)
     :pressure (or (get state :pen-pressure) 1.0)
     :pointer-down? (get state :pointer-down?)
     :panning? (get state :panning?)
     :space-down? (get state :space-down?)
     :ctrl-down? (get state :ctrl-down?)
     :window-focused? (get state :window-focused?)
     :tool (draw-tool-mode state)
     :brush-size (get state :brush-size)
     :elements (count (get state :elements))
     :selection (count (or (get state :selection) []))
     :strokes (count (get state :strokes))
     :active-points (if (get state :active-stroke)
                      (count (get (get state :active-stroke) :points))
                      0)
     :active-box? (if (get state :active-box) true false)
     :active-arrow? (if (get state :active-arrow) true false)
     :active-frame? (if (get state :active-frame) true false)
     :active-text? (if (get state :active-text) true false)
     :history (count (get state :history))
     :canvas-dirty? (get state :canvas-dirty?)
     :last-key (or (get state :last-key) "")
     :last-text (or (get state :last-text) "")
     :last-event (or (get state :last-event) "")}
    nil))

(defn draw-read-state-file
  "Read the latest full draw state from disk when available."
  []
  (let [path (draw-state-file-path)]
    (if (fs/file? path)
      (handle-exceptions _ false
        (draw-normalize-state
          (edn/read-string (io/slurp path))))
      false)))

(defn draw-element-kind
  "Return the normalized kind keyword for ELEMENT."
  [element]
  (let [kind (get element :kind)]
    (if (keyword? kind)
      kind
      :ink)))

(defn draw-ink-element?
  "Return true when ELEMENT is an ink stroke."
  [element]
  (draw-kind=? (draw-element-kind element) :ink))

(defn draw-box-element?
  "Return true when ELEMENT is a box."
  [element]
  (draw-kind=? (draw-element-kind element) :box))

(defn draw-arrow-element?
  "Return true when ELEMENT is an arrow."
  [element]
  (draw-kind=? (draw-element-kind element) :arrow))

(defn draw-frame-element?
  "Return true when ELEMENT is a frame."
  [element]
  (draw-kind=? (draw-element-kind element) :frame))

(defn draw-text-element?
  "Return true when ELEMENT is text."
  [element]
  (draw-kind=? (draw-element-kind element) :text))

(defn draw-normalize-ink-element
  "Return ELEMENT in canonical ink-element form."
  [element]
  {:id (get element :id)
   :kind :ink
   :points (vec (get element :points))
   :color (get element :color)
   :size (get element :size)})

(defn draw-normalize-box-element
  "Return ELEMENT in canonical box-element form."
  [element]
  {:id (get element :id)
   :kind :box
   :x (or (get element :x) 0.0)
   :y (or (get element :y) 0.0)
   :width (or (get element :width) 0.0)
   :height (or (get element :height) 0.0)
   :color (get element :color)
   :size (or (get element :size) 1)})

(defn draw-normalize-arrow-point
  "Return POINT in canonical [x y pressure] form."
  [point]
  [(or (nth point 0) 0.0)
   (or (nth point 1) 0.0)
   (or (if (> (count point) 2) (nth point 2) 1.0) 1.0)])

(defn draw-normalize-arrow-element
  "Return ELEMENT in canonical arrow-element form."
  [element]
  {:id (get element :id)
   :kind :arrow
   :start (draw-normalize-arrow-point
            (or (get element :start)
                [(or (get element :x1) 0.0)
                 (or (get element :y1) 0.0)
                 1.0]))
   :end (draw-normalize-arrow-point
          (or (get element :end)
              [(or (get element :x2) 0.0)
               (or (get element :y2) 0.0)
               1.0]))
   :color (get element :color)
   :size (or (get element :size) 1)})

(defn draw-normalize-frame-element
  "Return ELEMENT in canonical frame-element form."
  [element]
  {:id (get element :id)
   :kind :frame
   :x (or (get element :x) 0.0)
   :y (or (get element :y) 0.0)
   :width (or (get element :width) 0.0)
   :height (or (get element :height) 0.0)
   :color (get element :color)
   :size (or (get element :size) 1)})

(defn draw-normalize-text-element
  "Return ELEMENT in canonical text-element form."
  [element]
  {:id (get element :id)
   :kind :text
   :x (or (get element :x) 0.0)
   :y (or (get element :y) 0.0)
   :text (or (get element :text) "Text")
   :color (get element :color)
   :size (or (get element :size) 1)})

(defn draw-normalize-element
  "Return ELEMENT in canonical element form."
  [element]
  (if (draw-box-element? element)
    (draw-normalize-box-element element)
    (if (draw-arrow-element? element)
      (draw-normalize-arrow-element element)
      (if (draw-frame-element? element)
        (draw-normalize-frame-element element)
        (if (draw-text-element? element)
          (draw-normalize-text-element element)
          (draw-normalize-ink-element element))))))

(defn draw-legacy-strokes->elements
  "Upgrade legacy stroke maps into ink elements."
  [strokes]
  (let [next-id 1]
    (reduce (lambda (result stroke)
              (let [id (count result)]
                (conj result
                      {:id (+ id next-id)
                       :kind :ink
                       :points (vec (get stroke :points))
                       :color (get stroke :color)
                       :size (get stroke :size)})))
            []
            strokes)))

(defn draw-elements->strokes
  "Return the legacy strokes view derived from ELEMENTS."
  [elements]
  (reduce (lambda (strokes element)
            (if (draw-ink-element? element)
              (conj strokes
                    {:points (vec (get element :points))
                     :color (get element :color)
                     :size (get element :size)})
              strokes))
          []
          elements))

(defn draw-selection-has-id?
  "Return true when SELECTION contains ELEMENT-ID."
  [selection element-id]
  (if (empty? selection)
    false
    (truthy?
      (some (fn [selected-id]
              (if (= selected-id element-id)
                true
                false))
            selection))))

(defn draw-normalize-selection
  "Return SELECTION filtered down to ids present in ELEMENTS."
  [selection elements]
  (let [selection (or selection [])]
    (vec
      (filter (fn [element-id]
                (draw-selection-has-id?
                  (map (fn [element]
                         (get element :id))
                       elements)
                  element-id))
              selection))))

(defn draw-max-element-id
  "Return the highest element id present in ELEMENTS."
  [elements]
  (reduce (lambda (current element)
            (let [id (or (get element :id) 0)]
              (if (> id current)
                id
                current)))
          0
          elements))

(defn draw-elements-with-ids
  "Return ELEMENTS normalized and with stable ids assigned when missing."
  [elements]
  (vec
    (map-indexed
      (fn [index element]
        (let [element (draw-normalize-element element)]
          (if (get element :id)
            element
            (assoc element :id (+ index 1)))))
      elements)))

(defn draw-sync-elements
  "Install ELEMENTS as the authoritative element set and derive legacy strokes."
  [state elements]
  (let [elements (draw-elements-with-ids elements)
        strokes (vec (draw-elements->strokes elements))
        selection (draw-normalize-selection (get state :selection) elements)
        next-id (+ 1 (draw-max-element-id elements))]
    (assoc state
           :elements elements
           :selection selection
           :active-selection-drag (if (empty? selection)
                                    false
                                    (get state :active-selection-drag))
           :active-selection-resize (if (empty? selection)
                                      false
                                      (get state :active-selection-resize))
           :strokes strokes
           :next-element-id next-id)))

(defn draw-normalize-state
  "Upgrade STATE so element and stroke views are both populated."
  [state]
  (let [state (if (get state :elements)
                state
                (assoc state :elements (draw-legacy-strokes->elements (get state :strokes))))
        state (if (contains? state :tool)
                state
                (assoc state :tool :ink))
        state (if (contains? state :selection)
                state
                (assoc state :selection []))
        state (if (contains? state :active-selection-drag)
                state
                (assoc state :active-selection-drag false))
        state (if (contains? state :active-selection-resize)
                state
                (assoc state :active-selection-resize false))
        state (if (contains? state :tool-panel?)
                state
                (assoc state :tool-panel? false))]
    (draw-sync-elements state (get state :elements))))

(defn draw-heartbeat-payload
  "Return the external heartbeat payload for STATE at PHASE."
  [phase state]
  {:at (draw-wall-clock-ms)
   :phase phase
   :pid (draw-process-id)
   :running? *draw-running?*
   :watchdog? *draw-watchdog-enabled?*
   :state (draw-state-snapshot state)})

(defn draw-write-heartbeat!
  "Write a heartbeat for PHASE and STATE when enough time has elapsed."
  [phase state]
  (let [now (draw-wall-clock-ms)
        force? (or (equal? phase :start)
                   (equal? phase :stop)
                   (equal? phase :crash))
        due? (or force?
                 (= *draw-last-heartbeat-at* 0)
                 (>= (- now *draw-last-heartbeat-at*)
                     (draw-heartbeat-interval-ms)))]
    (if due?
      (let [path (draw-heartbeat-file-path)
            payload (draw-heartbeat-payload phase state)]
        (draw-write-file-atomic! path (pr-str payload))
        (set! *draw-last-heartbeat-at* now)
        payload)
      false)))

(defn draw-write-state-file!
  "Write STATE to the shared state file when enough time has elapsed."
  [state force?]
  (let [now (draw-wall-clock-ms)
        due? (or force?
                 (= *draw-last-state-sync-at* 0)
                 (>= (- now *draw-last-state-sync-at*)
                     (draw-state-sync-interval-ms)))]
    (if due?
      (let [path (draw-state-file-path)]
        (draw-write-file-atomic! path (pr-str state))
        (set! *draw-last-state-sync-at* now)
        path)
      false)))

(defn draw-log-entry!
  "Append a diagnostic KIND/PAYLOAD entry to the draw session log."
  [kind payload]
  (if *draw-log-enabled?*
    (let [path (draw-log-file-path)
          entry {:at (current-process-milliseconds)
                 :kind kind
                 :payload payload}
          line (pr-str entry)]
      (draw-ensure-parent-directory! path)
      (proc/system (format "printf '%%s\\n' %s >> %s"
                           (proc/qs line)
                           (proc/qs path)))
      line)
    nil))

(defn draw-write-crash-report!
  "Write a full crash report for EXN."
  [exn]
  (let [path (draw-crash-file-path)
        report {:at (current-process-milliseconds)
                :error (format "%s" exn)
                :state (draw-state-snapshot *draw-state*)
                :recent-events (if *draw-state* (get *draw-state* :recent-events) [])
                :last-error (if *draw-last-error*
                              (format "%s" *draw-last-error*)
                              "")}]
    (draw-write-file-atomic! path (pr-str report))
    path))

(defn draw-stop-watchdog!
  "Stop the external draw watchdog when one is running."
  []
  (let [pid *draw-watchdog-pid*]
    (set! *draw-watchdog-pid* false)
    (if pid
      (proc/system
        (format "kill %s >/dev/null 2>&1 || true"
                (proc/qs (str pid))))
      0)
    nil))

(defn draw-child-alive?
  "Return true when PID still exists."
  [pid]
  (and pid
       (zero? (proc/system
                (format "kill -0 %s >/dev/null 2>&1"
                        (proc/qs (str pid)))))))

(defn draw-write-control-command!
  "Write an OP/PAYLOAD command for the supervised child."
  [op payload]
    (let [seq (+ *draw-control-seq* 1)
        command {:seq seq
                 :op op
                 :payload payload}
        path (draw-control-file-path)]
    (set! *draw-control-seq* seq)
    (draw-write-file-atomic! path (pr-str command))
    command))

(defn draw-read-control-command
  "Read the latest supervised-child control command when present."
  []
  (let [path (draw-control-file-path)]
    (if (fs/file? path)
      (handle-exceptions _ false
        (edn/read-string (io/slurp path)))
      false)))

(defn draw-control-command-pending
  "Return the next unprocessed control command when present."
  []
  (let [command (draw-read-control-command)]
    (if command
      (let [seq (or (get command :seq) 0)]
        (if (> seq *draw-last-control-seq*)
          command
          false))
      false)))

(defn draw-start-watchdog!
  "Start the external draw watchdog if it is enabled."
  []
  (if (not *draw-watchdog-enabled?*)
    nil
    (let [script (draw-watchdog-script-path)]
      (if (not (fs/file? script))
        nil
        (begin
          (draw-stop-watchdog!)
          (draw-write-heartbeat! :start *draw-state*)
          (let [launcher
                  (format "%s %s %s %s %s %s %s %s >/dev/null 2>&1 & echo $!"
                          (proc/qs script)
                          (proc/qs (str (draw-process-id)))
                          (proc/qs (draw-heartbeat-file-path))
                          (proc/qs (draw-stall-file-path))
                          (proc/qs (draw-stall-sample-file-path))
                          (proc/qs (draw-log-file-path))
                          (proc/qs (str (draw-watchdog-stale-ms)))
                          (proc/qs (str (draw-watchdog-poll-ms))))
                command (format "/bin/sh -c %s"
                                (proc/qs launcher))
                result (proc/sh command)]
            (if (zero? (get result :exit))
              (let [pid-text (str/trim (get result :out))]
                (if (str/blank? pid-text)
                  nil
                  (begin
                    (set! *draw-watchdog-pid* (parse-long pid-text))
                    *draw-watchdog-pid*)))
              nil)))))))

(defn draw-dump-state!
  "Write the current full draw state to PATH, or the default state file."
  [path]
  (let [target (if path
                 (fs/path path)
                 (draw-state-file-path))]
    (draw-write-file-atomic! target (pr-str (current-state)))
    target))

(defn dump-current-state!
  "Write the current full draw state to the default dump file."
  []
  (draw-dump-state! false))

(defn draw-set-state-core!
  "Install STATE and refresh the cached canvas if needed."
  [state]
  (let [next-state (assoc (draw-normalize-state state) :canvas-dirty? true)]
    (if (draw-supervised-mode?)
      (begin
        (set! *draw-state* next-state)
        (draw-write-control-command! :set-state next-state)
        next-state)
      (begin
        (set! *draw-state* next-state)
        (draw-reset-preview-sync!)
        (draw-clear-preview!)
        (draw-log-entry! :set-state {:state (draw-state-snapshot *draw-state*)})
        (if *draw-running?*
          nil
          (draw-render-current!))
        *draw-state*))))

(defn draw-load-state-core!
  "Install STATE after loading it from disk."
  [state]
  (draw-set-state-core! state))

(defn draw-save-canvas-core!
  "Write STATE to the default draw save file and return STATE."
  [state]
  (let [path (draw-state-file-path)]
    (draw-ensure-parent-directory! path)
    (io/spit path (pr-str state))
    (draw-log-entry! :save
                     {:path path
                      :state (draw-state-snapshot state)})
    state))

(defn draw-load-canvas-core!
  "Load draw state from the default save file and return the next state."
  [state]
  (let [path (draw-state-file-path)]
    (if (fs/exists? path)
      (let [loaded (draw-normalize-state
                     (edn/read-string (io/slurp path)))
            next-state (assoc loaded
                              :debug-panel? (if (get state :debug-panel?) true false)
                              :tool-panel? (if (get state :tool-panel?) true false)
                              :window-focused? (if (contains? state :window-focused?)
                                                 (get state :window-focused?)
                                                 true)
                              :running? (if (contains? state :running?)
                                          (get state :running?)
                                          true)
                              :canvas-dirty? true)]
        (draw-log-entry! :load
                         {:path path
                          :state (draw-state-snapshot next-state)})
        next-state)
      state)))

(defn draw-view-zoom
  "Return the current zoom factor from STATE."
  [state]
  (let [zoom (or (get state :zoom) 1.0)]
    (if (> zoom (draw-min-zoom))
      zoom
      (draw-min-zoom))))

(defn draw-view-x
  "Return the current viewport X offset from STATE."
  [state]
  (or (get state :view-x) 0.0))

(defn draw-view-y
  "Return the current viewport Y offset from STATE."
  [state]
  (or (get state :view-y) 0.0))

(defn draw-clamp
  "Clamp VALUE between LOW and HIGH."
  [value low high]
  (cond
    (< value low) low
    (> value high) high
    :else value))

(defn draw-world-bound
  "Return the viewport world bound used for navigation clamping."
  []
  1000000000.0)

(defn draw-min-zoom
  "Return the minimum supported zoom level."
  []
  0.0005)

(defn draw-max-zoom
  "Return the maximum supported zoom level."
  []
  2048.0)

(defn draw-zoom-factor
  "Return the zoom multiplier used by keyboard shortcuts."
  []
  1.125)

(defn draw-pan-step
  "Return the keyboard pan step in screen pixels."
  []
  64)

(defn draw-clamp-view-coordinate
  "Clamp VALUE into the supported world navigation range."
  [value]
  (let [limit (draw-world-bound)]
    (draw-clamp value (- limit) limit)))

(defn draw-sync-pointer-state
  "Write WORLD-POINT and SCREEN-POINT back into STATE."
  [state world-point screen-point]
  (assoc state
         :mouse-x (nth world-point 0)
         :mouse-y (nth world-point 1)
         :mouse-screen-x (nth screen-point 0)
         :mouse-screen-y (nth screen-point 1)))

(defn draw-pointer-screen-anchor
  "Return the current screen-space pointer anchor for keyboard zoom."
  [state]
  [(or (get state :mouse-screen-x)
       (/ (or (get state :width) 0) 2.0))
   (or (get state :mouse-screen-y)
       (/ (or (get state :height) 0) 2.0))])

(defn draw-screen-point->world-point
  "Convert a screen POINT into world coordinates using STATE's viewport."
  [state point]
  (let [zoom (draw-view-zoom state)
        vx (draw-view-x state)
        vy (draw-view-y state)]
    [(+ vx (/ (nth point 0) zoom))
     (+ vy (/ (nth point 1) zoom))
     (draw-point-pressure point)]))

(defn draw-world-point->screen-point
  "Convert a world POINT into screen coordinates using STATE's viewport."
  [state point]
  (let [zoom (draw-view-zoom state)
        vx (draw-view-x state)
        vy (draw-view-y state)]
    [(draw-exact-int (math/round (* (- (nth point 0) vx) zoom)))
     (draw-exact-int (math/round (* (- (nth point 1) vy) zoom)))
     (draw-point-pressure point)]))

(defn draw-point-screen-size
  "Scale BASE-SIZE by POINT pressure in screen space."
  [state point base-size]
  (let [scaled (draw-exact-int (math/ceiling (* base-size
                                                 (draw-point-pressure point))))]
    (if (> scaled 0)
      scaled
      1)))

(defn draw-refresh!
  "Render the current draw state immediately when the window is live."
  []
  (draw-with-lock
    (lambda ()
      (if (draw-supervised-mode?)
        (draw-write-control-command! :redraw {:reason :repl})
        (draw-render-current!)))))

(defn draw-render-current!
  "Render the current state if the draw context is live."
  []
  (if (and *draw-running?* *draw-context* *draw-state*)
    (let [state (draw-sync-canvas! *draw-state*)]
      (set! *draw-state* state)
      (draw-ensure-preview! state)
      (draw-sync-cursor! state)
      (sync-window-title!)
      (render-frame *draw-context* state)
      *draw-state*)
    nil))

(defn current-state
  "Return the current draw state."
  []
  (if (draw-supervised-mode?)
    (or (draw-read-state-file)
        *draw-state*)
    *draw-state*))

(defn reset-state!
  "Reset the current draw state to the default."
  []
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! (default-state)))))

(defn set-state!
  "Replace the current draw state with STATE."
  [state]
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! state))))

(defn draw-save-state-to!
  "Write the current draw state to PATH."
  [path]
  (draw-with-lock
    (lambda ()
      (let [save-path (fs/path path)]
        (draw-ensure-parent-directory! save-path)
        (io/spit save-path (pr-str (current-state)))
        save-path))))

(defn save-canvas!
  "Write the current draw state to the default save file."
  []
  (draw-save-state-to! (draw-state-file-path)))

(defn save-canvas-to!
  "Write the current draw state to PATH."
  [path]
  (draw-save-state-to! path))

(defn draw-load-state-from!
  "Load a draw state from PATH."
  [path]
  (draw-with-lock
    (lambda ()
      (draw-load-state-core!
       (edn/read-string (io/slurp (fs/path path))))
      (fs/path path))))

(defn load-canvas!
  "Load the current draw state from the default save file."
  []
  (draw-load-state-from! (draw-state-file-path)))

(defn load-canvas-from!
  "Load a draw state from PATH."
  [path]
  (draw-load-state-from! path))

(defn draw-save-state-to!
  "Write the current draw state to PATH."
  [path]
  (draw-with-lock
    (lambda ()
      (draw-ensure-parent-directory! path)
      (io/spit path (pr-str (current-state)))
      path)))

(defn save-canvas!
  "Save the current draw state to the default save file."
  []
  (draw-save-state-to! (draw-state-file-path)))

(defn save-canvas-to!
  "Save the current draw state to PATH."
  [path]
  (draw-save-state-to! path))

(defn draw-load-state-from!
  "Load a draw state from PATH."
  [path]
  (draw-with-lock
    (lambda ()
      (draw-set-state-core!
       (edn/read-string (io/slurp path)))
      path)))

(defn load-canvas!
  "Load the current draw state from the default save file."
  []
  (draw-load-state-from! (draw-state-file-path)))

(defn load-canvas-from!
  "Load a draw state from PATH."
  [path]
  (draw-load-state-from! path))

(defn set-title!
  "Update the current window title."
  [title]
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! (assoc (or (current-state) (default-state))
                                   :title title)))))

(defn set-background!
  "Update the current background color to a [R G B] vector."
  [color]
  (draw-with-lock
    (lambda ()
      (draw-set-state-core! (assoc (or (current-state) (default-state))
                                   :background color)))))

(defn set-render-fn!
  "Install a custom render function of (lambda [ctx state] ...)."
  [render-fn]
  (set! *draw-render-fn* render-fn)
  *draw-render-fn*)

(defn clear-render-fn!
  "Restore the built-in clear-screen renderer."
  []
  (set! *draw-render-fn* nil)
  nil)

(defn draw-event-kind
  "Classify the SDL event description string DESC."
  [desc]
  (cond
    (str/starts-with? desc "SDL_EVENT_QUIT") :quit
    (str/starts-with? desc "SDL_EVENT_WINDOW_CLOSE_REQUESTED") :quit
    (str/starts-with? desc "SDL_EVENT_WINDOW_FOCUS_GAINED") :focus-gained
    (str/starts-with? desc "SDL_EVENT_WINDOW_FOCUS_LOST") :focus-lost
    (str/starts-with? desc "SDL_EVENT_WINDOW_MOUSE_ENTER") :mouse-enter
    (str/starts-with? desc "SDL_EVENT_WINDOW_MOUSE_LEAVE") :mouse-leave
    (str/starts-with? desc "SDL_EVENT_FINGER_MOTION") :finger-motion
    (str/starts-with? desc "SDL_EVENT_FINGER_DOWN") :finger-down
    (str/starts-with? desc "SDL_EVENT_FINGER_UP") :finger-up
    (str/starts-with? desc "SDL_EVENT_FINGER_CANCELED") :finger-canceled
    (str/starts-with? desc "SDL_EVENT_KEY_DOWN") :key-down
    (str/starts-with? desc "SDL_EVENT_KEY_UP") :key-up
    (str/starts-with? desc "SDL_EVENT_TEXT_INPUT") :text-input
    (str/starts-with? desc "SDL_EVENT_TEXT_EDITING") :text-editing
    (str/starts-with? desc "SDL_EVENT_MOUSE_MOTION") :mouse-motion
    (str/starts-with? desc "SDL_EVENT_MOUSE_BUTTON_DOWN") :mouse-down
    (str/starts-with? desc "SDL_EVENT_MOUSE_BUTTON_UP") :mouse-up
    (str/starts-with? desc "SDL_EVENT_MOUSE_WHEEL") :mouse-wheel
    (str/starts-with? desc "SDL_EVENT_PEN_MOTION") :pen-motion
    (str/starts-with? desc "SDL_EVENT_PEN_DOWN") :pen-down
    (str/starts-with? desc "SDL_EVENT_PEN_UP") :pen-up
    (str/starts-with? desc "SDL_EVENT_PEN_BUTTON_DOWN") :pen-button-down
    (str/starts-with? desc "SDL_EVENT_PEN_BUTTON_UP") :pen-button-up
    (str/starts-with? desc "SDL_EVENT_PEN_AXIS") :pen-axis
    :else :other))

(defn draw-trim-events
  "Keep only the newest few entries from EVENTS."
  [events]
  (let [limit (draw-recent-events-limit)
        total (count events)]
    (if (> total limit)
      (vec (drop (- total limit) events))
      (vec events))))

(defn draw-truncate-text
  "Clamp TEXT to at most LIMIT characters for live debug rendering."
  [text limit]
  (let [text (or text "")
        limit (if (and limit (> limit 4)) limit 4)]
    (if (> (count text) limit)
      (str (substring text 0 (- limit 3)) "...")
      text)))

(defn draw-compact-event-text
  "Return a shorter event description suitable for the debug panel."
  [text]
  (draw-truncate-text text 88))

(defn draw-truncate-text
  "Clamp TEXT to at most LIMIT characters for live debug rendering."
  [text limit]
  (let [text (or text "")
        limit (if (and limit (> limit 4)) limit 4)]
    (if (> (count text) limit)
      (str (substring text 0 (- limit 3)) "...")
      text)))

(defn draw-compact-event-text
  "Return a shorter event description suitable for the debug panel."
  [text]
  (draw-truncate-text text 88))

(defn draw-pen-event-kind?
  "Return true when KIND carries live pen pressure."
  [kind]
  (or (draw-kind=? kind :pen-motion)
      (draw-kind=? kind :pen-down)
      (draw-kind=? kind :pen-up)
      (draw-kind=? kind :pen-button-down)
      (draw-kind=? kind :pen-button-up)
      (draw-kind=? kind :pen-axis)))

(defn draw-event-pressure
  "Return the pen pressure for DESC when one is available."
  [state desc]
  (let [kind (draw-event-kind desc)
        live-pressure (sdl/event-pen-pressure)]
    (if (draw-pen-event-kind? kind)
      (if (draw-kind=? kind :pen-axis)
        live-pressure
        (or (get state :pen-pressure)
            live-pressure
            1.0))
      1.0)))

(defn draw-event-point
  "Return the [x y pressure] coordinate for DESC."
  [state desc]
  (draw-screen-point->world-point
    state
    [(draw-event-coordinate desc "x=")
     (draw-event-coordinate desc "y=")
     (draw-event-pressure state desc)]))

(defn draw-event-screen-point
  "Return the raw [x y] screen coordinate for DESC."
  [desc]
  [(draw-event-coordinate desc "x=")
   (draw-event-coordinate desc "y=")])

(defn draw-wheel-zoom-factor
  "Return the multiplicative zoom factor for a wheel delta."
  [delta]
  (math/pow (draw-zoom-factor) delta))

(defn draw-mark-canvas-dirty!
  "Mark the cached canvas as needing a rebuild."
  [state]
  (assoc state :canvas-dirty? true))

(defn draw-sync-canvas!
  "Rebuild the cached canvas when STATE says it is dirty."
  [state]
  (if (and (draw-canvas-ready?)
           (get state :canvas-dirty?))
    (begin
      (draw-rebuild-canvas! state)
      (assoc state :canvas-dirty? false))
    state))

(defn draw-zoom-at-core!
  "Zoom around SCREEN-X and SCREEN-Y using DELTA."
  [state delta screen-x screen-y]
  (let [screen-point [screen-x screen-y 1.0]
        world-point (draw-screen-point->world-point state screen-point)
        factor (draw-wheel-zoom-factor delta)
        next-zoom (draw-clamp (* (draw-view-zoom state) factor)
                              (draw-min-zoom)
                              (draw-max-zoom))
        next-state (assoc state
                          :zoom next-zoom
                          :view-x (draw-clamp-view-coordinate
                                    (- (nth world-point 0)
                                       (/ screen-x next-zoom)))
                          :view-y (draw-clamp-view-coordinate
                                    (- (nth world-point 1)
                                       (/ screen-y next-zoom)))
                          :canvas-dirty? true)]
    (draw-sync-pointer-state next-state world-point screen-point)))

(defn draw-zoom-at-pointer-core!
  "Zoom around the currently tracked pointer anchor."
  [state delta]
  (let [anchor (draw-pointer-screen-anchor state)]
    (draw-zoom-at-core! state
                        delta
                        (nth anchor 0)
                        (nth anchor 1))))

(defn draw-start-pan-core!
  "Begin a viewport drag at SCREEN-POINT."
  [state screen-point]
  (let [world-point (draw-screen-point->world-point state
                                                    [(nth screen-point 0)
                                                     (nth screen-point 1)
                                                     1.0])]
    (draw-sync-pointer-state
      (assoc state
             :panning? true
             :pan-last-x (nth screen-point 0)
             :pan-last-y (nth screen-point 1)
             :pointer-down? false
             :pointer-source false
             :active-stroke false
             :pen-pressure 1.0)
      world-point
      screen-point)))

(defn draw-pan-core!
  "Update the viewport pan using SCREEN-POINT."
  [state screen-point]
  (if (get state :panning?)
    (let [screen-x (nth screen-point 0)
          screen-y (nth screen-point 1)
          last-x (or (get state :pan-last-x) screen-x)
          last-y (or (get state :pan-last-y) screen-y)
          zoom (draw-view-zoom state)
          dx (- screen-x last-x)
          dy (- screen-y last-y)
          next-state (assoc state
                            :view-x (draw-clamp-view-coordinate
                                      (- (draw-view-x state)
                                         (/ dx zoom)))
                            :view-y (draw-clamp-view-coordinate
                                      (- (draw-view-y state)
                                         (/ dy zoom)))
                            :pan-last-x screen-x
                            :pan-last-y screen-y
                            :canvas-dirty? true)
          world-point (draw-screen-point->world-point next-state
                                                      [(nth screen-point 0)
                                                       (nth screen-point 1)
                                                       1.0])]
      (draw-sync-pointer-state next-state world-point screen-point))
    state))

(defn draw-finish-pan-core!
  "Finish a viewport drag."
  [state]
  (assoc state
         :panning? false
         :pointer-down? false
         :pointer-source false
         :canvas-dirty? true))

(defn draw-event-key-label
  "Return the normalized key label for the current SDL key event."
  [desc]
  (let [key (str/trim (sdl/event-key-name))]
    (if (str/blank? key)
      desc
      key)))

(defn draw-toggle-debug-panel!
  "Toggle the in-window debug panel."
  [state]
  (assoc state
         :debug-panel? (not (get state :debug-panel?))))

(defn draw-toggle-debug-panel-key?
  "Return true when KEY should toggle the debug panel."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "d")
        (string=? key "f1")
        (str/includes? key "key=d")
        (str/includes? key "sdlk_d")
        (str/includes? key "scancode_d"))))

(defn draw-toggle-tool-panel!
  "Toggle the in-window tool panel."
  [state]
  (assoc state
         :tool-panel? (not (get state :tool-panel?))))

(defn draw-toggle-tool-panel-key?
  "Return true when KEY should toggle the tool panel."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "tab")
        (str/includes? key "tab"))))

(defn draw-space-key?
  "Return true when KEY names the space bar."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "space")
        (str/includes? key "space"))))

(defn draw-control-key?
  "Return true when KEY names a control key."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (str/includes? key "ctrl")
        (str/includes? key "control"))))

(defn draw-save-shortcut-key?
  "Return true when KEY should save the current canvas with Ctrl."
  [key]
  (string=? (str/lower-case (or key "")) "s"))

(defn draw-load-shortcut-key?
  "Return true when KEY should load the current canvas with Ctrl."
  [key]
  (string=? (str/lower-case (or key "")) "o"))

(defn draw-plus-key?
  "Return true when KEY names a plus/equals zoom-in key."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "+")
        (string=? key "=")
        (str/includes? key "plus")
        (str/includes? key "keypad +"))))

(defn draw-minus-key?
  "Return true when KEY names a minus zoom-out key."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "-")
        (str/includes? key "minus")
        (str/includes? key "keypad -"))))

(defn draw-pan-left-key?
  "Return true when KEY should pan the viewport left."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "h")
        (string=? key "left"))))

(defn draw-pan-right-key?
  "Return true when KEY should pan the viewport right."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "l")
        (string=? key "right"))))

(defn draw-pan-up-key?
  "Return true when KEY should pan the viewport up."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "k")
        (string=? key "up"))))

(defn draw-pan-down-key?
  "Return true when KEY should pan the viewport down."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "j")
        (string=? key "down"))))

(defn draw-reset-view-key?
  "Return true when KEY resets the viewport."
  [key]
  (let [key (str/lower-case (or key ""))]
    (or (string=? key "0")
        (str/includes? key "kp0"))))

(defn draw-apply-key-modifier-state
  "Update persistent navigation modifiers from EVENT."
  [state event]
  (let [kind (get event :kind)
        key (str/lower-case (or (get event :key) ""))]
    (let [state (if (draw-space-key? key)
                  (assoc state :space-down? (draw-kind=? kind :key-down))
                  state)
          state (if (draw-control-key? key)
                  (assoc state :ctrl-down? (draw-kind=? kind :key-down))
                  state)]
      (if (and (draw-kind=? kind :key-down)
               (get event :ctrl?))
        (assoc state :ctrl-down? true)
        state))))

(defn draw-clear-error!
  "Clear the last recorded draw error."
  []
  (set! *draw-last-error* false)
  (draw-log-entry! :clear-error {:state (draw-state-snapshot *draw-state*)})
  false)

(defn draw-with-stroke-color
  "Run THUNK while binding the current stroke color."
  [color thunk]
  (let [saved *draw-current-stroke-color*]
    (dynamic-wind
      (lambda () false)
      (lambda ()
        (set! *draw-current-stroke-color* color)
        (thunk))
      (lambda ()
        (set! *draw-current-stroke-color* saved)))))

(defn draw-canvas
  "Return the cached canvas texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :canvas)
    false))

(defn draw-canvas-ready?
  "Return true when the cached canvas texture is available."
  []
  (and *draw-canvas-ready?*
       (sdl/pointer-ready? (draw-canvas))))

(defn draw-preview
  "Return the active-stroke preview texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :preview)
    false))

(defn draw-preview-ready?
  "Return true when the active-stroke preview texture is available."
  []
  (and *draw-preview-ready?*
       (sdl/pointer-ready? (draw-preview))))

(defn draw-brush-texture
  "Return the cached brush texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :brush-texture)
    false))

(defn draw-brush-texture-ready?
  "Return true when the cached brush texture is available."
  []
  (and *draw-brush-ready?*
       (sdl/pointer-ready? (draw-brush-texture))))

(defn draw-strip-texture
  "Return the cached strip texture if one is available."
  []
  (if *draw-context*
    (get *draw-context* :strip-texture)
    false))

(defn draw-strip-texture-ready?
  "Return true when the cached strip texture is available."
  []
  (and *draw-strip-ready?*
       (sdl/pointer-ready? (draw-strip-texture))))

(defn draw-brush-texture-diameter
  "Return the canonical brush stamp diameter."
  []
  128)

(defn draw-brush-hardness
  "Return the default brush hardness used by the stamp texture."
  []
  0.65)

(defn draw-strip-texture-width
  "Return the canonical width for the soft strip texture."
  []
  64)

(defn draw-strip-texture-height
  "Return the canonical height for the soft strip texture."
  []
  64)

(defn draw-strip-hardness
  "Return the default strip hardness used by the segment body texture."
  []
  0.75)

(defn draw-ensure-brush-texture!
  "Create or refresh the brush stamp texture."
  [state]
  (let [renderer (if *draw-context* (get *draw-context* :renderer) nil)
        diameter (draw-brush-texture-diameter)
        current (draw-brush-texture)
        current-diameter (if *draw-context* (get *draw-context* :brush-texture-diameter) nil)]
    (if (and (draw-brush-texture-ready?)
             (= current-diameter diameter))
      *draw-context*
      (begin
        (if (draw-brush-texture-ready?)
          (begin
            (sdl/destroy-texture! current)
            (set! *draw-context*
                  (dissoc *draw-context* :brush-texture :brush-texture-diameter))
            (set! *draw-brush-ready?* false))
          nil)
        (if renderer
          (let [texture (sdl/create-soft-brush-texture renderer
                                                       diameter
                                                       (draw-brush-hardness))]
            (if texture
              (let [ctx (assoc *draw-context*
                               :brush-texture texture
                               :brush-texture-diameter diameter)]
                (set! *draw-context* ctx)
                (set! *draw-brush-ready?* true)
                ctx)
              (begin
                (set! *draw-brush-ready?* false)
                *draw-context*)))
          *draw-context*)))))

(defn draw-release-brush-texture!
  "Destroy the cached brush stamp texture and clear it from the draw context."
  []
  (let [brush (draw-brush-texture)]
    (if (draw-brush-texture-ready?)
      (sdl/destroy-texture! brush))
    (if *draw-context*
      (set! *draw-context* (dissoc *draw-context* :brush-texture :brush-texture-diameter)))
    (set! *draw-brush-ready?* false)
    nil))

(defn draw-ensure-strip-texture!
  "Create or refresh the strip texture used for stroke bodies."
  [state]
  (let [renderer (if *draw-context* (get *draw-context* :renderer) nil)
        width (draw-strip-texture-width)
        height (draw-strip-texture-height)
        current (draw-strip-texture)
        current-width (if *draw-context* (get *draw-context* :strip-texture-width) nil)
        current-height (if *draw-context* (get *draw-context* :strip-texture-height) nil)]
    (if (and (draw-strip-texture-ready?)
             (= current-width width)
             (= current-height height))
      *draw-context*
      (begin
        (if (draw-strip-texture-ready?)
          (begin
            (sdl/destroy-texture! current)
            (set! *draw-context*
                  (dissoc *draw-context*
                          :strip-texture
                          :strip-texture-width
                          :strip-texture-height))
            (set! *draw-strip-ready?* false))
          nil)
        (if renderer
          (let [texture (sdl/create-soft-strip-texture renderer
                                                       width
                                                       height
                                                       (draw-strip-hardness))]
            (if texture
              (let [ctx (assoc *draw-context*
                               :strip-texture texture
                               :strip-texture-width width
                               :strip-texture-height height)]
                (set! *draw-context* ctx)
                (set! *draw-strip-ready?* true)
                ctx)
              (begin
                (set! *draw-strip-ready?* false)
                *draw-context*)))
          *draw-context*)))))

(defn draw-release-strip-texture!
  "Destroy the cached strip texture and clear it from the draw context."
  []
  (let [strip (draw-strip-texture)]
    (if (draw-strip-texture-ready?)
      (sdl/destroy-texture! strip))
    (if *draw-context*
      (set! *draw-context*
            (dissoc *draw-context*
                    :strip-texture
                    :strip-texture-width
                    :strip-texture-height)))
    (set! *draw-strip-ready?* false)
    nil))

(defn draw-release-cursors!
  "Destroy cached system cursors and clear them from the draw context."
  []
  (let [cache (if *draw-context*
                (or (get *draw-context* :cursor-cache) {})
                {})]
    (reduce (fn [acc entry]
              (let [cursor (nth entry 1)]
                (if cursor
                  (sdl/destroy-cursor! cursor)
                  nil)
                acc))
            nil
            cache)
    (if *draw-context*
      (set! *draw-context* (dissoc *draw-context* :cursor-cache :cursor-kind))
      nil)
    nil))

(defn draw-ensure-canvas!
  "Create or resize the cached canvas texture to match STATE."
  [state]
  (let [renderer (if *draw-context* (get *draw-context* :renderer) nil)
        width (get state :width)
        height (get state :height)
        canvas (draw-canvas)
        canvas-width (if *draw-context* (get *draw-context* :canvas-width) nil)
        canvas-height (if *draw-context* (get *draw-context* :canvas-height) nil)]
    (if (and (draw-canvas-ready?)
             (= canvas-width width)
             (= canvas-height height))
      *draw-context*
      (begin
        (if (draw-canvas-ready?)
          (begin
            (sdl/destroy-texture! canvas)
            (set! *draw-context* (dissoc *draw-context* :canvas :canvas-width :canvas-height))
            (set! *draw-canvas-ready?* false))
          nil)
        (if renderer
          (let [texture (sdl/create-canvas-texture renderer width height)]
            (if texture
              (let [ctx (assoc *draw-context*
                               :canvas texture
                               :canvas-width width
                               :canvas-height height)]
                (set! *draw-context* ctx)
                (set! *draw-canvas-ready?* true)
                ctx)
              (begin
                (set! *draw-canvas-ready?* false)
                *draw-context*)))
          *draw-context*)))))

(defn draw-ensure-preview!
  "Create or resize the active-stroke preview texture to match STATE."
  [state]
  (let [renderer (if *draw-context* (get *draw-context* :renderer) nil)
        width (get state :width)
        height (get state :height)
        preview (draw-preview)
        preview-width (if *draw-context* (get *draw-context* :preview-width) nil)
        preview-height (if *draw-context* (get *draw-context* :preview-height) nil)]
    (if (and (draw-preview-ready?)
             (= preview-width width)
             (= preview-height height))
      *draw-context*
      (begin
        (if (draw-preview-ready?)
          (begin
            (sdl/destroy-texture! preview)
            (set! *draw-context* (dissoc *draw-context* :preview :preview-width :preview-height))
            (set! *draw-preview-ready?* false))
          nil)
        (if renderer
          (let [texture (sdl/create-canvas-texture renderer width height)]
            (if texture
              (let [ctx (assoc *draw-context*
                               :preview texture
                               :preview-width width
                               :preview-height height)]
                (set! *draw-context* ctx)
                (set! *draw-preview-ready?* true)
                ctx)
              (begin
                (set! *draw-preview-ready?* false)
                *draw-context*)))
          *draw-context*)))))

(defn draw-with-canvas!
  "Run THUNK with the canvas texture bound as the SDL render target."
  [thunk]
  (let [renderer (if *draw-context* (get *draw-context* :renderer) nil)
        canvas (draw-canvas)]
    (if (and renderer (draw-canvas-ready?))
      (begin
        (sdl/set-render-target! renderer canvas)
        (thunk renderer)
        (sdl/clear-render-target! renderer)
        true)
      false)))

(defn draw-with-preview!
  "Run THUNK with the preview texture bound as the SDL render target."
  [thunk]
  (let [renderer (if *draw-context* (get *draw-context* :renderer) false)
        preview (draw-preview)]
    (if (and renderer (draw-preview-ready?))
      (begin
        (sdl/set-render-target! renderer preview)
        (thunk renderer)
        (sdl/clear-render-target! renderer)
        true)
      false)))

(defn draw-release-canvas!
  "Destroy the cached canvas texture and clear it from the draw context."
  []
  (let [canvas (draw-canvas)]
    (if (draw-canvas-ready?)
      (sdl/destroy-texture! canvas))
    (if *draw-context*
      (set! *draw-context* (dissoc *draw-context* :canvas :canvas-width :canvas-height)))
    (set! *draw-canvas-ready?* false)
    nil))

(defn draw-release-preview!
  "Destroy the active-stroke preview texture and clear it from the draw context."
  []
  (let [preview (draw-preview)]
    (if (draw-preview-ready?)
      (sdl/destroy-texture! preview))
    (if *draw-context*
      (set! *draw-context* (dissoc *draw-context* :preview :preview-width :preview-height)))
    (set! *draw-preview-ready?* false)
    (draw-reset-preview-sync!)
    nil))

(defn draw-clear-canvas!
  "Clear the cached canvas texture."
  []
  (draw-with-canvas!
    (lambda (renderer)
      (sdl/set-draw-color! renderer 0 0 0 0)
      (sdl/render-clear! renderer)
      nil)))

(defn draw-clear-preview!
  "Clear the active-stroke preview texture."
  []
  (draw-with-preview!
    (lambda (renderer)
      (sdl/set-draw-color! renderer 0 0 0 0)
      (sdl/render-clear! renderer)
      nil)))

(defn draw-commit-stroke!
  "Render a single stroke into the cached canvas texture."
  [state stroke]
  (draw-with-canvas!
    (lambda (renderer)
      (draw-render-stroke! renderer state stroke)
      nil)))

(defn draw-commit-element!
  "Render a single committed element into the cached canvas texture."
  [state element]
  (draw-with-canvas!
    (lambda (renderer)
      (draw-render-element! renderer state element)
      nil)))

(defn draw-rebuild-canvas!
  "Rebuild the cached canvas texture from STATE."
  [state]
  (draw-with-canvas!
    (lambda (renderer)
      (sdl/set-draw-color! renderer 0 0 0 0)
      (sdl/render-clear! renderer)
      (reduce (lambda (acc element)
                (begin
                  (draw-render-element! renderer state element)
                  acc))
              nil
              (get state :elements))
      nil)))

(defn draw-history-limit
  "Return the maximum number of undo snapshots to keep."
  []
  32)

(defn draw-history-snapshot
  "Return a history snapshot for STATE."
  [state]
  {:elements (edn/read-string (pr-str (get state :elements)))
   :brush-size (get state :brush-size)
   :brush-color (edn/read-string (pr-str (get state :brush-color)))
   :background (edn/read-string (pr-str (get state :background)))
   :tool (or (get state :tool) :ink)
   :eraser? (if (truthy? (get state :eraser?)) true false)})

(defn draw-history-trim
  "Trim HISTORY to the configured size."
  [history]
  (let [limit (draw-history-limit)
        total (count history)]
    (if (> total limit)
      (vec (drop (- total limit) history))
      (vec history))))

(defn draw-push-history!
  "Push the current STATE onto the undo history."
  [state]
  (let [history (conj (get state :history)
                      (draw-history-snapshot state))]
    (assoc state :history (draw-history-trim history))))

(defn draw-restore-history!
  "Restore the most recent undo snapshot."
  [state]
  (let [history (get state :history)]
    (if (empty? history)
      (if (or (get state :active-stroke)
              (get state :active-box)
              (get state :active-arrow)
              (get state :active-frame)
              (get state :active-text))
        (assoc state
               :active-box false
               :active-arrow false
               :active-frame false
               :active-text false
               :active-stroke false
               :active-selection-resize false
               :pointer-down? false)
        state)
      (let [total (count history)
            snapshot (nth history (- total 1))
            prior-history (if (> total 1)
                            (vec (take (- total 1) history))
                            [])]
        (draw-sync-elements
          (assoc state
                 :history prior-history
                 :brush-size (get snapshot :brush-size)
                 :brush-color (get snapshot :brush-color)
                 :background (get snapshot :background)
                 :tool (or (get snapshot :tool) :ink)
                 :eraser? (if (get snapshot :eraser?) true false)
                 :selection []
                 :active-selection-drag false
                 :active-selection-resize false
                 :active-stroke false
                 :active-box false
                 :active-arrow false
                 :active-frame false
                 :active-text false
                 :pointer-down? false
                 :pointer-source false
                 :panning? false)
          (get snapshot :elements))))))

(defn draw-tool-mode
  "Return the current tool mode label."
  [state]
  (if (get state :eraser?)
    "eraser"
    (if (draw-kind=? (or (get state :tool) :ink) :box)
      "rectangle"
      (if (draw-kind=? (or (get state :tool) :ink)
                       :arrow)
        "arrow"
        (if (draw-kind=? (or (get state :tool) :ink) :frame)
          "frame"
          (if (draw-kind=? (or (get state :tool) :ink) :text)
            "text"
            (if (draw-kind=? (or (get state :tool) :ink) :select)
              "select"
              "ink")))))))

(defn draw-next-element-id
  "Return the next canvas element id for STATE."
  [state]
  (or (get state :next-element-id) 1))

(defn draw-alloc-element-id
  "Allocate the next element id and return [id next-state]."
  [state]
  (let [id (draw-next-element-id state)]
    [id (assoc state :next-element-id (+ id 1))]))

(defn draw-append-element
  "Append ELEMENT to STATE and refresh the derived stroke view."
  [state element]
  (let [[id state] (if (get element :id)
                     [(get element :id) state]
                     (draw-alloc-element-id state))
        element (assoc element :id id)]
    (draw-sync-elements state
                        (conj (get state :elements) element))))

(defn draw-set-tool-core!
  "Set the current primary tool without recording history."
  [state tool]
  (assoc state
         :tool tool
         :eraser? false))

(defn draw-box-tool?
  "Return true when STATE is currently in box mode."
  [state]
  (draw-kind=? (or (get state :tool) :ink) :box))

(defn draw-arrow-tool?
  "Return true when STATE is currently in arrow mode."
  [state]
  (draw-kind=? (or (get state :tool) :ink) :arrow))

(defn draw-frame-tool?
  "Return true when STATE is currently in frame mode."
  [state]
  (draw-kind=? (or (get state :tool) :ink) :frame))

(defn draw-text-tool?
  "Return true when STATE is currently in text mode."
  [state]
  (draw-kind=? (or (get state :tool) :ink) :text))

(defn draw-selection-tool?
  "Return true when STATE is currently in selection mode."
  [state]
  (draw-kind=? (or (get state :tool) :ink) :select))

(defn draw-selected-element-ids
  "Return the current selected element ids from STATE."
  [state]
  (or (get state :selection) []))

(defn draw-selected?
  "Return true when ELEMENT is selected in STATE."
  [state element]
  (draw-selection-has-id?
    (draw-selected-element-ids state)
    (get element :id)))

(defn draw-stroke-color
  "Return the active stroke color for STATE."
  [state]
  (if (get state :eraser?)
    (get state :background)
    (get state :brush-color)))

(defn draw-set-brush-size-core!
  "Set the brush size and return to brush mode, recording undo history."
  [state size]
  (let [state (draw-push-history! state)
        next-state (assoc state
                          :brush-size size
                          :eraser? false)]
    (draw-log-entry! :brush-size
                     {:size size
                      :state (draw-state-snapshot next-state)})
    next-state))

(defn draw-set-brush-size!
  "Set the brush size and return to brush mode, recording undo history."
  [state size]
  (draw-with-lock
    (lambda ()
      (let [state (draw-set-brush-size-core! state size)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-toggle-eraser-core!
  "Toggle eraser mode for STATE and record undo history."
  [state]
  (let [state (draw-push-history! state)
        next-state (assoc state
                          :tool :ink
                          :eraser? (not (get state :eraser?)))]
    (draw-log-entry! :eraser-toggle
                     {:eraser? (get next-state :eraser?)
                      :state (draw-state-snapshot next-state)})
    next-state))

(defn draw-toggle-eraser!
  "Toggle eraser mode for STATE and record undo history."
  [state]
  (draw-with-lock
    (lambda ()
      (let [state (draw-toggle-eraser-core! state)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-clear-strokes-core!
  "Clear all finished and active strokes from STATE and record undo history."
  [state]
  (let [state (draw-push-history! state)]
    (draw-clear-preview!)
    (let [next-state (draw-sync-elements
                       (assoc state
                              :selection []
                              :active-selection-drag false
                              :active-selection-resize false
                              :active-stroke false
                              :active-box false
                              :active-arrow false
                              :active-frame false
                              :active-text false
                              :pointer-down? false
                              :panning? false
                              :canvas-dirty? true)
                       [])]
      (draw-log-entry! :clear
                       {:state (draw-state-snapshot next-state)})
      next-state)))

(defn draw-clear-strokes!
  "Clear all finished and active strokes from STATE and record undo history."
  [state]
  (draw-with-lock
    (lambda ()
      (let [state (draw-clear-strokes-core! state)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-undo-stroke-core!
  "Undo the most recent draw action."
  [state]
  (draw-clear-preview!)
  (let [next-state (assoc (draw-restore-history! state) :canvas-dirty? true)]
    (draw-log-entry! :undo
                     {:state (draw-state-snapshot next-state)})
    next-state))

(defn draw-undo-stroke!
  "Undo the most recent draw action."
  [state]
  (draw-with-lock
    (lambda ()
      (let [state (draw-undo-stroke-core! state)]
        (if *draw-running?*
          nil
          (draw-render-current!))
        state))))

(defn draw-handle-tool-key!
  "Apply draw tool shortcuts for KEY to STATE."
  [state key]
  (let [key (str/lower-case (or key ""))]
    (cond
      (string=? key "c") (draw-clear-strokes-core! state)
      (string=? key "u") (draw-undo-stroke-core! state)
      (string=? key "i") (draw-set-tool-core! state :ink)
      (string=? key "t") (draw-set-tool-core! state :text)
      (string=? key "v") (draw-set-tool-core! state :select)
      (string=? key "r") (draw-set-tool-core! state :box)
      (string=? key "b") (draw-set-tool-core! state :box)
      (string=? key "a") (draw-set-tool-core! state :arrow)
      (string=? key "e") (draw-toggle-eraser-core! state)
      (string=? key "1") (draw-set-brush-size-core! state 2)
      (string=? key "2") (draw-set-brush-size-core! state 6)
      (string=? key "3") (draw-set-brush-size-core! state 12)
      :else state)))

(defn draw-handle-view-key!
  "Apply zoom and pan shortcuts for KEY to STATE."
  [state key]
  (let [key (str/lower-case (or key ""))]
    (cond
      (and (get state :ctrl-down?)
           (draw-plus-key? key))
      (draw-zoom-at-pointer-core! state 1.0)

      (and (get state :ctrl-down?)
           (draw-minus-key? key))
      (draw-zoom-at-pointer-core! state -1.0)

      (draw-reset-view-key? key)
      (let [screen-point (draw-pointer-screen-anchor state)
            next-state (assoc state
                              :view-x 0.0
                              :view-y 0.0
                              :zoom 1.0
                              :canvas-dirty? true)
            world-point (draw-screen-point->world-point next-state
                                                        [(nth screen-point 0)
                                                         (nth screen-point 1)
                                                         (or (get state :pen-pressure) 1.0)])]
        (draw-sync-pointer-state next-state world-point screen-point))

      (draw-pan-left-key? key)
      (let [step (draw-pan-step)
            next-state (assoc state
                              :view-x (draw-clamp-view-coordinate
                                        (- (draw-view-x state)
                                           (/ step (draw-view-zoom state))))
                              :canvas-dirty? true)]
        next-state)

      (draw-pan-right-key? key)
      (let [step (draw-pan-step)
            next-state (assoc state
                              :view-x (draw-clamp-view-coordinate
                                        (+ (draw-view-x state)
                                           (/ step (draw-view-zoom state))))
                              :canvas-dirty? true)]
        next-state)

      (draw-pan-up-key? key)
      (let [step (draw-pan-step)
            next-state (assoc state
                              :view-y (draw-clamp-view-coordinate
                                        (- (draw-view-y state)
                                           (/ step (draw-view-zoom state))))
                              :canvas-dirty? true)]
        next-state)

      (draw-pan-down-key? key)
      (let [step (draw-pan-step)
            next-state (assoc state
                              :view-y (draw-clamp-view-coordinate
                                        (+ (draw-view-y state)
                                           (/ step (draw-view-zoom state))))
                              :canvas-dirty? true)]
        next-state)

      :else
      state)))

(defn draw-handle-wheel!
  "Apply mouse-wheel zoom to STATE."
  [state]
  (let [delta (sdl/event-wheel-y)]
    (if (= delta 0.0)
      state
      (draw-zoom-at-core! state
                          delta
                          (sdl/event-wheel-mouse-x)
                          (sdl/event-wheel-mouse-y)))))

(defn draw-crash!
  "Record EXN as the last draw error and stop the background loop."
  [exn]
  (set! *draw-last-error* exn)
  (set! *draw-running?* false)
  (set! *draw-thread* nil)
  (draw-write-state-file! *draw-state* true)
  (draw-write-heartbeat! :crash *draw-state*)
  (draw-stop-watchdog!)
  (draw-log-entry! :crash
                   {:error (format "%s" exn)
                    :state (draw-state-snapshot *draw-state*)})
  (draw-write-crash-report! exn)
  (println (format "Cluck Draw crashed: %s" exn))
  exn)

(defn draw-cancel-active-stroke-core!
  "Cancel the active stroke without recording history."
  [state]
  (draw-reset-preview-sync!)
  (draw-clear-preview!)
    (let [state (assoc state
                     :pointer-down? false
                     :pointer-source false
                     :active-selection-drag false
                     :active-selection-resize false
                     :active-stroke false
                     :active-box false
                     :active-arrow false
                     :active-frame false
                     :active-text false
                     :panning? false
                     :pen-pressure 1.0
                     :canvas-dirty? true)]
    state))

(defn draw-focus-lost-core!
  "Record that the window lost focus and cancel any active stroke."
  [state]
  (let [next-state (draw-cancel-active-stroke-core!
                     (assoc state
                            :window-focused? false
                            :space-down? false
                            :ctrl-down? false
                            :canvas-dirty? true))]
    (draw-log-entry! :focus-lost {:state (draw-state-snapshot next-state)})
    next-state))

(defn draw-focus-gained-core!
  "Record that the window regained focus."
  [state]
  (let [next-state (assoc state
                          :window-focused? true
                          :canvas-dirty? true
                          :space-down? false
                          :ctrl-down? false
                          :pen-pressure 1.0)]
    (draw-log-entry! :focus-gained {:state (draw-state-snapshot next-state)})
    next-state))

(defn draw-mouse-leave-core!
  "Handle the pointer leaving the window without changing focus state."
  [state]
  (draw-cancel-active-stroke-core! state))

(defn draw-mouse-enter-core!
  "Handle the pointer entering the window without changing focus state."
  [state]
  state)

(defn draw-stroke-record
  "Build a fresh stroke map."
  [points color size]
  {:points points
   :color color
   :size size})

(defn draw-box-record
  "Build a fresh active-box record."
  [start end color size]
  {:start start
   :end end
   :color color
   :size size})

(defn draw-box-rect
  "Return a normalized box rectangle from START and END world points."
  [start end]
  (let [x0 (nth start 0)
        y0 (nth start 1)
        x1 (nth end 0)
        y1 (nth end 1)]
    {:x (if (< x0 x1) x0 x1)
     :y (if (< y0 y1) y0 y1)
     :width (math/abs (- x1 x0))
     :height (math/abs (- y1 y0))}))

(defn draw-box-min-size
  "Return the minimum world-space box dimension worth committing."
  []
  1.0)

(defn draw-box-element
  "Build a committed box element from ACTIVE-BOX."
  [active-box]
  (let [rect (draw-box-rect (get active-box :start)
                            (get active-box :end))]
    {:kind :box
     :x (get rect :x)
     :y (get rect :y)
     :width (get rect :width)
     :height (get rect :height)
     :color (get active-box :color)
     :size (get active-box :size)}))

(defn draw-box-visible?
  "Return true when BOX is large enough to commit."
  [box]
  (and (>= (get box :width) (draw-box-min-size))
       (>= (get box :height) (draw-box-min-size))))

(defn draw-frame-record
  "Build a fresh active-frame record."
  [start end color size]
  {:start start
   :end end
   :color color
   :size size})

(defn draw-frame-element
  "Build a committed frame element from ACTIVE-FRAME."
  [active-frame]
  (let [rect (draw-box-rect (get active-frame :start)
                            (get active-frame :end))]
    {:kind :frame
     :x (get rect :x)
     :y (get rect :y)
     :width (get rect :width)
     :height (get rect :height)
     :color (get active-frame :color)
     :size (get active-frame :size)}))

(defn draw-frame-visible?
  "Return true when FRAME is large enough to commit."
  [frame]
  (draw-box-visible? frame))

(defn draw-text-default-value
  "Return the placeholder text used for newly created text elements."
  []
  "Text")

(defn draw-text-record
  "Build a fresh active-text record."
  [point text color size]
  {:point point
   :text (or text (draw-text-default-value))
   :color color
   :size size})

(defn draw-text-element
  "Build a committed text element from ACTIVE-TEXT."
  [active-text]
  {:kind :text
   :x (nth (get active-text :point) 0)
   :y (nth (get active-text :point) 1)
   :text (or (get active-text :text) (draw-text-default-value))
   :color (get active-text :color)
   :size (get active-text :size)})

(defn draw-text-visible?
  "Return true when TEXT-ELEMENT has visible content."
  [text-element]
  (not (str/blank? (or (get text-element :text) ""))))

(defn draw-text-screen-char-width
  "Return the approximate character width of the debug font."
  []
  8.0)

(defn draw-text-screen-height
  "Return the approximate line height of the debug font."
  []
  16.0)

(defn draw-text-screen-width
  "Return the approximate screen-space width for TEXT."
  [text]
  (max (draw-text-screen-char-width)
       (* (count (or text "")) (draw-text-screen-char-width))))

(defn draw-text-world-width
  "Return the approximate world-space width for TEXT in STATE."
  [state text]
  (/ (draw-text-screen-width text)
     (draw-view-zoom state)))

(defn draw-text-world-height
  "Return the approximate world-space height for text in STATE."
  [state]
  (/ (draw-text-screen-height)
     (draw-view-zoom state)))

(defn draw-selection-screen-padding
  "Return the screen-space padding used for hit testing and selection outlines."
  []
  8.0)

(defn draw-selection-world-padding
  "Return the world-space selection padding for STATE."
  [state]
  (/ (draw-selection-screen-padding)
     (draw-view-zoom state)))

(defn draw-point-bounds
  "Return bounds for POINTS expanded by PADDING."
  [points padding]
  (if (empty? points)
    false
    (let [point (first points)
          x (nth point 0)
          y (nth point 1)
          initial {:x x :y y :right x :bottom y}
          bounds (reduce (lambda (current next-point)
                           (let [px (nth next-point 0)
                                 py (nth next-point 1)]
                             {:x (if (< px (get current :x))
                                   px
                                   (get current :x))
                              :y (if (< py (get current :y))
                                   py
                                   (get current :y))
                              :right (if (> px (get current :right))
                                       px
                                       (get current :right))
                              :bottom (if (> py (get current :bottom))
                                        py
                                        (get current :bottom))}))
                         initial
                         (rest points))]
      {:x (- (get bounds :x) padding)
       :y (- (get bounds :y) padding)
       :width (+ (- (get bounds :right)
                    (get bounds :x))
                 (* padding 2.0))
       :height (+ (- (get bounds :bottom)
                     (get bounds :y))
                  (* padding 2.0))})))

(defn draw-element-bounds
  "Return world-space bounds for ELEMENT, expanded for selection."
  [state element]
  (let [padding (+ (draw-selection-world-padding state)
                   (or (get element :size) 1.0))]
    (if (draw-box-element? element)
      {:x (- (get element :x) padding)
       :y (- (get element :y) padding)
       :width (+ (get element :width) (* padding 2.0))
       :height (+ (get element :height) (* padding 2.0))}
      (if (draw-arrow-element? element)
        (draw-point-bounds [(get element :start) (get element :end)] padding)
        (if (draw-frame-element? element)
          {:x (- (get element :x) padding)
           :y (- (get element :y) padding)
           :width (+ (get element :width) (* padding 2.0))
           :height (+ (get element :height) (* padding 2.0))}
          (if (draw-text-element? element)
            {:x (- (get element :x) padding)
             :y (- (get element :y) padding)
             :width (+ (draw-text-world-width state (get element :text))
                       (* padding 2.0))
             :height (+ (draw-text-world-height state)
                        (* padding 2.0))}
            (draw-point-bounds (get element :points) padding)))))))

(defn draw-point-in-bounds?
  "Return true when POINT lies within BOUNDS."
  [point bounds]
  (and bounds
       (>= (nth point 0) (get bounds :x))
       (>= (nth point 1) (get bounds :y))
       (<= (nth point 0) (+ (get bounds :x) (get bounds :width)))
       (<= (nth point 1) (+ (get bounds :y) (get bounds :height)))))

(defn draw-find-hit-element
  "Return the topmost element under POINT, or false."
  [state point]
  (let [elements (get state :elements)
        total (count elements)]
    (let loop ((index (- total 1)))
      (if (< index 0)
        false
        (let [element (nth elements index)]
          (if (draw-point-in-bounds? point
                                     (draw-element-bounds state element))
            element
            (loop (- index 1))))))))

(defn draw-selection-ids
  "Return a normalized single-selection vector for ELEMENT."
  [element]
  (if element
    [(get element :id)]
    []))

(defn draw-selection-add-id
  "Return SELECTION with ELEMENT-ID appended when it is not already present."
  [selection element-id]
  (if (or (not element-id)
          (draw-selection-has-id? selection element-id))
    (vec selection)
    (conj (vec selection) element-id)))

(defn draw-selection-next-ids
  "Return the next selection ids after hitting ELEMENT."
  [state element extend-selection?]
  (let [current (draw-selected-element-ids state)]
    (if extend-selection?
      (if element
        (draw-selection-add-id current (get element :id))
        current)
      (if element
        (if (draw-selection-has-id? current (get element :id))
          current
          [(get element :id)])
        []))))

(defn draw-selection-color
  "Return the overlay color used for selected elements."
  []
  [120 180 255])

(defn draw-selection-outline-size
  "Return the stroke size used for selection outlines."
  []
  2)

(defn draw-selection-outline-element
  "Build a box-shaped outline element from BOUNDS."
  [bounds]
  {:kind :box
   :x (get bounds :x)
   :y (get bounds :y)
   :width (get bounds :width)
   :height (get bounds :height)
   :color (draw-selection-color)
   :size (draw-selection-outline-size)})

(defn draw-bounds-union
  "Return the union of A and B."
  [a b]
  (if a
    (if b
      (let [left (min (get a :x) (get b :x))
            top (min (get a :y) (get b :y))
            right (max (+ (get a :x) (get a :width))
                       (+ (get b :x) (get b :width)))
            bottom (max (+ (get a :y) (get a :height))
                        (+ (get b :y) (get b :height)))]
        {:x left
         :y top
         :width (- right left)
         :height (- bottom top)})
      a)
    b))

(defn draw-selected-elements
  "Return the selected elements from STATE in canvas order."
  [state]
  (vec
    (filter (fn [element]
              (draw-selected? state element))
            (get state :elements))))

(defn draw-selection-bounds
  "Return aggregate bounds for the current selection."
  [state]
  (reduce (fn [current element]
            (draw-bounds-union current
                               (draw-element-bounds state element)))
          false
          (draw-selected-elements state)))

(defn draw-single-selected-element
  "Return the sole selected element when exactly one element is selected."
  [state]
  (let [elements (draw-selected-elements state)]
    (if (= (count elements) 1)
      (first elements)
      false)))

(defn draw-single-selected-rectangle
  "Return the sole selected rectangle element when one is selected."
  [state]
  (let [element (draw-single-selected-element state)]
    (if (and element (draw-box-element? element))
      element
      false)))

(defn draw-selection-handle-screen-size
  "Return the square handle size in screen pixels."
  []
  10)

(defn draw-rectangle-handle-world-points
  "Return corner handle world points for BOX."
  [box]
  (let [x (get box :x)
        y (get box :y)
        right (+ x (get box :width))
        bottom (+ y (get box :height))]
    {:nw [x y 1.0]
     :ne [right y 1.0]
     :se [right bottom 1.0]
     :sw [x bottom 1.0]}))

(defn draw-selection-handle-screen-rects
  "Return screen-space handle rectangles for the selected rectangle."
  [state box]
  (let [size (draw-selection-handle-screen-size)
        radius (/ size 2.0)
        points (draw-rectangle-handle-world-points box)]
    (reduce (fn [handles handle]
              (let [screen-point (draw-world-point->screen-point state
                                                                 (get points handle))
                    x (draw-exact-int (math/round (- (nth screen-point 0) radius)))
                    y (draw-exact-int (math/round (- (nth screen-point 1) radius)))]
                (assoc handles
                       handle
                       {:x x
                        :y y
                        :width size
                        :height size})))
            {}
            [:nw :ne :se :sw])))

(defn draw-screen-point-in-rect?
  "Return true when screen POINT lies inside RECT."
  [point rect]
  (and rect
       (>= (nth point 0) (get rect :x))
       (>= (nth point 1) (get rect :y))
       (<= (nth point 0) (+ (get rect :x) (get rect :width)))
       (<= (nth point 1) (+ (get rect :y) (get rect :height)))))

(defn draw-find-selection-handle
  "Return the resize handle hit by SCREEN-POINT, or false."
  [state screen-point]
  (let [box (draw-single-selected-rectangle state)]
    (if box
      (let [rects (draw-selection-handle-screen-rects state box)]
        (cond
          (draw-screen-point-in-rect? screen-point (get rects :nw)) :nw
          (draw-screen-point-in-rect? screen-point (get rects :ne)) :ne
          (draw-screen-point-in-rect? screen-point (get rects :se)) :se
          (draw-screen-point-in-rect? screen-point (get rects :sw)) :sw
          :else false))
      false)))

(defn draw-tool-panel-width
  "Return the tool panel width in screen pixels."
  []
  184)

(defn draw-tool-panel-padding
  "Return the tool panel inner padding in screen pixels."
  []
  10)

(defn draw-tool-panel-button-height
  "Return the button height for tool panel buttons."
  []
  20)

(defn draw-tool-panel-button-gap
  "Return the vertical gap between tool panel buttons."
  []
  6)

(defn draw-tool-panel-rect
  "Return the tool panel screen rectangle for STATE."
  [state]
  (let [width (draw-tool-panel-width)
        x (- (or (get state :width) 1280) width 12)
        y 12
        height 304]
    {:x x
     :y y
     :width width
     :height height}))

(defn draw-save-format-label
  "Return the default on-disk canvas format label."
  []
  "EDN")

(defn draw-tool-panel-info-lines
  "Return the footer metadata and shortcut lines for the tool panel."
  [state]
  [(format "file: %s" (fs/basename (draw-state-file-path)))
   (format "format: %s" (draw-save-format-label))
   "TAB toggle  CTRL+S save"
   "CTRL+O load"])

(defn draw-tool-panel-buttons
  "Return clickable tool panel buttons for STATE."
  [state]
  (let [panel (draw-tool-panel-rect state)
        padding (draw-tool-panel-padding)
        x (+ (get panel :x) padding)
        width (- (get panel :width) (* padding 2))
        height (draw-tool-panel-button-height)
        gap (draw-tool-panel-button-gap)
        y0 (+ (get panel :y) 40)]
    [ {:id :tool-ink
       :label "Ink"
       :kind :tool
       :tool :ink
       :active? (draw-kind=? (or (get state :tool) :ink) :ink)
       :x x :y y0 :width width :height height}
      {:id :tool-select
       :label "Select"
       :kind :tool
       :tool :select
       :active? (draw-kind=? (or (get state :tool) :ink) :select)
       :x x :y (+ y0 (* 1 (+ height gap))) :width width :height height}
      {:id :tool-rectangle
       :label "Rectangle"
       :kind :tool
       :tool :box
       :active? (draw-kind=? (or (get state :tool) :ink) :box)
       :x x :y (+ y0 (* 2 (+ height gap))) :width width :height height}
      {:id :tool-arrow
       :label "Arrow"
       :kind :tool
       :tool :arrow
       :active? (draw-kind=? (or (get state :tool) :ink) :arrow)
       :x x :y (+ y0 (* 3 (+ height gap))) :width width :height height}
      {:id :tool-text
       :label "Text"
       :kind :tool
       :tool :text
       :active? (draw-kind=? (or (get state :tool) :ink) :text)
       :x x :y (+ y0 (* 4 (+ height gap))) :width width :height height}
      {:id :save
       :label "Save"
       :kind :save
       :active? false
       :x x :y (+ y0 (* 6 (+ height gap))) :width width :height height}
      {:id :load
       :label "Load"
       :kind :load
       :active? false
       :x x :y (+ y0 (* 7 (+ height gap))) :width width :height height}]))

(defn draw-selection-summary
  "Return a compact summary of the current selection."
  [state]
  (let [elements (draw-selected-elements state)
        total (count elements)]
    (if (= total 0)
      "selected: none"
      (if (= total 1)
        (format "selected: %s"
                (name (get (first elements) :kind)))
        (let [counts (reduce (fn [current element]
                               (let [kind (name (get element :kind))
                                     prior (or (get current kind) 0)]
                                 (assoc current kind (+ prior 1))))
                             {}
                             elements)
              parts (map (fn [entry]
                           (format "%d %s"
                                   (nth entry 1)
                                   (nth entry 0)))
                         counts)]
          (format "selected: %s"
                  (str/join ", " parts)))))))

(defn draw-tool-panel-hit?
  "Return true when SCREEN-POINT lies inside the visible tool panel."
  [state screen-point]
  (and (get state :tool-panel?)
       (draw-screen-point-in-rect? screen-point
                                   (draw-tool-panel-rect state))))

(defn draw-pointer-world-point
  "Return the current pointer world point from STATE."
  [state]
  [(or (get state :mouse-x) 0.0)
   (or (get state :mouse-y) 0.0)
   (or (get state :pen-pressure) 1.0)])

(defn draw-pointer-screen-point
  "Return the current pointer screen point from STATE."
  [state]
  [(or (get state :mouse-screen-x) 0.0)
   (or (get state :mouse-screen-y) 0.0)])

(defn draw-find-tool-panel-button
  "Return the clicked tool-panel button for SCREEN-POINT, or false."
  [state screen-point]
  (if (get state :tool-panel?)
    (let loop ((buttons (draw-tool-panel-buttons state)))
      (if (empty? buttons)
        false
        (let [button (first buttons)]
          (if (draw-screen-point-in-rect? screen-point button)
            button
            (loop (rest buttons))))))
    false))

(defn draw-selection-handle-cursor-kind
  "Return the appropriate resize cursor for HANDLE."
  [handle]
  (if (or (draw-kind=? handle :nw)
          (draw-kind=? handle :se))
    :nwse-resize
    (if (or (draw-kind=? handle :ne)
            (draw-kind=? handle :sw))
      :nesw-resize
      :default)))

(defn draw-desired-cursor-kind
  "Return the desired system cursor for STATE."
  [state]
  (let [screen-point (draw-pointer-screen-point state)
        world-point (draw-pointer-world-point state)]
    (cond
      (or (get state :panning?)
          (get state :space-down?))
      :move

      (and (draw-selection-tool? state)
           (get state :active-selection-resize))
      (draw-selection-handle-cursor-kind
        (get (get state :active-selection-resize) :handle))

      (and (draw-selection-tool? state)
           (get state :active-selection-drag))
      :move

      (draw-find-tool-panel-button state screen-point)
      :pointer

      (draw-tool-panel-hit? state screen-point)
      :default

      (and (draw-selection-tool? state)
           (draw-find-selection-handle state screen-point))
      (draw-selection-handle-cursor-kind
        (draw-find-selection-handle state screen-point))

      (and (draw-selection-tool? state)
           (draw-find-hit-element state world-point))
      :move

      (draw-text-tool? state)
      :text

      (or (draw-box-tool? state)
          (draw-arrow-tool? state)
          (draw-frame-tool? state)
          (draw-text-tool? state)
          (draw-kind=? (or (get state :tool) :ink) :ink)
          (get state :eraser?))
      :crosshair

      :else
      :default)))

(defn draw-ensure-system-cursor!
  "Return a cached system cursor pointer for KIND, creating it when needed."
  [kind]
  (if (not *draw-context*)
    false
    (let [cache (or (get *draw-context* :cursor-cache) {})
          current (get cache kind)]
      (if current
        current
        (let [cursor (sdl/create-system-cursor kind)]
          (if cursor
            (begin
              (set! *draw-context*
                    (assoc *draw-context*
                           :cursor-cache (assoc cache kind cursor)))
              cursor)
            false))))))

(defn draw-sync-cursor!
  "Apply the desired cursor for STATE when the live context is available."
  [state]
  (if (not *draw-context*)
    false
    (let [kind (draw-desired-cursor-kind state)
          current-kind (get *draw-context* :cursor-kind)]
      (if (equal? kind current-kind)
        kind
        (let [cursor (draw-ensure-system-cursor! kind)]
          (if cursor
            (begin
              (sdl/set-cursor! cursor)
              (set! *draw-context* (assoc *draw-context* :cursor-kind kind))
              kind)
            current-kind))))))

(defn draw-clear-active-interactions
  "Clear transient pointer interaction state from STATE."
  [state]
  (assoc state
         :pointer-down? false
         :pointer-source false
         :panning? false
         :active-selection-drag false
         :active-selection-resize false
         :active-stroke false
         :active-box false
         :active-arrow false
         :active-frame false
         :active-text false))

(defn draw-apply-tool-panel-button
  "Apply BUTTON from the tool panel to STATE."
  [state button point screen-point]
  (let [kind (get button :kind)
        base-state (draw-sync-pointer-state
                     (draw-clear-active-interactions state)
                     point
                     screen-point)]
    (cond
      (draw-kind=? kind :tool)
      (draw-set-tool-core! base-state (get button :tool))

      (draw-kind=? kind :save)
      (draw-save-canvas-core! base-state)

      (draw-kind=? kind :load)
      (draw-sync-pointer-state
        (draw-load-canvas-core! base-state)
        point
        screen-point)

      :else base-state)))

(defn draw-world-rect->screen-rect
  "Convert a world-space rectangle to a visible screen-space rectangle."
  [state x y width height]
  (let [zoom (draw-view-zoom state)
        vx (draw-view-x state)
        vy (draw-view-y state)
        left-world (min x (+ x width))
        right-world (max x (+ x width))
        top-world (min y (+ y height))
        bottom-world (max y (+ y height))
        raw-left (* (- left-world vx) zoom)
        raw-right (* (- right-world vx) zoom)
        raw-top (* (- top-world vy) zoom)
        raw-bottom (* (- bottom-world vy) zoom)
        left (draw-exact-int (math/floor (min raw-left raw-right)))
        right (draw-exact-int (math/ceiling (max raw-left raw-right)))
        top (draw-exact-int (math/floor (min raw-top raw-bottom)))
        bottom (draw-exact-int (math/ceiling (max raw-top raw-bottom)))
        visible-right (if (> right left) right (+ left 1))
        visible-bottom (if (> bottom top) bottom (+ top 1))]
    {:x left
     :y top
     :width (- visible-right left)
     :height (- visible-bottom top)
     :right visible-right
     :bottom visible-bottom}))

(defn draw-arrow-record
  "Build a fresh active-arrow record."
  [start end color size]
  {:start start
   :end end
   :color color
   :size size})

(defn draw-arrow-length
  "Return the world-space length of ARROW."
  [arrow]
  (let [start (get arrow :start)
        end (get arrow :end)
        dx (- (nth end 0) (nth start 0))
        dy (- (nth end 1) (nth start 1))]
    (math/sqrt (+ (* dx dx) (* dy dy)))))

(defn draw-arrow-visible?
  "Return true when ARROW is long enough to commit."
  [arrow]
  (>= (draw-arrow-length arrow) (draw-box-min-size)))

(defn draw-translate-point
  "Offset POINT by DX and DY, preserving pressure."
  [point dx dy]
  [(+ (nth point 0) dx)
   (+ (nth point 1) dy)
   (draw-point-pressure point)])

(defn draw-translate-element
  "Return ELEMENT moved by DX and DY."
  [element dx dy]
  (if (draw-box-element? element)
    {:id (get element :id)
     :kind :box
     :x (+ (get element :x) dx)
     :y (+ (get element :y) dy)
     :width (get element :width)
     :height (get element :height)
     :color (get element :color)
     :size (get element :size)}
    (if (draw-arrow-element? element)
      {:id (get element :id)
       :kind :arrow
       :start (draw-translate-point (get element :start) dx dy)
       :end (draw-translate-point (get element :end) dx dy)
       :color (get element :color)
       :size (get element :size)}
      (if (draw-frame-element? element)
        {:id (get element :id)
         :kind :frame
         :x (+ (get element :x) dx)
         :y (+ (get element :y) dy)
         :width (get element :width)
         :height (get element :height)
         :color (get element :color)
         :size (get element :size)}
        (if (draw-text-element? element)
          {:id (get element :id)
           :kind :text
           :x (+ (get element :x) dx)
           :y (+ (get element :y) dy)
           :text (get element :text)
           :color (get element :color)
           :size (get element :size)}
          {:id (get element :id)
           :kind :ink
           :points (vec (map (fn [point]
                               (draw-translate-point point dx dy))
                             (get element :points)))
           :color (get element :color)
           :size (get element :size)})))))

(defn draw-find-element-by-id
  "Return the element with ELEMENT-ID from ELEMENTS, or false."
  [elements element-id]
  (let loop ((remaining elements))
    (if (empty? remaining)
      false
      (let [element (first remaining)]
        (if (= (get element :id) element-id)
          element
          (loop (rest remaining)))))))

(defn draw-replace-element-by-id
  "Return ELEMENTS with ELEMENT-ID replaced by NEXT-ELEMENT."
  [elements element-id next-element]
  (vec
    (map (fn [element]
           (if (= (get element :id) element-id)
             next-element
             element))
         elements)))

(defn draw-translate-selected-elements
  "Return ELEMENTS with IDS translated by DX and DY."
  [elements ids dx dy]
  (vec
    (map (fn [element]
           (if (draw-selection-has-id? ids (get element :id))
             (draw-translate-element element dx dy)
             element))
         elements)))

(defn draw-start-selection-interaction
  "Update selection from POINT and begin a drag when an element was hit."
  [state point screen-point pointer-source extend-selection?]
  (let [element (draw-find-hit-element state point)
        ids (draw-selection-next-ids state element extend-selection?)]
    (draw-sync-pointer-state
      (assoc state
             :selection ids
             :pointer-down? (if element true false)
             :pointer-source (if element pointer-source false)
             :active-stroke false
             :active-selection-resize false
             :active-box false
             :active-arrow false
             :active-frame false
             :active-text false
             :active-selection-drag (if element
                                      {:ids ids
                                       :anchor point
                                       :original-elements (edn/read-string
                                                            (pr-str (get state :elements)))
                                       :moved? false}
                                      false))
      point
      screen-point)))

(defn draw-rectangle-opposite-corner
  "Return the fixed opposite corner world point for HANDLE on BOX."
  [box handle]
  (let [x (get box :x)
        y (get box :y)
        right (+ x (get box :width))
        bottom (+ y (get box :height))]
    (cond
      (draw-kind=? handle :nw) [right bottom 1.0]
      (draw-kind=? handle :ne) [x bottom 1.0]
      (draw-kind=? handle :se) [x y 1.0]
      (draw-kind=? handle :sw) [right y 1.0]
      :else [right bottom 1.0])))

(defn draw-start-selection-resize
  "Begin resizing the currently selected rectangle from HANDLE."
  [state point screen-point pointer-source handle]
  (let [box (draw-single-selected-rectangle state)]
    (if box
      (draw-sync-pointer-state
        (assoc state
               :pointer-down? true
               :pointer-source pointer-source
               :active-selection-drag false
               :active-selection-resize {:id (get box :id)
                                         :handle handle
                                         :original-elements (edn/read-string
                                                              (pr-str (get state :elements)))
                                         :moved? false})
        point
        screen-point)
      state)))

(defn draw-start-selection-drag
  "Select the topmost element under POINT and begin a drag when present."
  [state point screen-point pointer-source]
  (draw-start-selection-interaction state
                                    point
                                    screen-point
                                    pointer-source
                                    false))

(defn draw-extend-selection-drag
  "Move the current selection by the drag delta from its anchor."
  [state point screen-point]
  (let [drag (get state :active-selection-drag)]
    (if drag
      (let [anchor (get drag :anchor)
            dx (- (nth point 0) (nth anchor 0))
            dy (- (nth point 1) (nth anchor 1))
            moved? (or (get drag :moved?)
                       (not (= dx 0.0))
                       (not (= dy 0.0)))
            state (if (and moved?
                           (not (get drag :moved?)))
                    (draw-push-history! state)
                    state)
            next-elements (if moved?
                            (draw-translate-selected-elements
                              (get drag :original-elements)
                              (get drag :ids)
                              dx
                              dy)
                            (get drag :original-elements))
            next-drag (assoc drag :moved? moved?)
            next-state (draw-sync-pointer-state
                         (draw-sync-elements
                           (assoc state
                                  :active-selection-drag next-drag
                                  :canvas-dirty? moved?)
                           next-elements)
                         point
                         screen-point)]
        next-state)
      (draw-sync-pointer-state state point screen-point))))

(defn draw-extend-selection-resize
  "Resize the selected rectangle from the active resize handle."
  [state point screen-point]
  (let [resize (get state :active-selection-resize)]
    (if resize
      (let [original-elements (get resize :original-elements)
            element-id (get resize :id)
            original-box (draw-find-element-by-id original-elements element-id)]
        (if (and original-box (draw-box-element? original-box))
          (let [fixed (draw-rectangle-opposite-corner original-box (get resize :handle))
                moved? (or (get resize :moved?)
                           (not (= (nth point 0) (nth fixed 0)))
                           (not (= (nth point 1) (nth fixed 1))))
                state (if (and moved?
                               (not (get resize :moved?)))
                        (draw-push-history! state)
                        state)
                next-box (let [rect (draw-box-rect fixed point)]
                           {:id (get original-box :id)
                            :kind :box
                            :x (get rect :x)
                            :y (get rect :y)
                            :width (get rect :width)
                            :height (get rect :height)
                            :color (get original-box :color)
                            :size (get original-box :size)})
                next-elements (draw-replace-element-by-id original-elements
                                                          element-id
                                                          next-box)
                next-state (draw-sync-pointer-state
                             (draw-sync-elements
                               (assoc state
                                      :active-selection-resize (assoc resize :moved? moved?)
                                      :canvas-dirty? moved?)
                               next-elements)
                             point
                             screen-point)]
            next-state)
          (draw-sync-pointer-state
            (assoc state :active-selection-resize false)
            point
            screen-point)))
      (draw-sync-pointer-state state point screen-point))))

(defn draw-finish-selection-drag
  "Finish the current selection drag and leave the selection active."
  [state point screen-point]
  (draw-sync-pointer-state
    (assoc state
           :pointer-down? false
           :pointer-source false
           :active-selection-drag false)
    point
    screen-point))

(defn draw-finish-selection-resize
  "Finish the current selection resize and leave the selection active."
  [state point screen-point]
  (draw-sync-pointer-state
    (assoc state
           :pointer-down? false
           :pointer-source false
           :active-selection-resize false)
    point
    screen-point))

(defn draw-segment-stroke
  "Build a fresh temporary stroke for incremental canvas commits."
  [stroke points]
  (draw-stroke-record points
                      (get stroke :color)
                      (get stroke :size)))

(defn draw-point-screen-distance
  "Return the screen-space distance between A and B."
  [state a b]
  (let [screen-a (draw-world-point->screen-point state a)
        screen-b (draw-world-point->screen-point state b)
        dx (- (nth screen-b 0) (nth screen-a 0))
        dy (- (nth screen-b 1) (nth screen-a 1))]
    (math/sqrt (+ (* dx dx) (* dy dy)))))

(defn draw-min-point-spacing
  "Return the minimum screen-space spacing between active stroke samples."
  [state point size]
  (let [stamp (draw-point-screen-size state point size)
        spacing (/ stamp 2.0)]
    (if (> spacing 1.0)
      spacing
      1.0)))

(defn draw-replace-last
  "Return ITEMS with the final element replaced by VALUE."
  [items value]
  (let [total (count items)]
    (if (<= total 1)
      [value]
      (conj (vec (take (- total 1) items)) value))))

(defn draw-append-stroke-point
  "Append POINT on STROKE when it is far enough from the prior sample."
  [state stroke point]
  (let [points (get stroke :points)
        size (get stroke :size)]
    (if (empty? points)
      [point]
      (let [previous (last points)
            distance (draw-point-screen-distance state previous point)
            spacing (draw-min-point-spacing state point size)]
        (if (>= distance spacing)
          (conj points point)
          points)))))

(defn draw-start-stroke
  "Start a new stroke from WORLD-POINT and SCREEN-POINT."
  [state point screen-point pointer-source]
  (let [state (draw-push-history! state)
        stroke (draw-stroke-record [point]
                                   (draw-stroke-color state)
                                   (get state :brush-size))
        next-state (draw-sync-pointer-state
                     (assoc state
                            :pointer-down? true
                            :pointer-source pointer-source
                            :active-selection-drag false
                            :active-selection-resize false
                            :active-box false
                            :active-arrow false
                            :active-frame false
                            :active-text false
                            :active-stroke stroke)
                     point
                     screen-point)]
    (draw-reset-preview-sync!)
    (draw-clear-preview!)
    (draw-preview-stroke! next-state stroke)
    (draw-log-entry! :stroke-start
                     {:point point
                      :state (draw-state-snapshot next-state)})
    next-state))

(defn draw-extend-stroke
  "Add WORLD-POINT at SCREEN-POINT to the active stroke."
  [state point screen-point]
  (let [stroke (get state :active-stroke)]
    (if stroke
      (let [points (get stroke :points)
            next-points (draw-append-stroke-point state stroke point)
            appended? (> (count next-points) (count points))
            previous (if (empty? points) nil (last points))
            next-stroke (draw-stroke-record next-points
                                            (get stroke :color)
                                            (get stroke :size))
            next-state (draw-sync-pointer-state
                         (assoc state
                                :active-stroke next-stroke)
                         point
                         screen-point)]
        (if (and appended? previous)
          (draw-preview-segment! next-state
                                 previous
                                 point
                                 (get stroke :size)
                                 (get stroke :color))
          nil)
        next-state)
      (draw-start-stroke state point screen-point :mouse))))

(defn draw-finish-stroke
  "Finish the active stroke using WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [stroke (get state :active-stroke)]
    (if stroke
        (let [points (get stroke :points)
              finished-points (draw-append-stroke-point state stroke point)
              finished (draw-stroke-record finished-points
                                           (get stroke :color)
                                           (get stroke :size))
              next-state (draw-sync-pointer-state
                           (assoc state
                                  :pointer-down? false
                                  :pointer-source false
                                  :active-stroke false)
                           point
                           screen-point)
              next-state (draw-append-element next-state
                                              (assoc finished :kind :ink))]
          (draw-log-entry! :stroke-finish
                           {:point point
                            :points (count (get finished :points))
                            :state (draw-state-snapshot next-state)})
          (if (and (draw-preview-ready?)
                   (draw-canvas-ready?))
            (begin
              (draw-with-canvas!
                (lambda (renderer)
                  (sdl/render-texture! renderer (draw-preview))
                  nil))
              (draw-clear-preview!))
            (if (draw-canvas-ready?)
              (draw-commit-stroke! next-state finished)
              nil))
          (draw-reset-preview-sync!)
          next-state)
      (draw-sync-pointer-state
        (assoc state
               :pointer-down? false
               :pointer-source false
               :active-stroke false)
        point
        screen-point))))

(defn draw-start-box
  "Start a box drag from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [state (draw-push-history! state)
        active-box (draw-box-record point
                                    point
                                    (draw-stroke-color state)
                                    (get state :brush-size))]
    (draw-sync-pointer-state
      (assoc state
             :pointer-down? true
             :pointer-source :box
             :active-stroke false
             :active-selection-resize false
             :active-arrow false
             :active-frame false
             :active-text false
             :active-box active-box)
      point
      screen-point)))

(defn draw-start-arrow
  "Start an arrow drag from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [state (draw-push-history! state)
        active-arrow (draw-arrow-record point
                                        point
                                        (draw-stroke-color state)
                                        (get state :brush-size))]
    (draw-sync-pointer-state
      (assoc state
             :pointer-down? true
             :pointer-source :arrow
             :active-stroke false
             :active-selection-resize false
             :active-box false
             :active-frame false
             :active-text false
             :active-arrow active-arrow)
      point
      screen-point)))

(defn draw-start-frame
  "Start a frame drag from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [state (draw-push-history! state)
        active-frame (draw-frame-record point
                                        point
                                        (draw-stroke-color state)
                                        (get state :brush-size))]
    (draw-sync-pointer-state
      (assoc state
             :pointer-down? true
             :pointer-source :frame
             :active-stroke false
             :active-selection-resize false
             :active-box false
             :active-arrow false
             :active-text false
             :active-frame active-frame)
      point
      screen-point)))

(defn draw-start-text
  "Start a text placement interaction from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [active-text (draw-text-record point
                                      (draw-text-default-value)
                                      (draw-stroke-color state)
                                      (get state :brush-size))]
    (draw-sync-pointer-state
      (assoc state
             :pointer-down? true
             :pointer-source :text
             :active-selection-drag false
             :active-selection-resize false
             :active-stroke false
             :active-box false
             :active-arrow false
             :active-frame false
             :active-text active-text)
      point
      screen-point)))

(defn draw-extend-box
  "Update the active box drag to WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [active-box (get state :active-box)]
    (if active-box
      (draw-sync-pointer-state
        (assoc state
               :active-box (draw-box-record (get active-box :start)
                                            point
                                            (get active-box :color)
                                            (get active-box :size)))
        point
        screen-point)
      (draw-start-box state point screen-point))))

(defn draw-extend-arrow
  "Update the active arrow drag to WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [active-arrow (get state :active-arrow)]
    (if active-arrow
      (draw-sync-pointer-state
        (assoc state
               :active-arrow (draw-arrow-record (get active-arrow :start)
                                                point
                                                (get active-arrow :color)
                                                (get active-arrow :size)))
        point
        screen-point)
      (draw-start-arrow state point screen-point))))

(defn draw-extend-frame
  "Update the active frame drag to WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [active-frame (get state :active-frame)]
    (if active-frame
      (draw-sync-pointer-state
        (assoc state
               :active-frame (draw-frame-record (get active-frame :start)
                                                point
                                                (get active-frame :color)
                                                (get active-frame :size)))
        point
        screen-point)
      (draw-start-frame state point screen-point))))

(defn draw-extend-text
  "Update the active text placement point."
  [state point screen-point]
  (let [active-text (get state :active-text)]
    (if active-text
      (draw-sync-pointer-state
        (assoc state
               :active-text (draw-text-record point
                                              (get active-text :text)
                                              (get active-text :color)
                                              (get active-text :size)))
        point
        screen-point)
      (draw-start-text state point screen-point))))

(defn draw-finish-box
  "Commit the active box drag when it is large enough."
  [state point screen-point]
  (let [active-box (get state :active-box)]
    (if active-box
      (let [box (draw-box-element
                  (draw-box-record (get active-box :start)
                                   point
                                   (get active-box :color)
                                   (get active-box :size)))
            next-state (draw-sync-pointer-state
                         (assoc state
                                :pointer-down? false
                                :pointer-source false
                                :active-box false
                                :canvas-dirty? true)
                         point
                         screen-point)
            next-state (if (draw-box-visible? box)
                         (draw-append-element next-state box)
                         next-state)]
        (draw-log-entry! :box-finish
                         {:box (if (draw-box-visible? box) box false)
                          :state (draw-state-snapshot next-state)})
        next-state)
      (draw-sync-pointer-state
        (assoc state
               :pointer-down? false
               :pointer-source false
               :active-box false)
        point
        screen-point))))

(defn draw-finish-arrow
  "Commit the active arrow drag when it is large enough."
  [state point screen-point]
  (let [active-arrow (get state :active-arrow)]
    (if active-arrow
      (let [arrow (draw-arrow-record (get active-arrow :start)
                                     point
                                     (get active-arrow :color)
                                     (get active-arrow :size))
            next-state (draw-sync-pointer-state
                         (assoc state
                                :pointer-down? false
                                :pointer-source false
                                :active-arrow false
                                :canvas-dirty? true)
                         point
                         screen-point)
            next-state (if (draw-arrow-visible? arrow)
                         (draw-append-element next-state
                                              (assoc arrow :kind :arrow))
                         next-state)]
        (draw-log-entry! :arrow-finish
                         {:arrow (if (draw-arrow-visible? arrow) arrow false)
                          :state (draw-state-snapshot next-state)})
        next-state)
      (draw-sync-pointer-state
        (assoc state
               :pointer-down? false
               :pointer-source false
               :active-arrow false)
        point
        screen-point))))

(defn draw-finish-frame
  "Commit the active frame drag when it is large enough."
  [state point screen-point]
  (let [active-frame (get state :active-frame)]
    (if active-frame
      (let [frame (draw-frame-element (draw-frame-record (get active-frame :start)
                                                         point
                                                         (get active-frame :color)
                                                         (get active-frame :size)))
            next-state (draw-sync-pointer-state
                         (assoc state
                                :pointer-down? false
                                :pointer-source false
                                :active-frame false
                                :canvas-dirty? true)
                         point
                         screen-point)
            next-state (if (draw-frame-visible? frame)
                         (draw-append-element next-state frame)
                         next-state)]
        (draw-log-entry! :frame-finish
                         {:frame (if (draw-frame-visible? frame) frame false)
                          :state (draw-state-snapshot next-state)})
        next-state)
      (draw-sync-pointer-state
        (assoc state
               :pointer-down? false
               :pointer-source false
               :active-frame false)
        point
        screen-point))))

(defn draw-finish-text
  "Commit the active text placement when it has visible content."
  [state point screen-point]
  (let [active-text (get state :active-text)]
    (if active-text
      (let [text-element (draw-text-element
                           (draw-text-record point
                                             (get active-text :text)
                                             (get active-text :color)
                                             (get active-text :size)))
            next-state (draw-sync-pointer-state
                         (assoc state
                                :pointer-down? false
                                :pointer-source false
                                :active-text false
                                :canvas-dirty? true)
                         point
                         screen-point)
            next-state (if (draw-text-visible? text-element)
                         (draw-append-element (draw-push-history! next-state)
                                              text-element)
                         next-state)]
        (draw-log-entry! :text-finish
                         {:text (if (draw-text-visible? text-element) text-element false)
                          :state (draw-state-snapshot next-state)})
        next-state)
      (draw-sync-pointer-state
        (assoc state
               :pointer-down? false
               :pointer-source false
               :active-text false)
        point
        screen-point))))

(defn draw-pen-owned-pointer?
  "Return true when STATE says the active pointer source is the pen."
  [state]
  (draw-kind=? (get state :pointer-source) :pen))

(defn draw-kind=?
  "Compare two keyword event kinds by name."
  [kind expected]
  (and (keyword? kind)
       (keyword? expected)
       (string=? (name kind) (name expected))))

(defn draw-nonblank
  "Return VALUE when it contains visible text, otherwise FALLBACK."
  [value fallback]
  (if (str/blank? value)
    fallback
    value))

(defn draw-event-token
  "Return the text after LABEL in DESC, or nil when LABEL is missing."
  [desc label]
  (let [parts (str/split desc label)]
    (if (> (count parts) 1)
      (nth parts 1)
      nil)))

(defn draw-event-token-value
  "Return the first raw value token after LABEL in DESC."
  [desc label]
  (let [tail (draw-event-token desc label)]
    (if (str/blank? tail)
      nil
      (let [token (first (str/split tail " "))]
        (first (str/split token ")"))))))

(defn draw-event-coordinate
  "Parse the first integer coordinate after LABEL in DESC."
  [desc label]
  (let [token (draw-event-token-value desc label)]
    (if (str/blank? token)
      0
      (let [whole (first (str/split token "."))]
        (parse-long whole)))))

(defn draw-bump-frame!
  "Advance the frame counter in STATE."
  [state]
  (assoc state
         :frame (+ (get state :frame) 1)))

(defn draw-exact-int
  "Coerce VALUE to an exact integer."
  [value]
  (inexact->exact value))

(defn draw-input-event-screen-point
  "Return the raw [x y] screen coordinate from EVENT."
  [event]
  [(or (get event :mouse-x) (get event :wheel-mouse-x) 0)
   (or (get event :mouse-y) (get event :wheel-mouse-y) 0)])

(defn draw-input-event-point
  "Return the [x y pressure] world coordinate from EVENT."
  [state event]
  (draw-screen-point->world-point
    state
    [(or (get event :mouse-x) (get event :wheel-mouse-x) 0)
     (or (get event :mouse-y) (get event :wheel-mouse-y) 0)
     (or (get event :pressure)
         (get state :pen-pressure)
         1.0)]))

(defn draw-build-input-event
  "Build a synthetic event map for DESC using the current SDL event state."
  [state desc]
  (let [kind (draw-event-kind desc)]
    {:kind kind
     :desc desc
     :key (draw-event-key-label desc)
     :text (draw-nonblank (sdl/event-text-input) desc)
     :text-edit (draw-nonblank (sdl/event-text-editing) desc)
     :mouse-x (draw-event-coordinate desc "x=")
     :mouse-y (draw-event-coordinate desc "y=")
     :pressure (draw-event-pressure state desc)
     :shift? (sdl/mod-shift-pressed?)
     :ctrl? (sdl/mod-ctrl-pressed?)
     :wheel-y (sdl/event-wheel-y)
     :wheel-mouse-x (sdl/event-wheel-mouse-x)
     :wheel-mouse-y (sdl/event-wheel-mouse-y)}))

(defn draw-synthetic-pen-mouse-event?
  "Return true when EVENT is SDL's synthetic mouse mirror of pen input."
  [event]
  (let [kind (get event :kind)
        desc (or (get event :desc) "")]
    (and (or (draw-kind=? kind :mouse-motion)
             (draw-kind=? kind :mouse-down)
             (draw-kind=? kind :mouse-up))
         (str/includes? desc "which=4294967294"))))

(defn draw-ignorable-input-event?
  "Return true when EVENT should be discarded before it reaches app logic."
  [event]
  (let [kind (get event :kind)]
    (or (draw-synthetic-pen-mouse-event? event)
        (draw-kind=? kind :finger-motion)
        (draw-kind=? kind :finger-down)
        (draw-kind=? kind :finger-up)
        (draw-kind=? kind :finger-canceled))))

(defn draw-loggable-event?
  "Return true when EVENT is useful in the persistent draw log."
  [event]
  (let [kind (get event :kind)]
    (or (draw-kind=? kind :key-down)
        (draw-kind=? kind :key-up)
        (draw-kind=? kind :mouse-down)
        (draw-kind=? kind :mouse-up)
        (draw-kind=? kind :pen-down)
        (draw-kind=? kind :pen-up)
        (draw-kind=? kind :pen-button-down)
        (draw-kind=? kind :pen-button-up)
        (draw-kind=? kind :mouse-wheel)
        (draw-kind=? kind :focus-lost)
        (draw-kind=? kind :focus-gained)
        (draw-kind=? kind :mouse-enter)
        (draw-kind=? kind :mouse-leave)
        (draw-kind=? kind :text-input)
        (draw-kind=? kind :text-editing)
        (draw-kind=? kind :quit))))

(defn draw-apply-and-log-input-event!
  "Apply EVENT to STATE and emit a diagnostic log entry when relevant."
  [state event source]
  (if (draw-ignorable-input-event? event)
    state
    (let [next-state (draw-apply-input-event! state event)]
      (if (draw-loggable-event? event)
        (draw-log-entry! :input
                         {:source source
                          :kind (get event :kind)
                          :desc (or (get event :desc) "")
                          :key (or (get event :key) "")
                          :text (or (get event :text) "")
                          :pressure (or (get event :pressure) 1.0)
                          :shift? (get event :shift?)
                          :state (draw-state-snapshot next-state)})
        nil)
      next-state)))

(defn draw-handle-wheel-event!
  "Apply mouse-wheel zoom from EVENT to STATE."
  [state event]
  (let [delta (or (get event :wheel-y) 0.0)]
    (if (= delta 0.0)
      state
      (draw-zoom-at-core! state
                          delta
                          (or (get event :wheel-mouse-x) 0.0)
                          (or (get event :wheel-mouse-y) 0.0)))))

(defn draw-apply-input-event!
  "Apply a synthetic or live EVENT map to STATE."
  [state event]
  (let [kind (get event :kind)
        desc (or (get event :desc) "")
        events (conj (get state :recent-events) desc)
        recent (draw-trim-events events)
        state (assoc state
                     :recent-events recent
                     :last-event desc)]
    (cond
      (or (draw-kind=? kind :key-down)
          (draw-kind=? kind :key-up))
      (let [key-label (or (get event :key) "")
            state (assoc state
                         :last-key key-label
                         :last-key-desc desc)
            state (draw-apply-key-modifier-state state event)]
        (if (draw-kind=? kind :key-down)
          (let [state (if (and (get state :ctrl-down?)
                               (draw-save-shortcut-key? key-label))
                        (draw-save-canvas-core! state)
                        (if (and (get state :ctrl-down?)
                                 (draw-load-shortcut-key? key-label))
                          (draw-load-canvas-core! state)
                          state))
                state (draw-handle-view-key! state key-label)
                state (draw-handle-tool-key! state key-label)
                state (if (draw-toggle-debug-panel-key? key-label)
                        (draw-toggle-debug-panel! state)
                        state)]
            (if (draw-toggle-tool-panel-key? key-label)
              (draw-toggle-tool-panel! state)
              state))
          (if (and (draw-space-key? key-label)
                   (get state :panning?))
            (draw-finish-pan-core! state)
            state)))

      (draw-kind=? kind :mouse-wheel)
      (draw-handle-wheel-event! state event)

      (draw-kind=? kind :focus-lost)
      (draw-focus-lost-core! state)

      (draw-kind=? kind :focus-gained)
      (draw-focus-gained-core! state)

      (draw-kind=? kind :mouse-leave)
      (draw-mouse-leave-core! state)

      (draw-kind=? kind :mouse-enter)
      (draw-mouse-enter-core! state)

      (draw-kind=? kind :text-input)
      (assoc state
             :last-text (draw-nonblank (or (get event :text) desc) desc)
             :last-key (or (get event :key) desc))

      (or (draw-kind=? kind :mouse-motion)
          (draw-kind=? kind :mouse-down)
          (draw-kind=? kind :mouse-up))
      (if (draw-pen-owned-pointer? state)
        state
        (let [state (assoc state :pen-pressure 1.0)]
          (cond
            (and (draw-kind=? kind :mouse-down)
                 (get state :space-down?))
            (draw-start-pan-core! state (draw-input-event-screen-point event))

            (draw-kind=? kind :mouse-down)
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)
                  panel-button (draw-find-tool-panel-button state screen-point)
                  resize-handle (if (draw-selection-tool? state)
                                  (draw-find-selection-handle state screen-point)
                                  false)]
              (if panel-button
                (draw-apply-tool-panel-button state panel-button point screen-point)
                (if (draw-tool-panel-hit? state screen-point)
                  (draw-sync-pointer-state state point screen-point)
                (if (draw-selection-tool? state)
                (if resize-handle
                  (draw-start-selection-resize state
                                               point
                                               screen-point
                                               :mouse
                                               resize-handle)
                  (draw-start-selection-interaction state
                                                   point
                                                   screen-point
                                                   :mouse
                                                   (if (get event :shift?) true false)))
                (if (draw-box-tool? state)
                  (draw-start-box state point screen-point)
                  (if (draw-arrow-tool? state)
                    (draw-start-arrow state point screen-point)
                    (if (draw-frame-tool? state)
                      (draw-start-frame state point screen-point)
                      (if (draw-text-tool? state)
                        (draw-start-text state point screen-point)
                        (draw-start-stroke state point screen-point :mouse)))))))))

            (and (draw-kind=? kind :mouse-up)
                 (get state :panning?))
            (draw-finish-pan-core! state)

            (draw-kind=? kind :mouse-up)
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)]
              (if (get state :active-selection-resize)
                (draw-finish-selection-resize state point screen-point)
                (if (get state :active-selection-drag)
                (draw-finish-selection-drag state point screen-point)
                (if (get state :active-box)
                  (draw-finish-box state point screen-point)
                  (if (get state :active-arrow)
                    (draw-finish-arrow state point screen-point)
                    (if (get state :active-frame)
                      (draw-finish-frame state point screen-point)
                      (if (get state :active-text)
                        (draw-finish-text state point screen-point)
                        (draw-finish-stroke state point screen-point))))))))

            (get state :panning?)
            (draw-pan-core! state (draw-input-event-screen-point event))

            (get state :pointer-down?)
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)]
              (if (get state :active-selection-resize)
                (draw-extend-selection-resize state point screen-point)
                (if (get state :active-selection-drag)
                (draw-extend-selection-drag state point screen-point)
                (if (get state :active-box)
                  (draw-extend-box state point screen-point)
                  (if (get state :active-arrow)
                    (draw-extend-arrow state point screen-point)
                    (if (get state :active-frame)
                      (draw-extend-frame state point screen-point)
                      (if (get state :active-text)
                        (draw-extend-text state point screen-point)
                        (draw-extend-stroke state point screen-point))))))))

            :else
            (let [point (draw-input-event-point state event)
                  screen-point (draw-input-event-screen-point event)]
              (draw-sync-pointer-state state point screen-point)))))

      (or (draw-kind=? kind :pen-motion)
          (draw-kind=? kind :pen-down)
          (draw-kind=? kind :pen-up)
          (draw-kind=? kind :pen-button-down)
          (draw-kind=? kind :pen-button-up))
      (let [state (assoc state
                         :pen-pressure (or (get event :pressure) 1.0))]
        (cond
          (and (draw-kind=? kind :pen-down)
               (get state :space-down?))
          (draw-start-pan-core! state (draw-input-event-screen-point event))

          (draw-kind=? kind :pen-down)
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)
                panel-button (draw-find-tool-panel-button state screen-point)
                resize-handle (if (draw-selection-tool? state)
                                (draw-find-selection-handle state screen-point)
                                false)]
            (if panel-button
              (draw-apply-tool-panel-button state panel-button point screen-point)
              (if (draw-tool-panel-hit? state screen-point)
                (draw-sync-pointer-state state point screen-point)
              (if (draw-selection-tool? state)
              (if resize-handle
                (draw-start-selection-resize state
                                             point
                                             screen-point
                                             :pen
                                             resize-handle)
                (draw-start-selection-interaction state
                                                 point
                                                 screen-point
                                                 :pen
                                                 (if (get event :shift?) true false)))
              (if (draw-box-tool? state)
                (draw-start-box state point screen-point)
                (if (draw-arrow-tool? state)
                  (draw-start-arrow state point screen-point)
                  (if (draw-frame-tool? state)
                    (draw-start-frame state point screen-point)
                    (if (draw-text-tool? state)
                      (draw-start-text state point screen-point)
                      (draw-start-stroke state point screen-point :pen)))))))))

          (and (or (draw-kind=? kind :pen-up)
                   (draw-kind=? kind :pen-button-up))
               (get state :panning?))
          (draw-finish-pan-core! state)

          (or (draw-kind=? kind :pen-up)
              (draw-kind=? kind :pen-button-up))
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)]
            (if (get state :active-selection-resize)
              (draw-finish-selection-resize state point screen-point)
              (if (get state :active-selection-drag)
              (draw-finish-selection-drag state point screen-point)
              (if (get state :active-box)
                (draw-finish-box state point screen-point)
                (if (get state :active-arrow)
                  (draw-finish-arrow state point screen-point)
                  (if (get state :active-frame)
                    (draw-finish-frame state point screen-point)
                    (if (get state :active-text)
                      (draw-finish-text state point screen-point)
                      (draw-finish-stroke state point screen-point))))))))

          (get state :panning?)
          (draw-pan-core! state (draw-input-event-screen-point event))

          (get state :pointer-down?)
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)]
            (if (get state :active-selection-resize)
              (draw-extend-selection-resize state point screen-point)
              (if (get state :active-selection-drag)
              (draw-extend-selection-drag state point screen-point)
              (if (get state :active-box)
                (draw-extend-box state point screen-point)
                (if (get state :active-arrow)
                  (draw-extend-arrow state point screen-point)
                  (if (get state :active-frame)
                    (draw-extend-frame state point screen-point)
                    (if (get state :active-text)
                      (draw-extend-text state point screen-point)
                      (draw-extend-stroke state point screen-point))))))))

          :else
          (let [point (draw-input-event-point state event)
                screen-point (draw-input-event-screen-point event)]
            (draw-sync-pointer-state state point screen-point))))

      (draw-kind=? kind :pen-axis)
      (let [point (draw-input-event-point state event)
            screen-point (draw-input-event-screen-point event)]
        (draw-sync-pointer-state
          (assoc state
                 :pen-pressure (or (get event :pressure) 1.0))
          point
          screen-point))

      (draw-kind=? kind :text-editing)
      (assoc state
             :last-text (draw-nonblank (or (get event :text-edit) desc) desc)
             :last-key (or (get event :key) desc))

      :else
      state)))

(defn draw-record-input!
  "Record the latest SDL event description in STATE."
  [state desc]
  (draw-apply-and-log-input-event! state
                                   (draw-build-input-event state desc)
                                   :sdl))

(defn draw-simulate-input!
  "Apply a synthetic input EVENT to the current draw state."
  [event]
  (draw-with-lock
    (lambda ()
      (set! *draw-state*
            (draw-apply-and-log-input-event! (or *draw-state* (default-state))
                                             event
                                             :simulated))
      (if *draw-running?*
        (draw-render-current!)
        nil)
      *draw-state*)))

(defn draw-replay-events!
  "Apply EVENTS in order to the current draw state."
  [events]
  (draw-with-lock
    (lambda ()
      (set! *draw-state*
            (reduce (lambda (state event)
                      (draw-apply-and-log-input-event! state event :replay))
                    (or *draw-state* (default-state))
                    events))
      (if *draw-running?*
        (draw-render-current!)
        nil)
      *draw-state*)))

(defn draw-repeat-events!
  "Replay EVENTS ROUNDS times starting from STATE."
  [state events rounds]
  (if (<= rounds 0)
    state
    (draw-repeat-events! (reduce (lambda (next-state event)
                                   (draw-apply-input-event! next-state event))
                                 state
                                 events)
                         events
                         (- rounds 1))))

(defn draw-replay-benchmark!
  "Replay EVENTS and print the elapsed wall-clock time."
  [events rounds]
  (let [start (current-process-milliseconds)
        state (draw-repeat-events! (or *draw-state* (default-state))
                                   events
                                   rounds)
        elapsed (- (current-process-milliseconds) start)]
    (println (format "draw replay: %d events x %d rounds in %d ms"
                     (count events)
                     rounds
                     elapsed))
    (println (format "draw state: %s" (describe-state state)))
    state))

(defn draw-replay-live!
  "Replay EVENTS in the live window, pausing PAUSE-MS milliseconds between events."
  [events pause-ms]
  (let [pause (if (> (or pause-ms 0) 0)
                pause-ms
                0)]
    (reduce (lambda (state event)
              (let [next-state (draw-simulate-input! event)]
                (if (> pause 0)
                  (delay-ms pause)
                  nil)
                next-state))
            (or *draw-state* (default-state))
            events)))

(defn draw-repeat-live-events!
  "Replay EVENTS ROUNDS times in the live window."
  [events rounds pause-ms]
  (if (<= rounds 0)
    (or *draw-state* (default-state))
    (begin
      (draw-replay-live! events pause-ms)
      (draw-repeat-live-events! events (- rounds 1) pause-ms))))

(defn draw-replay-live-benchmark!
  "Replay EVENTS live and print the elapsed wall-clock time."
  [events rounds pause-ms]
  (let [start (current-process-milliseconds)
        state (draw-repeat-live-events! events rounds pause-ms)
        elapsed (- (current-process-milliseconds) start)]
    (println (format "draw live replay: %d events x %d rounds in %d ms"
                     (count events)
                     rounds
                     elapsed))
    (println (format "draw state: %s" (describe-state state)))
    state))

(defn mouse-position
  "Return the current mouse position from the draw state."
  []
  (let [state (or (current-state) (default-state))]
    {:x (get state :mouse-x)
     :y (get state :mouse-y)}))

(defn recent-events
  "Return the recent SDL event log."
  []
  (get (or (current-state) (default-state)) :recent-events))

(defn last-key-event
  "Return the last key event description."
  []
  (get (or (current-state) (default-state)) :last-key))

(defn last-input-event
  "Return the last SDL event description."
  []
  (get (or (current-state) (default-state)) :last-event))

(defn input-summary
  "Return a short textual summary of the current input state."
  []
  (let [state (or (current-state) (default-state))]
    (format "mouse %.1f,%.1f view %.1f,%.1f zoom %.2f key %s text %s event %s elements %d selection %d strokes %d undo %d tool %s size %d dbg %s focus %s pressure %.2f"
            (or (get state :mouse-x) 0.0)
            (or (get state :mouse-y) 0.0)
            (draw-view-x state)
            (draw-view-y state)
            (draw-view-zoom state)
            (or (get state :last-key) "")
            (or (get state :last-text) "")
            (or (get state :last-event) "")
            (count (get state :elements))
            (count (draw-selected-element-ids state))
            (count (get state :strokes))
            (count (get state :history))
            (draw-tool-mode state)
            (get state :brush-size)
            (if (get state :debug-panel?) "on" "off")
            (if (get state :window-focused?) "on" "off")
            (or (get state :pen-pressure) 1.0))))

(defn sync-window-title!
  "Update the SDL window title from the current state."
  []
  (if *draw-context*
    (sdl/set-window-title! (get *draw-context* :window)
                           (describe-state *draw-state*))
    nil))

(defn draw-input-batch-limit
  "Return the maximum number of SDL events to process in one frame."
  []
  64)

(defn draw-drain-input-batch!
  "Drain at most REMAINING SDL input events into the current state."
  [remaining quit?]
  (if (<= remaining 0)
    quit?
    (if (sdl/poll-event!)
      (let [desc (sdl/event-description)
            event (draw-build-input-event *draw-state* desc)
            kind (get event :kind)]
        (if (draw-ignorable-input-event? event)
          (draw-drain-input-batch! remaining quit?)
          (begin
            (set! *draw-state*
                  (draw-apply-and-log-input-event! *draw-state* event :sdl))
            (if (draw-kind=? kind :quit)
              (begin
                (set! *draw-running?* false)
                (draw-drain-input-batch! (- remaining 1) true))
              (draw-drain-input-batch! (- remaining 1) quit?)))))
      quit?)))

(defn draw-poll-input!
  "Drain pending SDL input events into the current state."
  []
  (let [quit? (draw-drain-input-batch! (draw-input-batch-limit) false)]
    (set! *draw-state* (draw-bump-frame! *draw-state*))
    (sync-window-title!)
    quit?))

(defn draw-apply-control-command!
  "Apply a supervisor control COMMAND to STATE inside the child process."
  [state command]
  (let [op (get command :op)
        payload (get command :payload)
        next-state
          (cond
            (equal? op :set-state)
            (assoc payload :canvas-dirty? true)

            (equal? op :redraw)
            (assoc state :canvas-dirty? true)

            (equal? op :stop)
            (begin
              (set! *draw-running?* false)
              state)

            :else
            state)]
    (draw-log-entry! :control
                     {:op op
                      :state (draw-state-snapshot next-state)})
    next-state))

(defn draw-poll-control!
  "Apply the latest pending supervisor control command in child mode."
  []
  (if *draw-child-mode?*
    (let [command (draw-control-command-pending)]
      (if command
        (begin
          (set! *draw-last-control-seq* (or (get command :seq) *draw-last-control-seq*))
          (set! *draw-state* (draw-apply-control-command! *draw-state* command))
          command)
        false))
    false))

(defn describe-state
  "Return a short human-readable summary of STATE."
  [state]
  (format "%s %dx%d frame %d mouse %.1f,%.1f view %.1f,%.1f zoom %.2f key %s text %s elements %d selection %d strokes %d undo %d tool %s size %d dbg %s focus %s pressure %.2f"
          (get state :title)
          (get state :width)
          (get state :height)
          (get state :frame)
          (or (get state :mouse-x) 0.0)
          (or (get state :mouse-y) 0.0)
          (draw-view-x state)
          (draw-view-y state)
          (draw-view-zoom state)
          (or (get state :last-key) "")
          (or (get state :last-text) "")
          (count (get state :elements))
          (count (draw-selected-element-ids state))
          (count (get state :strokes))
          (count (get state :history))
          (draw-tool-mode state)
          (get state :brush-size)
          (if (get state :debug-panel?) "on" "off")
          (if (get state :window-focused?) "on" "off")
          (or (get state :pen-pressure) 1.0)))

(defn draw-brush-radius
  "Return the brush radius for SIZE."
  [size]
  (if (> size 0)
    (draw-exact-int size)
    1))

(defn draw-point-pressure
  "Return the pressure stored in POINT, defaulting to 1.0."
  [point]
  (if (> (count point) 2)
    (nth point 2)
    1.0))

(defn draw-normalize-pressure
  "Map raw pen pressure into a more useful visual range for drawing."
  [pressure]
  (let [raw (draw-clamp (or pressure 1.0) 0.0 1.0)
        scaled (draw-clamp (/ raw 0.68) 0.0 1.0)]
    (math/sqrt scaled)))

(defn draw-point-size
  "Scale BASE-SIZE by POINT pressure."
  [point base-size]
  (let [pressure (draw-normalize-pressure (draw-point-pressure point))
        scaled (draw-exact-int (math/ceiling (* base-size
                                                (+ 0.5 (* 1.5 pressure)))))]
    (if (> scaled 0)
      scaled
      1)))

(defn draw-point-alpha
  "Scale the stroke alpha by POINT pressure."
  [point]
  (let [pressure (draw-normalize-pressure (draw-point-pressure point))
        alpha (draw-exact-int (math/ceiling (+ 72 (* 183 pressure))))]
    (if (> alpha 255)
      255
      alpha)))

(defn draw-stroke-color-value
  "Return the current stroke color, defaulting to white."
  []
  (if *draw-current-stroke-color*
    *draw-current-stroke-color*
    [255 255 255]))

(defn draw-set-stroke-color!
  "Set the draw color for the current stroke with ALPHA."
  [renderer alpha]
  (let [color (draw-stroke-color-value)]
    (sdl/set-draw-color! renderer
                         (nth color 0)
                         (nth color 1)
                         (nth color 2)
                         alpha)))

(defn draw-render-soft-brush!
  "Render the soft brush texture at POINT with SIZE."
  [renderer state point size]
  (let [brush (draw-brush-texture)
        color (draw-stroke-color-value)
        screen-point (draw-world-point->screen-point state point)
        stamp-size (draw-point-screen-size state point size)
        alpha (draw-point-alpha point)]
    (if (draw-brush-texture-ready?)
      (begin
        (sdl/set-texture-color-mod! brush
                                    (nth color 0)
                                    (nth color 1)
                                    (nth color 2))
        (sdl/set-texture-alpha-mod! brush alpha)
        (sdl/render-texture-at! renderer
                                brush
                                (- (nth screen-point 0) (/ stamp-size 2.0))
                                (- (nth screen-point 1) (/ stamp-size 2.0))
                                stamp-size
                                stamp-size)
        true)
      (begin
        (draw-set-stroke-color! renderer alpha)
        (sdl/render-fill-rect! renderer
                               (- (nth screen-point 0) (/ stamp-size 2.0))
                               (- (nth screen-point 1) (/ stamp-size 2.0))
                               stamp-size
                               stamp-size)
        false))))

(defn draw-render-stroke-point!
  "Render a single stroke sample at POINT."
  [renderer state point size]
  (draw-render-soft-brush! renderer state point size))

(defn draw-render-soft-segment!
  "Render a smooth segment from A to B using the compiled SDL helper."
  [renderer state a b size]
  (let [brush (draw-brush-texture)
        strip (draw-strip-texture)
        color (draw-stroke-color-value)
        screen-a (draw-world-point->screen-point state a)
        screen-b (draw-world-point->screen-point state b)
        size-a (draw-point-screen-size state a size)
        size-b (draw-point-screen-size state b size)
        alpha-a (draw-point-alpha a)
        alpha-b (draw-point-alpha b)]
    (if (and (draw-brush-texture-ready?)
             (draw-strip-texture-ready?))
      (sdl/render-soft-segment! renderer
                                strip
                                brush
                                (nth screen-a 0)
                                (nth screen-a 1)
                                size-a
                                alpha-a
                                (nth screen-b 0)
                                (nth screen-b 1)
                                size-b
                                alpha-b
                                (nth color 0)
                                (nth color 1)
                                (nth color 2))
      (begin
        (draw-set-stroke-color! renderer (if (> alpha-a alpha-b) alpha-a alpha-b))
        (sdl/render-line! renderer
                          (nth screen-a 0)
                          (nth screen-a 1)
                          (nth screen-b 0)
                          (nth screen-b 1))
        (draw-render-soft-brush! renderer state a size)
        (draw-render-soft-brush! renderer state b size)
        true))))

(defn draw-render-stroke-segment!
  "Render a line segment from A to B."
  [renderer state a b size]
  (draw-render-soft-segment! renderer state a b size))

(defn draw-render-stroke-segments!
  "Render a line strip from POINTS."
  [renderer state points size]
  (let [total (count points)]
    (if (<= total 1)
      nil
      (reduce (fn [previous point]
                (begin
                  (draw-render-stroke-segment! renderer state previous point size)
                  point))
              (first points)
              (rest points)))))

(defn draw-render-stroke!
  "Render a stroke map."
  [renderer state stroke]
  (let [points (get stroke :points)
        color (get stroke :color)
        size (get stroke :size)]
    (if (empty? points)
      nil
      (draw-with-stroke-color color
        (lambda ()
          (if (<= (count points) 1)
            (draw-render-stroke-point! renderer state (first points) size)
            (draw-render-stroke-segments! renderer state points size)))))))

(defn draw-render-box-edge!
  "Render one edge of a box from A to B."
  [renderer state color size a b]
  (draw-with-stroke-color color
    (lambda ()
      (draw-render-stroke-segment! renderer
                                   state
                                   [(nth a 0) (nth a 1) 1.0]
                                   [(nth b 0) (nth b 1) 1.0]
                                   size))))

(defn draw-render-screen-soft-segment!
  "Render a soft segment directly in screen coordinates."
  [renderer color size x1 y1 x2 y2]
  (let [brush (draw-brush-texture)
        strip (draw-strip-texture)
        alpha 255]
    (draw-with-stroke-color color
      (lambda ()
        (if (and (draw-brush-texture-ready?)
                 (draw-strip-texture-ready?))
          (sdl/render-soft-segment! renderer
                                    strip
                                    brush
                                    x1
                                    y1
                                    size
                                    alpha
                                    x2
                                    y2
                                    size
                                    alpha
                                    (nth color 0)
                                    (nth color 1)
                                    (nth color 2))
          (begin
            (draw-set-stroke-color! renderer alpha)
            (sdl/render-line! renderer x1 y1 x2 y2)
            (sdl/render-fill-rect! renderer
                                   (- x1 (/ size 2.0))
                                   (- y1 (/ size 2.0))
                                   size
                                   size)
            (sdl/render-fill-rect! renderer
                                   (- x2 (/ size 2.0))
                                   (- y2 (/ size 2.0))
                                   size
                                   size)
            true))))))

(defn draw-render-screen-rect!
  "Render a rectangle outline directly in screen coordinates."
  [renderer x y width height color size]
  (let [left x
        top y
        right (+ x width)
        bottom (+ y height)]
    (draw-render-screen-soft-segment! renderer color size left top right top)
    (draw-render-screen-soft-segment! renderer color size right top right bottom)
    (draw-render-screen-soft-segment! renderer color size right bottom left bottom)
    (draw-render-screen-soft-segment! renderer color size left bottom left top)))

(defn draw-render-box!
  "Render a box element."
  [renderer state box]
  (let [x (get box :x)
        y (get box :y)
        width (get box :width)
        height (get box :height)
        color (get box :color)
        size (max 1 (draw-exact-int (or (get box :size) 1)))
        screen-rect (draw-world-rect->screen-rect state x y width height)]
    (draw-render-screen-rect! renderer
                              (get screen-rect :x)
                              (get screen-rect :y)
                              (get screen-rect :width)
                              (get screen-rect :height)
                              color
                              size)))

(defn draw-frame-tab-width
  "Return the width of the frame header tab in world space."
  [state frame]
  (let [screen-width (max 28.0 72.0)
        world-width (/ screen-width (draw-view-zoom state))
        usable (- (get frame :width) (* 2.0 (get frame :size)))]
    (if (> usable world-width)
      world-width
      (max 0.0 usable))))

(defn draw-frame-tab-height
  "Return the height of the frame header tab in world space."
  [state frame]
  (/ 20.0 (draw-view-zoom state)))

(defn draw-render-frame!
  "Render a frame/container element."
  [renderer state frame]
  (let [x (get frame :x)
        y (get frame :y)
        width (get frame :width)
        height (get frame :height)
        color (get frame :color)
        size (get frame :size)
        tab-width (draw-frame-tab-width state frame)
        tab-height (draw-frame-tab-height state frame)
        screen-rect (draw-world-rect->screen-rect state x y width height)
        a [x y]
        tab-right (+ x tab-width)
        tab-bottom (+ y tab-height)]
    (draw-render-screen-rect! renderer
                              (get screen-rect :x)
                              (get screen-rect :y)
                              (get screen-rect :width)
                              (get screen-rect :height)
                              color
                              size)
    (if (> tab-width 0.0)
      (begin
        (draw-render-box-edge! renderer state color size a [tab-right y])
        (draw-render-box-edge! renderer state color size [x tab-bottom] [tab-right tab-bottom])
        (draw-render-box-edge! renderer state color size [tab-right y] [tab-right tab-bottom]))
      nil)))

(defn draw-render-text!
  "Render a text element using the built-in SDL debug font."
  [renderer state text-element]
  (let [screen-point (draw-world-point->screen-point
                       state
                       [(get text-element :x)
                        (get text-element :y)
                        1.0])
        color (or (get text-element :color) [245 245 245])
        text (or (get text-element :text) (draw-text-default-value))]
    (sdl/set-draw-color! renderer
                         (nth color 0)
                         (nth color 1)
                         (nth color 2)
                         255)
    (sdl/render-debug-text! renderer
                            (nth screen-point 0)
                            (nth screen-point 1)
                            text)))

(defn draw-arrow-head-length
  "Return the world-space arrowhead length for SIZE in STATE."
  [state size]
  (let [screen-length (max 12.0 (* size 4.0))]
    (/ screen-length (draw-view-zoom state))))

(defn draw-arrow-head-width
  "Return the world-space arrowhead width for SIZE in STATE."
  [state size]
  (* (draw-arrow-head-length state size) 0.55))

(defn draw-render-arrow!
  "Render an arrow element."
  [renderer state arrow]
  (let [start (get arrow :start)
        end (get arrow :end)
        size (get arrow :size)
        color (get arrow :color)
        dx (- (nth end 0) (nth start 0))
        dy (- (nth end 1) (nth start 1))
        length (math/sqrt (+ (* dx dx) (* dy dy)))]
    (if (<= length 0.0)
      (draw-with-stroke-color color
        (lambda ()
          (draw-render-stroke-point! renderer state end size)))
      (let [ux (/ dx length)
            uy (/ dy length)
            head-length (draw-arrow-head-length state size)
            head-width (draw-arrow-head-width state size)
            back-x (- (nth end 0) (* ux head-length))
            back-y (- (nth end 1) (* uy head-length))
            left [(+ back-x (* (- uy) head-width))
                  (+ back-y (* ux head-width))
                  1.0]
            right [(- back-x (* (- uy) head-width))
                   (- back-y (* ux head-width))
                   1.0]]
        (draw-with-stroke-color color
          (lambda ()
            (draw-render-stroke-segment! renderer state start end size)
            (draw-render-stroke-segment! renderer state left end size)
            (draw-render-stroke-segment! renderer state right end size)))))))

(defn draw-render-element!
  "Render a committed canvas element."
  [renderer state element]
  (if (draw-box-element? element)
    (draw-render-box! renderer state element)
    (if (draw-arrow-element? element)
      (draw-render-arrow! renderer state element)
      (if (draw-frame-element? element)
        (draw-render-frame! renderer state element)
        (if (draw-text-element? element)
          (draw-render-text! renderer state element)
          (draw-render-stroke! renderer state element))))))

(defn draw-render-active-box!
  "Render the current active box preview."
  [renderer state active-box]
  (draw-render-box! renderer
                    state
                    (draw-box-element active-box)))

(defn draw-render-active-arrow!
  "Render the current active arrow preview."
  [renderer state active-arrow]
  (draw-render-arrow! renderer
                      state
                      (assoc active-arrow :kind :arrow)))

(defn draw-render-active-frame!
  "Render the current active frame preview."
  [renderer state active-frame]
  (draw-render-frame! renderer
                      state
                      (draw-frame-element active-frame)))

(defn draw-render-active-text!
  "Render the current active text preview."
  [renderer state active-text]
  (draw-render-text! renderer
                     state
                     (draw-text-element active-text)))

(defn draw-render-selection-handles!
  "Render resize handles for the currently selected rectangle."
  [renderer state]
  (let [box (draw-single-selected-rectangle state)]
    (if box
      (let [rects (draw-selection-handle-screen-rects state box)
            color (draw-selection-color)]
        (sdl/set-draw-color! renderer
                             (nth color 0)
                             (nth color 1)
                             (nth color 2)
                             255)
                (reduce (fn [acc handle]
                  (let [rect (get rects handle)]
                    (sdl/render-fill-rect! renderer
                                           (get rect :x)
                                           (get rect :y)
                                           (get rect :width)
                                           (get rect :height))
                    acc))
                nil
                [:nw :ne :se :sw]))
      nil)))

(defn draw-render-selection!
  "Render selection bounds and handles for the current selection."
  [renderer state]
  (let [bounds (draw-selection-bounds state)]
    (if bounds
      (begin
        (draw-render-box! renderer
                          state
                          (draw-selection-outline-element bounds))
        (draw-render-selection-handles! renderer state))
      nil)))

(defn draw-preview-stroke!
  "Render STROKE into the preview texture."
  [state stroke]
  (draw-with-preview!
    (lambda (renderer)
      (draw-render-stroke! renderer state stroke)
      nil)))

(defn draw-preview-segment!
  "Render just the newest segment from PREVIOUS to POINT into the preview texture."
  [state previous point size color]
  (draw-with-preview!
    (lambda (renderer)
      (draw-with-stroke-color color
        (lambda ()
          (draw-render-stroke-segment! renderer state previous point size)))
      nil)))

(defn draw-preview-batch-render!
  "Render active stroke points from START-INDEX up to END-INDEX."
  [renderer state points start-index end-index size]
  (if (>= start-index end-index)
    nil
    (let [previous (nth points (- start-index 1))
          point (nth points start-index)]
      (draw-render-stroke-segment! renderer state previous point size)
      (draw-preview-batch-render! renderer
                                  state
                                  points
                                  (+ start-index 1)
                                  end-index
                                  size))))

(defn draw-sync-preview!
  "Render only the missing active-stroke segments into the preview texture."
  [state]
  (let [active (get state :active-stroke)]
    (if (and active (draw-preview-ready?))
      (let [points (get active :points)
            total (count points)
            rendered (if (and (integer? *draw-preview-point-count*)
                              (>= *draw-preview-point-count* 0)
                              (<= *draw-preview-point-count* total))
                       *draw-preview-point-count*
                       0)]
        (if (= rendered 0)
          (begin
            (draw-clear-preview!)
            (if (> total 0)
              (draw-with-preview!
                (lambda (renderer)
                  (draw-with-stroke-color (get active :color)
                    (lambda ()
                      (draw-render-stroke-point! renderer
                                                 state
                                                 (first points)
                                                 (get active :size))))))
              nil)
            (set! *draw-preview-point-count* (if (> total 0) 1 0)))
          nil)
        (if (< *draw-preview-point-count* total)
          (let [end-index (if (> (+ *draw-preview-point-count*
                                    (draw-preview-segment-budget))
                                 total)
                            total
                            (+ *draw-preview-point-count*
                               (draw-preview-segment-budget)))
                batch-count (- end-index *draw-preview-point-count*)]
            (if (> batch-count 0)
              (draw-with-preview!
                (lambda (renderer)
                  (draw-with-stroke-color (get active :color)
                    (lambda ()
                      (draw-preview-batch-render! renderer
                                                  state
                                                  points
                                                  *draw-preview-point-count*
                                                  end-index
                                                  (get active :size))))))
              nil)
            (set! *draw-preview-point-count* end-index))
          nil)
        true)
      (begin
        (if (> *draw-preview-point-count* 0)
          (draw-clear-preview!)
          nil)
        (draw-reset-preview-sync!)
        false))))

(defn draw-render-elements!
  "Render all committed elements plus active previews."
  [ctx state]
  (let [renderer (get ctx :renderer)
        elements (get state :elements)
        active-stroke (get state :active-stroke)
        active-box (get state :active-box)
        active-arrow (get state :active-arrow)
        active-frame (get state :active-frame)
        active-text (get state :active-text)]
    (reduce (fn [acc element]
              (begin
                (draw-render-element! renderer state element)
                acc))
            nil
            elements)
    (if active-stroke
      (draw-render-stroke! renderer state active-stroke)
      nil)
    (if active-box
      (draw-render-active-box! renderer state active-box)
      nil)
    (if active-arrow
      (draw-render-active-arrow! renderer state active-arrow)
      nil)
    (if active-frame
      (draw-render-active-frame! renderer state active-frame)
      nil)
    (if active-text
      (draw-render-active-text! renderer state active-text)
      nil)
    (draw-render-selection! renderer state)))

(defn draw-render-canvas!
  "Render the cached canvas texture, or fall back to stroke replay."
  [ctx state]
  (let [renderer (get ctx :renderer)
        canvas (if ctx (get ctx :canvas) nil)
        preview (if ctx (get ctx :preview) nil)
        active (get state :active-stroke)
        active-box (get state :active-box)
        active-arrow (get state :active-arrow)
        active-frame (get state :active-frame)
        active-text (get state :active-text)]
    (if (draw-canvas-ready?)
      (begin
        (sdl/render-texture! renderer canvas)
        (if (and active (draw-preview-ready?))
          (sdl/render-texture! renderer preview)
          (if active
            (draw-render-stroke! renderer state active)
            nil))
        (if active-box
          (draw-render-active-box! renderer state active-box)
          nil)
        (if active-arrow
          (draw-render-active-arrow! renderer state active-arrow)
          nil)
        (if active-frame
          (draw-render-active-frame! renderer state active-frame)
          nil)
        (if active-text
          (draw-render-active-text! renderer state active-text)
          nil)
        (draw-render-selection! renderer state)
        (if (and (not active) (draw-preview-ready?))
          nil
          nil))
      (draw-render-elements! ctx state))))

(defn draw-render-tool-panel-button!
  "Render BUTTON from the in-window tool panel."
  [renderer button]
  (let [active? (get button :active?)
        x (get button :x)
        y (get button :y)
        width (get button :width)
        height (get button :height)]
    (if active?
      (sdl/set-draw-color! renderer 70 110 170 255)
      (sdl/set-draw-color! renderer 46 50 60 235))
    (sdl/render-fill-rect! renderer x y width height)
    (sdl/set-draw-color! renderer 235 235 235 255)
    (sdl/render-debug-text! renderer (+ x 8) (+ y 6) (get button :label))
    nil))

(defn draw-render-tool-panel!
  "Render the toggleable in-window tool panel."
  [renderer state]
  (let [panel (draw-tool-panel-rect state)
        buttons (draw-tool-panel-buttons state)
        info-lines (draw-tool-panel-info-lines state)]
    (sdl/set-draw-color! renderer 18 20 26 228)
    (sdl/render-fill-rect! renderer
                           (get panel :x)
                           (get panel :y)
                           (get panel :width)
                           (get panel :height))
    (sdl/set-draw-color! renderer 235 235 235 255)
    (sdl/render-debug-text! renderer
                            (+ (get panel :x) 10)
                            (+ (get panel :y) 10)
                            "tool panel")
    (sdl/render-debug-text! renderer
                            (+ (get panel :x) 10)
                            (+ (get panel :y) 26)
                            (draw-selection-summary state))
    (reduce (fn [acc button]
              (begin
                (draw-render-tool-panel-button! renderer button)
                acc))
            nil
            buttons)
    (sdl/set-draw-color! renderer 210 210 210 255)
    (reduce (fn [next-y line]
              (begin
                (sdl/render-debug-text! renderer
                                        (+ (get panel :x) 10)
                                        next-y
                                        line)
                (+ next-y 16)))
            (+ (get panel :y) 228)
            info-lines)
    nil))

(defn draw-render-debug-panel!
  "Render the on-demand debug panel."
  [renderer state]
  (let [mouse-x (get state :mouse-x)
        mouse-y (get state :mouse-y)
        recent-lines (draw-debug-event-lines state)]
    (sdl/set-draw-color! renderer 245 245 245 255)
    (sdl/render-debug-text! renderer 12 12 (describe-state state))
    (sdl/render-debug-text! renderer 12 28
                            (format "mouse: %.1f, %.1f" mouse-x mouse-y))
    (sdl/render-debug-text! renderer 12 44
                            (format "view: %.1f, %.1f zoom: %.2f"
                                    (draw-view-x state)
                                    (draw-view-y state)
                                    (draw-view-zoom state)))
    (sdl/render-debug-text! renderer 12 60
                            (format "pointer: %s ink: %d rectangle: %s arrow: %s text: %s"
                                    (if (get state :pointer-down?) "down" "up")
                                    (if (get state :active-stroke)
                                      (count (get (get state :active-stroke) :points))
                                      0)
                                    (if (get state :active-box) "active" "idle")
                                    (if (get state :active-arrow) "active" "idle")
                                    (if (get state :active-text) "active" "idle")))
    (sdl/render-debug-text! renderer 12 76
                            (format "pan: %s cursor: %s"
                                    (if (get state :panning?) "on" "off")
                                    (name (draw-desired-cursor-kind state))))
    (sdl/render-debug-text! renderer 12 92
                            (format "tool: %s size: %d color: %s elements: %d selection: %d"
                                    (draw-tool-mode state)
                                    (get state :brush-size)
                                    (pr-str (draw-stroke-color state))
                                    (count (get state :elements))
                                    (count (draw-selected-element-ids state))))
    (sdl/render-debug-text! renderer 12 108
                            (format "undo history: %d"
                                    (count (get state :history))))
    (sdl/render-debug-text! renderer 12 124
                            (format "focus: %s pressure: %.2f"
                                    (if (get state :window-focused?) "on" "off")
                                    (or (get state :pen-pressure) 1.0)))
    (sdl/render-debug-text! renderer 12 140
                            (format "last key: %s" (or (get state :last-key) "")))
    (sdl/render-debug-text! renderer 12 156
                            (format "last key desc: %s"
                                    (draw-compact-event-text
                                      (or (get state :last-key-desc) ""))))
    (sdl/render-debug-text! renderer 12 172
                            (format "last text: %s"
                                    (draw-truncate-text (or (get state :last-text) "") 48)))
    (sdl/render-debug-text! renderer 12 188
                            (format "last event: %s"
                                    (draw-compact-event-text
                                      (or (get state :last-event) ""))))
    (sdl/render-debug-text! renderer 12 204
                            (format "last error: %s"
                                    (if *draw-last-error*
                                      (draw-truncate-text (format "%s" *draw-last-error*) 88)
                                      "")))
    (when (not (empty? recent-lines))
      (sdl/render-debug-text! renderer 12 220 "recent events:")
      (draw-render-debug-lines! renderer 236 recent-lines))
    (draw-render-debug-lines!
      renderer
      (+ 236 (* 16 (count recent-lines)))
      (draw-debug-control-lines))
    nil))

(defn draw-debug-control-lines
  "Return the fixed debug-panel help lines."
  []
  ["controls:"
   "  wheel: zoom at pointer"
   "  ctrl +/-: zoom at pointer"
   "  space+drag: pan"
   "  cursors: crosshair draw, move select, resize handles, text tool"
   "  drag: draw / move selection"
   "  rectangle handles: resize selected rectangle"
   "  shift+click: add to selection"
   "  i: ink   t: text   v: select   r: rectangle   a: arrow"
   "  mouse/pen: pressure-sensitive strokes"
   "  u: undo   c: clear   e: eraser"
   "  1/2/3: brush size"
   "  d: debug panel   tab: tool panel   0: reset view"
   "  ctrl+s: save   ctrl+o: load"
   "  repl: save-canvas!, load-canvas!, restart-dev!"
   "  repl: (draw-log-tail 20), draw-clear-log!, dump-current-state!"
   "  repl: draw-simulate-input!, draw-replay-live!"
   "  repl: draw-replay-benchmark!, draw-replay-live-benchmark!"])

(defn draw-debug-event-lines
  "Return compact recent event lines for the debug overlay."
  [state]
  (let [recent (reverse (take (draw-debug-event-lines-limit)
                              (get state :recent-events)))]
    (map-indexed (fn [index line]
                   (format "  %d: %s"
                           (+ index 1)
                           (draw-compact-event-text line)))
                 recent)))

(defn draw-render-debug-lines!
  "Render LINES in the debug overlay starting at Y."
  [renderer y lines]
  (reduce (lambda (next-y line)
            (begin
              (sdl/render-debug-text! renderer 12 next-y line)
              (+ next-y 16)))
          y
          lines))

(defn draw-render-status!
  "Render the text overlay and mouse marker for STATE."
  [ctx state]
  (let [renderer (get ctx :renderer)
        mouse-x (get state :mouse-x)
        mouse-y (get state :mouse-y)
        pressure (or (get state :pen-pressure) 1.0)
        marker-point [mouse-x mouse-y pressure]]
    (sdl/set-draw-color! renderer 220 180 90 255)
    (draw-render-stroke-point! renderer state marker-point 3)
    (if (get state :tool-panel?)
      (draw-render-tool-panel! renderer state)
      nil)
    (if (get state :debug-panel?)
      (draw-render-debug-panel! renderer state)
      nil)
    nil))

(defn draw-loop-step!
  "Drain input and render once when the window is active."
  []
  (draw-with-lock
    (lambda ()
      (draw-write-heartbeat! :poll *draw-state*)
      (draw-poll-control!)
      (draw-poll-input!)
      (draw-write-heartbeat! :render *draw-state*)
      (if *draw-state*
        (let [state (draw-render-current!)]
          (draw-write-state-file! state false)
          (draw-write-heartbeat! :idle state)
          state)
        *draw-state*))))

(defn default-render-frame
  "Clear and present one frame using STATE."
  [ctx state]
  (let [renderer (get ctx :renderer)
        background (get state :background)]
    (sdl/set-draw-color!
      renderer
      (nth background 0)
      (nth background 1)
      (nth background 2)
      255)
    (sdl/render-clear! renderer)
    (draw-render-canvas! ctx state)
    (draw-render-status! ctx state)
    (sdl/render-present! renderer)
    nil))

(defn render-frame
  "Clear and present one frame."
  [ctx state]
  (if *draw-render-fn*
    (*draw-render-fn* ctx state)
    (default-render-frame ctx state)))

(defn render-now!
  "Render one frame from the current state."
  []
  (draw-with-lock
    (lambda ()
      (if (draw-supervised-mode?)
        (draw-write-control-command! :redraw {:reason :manual})
        (begin
          (draw-poll-input!)
          (draw-render-current!))))))

(defn draw-loop
  "Render until the window is closed or the loop is stopped."
  []
  (handle-exceptions exn
    (draw-crash! exn)
    (if *draw-running?*
      (begin
        (draw-loop-step!)
        (if *draw-running?*
          (begin
            (thread-sleep! 0.016)
            (draw-loop))
          nil))
      nil)))

(defn start!
  "Open the SDL window and prepare the draw state."
  []
  (draw-with-lock
    (lambda ()
      (if (and *draw-running?* *draw-context*)
        *draw-context*
        (begin
          (if *draw-child-mode?*
            (draw-log-entry! :child-start-enter
                             {:state (draw-state-snapshot *draw-state*)})
            nil)
          (if (not (init-video!))
            (begin
              (if *draw-child-mode?*
                (draw-log-entry! :child-init-video-failed {:error (last-error)})
                nil)
              (println (format "SDL init failed: %s" (last-error)))
              nil)
            (let [state (if *draw-state*
                          (assoc *draw-state*
                                 :window-focused? true
                                 :pen-pressure 1.0)
                          (default-state))
                  ctx (sdl/open-context (get state :title)
                                        (get state :width)
                                        (get state :height))]
              (if (nil? ctx)
                (begin
                  (if *draw-child-mode?*
                    (draw-log-entry! :child-open-context-failed {:error (last-error)})
                    nil)
                  (println (format "SDL window failed: %s" (last-error)))
                  (shutdown!)
                  nil)
                (begin
                  (if *draw-child-mode?*
                    (draw-log-entry! :child-open-context-ok {:title (get state :title)})
                    nil)
                  (set! *draw-state* state)
                  (set! *draw-context* (assoc ctx :cursor-cache {} :cursor-kind false))
                  (set! *draw-running?* true)
                  (set! *draw-last-heartbeat-at* 0)
                  (draw-clear-watchdog-files!)
                  (draw-log-entry! :start
                                   {:state (draw-state-snapshot state)
                                    :log (draw-log-file-path)
                                    :crash (draw-crash-file-path)
                                    :heartbeat (draw-heartbeat-file-path)
                                    :stall (draw-stall-file-path)})
                  (draw-ensure-canvas! state)
                  (draw-ensure-preview! state)
                  (draw-ensure-brush-texture! state)
                  (draw-ensure-strip-texture! state)
                  (if (draw-canvas-ready?)
                    (draw-rebuild-canvas! state)
                    nil)
                  (draw-reset-preview-sync!)
                  (draw-clear-preview!)
                  (draw-write-state-file! state true)
                  (draw-write-heartbeat! :start state)
                  (draw-start-watchdog!)
                  (sync-window-title!)
                  ctx)))))))))

(defn draw-stop-local!
  "Stop the local draw loop and close the SDL context."
  []
  (draw-with-lock
    (lambda ()
      (draw-write-state-file! *draw-state* true)
      (draw-write-heartbeat! :stop *draw-state*)
      (draw-log-entry! :stop {:state (draw-state-snapshot *draw-state*)})
      (set! *draw-running?* false)
      (draw-stop-watchdog!)
      (draw-release-canvas!)
      (draw-release-preview!)
      (draw-release-brush-texture!)
      (draw-release-strip-texture!)
      (draw-release-cursors!)
      (if *draw-context*
        (begin
          (sdl/close-context! *draw-context*)
          (set! *draw-context* nil)))
      (set! *draw-thread* nil)
      (set! *draw-last-heartbeat-at* 0)
      (shutdown!)
      nil)))

(defn draw-start-local-dev!
  "Start the SDL window and background loop in the current process."
  []
  (if (and *draw-running?* *draw-context*)
    *draw-context*
    (begin
      (when *draw-context*
        (draw-stop-local!))
      (draw-clear-error!)
      (let [ctx (start!)]
      (if ctx
        (begin
          (render-now!)
          (set! *draw-thread*
                (make-thread
                  (lambda ()
                    (draw-loop))
                  "cluck-draw"))
          (thread-start! *draw-thread*)
          ctx)
        nil)))))

(defn draw-supervisor-launch-child!
  "Start the child draw process and return its pid."
  []
  (let [root (current-directory)
        runner (draw-child-runner-path)
        child-log (draw-child-stdout-path)
        launcher (format "cd %s && exec csi -q -s %s > %s 2>&1"
                         (proc/qs root)
                         (proc/qs runner)
                         (proc/qs child-log))
        pid (cproc:process-run "/bin/sh" (list "-c" launcher))]
    (set! *draw-child-pid* pid)
    pid))

(defn draw-supervisor-stop-child!
  "Stop the supervised child process when it is running."
  []
  (let [pid *draw-child-pid*]
    (set! *draw-child-pid* false)
    (if pid
      (proc/system
        (format "kill %s >/dev/null 2>&1 || true"
                (proc/qs (str pid))))
      0)
    nil))

(defn draw-heartbeat-age-ms
  "Return the age of the child heartbeat in milliseconds, or false."
  []
  (let [path (draw-heartbeat-file-path)]
    (if (fs/file? path)
      (let [heartbeat (edn/read-string (io/slurp path))
            at (or (get heartbeat :at) 0)]
        (if (> at 0)
          (- (draw-wall-clock-ms) at)
          false))
      false)))

(defn draw-wait-for-child-ready!
  "Wait until the supervised child writes its first heartbeat, or time out."
  [deadline-ms]
  (cond
    (fs/file? (draw-heartbeat-file-path))
    true

    (not *draw-running?*)
    false

    (and *draw-child-pid*
         (not (draw-child-alive? *draw-child-pid*)))
    false

    (> (draw-wall-clock-ms) deadline-ms)
    false

    :else
    (begin
      (thread-sleep! 0.1)
      (draw-wait-for-child-ready! deadline-ms))))

(defn draw-start-supervisor-loop!
  "Start the parent-side thread that restarts a dead or stale child."
  []
  (set! *draw-thread* nil)
  (set! *draw-supervisor-thread*
        (make-thread
          (lambda ()
            (handle-exceptions exn
              (draw-log-entry! :supervisor-crash
                               {:error (format "%s" exn)
                                :state (draw-state-snapshot *draw-state*)})
              (let loop ()
                (if (draw-supervised-mode?)
                  (begin
                    (let [pid *draw-child-pid*
                          age (draw-heartbeat-age-ms)]
                      (cond
                        (not pid)
                        (begin
                          (draw-log-entry! :supervisor-restart {:reason :missing-pid})
                          (draw-supervisor-launch-child!))

                        (not (draw-child-alive? pid))
                        (begin
                          (draw-log-entry! :supervisor-restart {:reason :child-exit :pid pid})
                          (draw-supervisor-launch-child!))

                        (and age (> age (draw-watchdog-stale-ms)))
                        (begin
                          (draw-log-entry! :supervisor-restart
                                           {:reason :stale-heartbeat
                                            :pid pid
                                            :age-ms age})
                          (draw-supervisor-stop-child!)
                          (draw-supervisor-launch-child!))

                        :else
                        nil))
                    (thread-sleep! (/ (draw-supervisor-poll-ms) 1000.0))
                    (loop))
                  nil))))
          "cluck-draw-supervisor"))
  (thread-start! *draw-supervisor-thread*)
  *draw-supervisor-thread*)

(defn draw-stop-supervisor-loop!
  "Stop the parent-side supervisor thread."
  []
  (let [thread *draw-supervisor-thread*]
    (set! *draw-supervisor-thread* nil)
    (if thread
      (thread-terminate! thread)
      false)
    nil))

(defn draw-start-supervised-dev!
  "Start the draw child process and the parent supervisor thread."
  []
  (draw-with-lock
    (lambda ()
      (set! *draw-state* (or *draw-state* (default-state)))
      (set! *draw-running?* true)
      (set! *draw-control-seq* 0)
      (set! *draw-last-control-seq* 0)
      (set! *draw-last-heartbeat-at* 0)
      (set! *draw-last-state-sync-at* 0)
      (draw-clear-error!)
      (draw-clear-control-file!)
      (draw-clear-watchdog-files!)
      (draw-write-state-file! *draw-state* true)
      (draw-log-entry! :supervised-start
                       {:state (draw-state-snapshot *draw-state*)
                        :child-log (draw-child-stdout-path)
                        :control (draw-control-file-path)})
      (let [pid (draw-supervisor-launch-child!)]
        (if pid
          (let [deadline (+ (draw-wall-clock-ms) 15000)]
            (begin
              (draw-start-supervisor-loop!)
              (if (draw-wait-for-child-ready! deadline)
                {:pid pid :mode :supervised}
                (begin
                  (draw-log-entry! :supervised-start-failed
                                   {:pid pid
                                    :child-log (draw-child-stdout-path)
                                    :heartbeat (draw-heartbeat-file-path)})
                  (set! *draw-running?* false)
                  (draw-stop-supervisor-loop!)
                  (draw-supervisor-stop-child!)
                  false))))
          (begin
            (set! *draw-running?* false)
            false))))))

(defn stop!
  "Stop the supervised child or the local draw loop."
  []
  (if (draw-supervised-mode?)
    (draw-with-lock
      (lambda ()
        (draw-log-entry! :supervised-stop {:state (draw-state-snapshot (current-state))})
        (set! *draw-running?* false)
        (draw-write-control-command! :stop {})
        (draw-stop-supervisor-loop!)
        (draw-supervisor-stop-child!)
        nil))
    (draw-stop-local!)))

(defn start-dev!
  "Start the draw app in supervised mode, or locally when supervision is disabled."
  []
  (if (draw-supervised-mode?)
    (draw-start-supervised-dev!)
    (draw-start-local-dev!)))

(defn restart-dev!
  "Restart the development window after a crash or reset."
  []
  (draw-log-entry! :restart {:state (draw-state-snapshot *draw-state*)})
  (stop!)
  (reset-state!)
  (draw-clear-error!)
  (start-dev!))

(defn run-loop
  "Run until SDL asks us to quit."
  [ctx state]
  (if *draw-running?*
    (begin
      (draw-loop-step!)
      (if *draw-running?*
        (begin
          (delay-ms 16)
          (run-loop ctx state))
        nil))
    nil))

(defn draw-child-main
  "Run the draw window in child-process mode."
  []
  (set! *draw-child-mode?* true)
  (set! *draw-supervision-enabled?* false)
  (draw-log-entry! :child-main-enter {:cwd (current-directory)})
  (set! *draw-state* (or (draw-read-state-file)
                         *draw-state*
                         (default-state)))
  (set! *draw-last-control-seq* 0)
  (draw-clear-error!)
  (let [ctx (start!)]
    (if ctx
      (begin
        (draw-log-entry! :child-main-started {:state (draw-state-snapshot *draw-state*)})
        (render-now!)
        (run-loop ctx *draw-state*)
        (draw-stop-local!))
      (begin
        (draw-log-entry! :child-main-start-returned-nil {:error (last-error)})
        nil))))

(defn main
  "Open a window and run the minimal SDL3 loop."
  [args]
  (set! *draw-state* (default-state))
  (if (member "--repl" args)
    (begin
      (if (start-dev!)
        (begin
          (println (format "Opened %s" (describe-state *draw-state*)))
          (println (format "Hint: %s" (str/upper-case "use the repl to change state")))
          (println (format "Hint: %s" (str/upper-case "call (stop!) or close the window to quit")))
          (cluck-repl)
          (stop!))
        nil))
    (let [state (current-state)]
      (if (not (init-video!))
        (begin
          (println (format "SDL init failed: %s" (last-error)))
          nil)
        (let [ctx (sdl/open-context (get state :title)
                                    (get state :width)
                                    (get state :height))]
          (if (nil? ctx)
            (begin
              (println (format "SDL window failed: %s" (last-error)))
              (shutdown!)
              nil)
            (begin
              (println (format "Opened %s" (describe-state state)))
              (println (format "Hint: %s" (str/upper-case "close the window to quit")))
              (run-loop ctx state)
              (sdl/close-context! ctx)
              (shutdown!)
              nil)))))))

(comment
  
  (load-file "examples/cluck/draw/dev.clk")
  (draw-clear-log!)
  (draw-clear-watchdog-files!)
  (start-dev!)

  (draw-log-tail 50)
  (dump-current-state!)
  (draw-watchdog-status)

  (default-state)
  (describe-state (default-state))
  (draw-clear-strokes! (default-state))
  (draw-undo-stroke! (default-state))
  (draw-set-brush-size! (default-state) 6)
  (draw-toggle-eraser! (default-state))
  (restart-dev!)
  (draw-toggle-debug-panel! (current-state))
  (main ["--help"]))
