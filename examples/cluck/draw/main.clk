(def *draw-heartbeat-path* false)
(def *draw-stall-path* false)
(def *draw-stall-sample-path* false)
(def *draw-watchdog-enabled?* true)
(def *draw-watchdog-pid* false)
(def *draw-last-heartbeat-at* 0)
(def *draw-last-state-sync-at* 0)
(def *draw-child-mode?* false)
(def *draw-supervision-enabled?* true)
(def *draw-supervisor-thread* nil)
(def *draw-child-pid* false)
(def *draw-control-seq* 0)
