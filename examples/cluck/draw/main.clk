;; SDL3 drawing app spike for Cluck.
;;
;; The app stays in Cluck syntax. The SDL3 bindings and extracted pure helper
;; namespaces live under src/cluck/examples/draw/, keeping this entrypoint
;; focused on orchestration and the live draw loop.

(ns cluck.examples.draw
  (:require [cluck.examples.draw.sdl3 :as sdl]
            [cluck.examples.draw.state :as draw-state]
            [cluck.examples.draw.history :as draw-history]
            [cluck.examples.draw.view :as draw-view]
            [cluck.examples.draw.panel :as draw-panel]
            [cluck.examples.draw.geometry :as draw-geometry]
            [cluck.examples.draw.selection :as draw-selection]
            [cluck.examples.draw.edit :as draw-edit]
            [cluck.examples.draw.create :as draw-create]
            [cluck.examples.draw.status :as draw-status]
            [cluck.examples.draw.stroke :as draw-stroke]
            [cluck.examples.draw.input :as draw-input]
            [cluck.fs :as fs]
            [cluck.io :as io]
            [cluck.process :as proc]
            [cluck.edn :as edn]
            [cluck.math :as math]
            [cluck.string :as str]))

(import srfi-18
        (prefix (chicken file) cfile:)
        (chicken time)
        (prefix (chicken process) cproc:)
        (prefix (chicken process-context posix) posix:))

