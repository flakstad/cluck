;; Focused draw-input probe for the SDL3 example.

(in-ns 'cluck.examples.draw)

(define (draw-input-pass label)
  (println "ok" label)
  true)

(define (draw-input-fail label expected actual)
  (error (string-append "draw input test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (draw-input-assert-true label value)
  (if value
      (draw-input-pass label)
      (draw-input-fail label "truthy value" (pr-str value))))

(define (draw-input-assert-false label value)
  (if (not value)
      (draw-input-pass label)
      (draw-input-fail label "falsey value" (pr-str value))))

(define (draw-input-assert-str= label expected actual)
  (if (string=? expected actual)
      (draw-input-pass label)
      (draw-input-fail label expected actual)))

(define (draw-input-assert-num= label expected actual)
  (if (= expected actual)
      (draw-input-pass label)
      (draw-input-fail label expected actual)))

(define (draw-input-has-line? lines target)
  (reduce (lambda (found line)
            (or found (string=? line target)))
          false
          lines))

(define (draw-input-copy-state state)
  (edn/read-string (pr-str state)))

(define (draw-input-find-button-kind buttons kind)
  (reduce (lambda (found button)
            (if found
                found
                (if (draw-kind=? (get button :kind) kind)
                    button
                    false)))
          false
          buttons))

(draw-input-assert-true "draw namespace exists" (find-ns 'cluck.examples.draw))
(draw-input-assert-true "focus gained event kind"
                        (draw-kind=? (draw-event-kind "SDL_EVENT_WINDOW_FOCUS_GAINED")
                                     :focus-gained))
(draw-input-assert-true "focus lost event kind"
                        (draw-kind=? (draw-event-kind "SDL_EVENT_WINDOW_FOCUS_LOST")
                                     :focus-lost))
(draw-input-assert-true "mouse enter event kind"
                        (draw-kind=? (draw-event-kind "SDL_EVENT_WINDOW_MOUSE_ENTER")
                                     :mouse-enter))
(draw-input-assert-true "mouse leave event kind"
                        (draw-kind=? (draw-event-kind "SDL_EVENT_WINDOW_MOUSE_LEAVE")
                                     :mouse-leave))
(draw-input-assert-true "pen axis event kind"
                        (draw-kind=? (draw-event-kind "SDL_EVENT_PEN_AXIS")
                                     :pen-axis))
(draw-input-assert-true "mouse wheel event kind"
                        (draw-kind=? (draw-event-kind "SDL_EVENT_MOUSE_WHEEL")
                                     :mouse-wheel))
(draw-input-assert-true "synthetic pen mouse detection"
                        (draw-synthetic-pen-mouse-event?
                         {:kind :mouse-down
                          :desc "SDL_EVENT_MOUSE_BUTTON_DOWN which=4294967294"}))
(draw-input-assert-false "normal mouse event is not synthetic pen"
                         (draw-synthetic-pen-mouse-event?
                          {:kind :mouse-down
                           :desc "SDL_EVENT_MOUSE_BUTTON_DOWN which=0"}))

(let [lines (draw-debug-control-lines)]
  (draw-input-assert-true "debug panel lists wheel zoom"
                          (draw-input-has-line? lines "  wheel: zoom at pointer"))
  (draw-input-assert-true "debug panel lists ctrl zoom"
                          (draw-input-has-line? lines "  ctrl +/-: zoom at pointer"))
  (draw-input-assert-true "debug panel lists space pan"
                          (draw-input-has-line? lines "  space+drag: pan"))
  (draw-input-assert-true "debug panel lists cursors"
                          (draw-input-has-line? lines "  cursors: crosshair draw/rotate, move select, resize handles"))
  (draw-input-assert-true "debug panel lists draw"
                          (draw-input-has-line? lines "  drag: draw / move selection"))
  (draw-input-assert-true "debug panel lists rectangle resize"
                          (draw-input-has-line? lines "  rectangle handles: resize corners, rotate top handle"))
  (draw-input-assert-true "debug panel lists shift selection"
                          (draw-input-has-line? lines "  shift+click: add to selection"))
  (draw-input-assert-true "debug panel lists tools"
                          (draw-input-has-line? lines "  1: ink   2: select   3: rectangle   4: eraser"))
  (draw-input-assert-true "debug panel lists brush sizes"
                          (draw-input-has-line? lines "  ctrl+1/2/3: brush sizes"))
  (draw-input-assert-true "debug panel lists color swatches"
                          (draw-input-has-line? lines "  brush/background swatches in the tool panel"))
  (draw-input-assert-true "debug panel lists pressure"
                          (draw-input-has-line? lines "  mouse/pen: pressure-sensitive strokes"))
  (draw-input-assert-true "debug panel lists undo"
                          (draw-input-has-line? lines "  u: undo   c: clear   e: eraser"))
  (draw-input-assert-true "debug panel lists tool panel"
                          (draw-input-has-line? lines "  d: debug panel   tab: tool panel   0: reset view"))
  (draw-input-assert-true "debug panel lists save load shortcuts"
                          (draw-input-has-line? lines "  ctrl+s: save   ctrl+o: load"))
  (draw-input-assert-true "debug panel lists repl helpers"
                          (draw-input-has-line? lines "  repl: save-canvas!, load-canvas!, restart-dev!")))

(let [lines (draw-tool-panel-info-lines (default-state))]
  (draw-input-assert-true "tool panel lists save file"
                          (draw-input-has-line? lines "file: cluck-draw-state.edn"))
  (draw-input-assert-true "tool panel lists edn format"
                          (draw-input-has-line? lines "format: EDN"))
  (draw-input-assert-true "tool panel lists brush sizes"
                          (draw-input-has-line? lines "ctrl+1/2/3 brush sizes"))
  (draw-input-assert-true "tool panel lists color swatches"
                          (draw-input-has-line? lines "brush/background swatches below"))
  (draw-input-assert-true "tool panel lists save shortcut"
                          (draw-input-has-line? lines "TAB toggle  CTRL+S save"))
  (draw-input-assert-true "tool panel lists load shortcut"
                          (draw-input-has-line? lines "CTRL+O load")))

(let [original-set-title sdl/set-window-title!
      captured false]
  (set! *draw-context* {:window :fake})
  (set! *draw-state* (assoc (default-state) :title "Mutated"))
  (set! sdl/set-window-title!
        (lambda (window title)
          (set! captured title)
          true))
  (sync-window-title!)
  (draw-input-assert-str= "window title stays static"
                          "Cluck Draw"
                          captured)
  (set! sdl/set-window-title! original-set-title))

(let [panel-state (assoc (default-state) :tool-panel? true)
      buttons (draw-tool-panel-buttons panel-state)
      brush-button (draw-input-find-button-kind buttons :brush-color)
      background-button (draw-input-find-button-kind buttons :background-color)]
  (draw-input-assert-true "tool panel includes brush color swatches"
                          brush-button)
  (draw-input-assert-true "tool panel includes background color swatches"
                          background-button)
  (draw-input-assert-true "tool panel hit finds brush color swatch"
                          (draw-kind=? (get (draw-find-tool-panel-button
                                              panel-state
                                              [(+ (get brush-button :x) 1)
                                               (+ (get brush-button :y) 1)])
                                            :kind)
                                       :brush-color))
  (draw-input-assert-true "tool panel hit finds background color swatch"
                          (draw-kind=? (get (draw-find-tool-panel-button
                                              panel-state
                                              [(+ (get background-button :x) 1)
                                               (+ (get background-button :y) 1)])
                                            :kind)
                                       :background-color)))

(let [lines (draw-tool-panel-selection-lines (default-state))]
  (draw-input-assert-true "tool panel selection lines mention no selection"
                          (draw-input-has-line? lines "actions: none selected"))
  (draw-input-assert-true "tool panel selection lines mention canvas"
                          (draw-input-has-line? lines "canvas: drag to draw")))

(let [lines (draw-tool-panel-selection-lines
              (draw-set-tool-core! (default-state) :select))]
  (draw-input-assert-true "tool panel selection lines mention marquee"
                          (draw-input-has-line? lines "canvas: drag empty space to marquee select")))

(let [state (assoc (draw-sync-elements
                     (draw-set-tool-core! (default-state) :select)
                     [{:kind :box
                       :x 10.0
                       :y 20.0
                       :width 30.0
                       :height 40.0
                       :color [255 255 255]
                       :size 2}])
                    :selection [1])
      lines (draw-tool-panel-selection-lines state)]
  (draw-input-assert-true "tool panel selection lines mention rectangle move"
                          (draw-input-has-line? lines "actions: move rectangle"))
  (draw-input-assert-true "tool panel selection lines mention rotate handle"
                          (draw-input-has-line? lines "handles: corners resize, top rotates")))

(let [state (assoc (draw-sync-elements
                     (draw-set-tool-core! (default-state) :select)
                     [{:kind :arrow
                       :start [10.0 20.0 1.0]
                       :end [40.0 60.0 1.0]
                       :color [255 255 255]
                       :size 2}])
                    :selection [1])
      lines (draw-tool-panel-selection-lines state)]
  (draw-input-assert-true "tool panel selection lines mention arrow move"
                          (draw-input-has-line? lines "actions: move arrow"))
  (draw-input-assert-true "tool panel selection lines mention arrow handles"
                          (draw-input-has-line? lines "handles: drag endpoints")))

(let [mouse-point (draw-event-point (default-state)
                                    "SDL_EVENT_MOUSE_MOTION x=12.0 y=34.0")]
  (draw-input-assert-str= "mouse point pressure defaults to 1"
                          "[12.0 34.0 1.0]"
                          (pr-str mouse-point)))

(let [pen-point (draw-event-point (assoc (default-state)
                                         :pen-pressure 0.5)
                                  "SDL_EVENT_PEN_MOTION x=12.0 y=34.0")]
  (draw-input-assert-str= "pen point carries pressure"
                          "[12.0 34.0 0.5]"
                          (pr-str pen-point)))

(let [original-pen-pressure sdl/event-pen-pressure]
  (set! sdl/event-pen-pressure
        (lambda ()
          0.37))
  (let [event (draw-build-input-event (default-state)
                                      "SDL_EVENT_PEN_AXIS x=12.0 y=34.0")]
    (draw-input-assert-num= "pen axis event reads live SDL pressure"
                            0.37
                            (get event :pressure)))
  (set! sdl/event-pen-pressure original-pen-pressure))

(draw-input-assert-true "pressure scales brush size"
                        (< (draw-point-size [10 20 0.25] 4)
                           (draw-point-size [10 20 1.0] 4)))

(draw-input-assert-true "pressure scales brush alpha"
                        (< (draw-point-alpha [10 20 0.25])
                           (draw-point-alpha [10 20 1.0])))

(let [focused (draw-focus-lost-core!
               (assoc (default-state)
                      :pointer-down? true
                      :active-stroke {:points [[1 2 1.0]]
                                      :color [1 2 3]
                                      :size 2}
                      :pen-pressure 0.4))]
  (draw-input-assert-false "focus lost clears pointer down"
                           (get focused :pointer-down?))
  (draw-input-assert-false "focus lost clears active stroke"
                           (get focused :active-stroke))
  (draw-input-assert-false "focus lost turns focus off"
                           (get focused :window-focused?))
  (draw-input-assert-false "focus lost clears panning"
                           (get focused :panning?))
  (draw-input-assert-true "focus lost marks canvas dirty"
                          (get focused :canvas-dirty?))
  (draw-input-assert-num= "focus lost resets pressure"
                          1.0
                          (get focused :pen-pressure)))

(let [gained (draw-focus-gained-core! (assoc (default-state) :window-focused? false))]
  (draw-input-assert-true "focus gained turns focus on"
                          (get gained :window-focused?))
  (draw-input-assert-num= "focus gained resets pressure"
                          1.0
                          (get gained :pen-pressure)))

(let [space-down (draw-input-copy-state
                   (draw-apply-input-event! (default-state)
                                            {:kind :key-down
                                             :key "Space"
                                             :desc "SDL_EVENT_KEY_DOWN key=Space"
                                             :ctrl? false}))
      panning (draw-input-copy-state
                (draw-apply-input-event! space-down
                                         {:kind :mouse-down
                                          :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=100.0 y=100.0"
                                          :mouse-x 100.0
                                          :mouse-y 100.0
                                          :pressure 1.0
                                          :shift? false}))
      dragged (draw-input-copy-state
                (draw-apply-input-event! panning
                                         {:kind :mouse-motion
                                          :desc "SDL_EVENT_MOUSE_MOTION x=140.0 y=130.0"
                                          :mouse-x 140.0
                                          :mouse-y 130.0
                                          :pressure 1.0
                                          :shift? false}))
      finished (draw-input-copy-state
                 (draw-apply-input-event! dragged
                                          {:kind :mouse-up
                                           :desc "SDL_EVENT_MOUSE_BUTTON_UP x=140.0 y=130.0"
                                           :mouse-x 140.0
                                           :mouse-y 130.0
                                           :pressure 1.0
                                           :shift? false}))
      space-up (draw-input-copy-state
                 (draw-apply-input-event! finished
                                          {:kind :key-up
                                           :key "Space"
                                           :desc "SDL_EVENT_KEY_UP key=Space"
                                           :ctrl? false}))]
  (draw-input-assert-true "space key enables pan mode"
                          (get panning :panning?))
  (draw-input-assert-num= "space drag changes view-x"
                          -40.0
                          (draw-view-x dragged))
  (draw-input-assert-num= "space drag changes view-y"
                          -30.0
                          (draw-view-y dragged))
  (draw-input-assert-false "mouse up ends panning"
                           (get finished :panning?))
  (draw-input-assert-false "space up clears modifier"
                           (get space-up :space-down?)))

(let [zoomed (draw-apply-input-event! (assoc (default-state)
                                             :mouse-screen-x 120.0
                                             :mouse-screen-y 80.0)
                                      {:kind :key-down
                                       :key "="
                                       :desc "SDL_EVENT_KEY_DOWN key=="
                                       :ctrl? true})]
  (draw-input-assert-true "ctrl plus zooms"
                          (> (draw-view-zoom zoomed) 1.0)))

(let [base (assoc (default-state)
                  :mouse-screen-x 320.0
                  :mouse-screen-y 180.0)
      zoomed (draw-input-copy-state
               (draw-apply-input-event! base
                                        {:kind :key-down
                                         :key "="
                                         :desc "SDL_EVENT_KEY_DOWN key=="
                                         :ctrl? true}))
      space-down (draw-input-copy-state
                   (draw-apply-input-event! zoomed
                                            {:kind :key-down
                                             :key "Space"
                                             :desc "SDL_EVENT_KEY_DOWN key=Space"
                                             :ctrl? false}))
      panning (draw-input-copy-state
                (draw-apply-input-event! space-down
                                         {:kind :mouse-down
                                          :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=320.0 y=180.0"
                                          :mouse-x 320.0
                                          :mouse-y 180.0
                                          :pressure 1.0
                                          :shift? false}))
      dragged (draw-input-copy-state
                (draw-apply-input-event! panning
                                         {:kind :mouse-motion
                                          :desc "SDL_EVENT_MOUSE_MOTION x=360.0 y=210.0"
                                          :mouse-x 360.0
                                          :mouse-y 210.0
                                          :pressure 1.0
                                          :shift? false}))
      pan-finished (draw-input-copy-state
                     (draw-apply-input-event! dragged
                                              {:kind :mouse-up
                                               :desc "SDL_EVENT_MOUSE_BUTTON_UP x=360.0 y=210.0"
                                               :mouse-x 360.0
                                               :mouse-y 210.0
                                               :pressure 1.0
                                               :shift? false}))
      ready (draw-input-copy-state
              (draw-apply-input-event! pan-finished
                                       {:kind :key-up
                                        :key "Space"
                                        :desc "SDL_EVENT_KEY_UP key=Space"
                                        :ctrl? false}))
      start-screen [460.0 260.0 1.0]
      end-screen [520.0 320.0 1.0]
      expected-start (draw-screen-point->world-point ready start-screen)
      expected-end (draw-screen-point->world-point ready end-screen)
      started (draw-input-copy-state
                (draw-apply-input-event! ready
                                         {:kind :mouse-down
                                          :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=460.0 y=260.0"
                                          :mouse-x 460.0
                                          :mouse-y 260.0
                                          :pressure 1.0
                                          :shift? false}))
      finished (draw-input-copy-state
                 (draw-apply-input-event! started
                                          {:kind :mouse-up
                                           :desc "SDL_EVENT_MOUSE_BUTTON_UP x=520.0 y=320.0"
                                           :mouse-x 520.0
                                           :mouse-y 320.0
                                           :pressure 1.0
                                           :shift? false}))
      stroke (first (get finished :strokes))]
  (draw-input-assert-str= "zoom pan draw keeps transformed start point"
                          (pr-str expected-start)
                          (pr-str (first (get stroke :points))))
  (draw-input-assert-str= "zoom pan draw keeps transformed end point"
                          (pr-str expected-end)
                          (pr-str (last (get stroke :points)))))

(let [panel-on (draw-apply-input-event! (default-state)
                                        {:kind :key-down
                                         :key "Tab"
                                         :desc "SDL_EVENT_KEY_DOWN key=Tab"
                                         :ctrl? false})]
  (draw-input-assert-true "tab toggles tool panel on"
                          (get panel-on :tool-panel?)))

(let [base (assoc (default-state) :tool-panel? true)
      button (nth (draw-tool-panel-buttons base) 2)
      clicked (draw-input-copy-state
                (draw-apply-input-event! base
                                         {:kind :mouse-down
                                          :desc "SDL_EVENT_MOUSE_BUTTON_DOWN panel"
                                          :mouse-x (+ (get button :x) 4)
                                          :mouse-y (+ (get button :y) 4)
                                          :pressure 1.0
                                          :shift? false}))]
  (draw-input-assert-str= "tool panel click selects rectangle tool"
                          "rectangle"
                          (draw-tool-mode clicked)))

(let [base (assoc (default-state) :tool-panel? true :title "Panel Button Save")
      eraser-button (nth (draw-tool-panel-buttons base) 3)
      save-button (nth (draw-tool-panel-buttons base) 4)
      load-button (nth (draw-tool-panel-buttons base) 5)
      erased (draw-input-copy-state
               (draw-apply-input-event! base
                                        {:kind :mouse-down
                                         :desc "SDL_EVENT_MOUSE_BUTTON_DOWN panel-eraser"
                                         :mouse-x (+ (get eraser-button :x) 4)
                                         :mouse-y (+ (get eraser-button :y) 4)
                                         :pressure 1.0
                                         :shift? false}))
      saved (draw-input-copy-state
              (draw-apply-input-event! base
                                       {:kind :mouse-down
                                        :desc "SDL_EVENT_MOUSE_BUTTON_DOWN panel-save"
                                        :mouse-x (+ (get save-button :x) 4)
                                        :mouse-y (+ (get save-button :y) 4)
                                        :pressure 1.0
                                        :shift? false}))
      loaded (draw-input-copy-state
               (draw-apply-input-event! (assoc saved :title "Mutated")
                                        {:kind :mouse-down
                                         :desc "SDL_EVENT_MOUSE_BUTTON_DOWN panel-load"
                                         :mouse-x (+ (get load-button :x) 4)
                                         :mouse-y (+ (get load-button :y) 4)
                                         :pressure 1.0
                                         :shift? false}))]
  (draw-input-assert-true "tool panel eraser toggles eraser mode"
                          (get erased :eraser?))
  (draw-input-assert-true "tool panel save button writes state file"
                          (fs/exists? (draw-state-file-path)))
  (draw-input-assert-true "tool panel save button shows feedback"
                          (not (empty? (get saved :status-note))))
  (draw-input-assert-true "tool panel load button shows feedback"
                          (not (empty? (get loaded :status-note))))
  (draw-input-assert-str= "tool panel load button restores saved title"
                          "Panel Button Save"
                          (get loaded :title)))

(let [path (draw-state-file-path)
      saved (draw-apply-input-event! (assoc (default-state) :title "Panel Save")
                                     {:kind :key-down
                                      :key "s"
                                      :desc "SDL_EVENT_KEY_DOWN key=s"
                                      :ctrl? true})
      loaded (draw-apply-input-event! (assoc saved :title "Mutated")
                                      {:kind :key-down
                                       :key "o"
                                       :desc "SDL_EVENT_KEY_DOWN key=o"
                                       :ctrl? true})]
  (draw-input-assert-true "ctrl save writes state file"
                          (fs/exists? path))
  (draw-input-assert-true "ctrl save shows feedback"
                          (not (empty? (get saved :status-note))))
  (draw-input-assert-true "ctrl load shows feedback"
                          (not (empty? (get loaded :status-note)))))

(let [cursor (draw-desired-cursor-kind (default-state))]
  (draw-input-assert-str= "ink tool uses crosshair cursor"
                          "crosshair"
                          (name cursor)))

(let [base (assoc (default-state) :tool-panel? true)
      button (nth (draw-tool-panel-buttons base) 2)
      hovered (draw-sync-pointer-state base
                                       [(+ (get button :x) 4) (+ (get button :y) 4) 1.0]
                                       [(+ (get button :x) 4) (+ (get button :y) 4)])]
  (draw-input-assert-str= "tool panel button uses pointer cursor"
                          "pointer"
                          (name (draw-desired-cursor-kind hovered))))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 30.0
               :height 40.0
               :color [255 255 255]
               :size 2}])
      selected (assoc base :selection [1])
      hovered (draw-sync-pointer-state selected [10.0 20.0 1.0] [10.0 20.0])]
  (draw-input-assert-str= "selection handle uses diagonal resize cursor"
                          "nwse-resize"
                          (name (draw-desired-cursor-kind hovered))))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 30.0
               :height 40.0
               :rotation 0.0
               :color [255 255 255]
               :size 2}])
      selected (assoc base :selection [1])
      rect (get (draw-selection-handle-screen-rects selected
                                                    (first (get selected :elements)))
                :rotate)
      hovered (draw-sync-pointer-state selected
                                       [25.0 20.0 1.0]
                                       [(+ (get rect :x) 2.0)
                                        (+ (get rect :y) 2.0)])]
  (draw-input-assert-str= "rotation handle uses crosshair cursor"
                          "crosshair"
                          (name (draw-desired-cursor-kind hovered))))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :arrow
               :start [10.0 20.0 1.0]
               :end [40.0 60.0 1.0]
               :color [255 255 255]
               :size 2}])
      selected (assoc base :selection [1])
      hovered (draw-sync-pointer-state selected [10.0 20.0 1.0] [10.0 20.0])]
  (draw-input-assert-str= "arrow handle uses crosshair cursor"
                          "crosshair"
                          (name (draw-desired-cursor-kind hovered))))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 30.0
               :height 40.0
               :color [255 255 255]
               :size 2}])
      selected (assoc base :selection [1])
      hovered (draw-sync-pointer-state selected [24.0 36.0 1.0] [24.0 36.0])]
  (draw-input-assert-str= "selection hover uses move cursor"
                          "move"
                          (name (draw-desired-cursor-kind hovered))))

(let [text-state (draw-set-tool-core! (default-state) :text)]
  (draw-input-assert-str= "text tool uses text cursor"
                          "text"
                          (name (draw-desired-cursor-kind text-state))))

(let [panning (assoc (default-state) :space-down? true)]
  (draw-input-assert-str= "space pan uses move cursor"
                          "move"
                          (name (draw-desired-cursor-kind panning))))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 30.0
               :height 40.0
               :color [255 255 255]
               :size 2}])
      selected (draw-input-copy-state
                 (draw-apply-input-event! base
                                          {:kind :mouse-down
                                           :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=15.0 y=25.0"
                                           :mouse-x 15.0
                                           :mouse-y 25.0
                                           :pressure 1.0
                                           :shift? false}))
      moved (draw-input-copy-state
              (draw-apply-input-event! selected
                                       {:kind :mouse-motion
                                        :desc "SDL_EVENT_MOUSE_MOTION x=25.0 y=35.0"
                                        :mouse-x 25.0
                                        :mouse-y 35.0
                                        :pressure 1.0
                                        :shift? false}))
      finished (draw-input-copy-state
                 (draw-apply-input-event! moved
                                          {:kind :mouse-up
                                           :desc "SDL_EVENT_MOUSE_BUTTON_UP x=25.0 y=35.0"
                                           :mouse-x 25.0
                                           :mouse-y 35.0
                                           :pressure 1.0
                                           :shift? false}))
      moved-box (first (get finished :elements))]
  (draw-input-assert-num= "selection mouse-down picks one element"
                          1
                          (count (draw-selected-element-ids selected)))
  (draw-input-assert-num= "selection mouse drag moves element x"
                          20.0
                          (get moved-box :x))
  (draw-input-assert-num= "selection mouse drag moves element y"
                          30.0
                          (get moved-box :y))
  (draw-input-assert-false "selection mouse-up clears active drag"
                           (get finished :active-selection-drag)))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 30.0
               :height 40.0
               :color [255 255 255]
               :size 2}])
      selected (draw-input-copy-state
                 (draw-apply-input-event! base
                                          {:kind :mouse-down
                                           :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=15.0 y=25.0"
                                           :mouse-x 15.0
                                           :mouse-y 25.0
                                           :pressure 1.0
                                           :shift? false}))
      resize-start (draw-input-copy-state
                     (draw-apply-input-event! selected
                                              {:kind :mouse-down
                                               :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=40.0 y=60.0"
                                               :mouse-x 40.0
                                               :mouse-y 60.0
                                               :pressure 1.0
                                               :shift? false}))
      resized (draw-input-copy-state
                (draw-apply-input-event! resize-start
                                         {:kind :mouse-motion
                                          :desc "SDL_EVENT_MOUSE_MOTION x=50.0 y=70.0"
                                          :mouse-x 50.0
                                          :mouse-y 70.0
                                          :pressure 1.0
                                          :shift? false}))
      finished (draw-input-copy-state
                 (draw-apply-input-event! resized
                                          {:kind :mouse-up
                                           :desc "SDL_EVENT_MOUSE_BUTTON_UP x=50.0 y=70.0"
                                           :mouse-x 50.0
                                           :mouse-y 70.0
                                           :pressure 1.0
                                           :shift? false}))
      box (first (get finished :elements))]
  (draw-input-assert-true "selection handle mouse-down starts resize"
                          (get resize-start :active-selection-resize))
  (draw-input-assert-num= "selection handle drag updates width"
                          40.0
                          (get box :width))
  (draw-input-assert-num= "selection handle drag updates height"
                          50.0
                          (get box :height))
  (draw-input-assert-false "selection handle mouse-up clears resize"
                           (get finished :active-selection-resize)))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :arrow
               :start [10.0 20.0 1.0]
               :end [40.0 60.0 1.0]
               :color [255 255 255]
               :size 2}])
      selected (assoc base :selection [1])
      resize-start (draw-input-copy-state
                     (draw-apply-input-event! selected
                                              {:kind :mouse-down
                                               :desc "SDL_EVENT_MOUSE_BUTTON_DOWN arrow-start"
                                               :mouse-x 10.0
                                               :mouse-y 20.0
                                               :pressure 1.0
                                               :shift? false}))
      resized (draw-input-copy-state
                (draw-apply-input-event! resize-start
                                         {:kind :mouse-motion
                                          :desc "SDL_EVENT_MOUSE_MOTION arrow-start"
                                          :mouse-x 5.0
                                          :mouse-y 15.0
                                          :pressure 1.0
                                          :shift? false}))
      finished (draw-input-copy-state
                 (draw-apply-input-event! resized
                                          {:kind :mouse-up
                                           :desc "SDL_EVENT_MOUSE_BUTTON_UP arrow-start"
                                           :mouse-x 5.0
                                           :mouse-y 15.0
                                           :pressure 1.0
                                           :shift? false}))
      arrow (first (get finished :elements))]
  (draw-input-assert-true "arrow handle mouse-down starts resize"
                          (get resize-start :active-selection-resize))
  (draw-input-assert-str= "arrow handle drag updates start"
                          "[5.0 15.0 1.0]"
                          (pr-str (get arrow :start)))
  (draw-input-assert-str= "arrow handle drag keeps end"
                          "[40.0 60.0 1.0]"
                          (pr-str (get arrow :end)))
  (draw-input-assert-false "arrow handle mouse-up clears resize"
                           (get finished :active-selection-resize)))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 30.0
               :height 40.0
               :rotation 0.0
               :color [255 255 255]
               :size 2}])
      selected (assoc base :selection [1])
      handle-rect (get (draw-selection-handle-screen-rects selected
                                                           (first (get selected :elements)))
                       :rotate)
      rotate-start (draw-input-copy-state
                     (draw-apply-input-event! selected
                                              {:kind :mouse-down
                                               :desc "SDL_EVENT_MOUSE_BUTTON_DOWN rotate"
                                               :mouse-x (+ (get handle-rect :x) 2.0)
                                               :mouse-y (+ (get handle-rect :y) 2.0)
                                               :pressure 1.0
                                               :shift? false}))
      rotated (draw-input-copy-state
                (draw-apply-input-event! rotate-start
                                         {:kind :mouse-motion
                                          :desc "SDL_EVENT_MOUSE_MOTION rotate"
                                          :mouse-x 60.0
                                          :mouse-y 80.0
                                          :pressure 1.0
                                          :shift? false}))
      finished (draw-input-copy-state
                 (draw-apply-input-event! rotated
                                          {:kind :mouse-up
                                           :desc "SDL_EVENT_MOUSE_BUTTON_UP rotate"
                                           :mouse-x 60.0
                                           :mouse-y 80.0
                                           :pressure 1.0
                                           :shift? false}))
      box (first (get finished :elements))]
  (draw-input-assert-true "rotation handle mouse-down starts rotate"
                          (get rotate-start :active-selection-rotate))
  (draw-input-assert-true "rotation drag updates rectangle rotation"
                          (not (= 0.0 (get box :rotation))))
  (draw-input-assert-false "rotation mouse-up clears rotate"
                           (get finished :active-selection-rotate)))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 20.0
               :height 20.0
               :color [255 255 255]
               :size 2}
              {:kind :box
               :x 60.0
               :y 80.0
               :width 20.0
               :height 20.0
               :color [255 255 255]
               :size 2}])
      marquee-start (draw-input-copy-state
                      (draw-apply-input-event! base
                                               {:kind :mouse-down
                                                :desc "SDL_EVENT_MOUSE_BUTTON_DOWN marquee"
                                                :mouse-x 0.0
                                                :mouse-y 0.0
                                                :pressure 1.0
                                                :shift? false}))
      marquee-dragged (draw-input-copy-state
                        (draw-apply-input-event! marquee-start
                                                 {:kind :mouse-motion
                                                  :desc "SDL_EVENT_MOUSE_MOTION marquee"
                                                  :mouse-x 100.0
                                                  :mouse-y 120.0
                                                  :pressure 1.0
                                                  :shift? false}))
      marquee-finished (draw-input-copy-state
                         (draw-apply-input-event! marquee-dragged
                                                  {:kind :mouse-up
                                                   :desc "SDL_EVENT_MOUSE_BUTTON_UP marquee"
                                                   :mouse-x 100.0
                                                   :mouse-y 120.0
                                                   :pressure 1.0
                                                   :shift? false}))]
  (draw-input-assert-true "empty canvas drag starts marquee"
                          (get marquee-start :active-selection-marquee))
  (draw-input-assert-num= "marquee mouse-up selects both boxes"
                          2
                          (count (draw-selected-element-ids marquee-finished)))
  (draw-input-assert-false "marquee mouse-up clears marquee"
                           (get marquee-finished :active-selection-marquee)))

(let [base (assoc (draw-sync-elements
                    (draw-set-tool-core! (default-state) :select)
                    [{:kind :box
                      :x 10.0
                      :y 20.0
                      :width 20.0
                      :height 20.0
                      :color [255 255 255]
                      :size 2}
                     {:kind :box
                      :x 60.0
                      :y 80.0
                      :width 20.0
                      :height 20.0
                      :color [255 255 255]
                      :size 2}])
                   :selection [1])
      marquee-start (draw-input-copy-state
                      (draw-apply-input-event! base
                                               {:kind :mouse-down
                                                :desc "SDL_EVENT_MOUSE_BUTTON_DOWN marquee-shift"
                                                :mouse-x 55.0
                                                :mouse-y 75.0
                                                :pressure 1.0
                                                :shift? true}))
      marquee-finished (draw-input-copy-state
                         (draw-apply-input-event! marquee-start
                                                  {:kind :mouse-up
                                                   :desc "SDL_EVENT_MOUSE_BUTTON_UP marquee-shift"
                                                   :mouse-x 95.0
                                                   :mouse-y 115.0
                                                   :pressure 1.0
                                                   :shift? true}))]
  (draw-input-assert-num= "shift marquee keeps prior selection"
                          2
                          (count (draw-selected-element-ids marquee-finished)))
  (draw-input-assert-true "shift marquee adds second box"
                          (draw-selection-has-id? (draw-selected-element-ids marquee-finished)
                                                  2)))

(let [base (draw-sync-elements
             (draw-set-tool-core! (default-state) :select)
             [{:kind :box
               :x 10.0
               :y 20.0
               :width 30.0
               :height 40.0
               :color [255 255 255]
               :size 2}
              {:kind :box
               :x 70.0
               :y 90.0
               :width 20.0
               :height 30.0
               :color [255 255 255]
               :size 2}])
      first (draw-input-copy-state
              (draw-apply-input-event! base
                                       {:kind :mouse-down
                                        :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=15.0 y=25.0"
                                        :mouse-x 15.0
                                        :mouse-y 25.0
                                        :pressure 1.0
                                        :shift? false}))
      second (draw-input-copy-state
               (draw-apply-input-event! first
                                        {:kind :mouse-down
                                         :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=75.0 y=95.0"
                                         :mouse-x 75.0
                                         :mouse-y 95.0
                                         :pressure 1.0
                                         :shift? true}))]
  (draw-input-assert-num= "shift mouse-down adds to selection"
                          2
                          (count (draw-selected-element-ids second))))

(let [frame-created (draw-input-copy-state
                      (draw-apply-input-event!
                        (draw-apply-input-event! (draw-set-tool-core! (default-state) :frame)
                                                 {:kind :mouse-down
                                                  :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=15.0 y=25.0"
                                                  :mouse-x 15.0
                                                  :mouse-y 25.0
                                                  :pressure 1.0
                                                  :shift? false})
                        {:kind :mouse-up
                         :desc "SDL_EVENT_MOUSE_BUTTON_UP x=45.0 y=55.0"
                         :mouse-x 45.0
                         :mouse-y 55.0
                         :pressure 1.0
                         :shift? false}))
      frame-element (first (get frame-created :elements))]
  (draw-input-assert-str= "legacy frame tool creates rectangle element"
                          ":box"
                          (pr-str (get frame-element :kind)))
  (draw-input-assert-num= "legacy frame tool stores width"
                          30.0
                          (get frame-element :width))
  (draw-input-assert-num= "legacy frame tool stores height"
                          30.0
                          (get frame-element :height)))

(let [text-created (draw-input-copy-state
                     (draw-apply-input-event!
                       (draw-apply-input-event! (draw-set-tool-core! (default-state) :text)
                                                {:kind :mouse-down
                                                 :desc "SDL_EVENT_MOUSE_BUTTON_DOWN x=18.0 y=28.0"
                                                 :mouse-x 18.0
                                                 :mouse-y 28.0
                                                 :pressure 1.0
                                                 :shift? false})
                       {:kind :mouse-up
                        :desc "SDL_EVENT_MOUSE_BUTTON_UP x=48.0 y=58.0"
                        :mouse-x 48.0
                        :mouse-y 58.0
                        :pressure 1.0
                        :shift? false}))
      text-element (first (get text-created :elements))]
  (draw-input-assert-str= "text tool creates text element"
                          ":text"
                          (pr-str (get text-element :kind)))
  (draw-input-assert-num= "text tool stores text x"
                          48.0
                          (get text-element :x))
  (draw-input-assert-num= "text tool stores text y"
                          58.0
                          (get text-element :y))
  (draw-input-assert-str= "text tool stores default label"
                          "Text"
                          (get text-element :text)))

(let [pen-state (draw-apply-and-log-input-event!
                  (default-state)
                  {:kind :pen-down
                   :desc "SDL_EVENT_PEN_DOWN x=12.0 y=34.0"
                   :mouse-x 12.0
                   :mouse-y 34.0
                   :pressure 1.0
                   :shift? false}
                  :simulated)
      deduped (draw-apply-and-log-input-event!
                pen-state
                {:kind :mouse-down
                 :desc "SDL_EVENT_MOUSE_BUTTON_DOWN which=4294967294 x=12.0 y=34.0"
                 :mouse-x 12.0
                 :mouse-y 34.0
                 :pressure 1.0
                 :shift? false}
                :simulated)]
  (draw-input-assert-num= "synthetic pen mouse does not add history"
                          1
                          (count (get deduped :history)))
  (draw-input-assert-num= "synthetic pen mouse keeps one active point"
                          1
                          (count (get (get deduped :active-stroke) :points))))

(let [pen-state (draw-apply-and-log-input-event!
                  (default-state)
                  {:kind :pen-down
                   :desc "SDL_EVENT_PEN_DOWN x=12.0 y=34.0"
                   :mouse-x 12.0
                   :mouse-y 34.0
                   :pressure 0.4
                   :shift? false}
                  :simulated)
      ignored-mouse-up (draw-apply-and-log-input-event!
                         pen-state
                         {:kind :mouse-up
                          :desc "SDL_EVENT_MOUSE_BUTTON_UP which=0 x=12.0 y=34.0"
                          :mouse-x 12.0
                          :mouse-y 34.0
                          :pressure 1.0
                          :shift? false}
                         :simulated)]
  (draw-input-assert-true "mouse-up is ignored while pen owns pointer"
                          (get ignored-mouse-up :pointer-down?))
  (draw-input-assert-true "mouse-up keeps active pen stroke alive"
                          (get ignored-mouse-up :active-stroke)))

(let [left (draw-mouse-leave-core!
             (assoc (default-state)
                    :window-focused? true
                    :pointer-down? true
                    :active-stroke {:points [[1 2 1.0]]
                                    :color [1 2 3]
                                    :size 2}))]
  (draw-input-assert-true "mouse leave keeps focus state"
                          (get left :window-focused?))
  (draw-input-assert-false "mouse leave clears active stroke"
                           (get left :active-stroke)))

(let [state (draw-input-copy-state (default-state))
      next (draw-handle-view-key! state "tab")]
  (draw-input-assert-num= "tab key leaves zoom unchanged"
                          1.0
                          (draw-view-zoom next))
  (draw-input-assert-num= "tab key leaves view-x unchanged"
                          0.0
                          (draw-view-x next))
  (draw-input-assert-num= "tab key leaves view-y unchanged"
                          0.0
                          (draw-view-y next)))

(let [original-render-text sdl/render-debug-text!
      original-set-color sdl/set-draw-color!]
  (set! sdl/render-debug-text!
        (lambda (renderer x y text)
          true))
  (set! sdl/set-draw-color!
        (lambda (renderer r g b a)
          true))
  (draw-status/draw-render-debug-panel-base!
    :dummy
    (assoc (default-state)
           :debug-panel? true)
    (lambda (renderer state point size)
      true)
    (lambda (state)
      :crosshair)
    false)
  (draw-input-assert-true "debug panel render path completes"
                          true)
  (set! sdl/render-debug-text! original-render-text)
  (set! sdl/set-draw-color! original-set-color))

  (let [original-poll sdl/poll-event!
        original-desc sdl/event-description
        original-build draw-build-input-event
        original-apply draw-apply-and-log-input-event!
        original-sync sync-window-title!
        events 0
        recorded 0]
  (set! *draw-state* (default-state))
  (set! sdl/poll-event!
        (lambda ()
          (if (< events 100)
            (begin
              (set! events (+ events 1))
              true)
            false)))
  (set! sdl/event-description
        (lambda ()
          "SDL_EVENT_PEN_MOTION x=12.0 y=34.0"))
  (set! draw-build-input-event
        (lambda (state desc)
          {:kind :pen-motion
           :desc desc
           :mouse-x 12
           :mouse-y 34
           :pressure 1.0}))
  (set! draw-apply-and-log-input-event!
        (lambda (state event source)
          (set! recorded (+ recorded 1))
          state))
  (set! sync-window-title!
        (lambda ()
          true))
  (draw-poll-input!)
  (draw-input-assert-num= "input drain respects batch limit"
                          (draw-input-batch-limit)
                          recorded)
  (draw-input-assert-num= "input drain still bumps frame"
                          1
                          (get *draw-state* :frame))
  (set! sdl/poll-event! original-poll)
  (set! sdl/event-description original-desc)
  (set! draw-build-input-event original-build)
  (set! draw-apply-and-log-input-event! original-apply)
  (set! sync-window-title! original-sync))
