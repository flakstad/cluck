(let [original draw-resources/draw-resource-ensure-system-cursor!]
  (set! draw-resources/draw-resource-ensure-system-cursor!
        (lambda (context kind)
          {:context (assoc context :cursor-kind kind)
           :cursor :mock-cursor}))
  (set! *draw-context* {:cursor-cache {}})
  (draw-input-assert-str= "system cursor helper returns cached cursor"
                          ":mock-cursor"
                          (pr-str (draw-ensure-system-cursor! :crosshair)))
  (draw-input-assert-str= "system cursor helper records cursor kind"
                          ":crosshair"
                          (pr-str (get *draw-context* :cursor-kind)))
  (set! *draw-context* false)
  (set! draw-resources/draw-resource-ensure-system-cursor! original))

