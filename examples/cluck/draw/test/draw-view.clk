;; Focused draw-view probe for the SDL3 example.

(in-ns 'cluck.examples.draw)

(define (draw-view-pass label)
  (println "ok" label)
  true)

(define (draw-view-fail label expected actual)
  (error (string-append "draw view test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (draw-view-assert-true label value)
  (if value
      (draw-view-pass label)
      (draw-view-fail label "truthy value" (pr-str value))))

(define (draw-view-assert-str= label expected actual)
  (if (string=? expected actual)
      (draw-view-pass label)
      (draw-view-fail label expected actual)))

(define (draw-view-assert-num= label expected actual)
  (if (= expected actual)
      (draw-view-pass label)
      (draw-view-fail label expected actual)))

(draw-view-assert-true "draw namespace exists" (find-ns 'cluck.examples.draw))

(draw-view-assert-true "world bound is very large"
                       (> (draw-world-bound) 100000000000.0))
(draw-view-assert-true "min zoom supports deep zoom out"
                       (< (draw-min-zoom) 0.00001))
(draw-view-assert-true "max zoom supports deep zoom in"
                       (> (draw-max-zoom) 100000.0))

(draw-view-assert-str= "screen point converts to world at default zoom"
                       "[12.0 34.0 1.0]"
                       (pr-str (draw-event-point (default-state)
                                                "SDL_EVENT_MOUSE_MOTION x=12.0 y=34.0")))

(let [state (assoc (default-state)
                   :view-x 10.0
                   :view-y 20.0
                   :zoom 2.0)]
  (draw-view-assert-str= "world point converts to screen with viewport"
                         "[10 12 1.0]"
                         (pr-str (draw-world-point->screen-point state [15 26 1.0])))
  (draw-view-assert-str= "world point keeps subpixel screen precision"
                         "[10.5 13.0 1.0]"
                         (pr-str (draw-world-point->screen-fpoint state [15.25 26.5 1.0])))
  (draw-view-assert-str= "event point uses viewport transform"
                         "[17.0 32.0 1.0]"
                         (pr-str (draw-event-point state
                                                  "SDL_EVENT_MOUSE_MOTION x=14.0 y=24.0"))))

(let [zoomed-out (assoc (default-state)
                        :zoom 0.5)
      zoomed-in (assoc (default-state)
                       :zoom 2.0)]
  (draw-view-assert-num= "stored stroke renders smaller when zoomed out"
                         2
                         (draw-point-screen-size zoomed-out [15 26 1.0] 4))
  (draw-view-assert-num= "stored stroke renders larger when zoomed in"
                         8
                         (draw-point-screen-size zoomed-in [15 26 1.0] 4)))

(let [zoomed-out (assoc (default-state)
                        :zoom 0.5)
      zoomed-in (assoc (default-state)
                       :zoom 2.0)]
  (draw-view-assert-num= "current brush stores larger world size when zoomed out"
                         8.0
                         (draw-current-brush-size zoomed-out [15 26 1.0] 4))
  (draw-view-assert-num= "current brush stores smaller world size when zoomed in"
                         2.0
                         (draw-current-brush-size zoomed-in [15 26 1.0] 4)))

(let [deep-zoomed-in (assoc (default-state)
                            :zoom 64.0)
      stored-size (draw-current-brush-size deep-zoomed-in [15 26 1.0] 4)]
  (draw-view-assert-num= "deep zoom current brush still renders at base screen size"
                         4
                         (draw-point-screen-size deep-zoomed-in [15 26 1.0] stored-size)))

(let [state (assoc (default-state)
                   :view-x 100.0
                   :view-y 200.0
                   :view-anchor-x 320.0
                   :view-anchor-y 180.0
                   :zoom 4.0)
      world [105.0 203.0 1.0]
      screen (draw-world-point->screen-point state world)
      roundtrip (draw-screen-point->world-point state screen)]
  (draw-view-assert-str= "anchored view converts world to screen"
                         "[340 192 1.0]"
                         (pr-str screen))
  (draw-view-assert-str= "anchored view roundtrip keeps world point"
                         (pr-str world)
                         (pr-str roundtrip)))

(let [screen-rect (draw-world-rect->screen-rect
                    (assoc (default-state)
                           :zoom 0.05)
                    10.0
                    20.0
                    2.0
                    3.0)]
  (draw-view-assert-true "screen rect keeps minimum visible width"
                         (>= (get screen-rect :width) 1))
  (draw-view-assert-true "screen rect keeps minimum visible height"
                         (>= (get screen-rect :height) 1)))

(let [state (assoc (default-state)
                   :ctrl-down? true
                   :mouse-screen-x 100.0
                   :mouse-screen-y 50.0)
      anchor (draw-screen-point->world-point state [100.0 50.0 1.0])
      zoomed (draw-handle-view-key! state "=")]
  (draw-view-assert-true "ctrl plus changes zoom"
                         (> (draw-view-zoom zoomed) 1.0))
  (draw-view-assert-num= "ctrl plus stores zoom anchor x"
                         100.0
                         (draw-view-anchor-x zoomed))
  (draw-view-assert-num= "ctrl plus stores zoom anchor y"
                         50.0
                         (draw-view-anchor-y zoomed))
  (draw-view-assert-str= "ctrl plus keeps pointer anchored"
                         "[100 50 1.0]"
                         (pr-str (draw-world-point->screen-point zoomed anchor))))

(let [plain (draw-handle-view-key! (default-state) "=")]
  (draw-view-assert-num= "plain equals does not zoom without ctrl"
                         1.0
                         (draw-view-zoom plain)))

(let [shifted (draw-handle-view-key! (assoc (default-state) :view-x 10.0) "Left Shift")
      controlled (draw-handle-view-key! (assoc (default-state) :view-x 10.0) "Right Ctrl")]
  (draw-view-assert-num= "shift key does not pan view"
                         10.0
                         (draw-view-x shifted))
  (draw-view-assert-num= "ctrl key does not pan view"
                         10.0
                         (draw-view-x controlled)))

(let [panned (draw-handle-view-key! (assoc (default-state)
                                           :view-x 10.0
                                           :view-y 20.0
                                           :zoom 2.0)
                                    "h")]
  (draw-view-assert-num= "pan left updates view-x"
                         -22.0
                         (draw-view-x panned)))

(let [state (default-state)
      wheel-zoomed (draw-zoom-at-core! state 1.0 100.0 50.0)
      anchor (draw-screen-point->world-point state [100.0 50.0 1.0])]
  (draw-view-assert-true "wheel zoom changes zoom"
                         (> (draw-view-zoom wheel-zoomed) 1.0))
  (draw-view-assert-str= "wheel zoom keeps cursor anchored"
                         "[100 50 1.0]"
                         (pr-str (draw-world-point->screen-point wheel-zoomed anchor))))

(let [base (assoc (default-state)
                  :view-x 123456789.0
                  :view-y -234567890.0
                  :zoom 0.5)
      anchor [400.0 280.0 1.0]
      world (draw-screen-point->world-point base anchor)
      zoom-a (draw-zoom-at-core! base 10.0 400.0 280.0)
      zoom-b (draw-zoom-at-core! zoom-a -18.0 400.0 280.0)
      zoom-c (draw-zoom-at-core! zoom-b 6.0 400.0 280.0)]
  (draw-view-assert-str= "deep repeated zoom keeps anchor after zoom a"
                         "[400 280 1.0]"
                         (pr-str (draw-world-point->screen-point zoom-a world)))
  (draw-view-assert-str= "deep repeated zoom keeps anchor after zoom b"
                         "[400 280 1.0]"
                         (pr-str (draw-world-point->screen-point zoom-b world)))
  (draw-view-assert-str= "deep repeated zoom keeps anchor after zoom c"
                         "[400 280 1.0]"
                         (pr-str (draw-world-point->screen-point zoom-c world))))

(let [base (assoc (default-state)
                  :view-x 1234.0
                  :view-y -5678.0
                  :view-anchor-x 300.0
                  :view-anchor-y 200.0
                  :zoom 3.0)
      world (draw-screen-point->world-point base [412.0 256.0 1.0])
      zoom-a (draw-zoom-at-core! base 4.0 412.0 256.0)
      zoom-b (draw-zoom-at-core! zoom-a -2.0 412.0 256.0)]
  (draw-view-assert-str= "anchored repeated zoom keeps world under cursor after zoom a"
                         "[412 256 1.0]"
                         (pr-str (draw-world-point->screen-point zoom-a world)))
  (draw-view-assert-str= "anchored repeated zoom keeps world under cursor after zoom b"
                         "[412 256 1.0]"
                         (pr-str (draw-world-point->screen-point zoom-b world))))

(let [panning (draw-pan-core! (assoc (default-state)
                                     :panning? true
                                     :pan-last-x 10.0
                                     :pan-last-y 20.0
                                     :view-x 10.0
                                     :view-y 20.0
                                     :zoom 2.0)
                              [14.0 24.0])]
  (draw-view-assert-num= "pan drag updates view-x"
                         8.0
                         (draw-view-x panning))
  (draw-view-assert-num= "pan drag updates view-y"
                         18.0
                         (draw-view-y panning)))

(let [panning (draw-pan-core! (assoc (default-state)
                                     :panning? true
                                     :pan-last-x 10.0
                                     :pan-last-y 20.0
                                     :view-x 100.0
                                     :view-y 200.0
                                     :view-anchor-x 320.0
                                     :view-anchor-y 180.0
                                     :zoom 4.0)
                              [26.0 32.0])]
  (draw-view-assert-num= "anchored pan drag updates view-x"
                         96.0
                         (draw-view-x panning))
  (draw-view-assert-num= "anchored pan drag updates view-y"
                         197.0
                         (draw-view-y panning)))

(let [state (assoc (default-state)
                   :view-x 500000000.0
                   :view-y -500000000.0
                   :zoom 0.0005)
      world [(+ (draw-view-x state) 4000.0)
             (+ (draw-view-y state) 6000.0)
             1.0]
      screen (draw-world-point->screen-point state world)
      roundtrip (draw-screen-point->world-point state screen)]
  (draw-view-assert-str= "deep zoom out world point converts to coarse screen"
                         "[2 3 1.0]"
                         (pr-str screen))
  (draw-view-assert-str= "deep zoom out roundtrip keeps world point"
                         (pr-str world)
                         (pr-str roundtrip)))

(let [panned (draw-pan-core! (assoc (default-state)
                                    :panning? true
                                    :pan-last-x 0.0
                                    :pan-last-y 0.0
                                    :view-x 999999950.0
                                    :view-y -999999950.0
                                    :zoom 0.0005)
                             [640.0 360.0])]
  (draw-view-assert-true "extreme pan clamps view x"
                         (<= (math/abs (draw-view-x panned))
                             (draw-world-bound)))
  (draw-view-assert-true "extreme pan clamps view y"
                         (<= (math/abs (draw-view-y panned))
                             (draw-world-bound))))

(let [started (draw-start-stroke (assoc (default-state)
                                        :view-x 100.0
                                        :view-y 200.0
                                        :zoom 2.0)
                                 [150.0 240.0 1.0]
                                 [100.0 80.0]
                                 :mouse)
      finished (draw-finish-stroke started
                                   [170.0 260.0 1.0]
                                   [140.0 120.0])
      stroke (first (get finished :strokes))]
  (draw-view-assert-str= "zoomed stroke keeps world start point"
                         "[150.0 240.0 1.0]"
                         (pr-str (first (get stroke :points))))
  (draw-view-assert-str= "zoomed stroke keeps world end point"
                         "[170.0 260.0 1.0]"
                         (pr-str (last (get stroke :points))))
  (draw-view-assert-num= "zoomed-in stroke stores smaller world brush size"
                         1.0
                         (get stroke :size)))
