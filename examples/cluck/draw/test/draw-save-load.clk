;; Focused draw-save-load probe for the SDL3 example.

(in-ns 'cluck.examples.draw)

(define (draw-save-load-pass label)
  (println "ok" label)
  true)

(define (draw-save-load-fail label expected actual)
  (error (string-append "draw save/load test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (draw-save-load-assert-true label value)
  (if value
      (draw-save-load-pass label)
      (draw-save-load-fail label "truthy value" (pr-str value))))

(define (draw-save-load-assert-false label value)
  (if (not value)
      (draw-save-load-pass label)
      (draw-save-load-fail label "falsey value" (pr-str value))))

(define (draw-save-load-assert-str= label expected actual)
  (if (string=? expected actual)
      (draw-save-load-pass label)
      (draw-save-load-fail label expected actual)))

(define (draw-save-load-assert-num= label expected actual)
  (if (= expected actual)
      (draw-save-load-pass label)
      (draw-save-load-fail label expected actual)))

(let [path (fs/path (fs/temp-dir) "cluck-draw-save-load.edn")
      original (draw-sync-elements
        (assoc (default-state)
               :title "Saved Draw"
               :brush-size 7
               :opacity 0.75
               :recent-brush-colors [[103 169 255]
                                     [255 112 122]
                                     [245 245 245]]
               :tool :box
               :status-note "saved note"
               :status-note-frame 42
                        :history [(draw-history-snapshot
                                    (draw-sync-elements
                                      (assoc (default-state)
                                             :title "Older"
                                             :brush-size 3)
                                      [{:kind :ink
                                        :points [[1 1 1.0] [2 2 1.0]]
                                        :color [9 9 9]
                                        :size 2}]))]
                        :last-event "save test")
                 [{:kind :ink
                   :points [[10 10 1.0] [20 20 0.5]]
                   :color [1 2 3]
                   :size 4
                   :opacity 0.5}
                 {:kind :box
                   :x 30.0
                   :y 40.0
                   :width 50.0
                   :height 60.0
                   :rotation 0.5
                   :color [4 5 6]
                   :size 3
                   :opacity 0.25}
                 {:kind :circle
                   :x 90.0
                   :y 100.0
                   :width 20.0
                   :height 30.0
                   :rotation 0.0
                   :color [7 8 9]
                   :size 2
                   :opacity 1.0}
                 {:kind :line
                   :start [120.0 130.0 1.0]
                   :end [150.0 170.0 1.0]
                   :color [10 11 12]
                   :size 3
                   :opacity 0.6}
                 {:kind :arrow
                   :start [180.0 190.0 1.0]
                   :end [210.0 230.0 1.0]
                   :color [13 14 15]
                   :size 2
                   :opacity 0.8}
                 {:kind :frame
                   :x 240.0
                   :y 260.0
                   :width 70.0
                   :height 80.0
                   :color [16 17 18]
                   :size 3
                   :opacity 0.9}
                 {:kind :text
                   :x 320.0
                   :y 340.0
                   :text "Text"
                   :color [19 20 21]
                   :size 2
                   :opacity 0.3}])]
  (dynamic-wind
    (lambda ()
      (set-state! original)
      (draw-save-load-assert-str= "save returns path"
                                  (pr-str path)
                                  (pr-str (save-canvas-to! path))))
    (lambda ()
      (draw-save-load-assert-false "saved file strips document path"
                                   (contains? (edn/read-string (io/slurp path))
                                              :file-path))
      (set-state! (default-state))
      (draw-save-load-assert-str= "load returns path"
                                  (pr-str path)
                                  (pr-str (load-canvas-from! path)))
      (draw-save-load-assert-str= "load restored title"
                                  "Saved Draw"
                                  (get (current-state) :title))
      (draw-save-load-assert-str= "load restored document path"
                                  (pr-str path)
                                  (pr-str (get (current-state) :file-path)))
      (draw-save-load-assert-str= "load shows status note"
                                  (format "opened %s" path)
                                  (get (current-state) :status-note))
      (draw-save-load-assert-num= "load sets transient status note frame"
                                  0
                                  (get (current-state) :status-note-frame))
      (draw-save-load-assert-num= "load restored brush size"
                                  7
                                  (get (current-state) :brush-size))
      (draw-save-load-assert-str= "load restored recent brush colors"
                                  "[103 169 255]"
                                  (pr-str (first (get (current-state) :recent-brush-colors))))
      (draw-save-load-assert-num= "load restored opacity"
                                  0.75
                                  (get (current-state) :opacity))
      (draw-save-load-assert-str= "load restored tool"
                                  ":box"
                                  (pr-str (get (current-state) :tool)))
      (draw-save-load-assert-num= "load restored element count"
                                  7
                                  (count (get (current-state) :elements)))
      (draw-save-load-assert-num= "load restored rectangle rotation"
                                  0.5
                                  (get (nth (get (current-state) :elements) 1) :rotation))
      (draw-save-load-assert-num= "load restored box opacity"
                                  0.25
                                  (get (nth (get (current-state) :elements) 1) :opacity))
      (draw-save-load-assert-str= "load restored circle kind"
                                  ":circle"
                                  (pr-str (get (nth (get (current-state) :elements) 2) :kind)))
      (draw-save-load-assert-str= "load restored line kind"
                                  ":line"
                                  (pr-str (get (nth (get (current-state) :elements) 3) :kind)))
      (draw-save-load-assert-str= "load restored line start"
                                  "[120.0 130.0 1.0]"
                                  (pr-str (get (nth (get (current-state) :elements) 3) :start)))
      (draw-save-load-assert-num= "load restored line opacity"
                                  0.6
                                  (get (nth (get (current-state) :elements) 3) :opacity))
      (draw-save-load-assert-num= "load restored stroke count"
                                  1
                                  (count (get (current-state) :strokes)))
      (draw-save-load-assert-num= "load restored history count"
                                  1
                                  (count (get (current-state) :history)))
      (draw-save-load-assert-true "load restored last event"
                                  (string=? "save test"
                                            (get (current-state) :last-event))))
    (lambda ()
      (fs/delete! path))))
