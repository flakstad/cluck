;; REPL-first development bootstrap for the SDL3 drawing example.
;;
;; Load this from a normal Cluck REPL after starting the project runtime:
;;
;;   (load-file "examples/cluck/draw/dev.clk")
;;
;; It compiles a loadable SDL3 extension on demand and loads it into the
;; current process, then loads the draw example definitions. Call `start-dev!`
;; explicitly from the REPL when you want to open the window.

(ns cluck.examples.draw.dev
  "REPL-first development bootstrap for the SDL3 drawing example."
  (:require [cluck.fs :as fs]
            [cluck.process :as proc]
            [cluck.string :as str]))

(import (chicken file))

(defn draw-dev-build-dir
  [root]
  (fs/path root "build" "dev"))

(defn draw-dev-root
  []
  (fs/cwd))

(defn draw-dev-vendor-pkg-config-path
  [root]
  (fs/path root "build/vendor/sdl3-static/lib/pkgconfig"))

(defn draw-dev-loadable-source-path
  [root]
  (fs/path root "examples/cluck/draw/dev-loadable.scm"))

(defn draw-dev-library-path
  [root]
  (fs/path (draw-dev-build-dir root) "cluck-sdl3.so"))

(defn draw-dev-build-lock-path
  [root]
  (fs/path (draw-dev-build-dir root) ".build-lock"))

(defn draw-dev-source-path
  [root]
  (fs/path root "src/cluck/sdl3.clk"))

(defn draw-dev-source-mtime
  [path]
  (let [result (proc/sh (format "stat -f %%m %s" (proc/qs path)))]
    (if (zero? (get result :exit))
      (parse-long (str/trim (get result :out)))
      0)))

(defn draw-dev-library-sources
  [root]
  [(draw-dev-loadable-source-path root)
   (draw-dev-source-path root)
   (fs/path root "src/syntax-bootstrap.scm")
   (fs/path root "src/syntax-bootstrap-core.scm")
   (fs/path root "src/cluck.scm")
   (fs/path root "src/cluck-standalone-prelude.scm")])

(defn draw-dev-library-stale?
  [root]
  (let [lib (draw-dev-library-path root)
        lib-mtime (draw-dev-source-mtime lib)
        sources (draw-dev-library-sources root)]
    (reduce (fn [stale path]
              (if stale
                true
                (> (draw-dev-source-mtime path) lib-mtime)))
            (not (fs/file? lib))
            sources)))

(defn draw-dev-pkg-config
  [root args]
  (let [result (proc/sh (format "PKG_CONFIG_PATH=%s pkg-config %s"
                                (proc/qs (draw-dev-vendor-pkg-config-path root))
                                args))]
    (if (zero? (get result :exit))
      (str/trim (get result :out))
      (error (format "pkg-config failed for %s: %s"
                     args
                     (get result :out))))))

(defn draw-dev-library-build-command
  [root]
  (format "cd %s && csc -v -s -J -unit cluck.sdl3 -o %s %s %s -L \"%s\""
          (proc/qs root)
          (proc/qs (draw-dev-library-path root))
          (proc/qs (draw-dev-loadable-source-path root))
          (draw-dev-pkg-config root "--cflags sdl3")
          (draw-dev-pkg-config root "--libs --static sdl3")))

(defn draw-dev-ensure-directory!
  [path]
  (if (not (fs/directory? path))
    (create-directory path)
    path))

(defn draw-dev-acquire-build-lock-loop!
  [lock]
  (handle-exceptions _
    (begin
      (proc/system "sleep 0.1")
      (draw-dev-acquire-build-lock-loop! lock))
    (begin
      (create-directory lock)
      lock)))

(defn draw-dev-acquire-build-lock!
  [root]
  (draw-dev-acquire-build-lock-loop! (draw-dev-build-lock-path root)))

(defn draw-dev-release-build-lock!
  [root]
  (let [lock (draw-dev-build-lock-path root)]
    (if (fs/directory? lock)
      (delete-directory lock)
      false)))

(defn draw-dev-ensure-library!
  [root]
  (let [lib (draw-dev-library-path root)]
    (begin
      (draw-dev-ensure-directory! (draw-dev-build-dir root))
      (draw-dev-acquire-build-lock! root)
      (handle-exceptions exn
        (begin
          (draw-dev-release-build-lock! root)
          (error (format "SDL3 dev library build failed: %s" exn)))
        (begin
          (if (draw-dev-library-stale? root)
            (if (not (zero? (proc/system (draw-dev-library-build-command root))))
              (error "SDL3 dev library build failed"))
            lib)
          (draw-dev-release-build-lock! root)))
      lib)))

(let [root (draw-dev-root)
      lib (draw-dev-ensure-library! root)
      app (fs/path root "examples/cluck/draw/main.clk")]
  (load-library 'cluck.sdl3 lib)
  (load-file app))
