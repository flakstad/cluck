  if (!cluck_have_last_event) {
    return cluck_mouse_x();
  }
  if (cluck_last_event.type == SDL_EVENT_MOUSE_WHEEL) {
    return cluck_last_event.wheel.mouse_x;
  }
  return cluck_mouse_x();
}

static float cluck_event_wheel_mouse_y(void) {
  if (!cluck_have_last_event) {
    return cluck_mouse_y();
  }
  if (cluck_last_event.type == SDL_EVENT_MOUSE_WHEEL) {
    return cluck_last_event.wheel.mouse_y;
  }
  return cluck_mouse_y();
}

static bool cluck_mod_shift_pressed(void) {
  return (SDL_GetModState() & SDL_KMOD_SHIFT) != 0;
}

static bool cluck_mod_ctrl_pressed(void) {
  return (SDL_GetModState() & SDL_KMOD_CTRL) != 0;
}

static SDL_Cursor *cluck_create_system_cursor(int id) {
  return SDL_CreateSystemCursor((SDL_SystemCursor)id);
}

static bool cluck_set_cursor(SDL_Cursor *cursor) {
  return SDL_SetCursor(cursor);
}

static void cluck_destroy_cursor(SDL_Cursor *cursor) {
  if (cursor) {
    SDL_DestroyCursor(cursor);
  }
}

static bool cluck_render_fill_rect(SDL_Renderer *renderer, float x, float y, float w, float h) {
  SDL_FRect rect;
  rect.x = x;
  rect.y = y;
  rect.w = w;
  rect.h = h;
  return SDL_RenderFillRect(renderer, &rect);
}

static bool cluck_render_line(SDL_Renderer *renderer, float x1, float y1, float x2, float y2) {
  return SDL_RenderLine(renderer, x1, y1, x2, y2);
}

static bool cluck_render_debug_text(SDL_Renderer *renderer, float x, float y, const char *text) {
  return SDL_RenderDebugText(renderer, x, y, text);
}

static bool cluck_set_window_title(SDL_Window *window, const char *title) {
  return SDL_SetWindowTitle(window, title);
}

static char cluck_render_target_pixel_buffer[64];

static const char *cluck_render_target_pixel_rgba(SDL_Renderer *renderer, int x, int y) {
  SDL_Rect rect;
  SDL_Surface *surface;
  Uint8 r = 0;
  Uint8 g = 0;
  Uint8 b = 0;
  Uint8 a = 0;

  cluck_render_target_pixel_buffer[0] = 0;
  if (!renderer) {
    return cluck_render_target_pixel_buffer;
  }

  rect.x = x;
  rect.y = y;
  rect.w = 1;
  rect.h = 1;
  surface = SDL_RenderReadPixels(renderer, &rect);
  if (!surface) {
    return cluck_render_target_pixel_buffer;
  }

  if (surface->w < 1 || surface->h < 1) {
    SDL_DestroySurface(surface);
    return cluck_render_target_pixel_buffer;
  }

  if (!SDL_ReadSurfacePixel(surface, 0, 0, &r, &g, &b, &a)) {
    SDL_DestroySurface(surface);
    return cluck_render_target_pixel_buffer;
  }

  SDL_DestroySurface(surface);
  snprintf(cluck_render_target_pixel_buffer,
           sizeof(cluck_render_target_pixel_buffer),
           \"%u,%u,%u,%u\",
           (unsigned int)r,
           (unsigned int)g,
           (unsigned int)b,
           (unsigned int)a);
  return cluck_render_target_pixel_buffer;
}

static SDL_Texture *cluck_create_canvas_texture(SDL_Renderer *renderer, int width, int height) {
  SDL_Texture *texture = SDL_CreateTexture(renderer, SDL_PIXELFORMAT_RGBA8888, SDL_TEXTUREACCESS_TARGET, width, height);
  if (texture) {
    SDL_SetTextureBlendMode(texture, SDL_BLENDMODE_BLEND);
  }
  return texture;
}

static SDL_Texture *cluck_create_soft_brush_texture(SDL_Renderer *renderer, int diameter, float hardness) {
  if (diameter < 4) {
    diameter = 4;
  }
  if (hardness < 0.0f) {
    hardness = 0.0f;
  }
  if (hardness > 1.0f) {
    hardness = 1.0f;
  }

  SDL_Surface *surface = SDL_CreateSurface(diameter, diameter, SDL_PIXELFORMAT_RGBA8888);
  if (!surface) {
    return NULL;
  }

  const SDL_PixelFormatDetails *details = SDL_GetPixelFormatDetails(surface->format);
  SDL_Palette *palette = SDL_GetSurfacePalette(surface);
  Uint32 *pixels = (Uint32 *)surface->pixels;
  int pitch = surface->pitch / (int)sizeof(Uint32);
  float radius = ((float)diameter - 1.0f) * 0.5f;
  float inner = radius * hardness;
  float outer = radius;

  for (int y = 0; y < diameter; ++y) {
    for (int x = 0; x < diameter; ++x) {
      float dx = (float)x - radius;
      float dy = (float)y - radius;
      float dist = sqrtf(dx * dx + dy * dy);
      Uint8 alpha = 0;

      if (dist <= inner) {
        alpha = 255;
      }
      else if (dist < outer) {
        float t = (dist - inner) / (outer - inner);
        float v = 1.0f - t;
        alpha = (Uint8)(255.0f * v * v);
      }

      pixels[y * pitch + x] = SDL_MapRGBA(details, palette, 255, 255, 255, alpha);
    }
  }

  SDL_Texture *texture = SDL_CreateTextureFromSurface(renderer, surface);
  SDL_DestroySurface(surface);
  if (texture) {
    SDL_SetTextureBlendMode(texture, SDL_BLENDMODE_BLEND);
    SDL_SetTextureScaleMode(texture, SDL_SCALEMODE_LINEAR);
  }
  return texture;
}

static SDL_Texture *cluck_create_soft_strip_texture(SDL_Renderer *renderer, int width, int height, float hardness) {
  if (width < 4) {
    width = 4;
  }
  if (height < 4) {
    height = 4;
  }
  if (hardness < 0.0f) {
    hardness = 0.0f;
  }
  if (hardness > 1.0f) {
    hardness = 1.0f;
  }

  SDL_Surface *surface = SDL_CreateSurface(width, height, SDL_PIXELFORMAT_RGBA8888);
  if (!surface) {
    return NULL;
  }

  const SDL_PixelFormatDetails *details = SDL_GetPixelFormatDetails(surface->format);
  SDL_Palette *palette = SDL_GetSurfacePalette(surface);
  Uint32 *pixels = (Uint32 *)surface->pixels;
  int pitch = surface->pitch / (int)sizeof(Uint32);
  float radius = ((float)height - 1.0f) * 0.5f;
  float inner = radius * hardness;
  float outer = radius;

  for (int y = 0; y < height; ++y) {
    float dy = fabsf((float)y - radius);
    Uint8 alpha = 0;

    if (dy <= inner) {
      alpha = 255;
    }
    else if (dy < outer) {
      float t = (dy - inner) / (outer - inner);
      float v = 1.0f - t;
      alpha = (Uint8)(255.0f * v * v);
    }

    Uint32 pixel = SDL_MapRGBA(details, palette, 255, 255, 255, alpha);
    for (int x = 0; x < width; ++x) {
      pixels[y * pitch + x] = pixel;
    }
  }

  SDL_Texture *texture = SDL_CreateTextureFromSurface(renderer, surface);
  SDL_DestroySurface(surface);
  if (texture) {
    SDL_SetTextureBlendMode(texture, SDL_BLENDMODE_BLEND);
    SDL_SetTextureScaleMode(texture, SDL_SCALEMODE_LINEAR);
  }
  return texture;
}

static bool cluck_render_soft_segment(SDL_Renderer *renderer,
                                      SDL_Texture *strip,
                                      SDL_Texture *brush,
                                      float x1,
                                      float y1,
                                      float size1,
                                      Uint8 alpha1,
                                      float x2,
                                      float y2,
                                      float size2,
                                      Uint8 alpha2,
                                      Uint8 r,
                                      Uint8 g,
                                      Uint8 b) {
  if (!renderer || !brush) {
    return false;
  }

  float dx = x2 - x1;
  float dy = y2 - y1;
  float length = sqrtf(dx * dx + dy * dy);
  float start_size = size1 > 1.0f ? size1 : 1.0f;
  float end_size = size2 > 1.0f ? size2 : 1.0f;
  float body_size = (start_size + end_size) * 0.5f;
  float body_alpha = ((float)alpha1 + (float)alpha2) * 0.5f;
  if (body_size < 1.0f) {
    body_size = 1.0f;
  }
  SDL_SetTextureColorMod(brush, r, g, b);
  if (length > 0.01f && strip) {
    SDL_FRect body_rect;
    SDL_FPoint center;
    float mid_x = (x1 + x2) * 0.5f;
    float mid_y = (y1 + y2) * 0.5f;
    double angle = atan2((double)dy, (double)dx) * (180.0 / M_PI);
    int body_alpha_value = (int)roundf(body_alpha);
    if (body_alpha_value < 0) {
      body_alpha_value = 0;
    }
    if (body_alpha_value > 255) {
      body_alpha_value = 255;
    }
    SDL_SetTextureColorMod(strip, r, g, b);
    SDL_SetTextureAlphaMod(strip, (Uint8)body_alpha_value);
    body_rect.x = mid_x - ((length + body_size) * 0.5f);
    body_rect.y = mid_y - (body_size * 0.5f);
    body_rect.w = length + body_size;
    body_rect.h = body_size;
    center.x = body_rect.w * 0.5f;
    center.y = body_rect.h * 0.5f;
    SDL_RenderTextureRotated(renderer, strip, NULL, &body_rect, angle, &center, SDL_FLIP_NONE);
  }

  return true;
}

static bool cluck_set_render_target(SDL_Renderer *renderer, SDL_Texture *texture) {
  return SDL_SetRenderTarget(renderer, texture);
}

static bool cluck_clear_render_target(SDL_Renderer *renderer) {
  return SDL_SetRenderTarget(renderer, NULL);
}

static bool cluck_render_texture(SDL_Renderer *renderer, SDL_Texture *texture) {
  return SDL_RenderTexture(renderer, texture, NULL, NULL);
}

static bool cluck_render_texture_at(SDL_Renderer *renderer, SDL_Texture *texture, float x, float y, float w, float h) {
  SDL_FRect rect;
  rect.x = x;
  rect.y = y;
  rect.w = w;
  rect.h = h;
  return SDL_RenderTexture(renderer, texture, NULL, &rect);
}

static bool cluck_set_texture_color_mod(SDL_Texture *texture, Uint8 r, Uint8 g, Uint8 b) {
  return SDL_SetTextureColorMod(texture, r, g, b);
}

static bool cluck_set_texture_alpha_mod(SDL_Texture *texture, Uint8 a) {
  return SDL_SetTextureAlphaMod(texture, a);
}

static void cluck_destroy_texture(SDL_Texture *texture) {
  SDL_DestroyTexture(texture);
}
")

