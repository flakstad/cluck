  "Update the active line drag to WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [active-line (get state :active-line)]
    (if active-line
      (draw.view/draw-sync-pointer-state
        (assoc state
               :active-line (assoc (draw.geometry/draw-line-record (get active-line :start)
                                                                    point
