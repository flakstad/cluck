(defn draw-start-line
  "Start a line drag from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [state (draw.history/draw-push-history! state)
        active-line (assoc (draw.geometry/draw-line-record point
                                                           point
                                                           (draw.history/draw-stroke-color state)
                                                           (get state :brush-size))
                           :opacity (draw-active-opacity state))]
    (draw.view/draw-sync-pointer-state
      (assoc state
             :pointer-down? true
             :pointer-source :line
             :active-stroke false
             :active-selection-resize false
             :active-selection-rotate false
             :active-selection-marquee false
             :active-box false
             :active-arrow false
             :active-circle false
             :active-frame false
             :active-text false
             :active-line active-line)
