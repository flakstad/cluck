;; Pure draw element-creation interaction helpers.

(ns cluck.examples.draw.create
  (:require [cluck.examples.draw.history :as draw.history]
            [cluck.examples.draw.state :as draw.state]
            [cluck.examples.draw.view :as draw.view]
            [cluck.examples.draw.geometry :as draw.geometry]))

(defn draw-active-opacity
  "Return the opacity setting used for new or updated active elements."
  [state]
  (draw.state/draw-current-opacity state))

(defn draw-start-box
  "Start a rectangle drag from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [state (draw.history/draw-push-history! state)
        active-box (assoc (draw.geometry/draw-box-record point
                                                         point
                                                         (draw.history/draw-stroke-color state)
                                                         (get state :brush-size))
                          :opacity (draw-active-opacity state))]
  (draw.view/draw-sync-pointer-state
    (assoc state
           :pointer-down? true
           :pointer-source :box
           :active-stroke false
           :active-selection-resize false
           :active-selection-rotate false
           :active-selection-marquee false
           :active-arrow false
           :active-circle false
           :active-line false
           :active-frame false
           :active-text false
           :active-box active-box)
    point
      screen-point)))

(defn draw-start-arrow
  "Start an arrow drag from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [state (draw.history/draw-push-history! state)
        active-arrow (assoc (draw.geometry/draw-arrow-record point
                                                             point
                                                             (draw.history/draw-stroke-color state)
                                                             (get state :brush-size))
                            :opacity (draw-active-opacity state))]
  (draw.view/draw-sync-pointer-state
    (assoc state
           :pointer-down? true
           :pointer-source :arrow
           :active-stroke false
           :active-selection-resize false
           :active-selection-rotate false
           :active-selection-marquee false
           :active-box false
           :active-circle false
           :active-line false
           :active-frame false
           :active-text false
           :active-arrow active-arrow)
    point
      screen-point)))

