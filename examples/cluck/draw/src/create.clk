  "Update the active circle drag to WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [active-circle (get state :active-circle)]
    (if active-circle
      (draw.view/draw-sync-pointer-state
        (assoc state
               :active-circle (assoc (draw.geometry/draw-circle-record (get active-circle :start)
                                                                        point
                                                                        (get active-circle :color)
                                                                        (get active-circle :size))
                                     :opacity (get active-circle :opacity)))
        point
        screen-point)
      (draw-start-circle state point screen-point))))

