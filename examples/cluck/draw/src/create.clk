  "Start a legacy frame drag from WORLD-POINT and SCREEN-POINT."
  [state point screen-point]
  (let [state (draw.history/draw-push-history! state)
        active-frame (assoc (draw.geometry/draw-frame-record point
                                                             point
                                                             (draw.history/draw-stroke-color state)
                                                             (get state :brush-size))
                            :opacity (draw-active-opacity state))]
  (draw.view/draw-sync-pointer-state
    (assoc state
           :pointer-down? true
           :pointer-source :frame
           :active-stroke false
           :active-selection-resize false
           :active-selection-rotate false
           :active-selection-marquee false
           :active-box false
           :active-arrow false
           :active-circle false
           :active-line false
           :active-text false
           :active-frame active-frame)
    point
    screen-point)))

