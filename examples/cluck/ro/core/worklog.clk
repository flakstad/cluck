;; Pure worklog-surface helpers for the Ro CLI spike.

(ns cluck.examples.ro.core.worklog
  (:require [cluck.string :as str]
            [cluck.examples.ro.core.cli :as cli]))

(def cli-top-level-command-spec cli/top-level-command-spec)

(def cli-dispatch cli/dispatch)

(defn help-flag?
  [arg]
  (or (string=? arg "help")
      (string=? arg "--help")
      (string=? arg "-h")))

(defn any-help-arg?
  [args]
  (let loop ((xs (seq args)))
    (cond
      (empty? xs) false
      (help-flag? (car xs)) true
      :else (loop (cdr xs)))))

(def worklog-help-lines
  (list
   "ro worklog"
   ""
   "usage:"
   "  ro worklog list <item-id> [--limit N] [--offset N]"
   "  ro worklog add <item-id> --body \"...\""))

(def worklog-help-text
  (str/join "\n" worklog-help-lines))

(def worklog-help-output
  (string-append worklog-help-text "\n"))

(defn worklog-list-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "worklog")
                             (cons "list" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:worklog/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false
         :error "ro worklog list expects <item-id>"
         :command args}

        (equal? (get result :reason) :missing-flag-value)
        (if (and (not (empty? args))
                 (string=? (first args) "--offset"))
            {:ok? false
             :error "ro worklog list expects a value after --offset"
             :command args}
            {:ok? false
             :error "ro worklog list expects a value after --limit"
             :command args})

        (equal? (get result :reason) :invalid-flag-value)
        (if (equal? (get result :flag) :offset)
            {:ok? false
             :error "ro worklog list expects a non-negative --offset"
             :command args}
            {:ok? false
             :error "ro worklog list expects a non-negative --limit"
             :command args})

        (equal? (get result :reason) :unknown-flag)
        {:ok? false
         :error "unsupported worklog list flag"
         :command args}

        :else
        {:ok? false
         :error "unexpected worklog list argument"
         :command args})

      :else
      (let [item-id (get (get result :arguments) :item-id "")
            limit (get (get result :flags) :limit 200)
            offset (get (get result :flags) :offset 0)]
        (cond
          (< limit 0)
          {:ok? false
           :error "ro worklog list expects a non-negative --limit"
           :command args}

          (< offset 0)
          {:ok? false
           :error "ro worklog list expects a non-negative --offset"
           :command args}

          :else
          {:ok? true
           :effects [[:worklog/list {:item-id item-id
                                     :limit limit
                                     :offset offset}]]})))))

(defn worklog-add-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "worklog")
                             (cons "add" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:worklog/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false
         :error "ro worklog add expects <item-id>"
         :command args}

        (equal? (get result :reason) :missing-required-flag)
        {:ok? false
         :error "ro worklog add expects --body"
         :command args}

        (equal? (get result :reason) :missing-flag-value)
        {:ok? false
         :error "ro worklog add expects a value after --body"
         :command args}

        (equal? (get result :reason) :unknown-flag)
        {:ok? false
         :error "unsupported worklog add flag"
         :command args}

        :else
        {:ok? false
         :error "unexpected worklog add argument"
         :command args})

      :else
      {:ok? true
       :effects [[:worklog/add {:item-id (get (get result :arguments) :item-id "")
                                :body (get (get result :flags) :body "")}]]})))

(defn worklog-main-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "worklog") args)]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:worklog/help {}]]}

      (equal? (get result :status) :error)
      {:ok? false
       :error "ro worklog commands are not implemented yet"
       :command args}

      (string=? (get (get result :spec) :name) "list")
      (worklog-list-plan (rest args))

      (string=? (get (get result :spec) :name) "add")
      (worklog-add-plan (rest args))

      :else
      {:ok? false
       :error "ro worklog commands are not implemented yet"
       :command args})))
