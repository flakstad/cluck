       :effects [[:workspace/migrate {}]]})))

(defn init-main-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "init") args)]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:init/help {}]]}

      (equal? (get result :status) :error)
      {:ok? false
       :error "ro init expects no arguments"
       :command args}

      :else
      {:ok? true
       :effects [[:init/run {}]]})))

(defn workspace-main-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "workspace") args)]
    (cond
      (equal? (get result :status) :help)
      (let [name (get (get result :spec) :name)]
        (cond
          (or (string=? name "workspace")
              (string=? name "current")
              (string=? name "list"))
          {:ok? true
           :effects [[:workspace/help {}]]}

          (string=? name "add")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-add-usage-output
                                          :root? true}]]}

          (string=? name "init")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-init-usage-output
                                          :root? true}]]}

          (string=? name "use")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-use-usage-output
                                          :root? false}]]}

          (string=? name "forget")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-forget-usage-output
                                          :root? false}]]}

          (string=? name "archive")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-archive-usage-output
                                          :root? false}]]}

          (string=? name "unarchive")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-unarchive-usage-output
                                          :root? false}]]}

          (string=? name "rename")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-rename-usage-output
                                          :root? false}]]}

          (string=? name "delete")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-delete-usage-output
                                          :root? false}]]}

          (string=? name "export")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-export-usage-output
                                          :root? false}]]}

          (string=? name "import")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-import-usage-output
                                          :root? false}]]}

          (string=? name "migrate")
          {:ok? true
           :effects [[:workspace/subhelp {:usage workspace-migrate-usage-output
                                          :root? false}]]}

          :else
          {:ok? true
           :effects [[:workspace/help {}]]}))

      (equal? (get result :status) :error)
      (let [name (get (get result :spec) :name)]
        (cond
          (string=? name "add")
          (workspace-add-plan (rest args))

          (string=? name "init")
          (workspace-init-plan (rest args))

          (string=? name "use")
          (workspace-use-plan (rest args))

          (string=? name "forget")
          (workspace-flagless-name-plan "forget" (rest args) workspace-forget-usage-output "ro workspace forget expects <name>" :workspace/forget)

          (string=? name "archive")
          (workspace-flagless-name-plan "archive" (rest args) workspace-archive-usage-output "ro workspace archive expects <name>" :workspace/archive)

          (string=? name "unarchive")
          (workspace-flagless-name-plan "unarchive" (rest args) workspace-unarchive-usage-output "ro workspace unarchive expects <name>" :workspace/unarchive)

          (string=? name "rename")
          (workspace-rename-plan (rest args))

          (string=? name "delete")
          (workspace-delete-plan (rest args))

          (string=? name "export")
          (workspace-export-plan (rest args))

          (string=? name "import")
          (workspace-import-plan (rest args))

          (string=? name "migrate")
          (workspace-migrate-plan (rest args))

          :else
          {:ok? false
           :error "ro workspace commands are not implemented yet"
           :command args}))

      (string=? (get (get result :spec) :name) "current")
      {:ok? true
       :effects [[:workspace/current {}]]}

      (string=? (get (get result :spec) :name) "list")
      {:ok? true
       :effects [[:workspace/list {}]]}

      (string=? (get (get result :spec) :name) "forget")
      {:ok? true
       :effects [[:workspace/forget {:name (get (get result :arguments) :name "")}]]}

      (string=? (get (get result :spec) :name) "add")
      {:ok? true
       :effects [[:workspace/add {:name (get (get result :arguments) :name "")
                                  :dir (get (get result :flags) :dir "")
                                  :kind (get (get result :flags) :kind "git")
                                  :use? (get (get result :flags) :use false)}]]}

      (string=? (get (get result :spec) :name) "init")
      {:ok? true
       :effects [[:workspace/init {:name (get (get result :arguments) :name "")
                                   :dir (get (get result :flags) :dir "")
                                   :use? (get (get result :flags) :use false)}]]}

      (string=? (get (get result :spec) :name) "use")
      {:ok? true
       :effects [[:workspace/use {:name (get (get result :arguments) :name "")}]]}

      (string=? (get (get result :spec) :name) "archive")
      {:ok? true
       :effects [[:workspace/archive {:name (get (get result :arguments) :name "")}]]}

      (string=? (get (get result :spec) :name) "unarchive")
      {:ok? true
       :effects [[:workspace/unarchive {:name (get (get result :arguments) :name "")}]]}

      (string=? (get (get result :spec) :name) "rename")
      {:ok? true
       :effects [[:workspace/rename {:from (get (get result :arguments) :from "")
                                     :to (get (get result :arguments) :to "")}]]}

      (string=? (get (get result :spec) :name) "delete")
      {:ok? true
       :effects [[:workspace/delete {:name (get (get result :arguments) :name "")
                                     :yes? (get (get result :flags) :yes false)
                                     :force-legacy? (get (get result :flags) :force-legacy false)}]]}

      (string=? (get (get result :spec) :name) "export")
      {:ok? true
       :effects [[:workspace/export {:to (get (get result :flags) :to "")
                                     :events? (get (get result :flags) :events false)
                                     :force? (get (get result :flags) :force false)}]]}

      (string=? (get (get result :spec) :name) "import")
      {:ok? true
       :effects [[:workspace/import {:name (let [arg-name (get (get result :arguments) :name "")]
                                             (if (string=? arg-name "")
                                                 (get (get result :flags) :name "")
                                                 arg-name))
                                     :from (get (get result :flags) :from "")
                                     :force? (get (get result :flags) :force false)
                                     :use? (get (get result :flags) :use false)
                                     :events? (get (get result :flags) :events false)}]]}

      (string=? (get (get result :spec) :name) "migrate")
      {:ok? true
       :effects [[:workspace/migrate {}]]}

      :else
      {:ok? false
       :error "ro workspace commands are not implemented yet"
       :command args})))

(defn identity-main-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "identity") args)]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:identity/help {}]]}

      (equal? (get result :status) :error)
      (let [name (get (get result :spec) :name)]
        (cond
          (string=? name "whoami")
          {:ok? false
           :error "unexpected identity whoami argument"
           :command args}

          (string=? name "list")
          {:ok? false
           :error "unexpected identity list argument"
           :command args}

          (string=? name "create")
          (cond
            (equal? (get result :reason) :missing-required-flag)
            {:ok? false
             :error "ro identity create expects --name <name>"
             :command args}

            (equal? (get result :reason) :missing-flag-value)
            {:ok? false
             :error "ro identity create expects a value after the flag"
             :command args}

            (equal? (get result :reason) :unknown-flag)
            {:ok? false
             :error "unsupported identity create flag"
             :command args}

            :else
            {:ok? false
             :error "unexpected identity create argument"
             :command args})

          (string=? name "use")
          (if (equal? (get result :reason) :missing-argument)
              {:ok? false
               :error "ro identity use expects <actor-id>"
               :command args}
              {:ok? false
               :error "unexpected identity use argument"
               :command args})

          (string=? name "ensure")
          (cond
            (equal? (get result :reason) :missing-flag-value)
            {:ok? false
             :error "ro identity agent ensure expects a value after the flag"
             :command args}

            (equal? (get result :reason) :unknown-flag)
            {:ok? false
             :error "unsupported identity agent ensure flag"
             :command args}

            :else
            {:ok? false
             :error "unexpected identity agent ensure argument"
             :command args})

          :else
          {:ok? false
           :error "unsupported identity subcommand"
           :command args}))

      (string=? (get (get result :spec) :name) "whoami")
      {:ok? true
       :effects [[:identity/whoami {}]]}

      (string=? (get (get result :spec) :name) "list")
      {:ok? true
       :effects [[:identity/list {}]]}

      (string=? (get (get result :spec) :name) "create")
      {:ok? true
       :effects [[:identity/create {:name (get (get result :flags) :name "")
                                    :kind (get (get result :flags) :kind "human")
                                    :user (get (get result :flags) :user "")
                                    :use? (get (get result :flags) :use false)}]]}

      (string=? (get (get result :spec) :name) "use")
      {:ok? true
       :effects [[:identity/use {:actor-id (get (get result :arguments) :actor-id "")}]]}

      (string=? (get (get result :spec) :name) "ensure")
      {:ok? true
       :effects [[:identity/agent-ensure {:session (get (get result :flags) :session "")
                                          :name (get (get result :flags) :name "")
                                          :user (get (get result :flags) :user "")
                                          :use? (get (get result :flags) :use false)}]]}

      :else
      {:ok? false
       :error "unsupported identity subcommand"
       :command args})))
