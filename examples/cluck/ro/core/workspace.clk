  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "workspace")
                             (cons "init" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:workspace/subhelp {:usage workspace-init-usage-output
                                      :root? true}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-flag-value)
        {:ok? false
         :error "missing workspace dir"
         :command args}

        (equal? (get result :reason) :missing-argument)
        {:ok? false
         :error "ro workspace init expects <name>"
         :command args}

        (equal? (get result :reason) :unknown-flag)
        {:ok? false
         :error "unsupported workspace init flag"
         :command args}

        :else
        {:ok? false
         :error "unexpected workspace init argument"
         :command args})

      :else
      {:ok? true
       :effects [[:workspace/init {:name (get (get result :arguments) :name "")
                                   :dir (get (get result :flags) :dir "")
                                   :use? (get (get result :flags) :use false)}]]})))

(defn workspace-use-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "workspace")
                             (cons "use" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:workspace/subhelp {:usage workspace-use-usage-output
                                      :root? false}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false
         :error "ro workspace use expects <name>"
         :command args}

        :else
        {:ok? false
         :error "unexpected workspace use argument"
         :command args})

      :else
      {:ok? true
       :effects [[:workspace/use {:name (get (get result :arguments) :name "")}]]})))

(defn workspace-flagless-name-plan
  [subcommand args usage error-prefix tag]
  (let [result (cli-dispatch (cli-top-level-command-spec "workspace")
                             (cons subcommand args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:workspace/subhelp {:usage usage
                                      :root? false}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false
         :error error-prefix
         :command args}

        :else
        {:ok? false
         :error (string-append "unexpected workspace " subcommand " argument")
         :command args})

      :else
      {:ok? true
       :effects [[tag {:name (get (get result :arguments) :name "")}]]})))

