(defn items-unary-flag-plan
  [subcommand args required-flag error-prefix effect-key value-builder]
  (let [result (cli-dispatch (cli-top-level-command-spec "items")
                             (cons subcommand args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true :effects [[:items/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false :error (string-append error-prefix " expects <item-id>") :command args}

        (equal? (get result :reason) :missing-required-flag)
        {:ok? false :error (string-append error-prefix " expects " required-flag) :command args}

        (equal? (get result :reason) :missing-flag-value)
        {:ok? false :error (string-append error-prefix " expects a value after the flag") :command args}

        (equal? (get result :reason) :unknown-flag)
        {:ok? false :error (string-append "unsupported " subcommand " flag") :command args}

        :else
        {:ok? false :error (string-append "unexpected " subcommand " argument") :command args})

      :else
      {:ok? true
       :effects [[effect-key (value-builder result)]]})))

(defn items-bool-toggle-plan
  [subcommand args effect-key]
  (let [result (cli-dispatch (cli-top-level-command-spec "items")
                             (cons subcommand args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true :effects [[:items/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false :error (string-append "ro items " subcommand " expects <item-id>") :command args}

        (equal? (get result :reason) :unknown-flag)
        {:ok? false :error (string-append "unsupported items " subcommand " flag") :command args}

        :else
        {:ok? false :error (string-append "unexpected items " subcommand " argument") :command args})

      :else
      (let [flags (get result :flags)
            on? (get flags :on false)
            off? (get flags :off false)]
        (if (equal? on? off?)
            {:ok? false
             :error (string-append "ro items " subcommand " expects exactly one of --on or --off")
             :command args}
            {:ok? true
             :effects [[effect-key {:item-id (get (get result :arguments) :item-id "")
                                    :value on?}]]})))))

(defn items-set-title-plan
  [args]
  (items-unary-flag-plan
   "set-title" args "--title <title>" "ro items set-title" :items/set-title
   (fn [result]
     {:item-id (get (get result :arguments) :item-id "")
      :title (get (get result :flags) :title "")})))

