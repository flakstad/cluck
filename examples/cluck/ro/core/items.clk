(defn items-main-plan
  [args]
  (if (and (not (empty? args))
           (string=? (first args) "tags"))
      (items-tags-plan (rest args))
      (let [result (cli-dispatch (cli-top-level-command-spec "items") args)]
        (cond
          (equal? (get result :status) :help)
          {:ok? true
           :effects [[:items/help {}]]}

          (equal? (get result :status) :error)
          {:ok? false
           :error "ro items commands are not implemented yet"
           :command args}

          (string=? (get (get result :spec) :name) "create")
          (items-create-plan (rest args))

          (string=? (get (get result :spec) :name) "copy")
          (items-copy-plan (rest args))

          (string=? (get (get result :spec) :name) "show")
          (items-show-plan (rest args))

          (string=? (get (get result :spec) :name) "list")
          (items-list-plan (rest args))

          (string=? (get (get result :spec) :name) "set-status")
          (items-set-status-plan (rest args))

          (string=? (get (get result :spec) :name) "set-assign")
          (items-set-assign-plan (rest args))

          (string=? (get (get result :spec) :name) "set-title")
          (items-set-title-plan (rest args))

          (string=? (get (get result :spec) :name) "set-description")
          (items-set-description-plan (rest args))

          (string=? (get (get result :spec) :name) "set-priority")
          (items-set-priority-plan (rest args))

          (string=? (get (get result :spec) :name) "set-on-hold")
          (items-set-on-hold-plan (rest args))

          (string=? (get (get result :spec) :name) "set-children-checkbox")
          (items-set-children-checkbox-plan (rest args))

          (string=? (get (get result :spec) :name) "set-item-kind")
          (items-set-item-kind-plan (rest args))

          (string=? (get (get result :spec) :name) "set-due")
          (items-set-due-plan (rest args))

          (string=? (get (get result :spec) :name) "set-schedule")
          (items-set-schedule-plan (rest args))

          (string=? (get (get result :spec) :name) "claim")
          (items-claim-plan (rest args))

          (string=? (get (get result :spec) :name) "tags")
          (items-tags-plan (rest args))

          (string=? (get (get result :spec) :name) "move")
          (items-move-plan (rest args))

          (string=? (get (get result :spec) :name) "set-parent")
          (items-set-parent-plan (rest args))

          (string=? (get (get result :spec) :name) "move-outline")
          (items-move-outline-plan (rest args))

          (string=? (get (get result :spec) :name) "ready")
          (items-ready-plan (rest args))

          (string=? (get (get result :spec) :name) "events")
          (items-events-plan (rest args))

          (string=? (get (get result :spec) :name) "archive")
          (items-archive-plan (rest args))

          :else
          {:ok? false
           :error "ro items commands are not implemented yet"
           :command args}))))

(defn item-main-plan
  [args]
  (let [item-id (if (empty? args)
                  ""
                  (first args))
        more (if (empty? args)
               '()
               (rest args))]
    (cond
      (string=? item-id "")
      {:ok? false
       :error "ro item expects <item-id>"
       :command args}

      (not (empty? more))
      {:ok? false
       :error "unexpected item argument"
       :command args}

      :else
      {:ok? true
       :effects [[:items/show {:item-id item-id}]]})))
