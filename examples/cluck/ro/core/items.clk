      {:ok? true
       :effects [[:items/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-required-flag)
        {:ok? false
         :error "ro items create expects --title <title>"
         :command args}

        (equal? (get result :reason) :missing-flag-value)
        {:ok? false
         :error "ro items create expects a value after the flag"
         :command args}

        (equal? (get result :reason) :unknown-flag)
        {:ok? false
         :error "unsupported items create flag"
         :command args}

        :else
        {:ok? false
         :error "unexpected items create argument"
         :command args})

      :else
      {:ok? true
       :effects [[:items/create {:title (get (get result :flags) :title "")
                                 :parent-id (get (get result :flags) :parent "")
                                 :outline-id (get (get result :flags) :outline "")
                                 :project-id (get (get result :flags) :project "")}]]})))

