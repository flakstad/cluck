(defn items-list-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "items")
                             (cons "list" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:items/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-flag-value)
        (cond
          (and (not (empty? args))
               (string=? (first args) "--project"))
          {:ok? false
           :error "missing items project id"
           :command args}

          (and (not (empty? args))
               (string=? (first args) "--outline"))
          {:ok? false
           :error "missing items outline id"
           :command args}

          :else
          {:ok? false
           :error "missing items status"
           :command args})

        (equal? (get result :reason) :unknown-flag)
        {:ok? false
         :error "unsupported items list flag"
         :command args}

        :else
        {:ok? false
         :error "unexpected items list argument"
         :command args})

      :else
      {:ok? true
       :effects [[:items/list {:project-id (get (get result :flags) :project "")
                               :outline-id (get (get result :flags) :outline "")
                               :status (get (get result :flags) :status "")}]]})))

