(defn items-events-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "items")
                             (cons "events" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true
       :effects [[:items/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false
         :error "ro items events expects <item-id>"
         :command args}

        (equal? (get result :reason) :missing-flag-value)
        {:ok? false
         :error "ro items events expects a value after --limit"
         :command args}

        (equal? (get result :reason) :invalid-flag-value)
        {:ok? false
         :error "ro items events expects a non-negative --limit"
         :command args}

        (equal? (get result :reason) :unknown-flag)
        {:ok? false
         :error "unsupported items events flag"
         :command args}

        :else
        {:ok? false
         :error "unexpected items events argument"
         :command args})

      :else
      (let [limit (get (get result :flags) :limit 0)]
        (if (< limit 0)
            {:ok? false
             :error "ro items events expects a non-negative --limit"
             :command args}
            {:ok? true
             :effects [[:items/events {:item-id (get (get result :arguments) :item-id "")
                                       :limit limit}]]})))))

