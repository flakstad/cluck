(defn items-tags-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "items")
                             (cons "tags" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true :effects [[:items/help {}]]}

      (equal? (get result :status) :error)
      {:ok? false :error "ro items tags commands are not implemented yet" :command args}

      (string=? (get (get result :spec) :name) "add")
      {:ok? true
       :effects [[:items/tags-add {:item-id (get (get result :arguments) :item-id "")
                                   :tag (get (get result :flags) :tag "")}]]}

      (string=? (get (get result :spec) :name) "remove")
      {:ok? true
       :effects [[:items/tags-remove {:item-id (get (get result :arguments) :item-id "")
                                      :tag (get (get result :flags) :tag "")}]]}

      (string=? (get (get result :spec) :name) "set")
      {:ok? true
       :effects [[:items/tags-set {:item-id (get (get result :arguments) :item-id "")
                                   :tags (get (get result :flags) :tags "")}]]}

      :else
      {:ok? false :error "unsupported items tags subcommand" :command args})))

(defn items-move-plan
  [args]
  (let [result (cli-dispatch (cli-top-level-command-spec "items")
                             (cons "move" args))]
    (cond
      (equal? (get result :status) :help)
      {:ok? true :effects [[:items/help {}]]}

      (equal? (get result :status) :error)
      (cond
        (equal? (get result :reason) :missing-argument)
        {:ok? false :error "ro items move expects <item-id>" :command args}

        (equal? (get result :reason) :missing-flag-value)
        {:ok? false :error "ro items move expects a value after the flag" :command args}

        (equal? (get result :reason) :unknown-flag)
        {:ok? false :error "unsupported items move flag" :command args}

        :else
        {:ok? false :error "unexpected items move argument" :command args})

      :else
      (let [flags (get result :flags)
            before-id (get flags :before "")
            after-id (get flags :after "")]
        (if (or (and (string=? before-id "") (string=? after-id ""))
                (and (not (string=? before-id "")) (not (string=? after-id ""))))
            {:ok? false
             :error "ro items move expects exactly one of --before or --after"
             :command args}
            {:ok? true
             :effects [[:items/move {:item-id (get (get result :arguments) :item-id "")
                                     :before-id before-id
                                     :after-id after-id}]]})))))

