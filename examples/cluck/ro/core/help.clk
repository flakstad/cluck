(defn help-flag?
  [arg]
  (or (string=? arg "help")
      (string=? arg "--help")
      (string=? arg "-h")))

(defn help-request?
  [args]
  (if (empty? args)
      true
      (let [command (first args)]
        (help-flag? command))))

(defn completion-help-request?
  [args]
  (if (empty? args)
      false
      (help-flag? (first args))))

(defn completion-output
  [shell]
  (cond
    (string=? shell "bash") completion-bash-output
    (string=? shell "zsh") completion-zsh-output
    (string=? shell "fish") completion-fish-output
    :else false))
