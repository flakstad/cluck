;; Pure help-surface helpers for the Ro CLI spike.

(ns cluck.examples.ro.core.help
  (:require [cluck.io :as io]
            [cluck.string :as str]
            [json :as json]
            [cluck.examples.ro.core.commands :as commands]
            [cluck.examples.ro.core.cli :as cli]
            [cluck.examples.ro.core.cli.completions :as cli-completions]))

(defn compact-json-step
  [text i len in-string? escaped? acc]
  (if (= i len)
      (list->string (reverse acc))
      (let [ch (string-ref text i)]
        (cond
          escaped?
          (compact-json-step text (+ i 1) len in-string? false (cons ch acc))

          (char=? ch #\")
          (compact-json-step text (+ i 1) len (not in-string?) false (cons ch acc))

          (and in-string?
               (char=? ch #\\))
          (compact-json-step text (+ i 1) len true true (cons ch acc))

          in-string?
          (compact-json-step text (+ i 1) len true false (cons ch acc))

          (char-whitespace? ch)
          (compact-json-step text (+ i 1) len false false acc)

          :else
          (compact-json-step text (+ i 1) len false false (cons ch acc))))))

(defn compact-json-text
  [text]
  (compact-json-step text 0 (string-length text) false false '()))

(defn json-write-output
  [value]
  (string-append
   (compact-json-text
    (io/with-output-string
     (fn [port]
       (json/json-write value port))))
   "\n"))

(def commands-command-root-help-lines commands/command-root-help-lines)

(def commands-top-commands commands/command-top-commands)

(def cli-docs-topics cli/docs-topics)

(def cli-command-help-lines cli/command-help-lines)

(def cli-top-level-command-spec cli/top-level-command-spec)

(def cli-render-command-help cli/render-command-help)

(def cli-completion-command-line cli/completion-command-line)

(def cli-docs-topics-line cli/docs-topics-line)

(def cli-bash-completion-lines cli-completions/bash-completion-lines)

(def cli-zsh-completion-lines cli-completions/zsh-completion-lines)

(def cli-fish-completion-lines cli-completions/fish-completion-lines)

(def root-help-lines
  (append
   (list
    "ro"
    ""
    "usage:"
    "  ro                        # start the TUI"
    "  ro help                   # show this help"
    "  ro <item-id>              # shortcut for: ro items show <item-id>")
   (cdr commands-command-root-help-lines)
   (list
    ""
    "global flags:"
    "  --workspace <name>  Select workspace"
    "  --pretty            Pretty-print JSON output")))

(def root-help-text
  (str/join "\n" root-help-lines))

(def root-help-output
  (string-append root-help-text "\n"))

(def docs-help-lines
  (or (cli-command-help-lines "docs")
      (list
       "ro docs"
       ""
       "usage:"
       "  ro docs"
       "  ro docs <topic>"
       "  ro docs <topic> --raw")))

(def docs-help-text
  (str/join "\n" docs-help-lines))

(def docs-help-output
  (string-append docs-help-text "\n"))

(def docs-topics
  cli-docs-topics)

(def docs-output
  (json-write-output
   (vector (cons 'data
                 (vector (cons 'topics docs-topics))))))

(def projects-help-lines
  (or (cli-command-help-lines "projects")
      (list
       "ro projects"
       ""
       "usage:"
       "  ro projects create --name <name> [--use]"
       "  ro projects list"
       "  ro projects archive <project-id> [--unarchive]"
       "  ro projects use <project-id>"
       "  ro projects current")))

(def projects-help-text
