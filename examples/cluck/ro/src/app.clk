(defn projects-run-effect
  [effect]
  (let ((op (pr-str (vector-ref effect 0)))
        (args (vector-ref effect 1)))
    (cond
      (string=? op ":projects/help")
      (print-projects-help)

      (string=? op ":projects/list")
      (print-projects-list)

      (string=? op ":projects/current")
      (print-projects-current)

      (string=? op ":projects/create")
      (print-projects-create (or (get args :name) "")
                             (or (get args :use?) false))

      (string=? op ":projects/archive")
      (print-projects-archive (or (get args :project-id) "")
                              (or (get args :archived) false))

      (string=? op ":projects/use")
      (print-projects-use (or (get args :project-id) ""))

      :else
      (error "unsupported projects effect" effect))))

(defn projects-run-effects
  [effects]
  (let loop ((xs (or effects '()))
             (result 0))
    (cond
      (empty? xs)
      result

      :else
      (loop (rest xs)
            (projects-run-effect (first xs))))))

