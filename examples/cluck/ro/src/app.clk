                       (or (json-field-value item "description" "") "")
                       (or (json-field-value item "status" "") "")
                       value
                       (or (json-field-value item "onHold" false) false)
                       (or (json-field-value item "archived" false) false)
                       (or (json-field-value item "ownerActorId" "") "")
                       (or (json-field-value item "assignedActorId" "") "")
                       (or (json-field-value item "dueDate" "") "")
                       (or (json-field-value item "scheduleDate" "") "")
                       (or (json-field-value item "tags" '()) '())
                       (or (json-field-value item "itemKind" "") "")
                       (or (json-field-value item "childrenKind" "") "")
                       (or (json-field-value item "createdBy" "") "")
                       (or (json-field-value item "createdAt" "") "")
                       issued-at
