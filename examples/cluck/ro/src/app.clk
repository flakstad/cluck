;; Cluck Ro CLI spike.
;;
;; This first slice captures the root command surface and prints the canonical
;; top-level help text. Command handling will expand slice by slice under tests.

(ns cluck.examples.ro.app
  (:require [cluck.io :as io]
            [cluck.fs :as fs]
            [cluck.process :as proc]
            [cluck.string :as str]
            [json :as json]
            [sqlite3 :as db]))

;; Core surface data and pure helpers are loaded via the bootstrap aliases
;; in `examples/cluck/ro/bootstrap-core-aliases.scm`.

(defn workspace-config-dir
  []
  (let [override (or (get-environment-variable "RO_CONFIG_DIR") "")]
    (if (string=? (str/trim override) "")
        (fs/path (fs/home) ".ro")
        (fs/path override))))

(def workspace-json-path
  (fs/path (workspace-config-dir) "workspaces.json"))

(defn workspace-json-root
  []
  (call-with-input-file workspace-json-path
    (fn [port]
      (json/json-read port))))

(defn workspace-detail-value
  [detail key]
  (let [entry (json-find-entry detail key)]
    (and entry (cdr entry))))

(defn workspace-current-detail
  [details current-name]
  (if (or (not details)
          (null? details))
      #f
      (let loop ((xs (seq details)))
        (cond
          (empty? xs) #f
          (string=? (or (workspace-detail-value (car xs) "name") "")
                    (or current-name ""))
          (car xs)
          :else (loop (cdr xs))))))

(defn workspace-current-output
  []
  (let [info (workspace-current-info)]
    (and info
         (ro-workspace/workspace-current-output (car info) (cdr info)))))

(defn workspace-registry-output
  [root]
  (let [compact
        (io/with-output-string
         (fn [port]
           (json/json-write root port)))]
    (let [result
          (proc/exec
           "python3"
           "-c"
           "import json,sys; print(json.dumps(json.loads(sys.argv[1]), indent=2))"
           compact)]
      (let [exit (or (get result :exit) 1)
            out (or (get result :out) "")]
        (if (= exit 0)
            out
            (string-append compact "\n"))))))

(defn workspace-list-output
  []
  (workspace-registry-output (workspace-registry-root)))

(defn workspace-current-info
  []
  (let [root (workspace-json-root)]
    (let [data-entry (json-find-entry root "data")
          data (and data-entry (cdr data-entry))]
      (let [current-entry (json-find-entry data "currentWorkspace")
            current-workspace (and current-entry (cdr current-entry))]
        (let [meta-entry (json-find-entry root "meta")
              meta (and meta-entry (cdr meta-entry))]
          (let [details-entry (json-find-entry meta "details")
                details (and details-entry (cdr details-entry))]
            (let [detail (workspace-current-detail details current-workspace)
                  path (and detail (workspace-detail-value detail "path"))]
              (and detail (cons current-workspace path)))))))))

(defn workspace-current-name
  []
  (let [info (workspace-current-info)]
    (and info (car info))))

(defn workspace-current-path
  []
  (let [info (workspace-current-info)]
    (and info (cdr info))))

(defn workspace-db-path
  []
  (let [path (workspace-current-path)]
    (and path (fs/path path ".ro" "index.sqlite"))))

(defn open-workspace-db
  []
  (let [db-path (workspace-db-path)]
    (if (and db-path (fs/exists? db-path))
        (let [conn (db/open-database db-path)]
          (db/set-busy-handler! conn (db/make-busy-timeout 1000))
          conn)
        (error "ro workspace database is unavailable" db-path))))

(defn workspace-status-workspace-id
  [conn]
  (db/first-result
   conn
   "select workspace_id from events where workspace_id != '' group by workspace_id order by count(*) desc, workspace_id limit 1"))

(defn workspace-status-current-actor-id
  [conn]
  (db/first-result conn "select v from state_meta where k='current_actor_id' limit 1"))

(defn workspace-status-current-project-id
  [conn]
  (let [rows
        (db/map-row
         (fn [v] v)
         conn
         "select v from state_meta where k='current_project_id' limit 1")]
    (if (or (not rows)
            (null? rows))
        ""
        (or (car (seq rows)) ""))))

(defn workspace-status-count
  [conn sql]
  (db/first-result conn sql))

(defn workspace-current-write-actor-id
  [conn current-actor-id]
  (let [actor (workspace-actor-by-id conn current-actor-id)]
    (ro-workspace/workspace-current-write-actor-id actor current-actor-id)))

(defn project-json-record
  [json-text]
  (call-with-input-string
   json-text
   (fn [port]
     (json/json-read port))))

(defn workspace-projects
  [conn]
  (db/map-row
   (fn [json-text]
     (project-json-record json-text))
   conn
   "select json from projects where archived = 0 order by updated_at_unixms desc"))

(defn workspace-project-by-id
  [conn project-id]
  (let [rows
        (db/map-row
         (fn [json-text]
           (project-json-record json-text))
         conn
         "select json from projects where id = ?1 limit 1"
         project-id)]
    (if (or (not rows)
            (null? rows))
        #f
        (car (seq rows)))))

(defn workspace-current-project-output
  [conn]
  (let [current-project-id (or (workspace-status-current-project-id conn) "")
        project (if (string=? current-project-id "")
                  #f
                  (workspace-project-by-id conn current-project-id))]
    (ro-projects/projects-current-output current-project-id project)))

(defn json-write-text
  [value]
  (let [output (json-write-output value)
        len (string-length output)]
    (if (and (> len 0)
             (char=? (string-ref output (- len 1)) #\newline))
        (substring output 0 (- len 1))
        output)))

(defn workspace-bootstrap-context
  []
  (let [result
        (proc/exec
         "python3"
         "-c"
         "from datetime import datetime, timezone; import json, uuid; now=datetime.now(timezone.utc); print(json.dumps({'workspaceId':str(uuid.uuid4()),'deviceId':str(uuid.uuid4()),'replicaId':str(uuid.uuid4()),'createdAt':now.isoformat(timespec='microseconds').replace('+00:00','Z'),'modifiedAt':now.isoformat(timespec='microseconds').replace('+00:00','Z')}, ensure_ascii=False))")
        exit (or (get result :exit) 1)]
    (if (= exit 0)
        (call-with-input-string
         (or (get result :out) "")
         (fn [port]
           (json/json-read port)))
        (error "unable to generate workspace bootstrap metadata" result))))

(defn workspace-canonical-path
  [path]
  (let [result
        (proc/exec
         "python3"
         "-c"
         "import os,sys; print(os.path.realpath(sys.argv[1]))"
         path)
        exit (or (get result :exit) 1)
        out (str/trim (or (get result :out) ""))]
    (if (= exit 0)
        out
        (fs/absolute-path path))))

(defn workspace-root-meta-path
  [workspace-root]
  (fs/path workspace-root "meta" "workspace.json"))

(defn workspace-root-device-path
  [workspace-root]
  (fs/path workspace-root ".ro" "device.json"))

(defn workspace-root-index-path
  [workspace-root]
  (fs/path workspace-root ".ro" "index.sqlite"))

(defn workspace-root-events-dir
  [workspace-root]
  (fs/path workspace-root "events"))

(defn workspace-root-event-log-path
  [workspace-root replica-id]
  (and (not (string=? (or workspace-root "") ""))
       (not (string=? (or replica-id "") ""))
       (fs/path workspace-root "events" (string-append "events." replica-id ".jsonl"))))

(defn workspace-read-json-file
  [path]
  (if (and path (fs/file? path))
      (call-with-input-file path
        (fn [port]
          (json/json-read port)))
      #f))

(defn workspace-write-json-file!
  [path value]
  (ensure-directory! (fs/dirname path))
  (fs/spit path (string-append (json-write-text value) "\n"))
  path)

(defn ensure-directory!
  [path]
  (if (or (not path)
          (string=? (or path "") ""))
      #t
      (let ((result (proc/exec "mkdir" "-p" path)))
        (if (= 0 (or (get result :exit) 1))
            path
            (error "unable to create directory" path result)))))

(def workspace-sqlite-schema-statements
  (list
   "CREATE TABLE IF NOT EXISTS state_meta (k TEXT PRIMARY KEY, v TEXT NOT NULL);"
   "CREATE TABLE IF NOT EXISTS actors (id TEXT PRIMARY KEY, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE TABLE IF NOT EXISTS projects (id TEXT PRIMARY KEY, name TEXT NOT NULL, archived INTEGER NOT NULL, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE TABLE IF NOT EXISTS outlines (id TEXT PRIMARY KEY, project_id TEXT NOT NULL, name TEXT NOT NULL, description TEXT NOT NULL DEFAULT '', archived INTEGER NOT NULL, status_defs_json TEXT NOT NULL, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE INDEX IF NOT EXISTS idx_outlines_project ON outlines(project_id);"
   "CREATE TABLE IF NOT EXISTS items (id TEXT PRIMARY KEY, project_id TEXT NOT NULL, outline_id TEXT NOT NULL, parent_id TEXT NOT NULL, rank TEXT NOT NULL, title TEXT NOT NULL, status_id TEXT NOT NULL, priority INTEGER NOT NULL, on_hold INTEGER NOT NULL, archived INTEGER NOT NULL, owner_actor_id TEXT NOT NULL, assigned_actor_id TEXT NOT NULL, due_date TEXT NOT NULL, schedule_date TEXT NOT NULL, tags_json TEXT NOT NULL, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE INDEX IF NOT EXISTS idx_items_outline ON items(outline_id);"
   "CREATE INDEX IF NOT EXISTS idx_items_status ON items(status_id);"
   "CREATE INDEX IF NOT EXISTS idx_items_due ON items(due_date);"
   "CREATE INDEX IF NOT EXISTS idx_items_sched ON items(schedule_date);"
   "CREATE TABLE IF NOT EXISTS deps (id TEXT PRIMARY KEY, from_item_id TEXT NOT NULL, to_item_id TEXT NOT NULL, type TEXT NOT NULL, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE INDEX IF NOT EXISTS idx_deps_from ON deps(from_item_id);"
   "CREATE INDEX IF NOT EXISTS idx_deps_to ON deps(to_item_id);"
   "CREATE TABLE IF NOT EXISTS comments (id TEXT PRIMARY KEY, entity_kind TEXT NOT NULL, entity_id TEXT NOT NULL, author_id TEXT NOT NULL, created_at_unixms INTEGER NOT NULL, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE INDEX IF NOT EXISTS idx_comments_entity ON comments(entity_kind, entity_id, created_at_unixms);"
   "CREATE TABLE IF NOT EXISTS discussions (id TEXT PRIMARY KEY, entity_kind TEXT NOT NULL, entity_id TEXT NOT NULL, root_comment_id TEXT NOT NULL, state TEXT NOT NULL, author_id TEXT NOT NULL, created_at_unixms INTEGER NOT NULL, resolved_at_unixms INTEGER NOT NULL DEFAULT 0, resolved_by_actor_id TEXT NOT NULL DEFAULT '', reopened_at_unixms INTEGER NOT NULL DEFAULT 0, reopened_by_actor_id TEXT NOT NULL DEFAULT '', json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE INDEX IF NOT EXISTS idx_discussions_entity ON discussions(entity_kind, entity_id, created_at_unixms);"
   "CREATE INDEX IF NOT EXISTS idx_discussions_root_comment ON discussions(root_comment_id);"
   "CREATE TABLE IF NOT EXISTS worklog (id TEXT PRIMARY KEY, entity_kind TEXT NOT NULL, entity_id TEXT NOT NULL, author_id TEXT NOT NULL, created_at_unixms INTEGER NOT NULL, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE INDEX IF NOT EXISTS idx_worklog_entity ON worklog(entity_kind, entity_id, created_at_unixms);"
   "CREATE TABLE IF NOT EXISTS attachments (id TEXT PRIMARY KEY, entity_kind TEXT NOT NULL, entity_id TEXT NOT NULL, original_name TEXT NOT NULL, size_bytes INTEGER NOT NULL, json TEXT NOT NULL, updated_at_unixms INTEGER NOT NULL);"
   "CREATE INDEX IF NOT EXISTS idx_attachments_entity ON attachments(entity_kind, entity_id, updated_at_unixms);"))

(defn workspace-ensure-sqlite-schema!
  [db-path]
  (let ((conn (db/open-database db-path)))
    (let loop ((xs workspace-sqlite-schema-statements))
      (if (empty? xs)
          #t
          (begin
            (db/execute conn (first xs))
            (loop (rest xs)))))
    (db/finalize! conn)
    db-path))

(defn workspace-ensure-gitignore!
  [workspace-root]
  (let [gitignore-path (fs/path workspace-root ".gitignore")
        git-dir-path (fs/path workspace-root ".git")]
    (if (or (fs/exists? gitignore-path)
            (fs/exists? git-dir-path))
        (let [existing (if (fs/exists? gitignore-path)
                         (fs/slurp gitignore-path)
                         "")
              want ".ro/"
              lines (str/split-lines existing)
              has-want (let loop ((xs lines))
                         (cond
                           (empty? xs) false
                           (string=? (str/trim (first xs)) want) true
                           :else (loop (rest xs))))]
          (if has-want
              gitignore-path
              (let [prefix (if (string=? (str/trimr existing) "")
                             ""
                             (string-append (str/trimr existing) "\n"))
                    body "# Ro (derived/local-only)\n.ro/\n"]
                (fs/spit gitignore-path (string-append prefix body))
                gitignore-path)))
        #t)))

(defn workspace-ensure-local-layout!
  [workspace-root]
  (let [root (workspace-canonical-path (fs/absolute-path workspace-root))
        bootstrap (workspace-bootstrap-context)
        meta-path (workspace-root-meta-path root)
        device-path (workspace-root-device-path root)
        index-path (workspace-root-index-path root)
        events-dir (workspace-root-events-dir root)
        existing-meta (workspace-read-json-file meta-path)
        existing-device (workspace-read-json-file device-path)
        workspace-id (or (json-field-value existing-meta "workspaceId" "")
                         (json-field-value bootstrap "workspaceId" "")
                         "")
        created-at (or (json-field-value existing-meta "createdAt" "")
                       (json-field-value bootstrap "createdAt" "")
                       "")
        device-id (or (json-field-value existing-device "deviceId" "")
                      (json-field-value bootstrap "deviceId" "")
                      "")
        replica-id (or (json-field-value existing-device "replicaId" "")
                       (json-field-value bootstrap "replicaId" "")
                       "")
        modified-at (or (json-field-value existing-device "modifiedAt" "")
                        (json-field-value bootstrap "modifiedAt" "")
                        "")]
    (ensure-directory! root)
    (ensure-directory! (fs/path root "meta"))
    (ensure-directory! (fs/path root ".ro"))
    (ensure-directory! (fs/path root ".ro" "meta"))
    (ensure-directory! events-dir)
    (if (not existing-meta)
        (workspace-write-json-file!
         meta-path
         (vector (cons 'workspaceId workspace-id)
                 (cons 'createdAt created-at)))
        #t)
    (if (not existing-device)
        (workspace-write-json-file!
         device-path
         (vector (cons 'deviceId device-id)
                 (cons 'replicaId replica-id)
                 (cons 'createdAt created-at)
                 (cons 'modifiedAt modified-at)))
        #t)
    (workspace-ensure-sqlite-schema! index-path)
    (let ((event-log-path (workspace-root-event-log-path root replica-id)))
      (if (and event-log-path
               (not (fs/file? event-log-path)))
          (fs/spit event-log-path "")
          #t))
    (workspace-ensure-gitignore! root)
    (vector
     (cons 'dir root)
     (cons 'workspaceId workspace-id)
     (cons 'deviceId device-id)
     (cons 'replicaId replica-id)
     (cons 'createdAt created-at)
     (cons 'modifiedAt modified-at)
     (cons 'metaPath meta-path)
     (cons 'devicePath device-path)
     (cons 'indexPath index-path)
     (cons 'eventLogPath (workspace-root-event-log-path root replica-id)))))

(defn workspace-registry-default-root
  []
  (vector
   (cons 'data
         (vector (cons 'workspaces '())
                 (cons 'currentWorkspace "")))
   (cons 'meta
         (vector (cons 'details '())))))

(defn workspace-registry-root
  []
  (if (fs/file? workspace-json-path)
      (workspace-json-root)
      (workspace-registry-default-root)))

(defn workspace-registry-workspaces
  [root]
  (let [data-entry (json-find-entry root "data")
        data (and data-entry (cdr data-entry))
        workspaces-entry (json-find-entry data "workspaces")]
    (and workspaces-entry (cdr workspaces-entry))))

(defn workspace-registry-details
  [root]
  (let [meta-entry (json-find-entry root "meta")
        meta (and meta-entry (cdr meta-entry))
        details-entry (json-find-entry meta "details")]
    (and details-entry (cdr details-entry))))

(defn workspace-registry-current-name
  [root]
  (let [data-entry (json-find-entry root "data")
        data (and data-entry (cdr data-entry))
        current-entry (json-find-entry data "currentWorkspace")]
    (and current-entry (cdr current-entry))))

(defn workspace-registry-detail
  [root workspace-name]
  (workspace-current-detail (workspace-registry-details root) workspace-name))

(defn workspace-registry-write-root!
  [root]
  (workspace-write-json-file! workspace-json-path root))

(defn workspace-registry-detail-record
  [name path kind archived current]
  (vector
   (cons 'name name)
   (cons 'path path)
   (cons 'kind kind)
   (cons 'legacy #f)
   (cons 'archived archived)
   (cons 'current current)))

(defn workspace-registry-upsert!
  [name path kind use?]
  (let [root (workspace-registry-root)
        data-entry (json-find-entry root "data")
        data (and data-entry (cdr data-entry))
        meta-entry (json-find-entry root "meta")
        meta (and meta-entry (cdr meta-entry))
        workspaces (or (workspace-registry-workspaces root) '())
        details (or (workspace-registry-details root) '())
        existing-current (or (workspace-registry-current-name root) "")
        current-name (if (or use?
                             (string=? existing-current ""))
                       name
                       existing-current)
        names (let loop ((xs (seq workspaces)) (acc '()) (seen false))
                (cond
                  (empty? xs)
                  (if seen
                      (reverse acc)
                      (reverse (cons name acc)))

                  (string=? (or (first xs) "") name)
                  (loop (rest xs) (cons name acc) true)

                  :else
                  (loop (rest xs) (cons (first xs) acc) seen)))
        next-details
        (let loop ((xs (seq details)) (acc '()) (seen false))
          (cond
            (empty? xs)
            (let ((detail (workspace-registry-detail-record
                           name
                           path
                           kind
                           #f
                           (string=? current-name name))))
              (reverse (if seen acc (cons detail acc))))

            (string=? (or (workspace-detail-value (first xs) "name") "") name)
            (let ((detail (workspace-registry-detail-record
                           name
                           path
                           kind
                           (or (workspace-detail-value (first xs) "archived") #f)
                           (string=? current-name name))))
              (loop (rest xs) (cons detail acc) true))

            :else
            (loop (rest xs) (cons (first xs) acc) seen)))]
    (workspace-registry-write-root!
     (vector
      (cons 'data
            (vector (cons 'workspaces names)
                    (cons 'currentWorkspace current-name)))
      (cons 'meta
            (vector (cons 'details next-details)))))
    (list (string=? current-name name) path)))
(defn workspace-device-json-path
  []
  (let [workspace-root (or (workspace-current-path) "")]
    (and (not (string=? workspace-root ""))
         (fs/path workspace-root ".ro" "device.json"))))

(defn workspace-replica-id
  []
  (let ((path (workspace-device-json-path)))
    (if (and path (fs/exists? path))
        (let [root (call-with-input-file path
                     (fn [port]
                       (json/json-read port)))
              replica-id (or (workspace-detail-value root "replicaId") "")]
          replica-id)
        "")))

(defn workspace-event-log-path
  []
  (let [workspace-root (or (workspace-current-path) "")
        replica-id (workspace-replica-id)]
    (if (or (string=? workspace-root "")
            (string=? replica-id ""))
        #f
        (fs/path workspace-root "events" (string-append "events." replica-id ".jsonl")))))

(defn workspace-event-context
  []
  (let [result
        (proc/exec
         "python3"
         "-c"
         "from datetime import datetime, timezone; import json, uuid; now=datetime.now(timezone.utc); print(json.dumps({'eventId':'evt-' + uuid.uuid4().hex,'issuedAt':now.isoformat(timespec='microseconds').replace('+00:00','Z'),'issuedAtUnixms':int(now.timestamp()*1000)}, ensure_ascii=False))")
        exit (or (get result :exit) 1)]
    (if (= exit 0)
        (call-with-input-string
         (or (get result :out) "")
         (fn [port]
           (json/json-read port)))
        (error "unable to generate event metadata" result))))

(defn workspace-project-create-context
  []
  (let [result
        (proc/exec
         "python3"
         "-c"
         "from datetime import datetime, timezone; import json, uuid; now=datetime.now(timezone.utc); print(json.dumps({'eventId':'evt-' + uuid.uuid4().hex,'projectId':'proj-' + uuid.uuid4().hex[:8],'issuedAt':now.isoformat(timespec='microseconds').replace('+00:00','Z'),'issuedAtUnixms':int(now.timestamp()*1000)}, ensure_ascii=False))")
        exit (or (get result :exit) 1)]
    (if (= exit 0)
        (call-with-input-string
         (or (get result :out) "")
         (fn [port]
           (json/json-read port)))
        (error "unable to generate project metadata" result))))

(defn workspace-project-record
  [project-id name description archived updated-at-unixms created-by created-at]
  (let ((parts (list
                (cons 'id project-id)
                (cons 'name name)
                (cons 'description description)
                (cons 'archived archived)
                (cons 'updatedAtUnixms updated-at-unixms))))
    (if (not (string=? created-by ""))
        (set! parts (append parts (list (cons 'createdBy created-by)))))
    (if (not (string=? created-at ""))
        (set! parts (append parts (list (cons 'createdAt created-at)))))
    (list->vector parts)))

(defn workspace-project-record-archived
  [project archived updated-at-unixms]
  (if project
      (workspace-project-record
       (or (json-field-value project "id" "") "")
       (or (json-field-value project "name" "") "")
       (or (json-field-value project "description" "") "")
       archived
       updated-at-unixms
       (or (json-field-value project "createdBy" "") "")
       (or (json-field-value project "createdAt" "") ""))
      #f))

(defn workspace-project-save!
  [conn project]
  (let [project-id (or (json-field-value project "id" "") "")
        name (or (json-field-value project "name" "") "")
        archived (or (json-field-value project "archived" false) false)
        updated-at-unixms (or (json-field-value project "updatedAtUnixms" 0) 0)
        json-text (json-write-text project)]
    (db/execute
     conn
     "insert or replace into projects(id, name, archived, json, updated_at_unixms) values(?1, ?2, ?3, ?4, ?5)"
     project-id
     name
     (if archived 1 0)
     json-text
     updated-at-unixms)
    project))

(defn workspace-project-append-event!
  [event]
  (let ((path (workspace-event-log-path)))
    (if (not path)
        (error "ro events log is unavailable" (workspace-current-path))
        (let ((existing (if (fs/exists? path)
                            (fs/slurp path)
                            "")))
          (fs/spit path (string-append existing (json-write-output event)))
          event))))

(defn workspace-item-append-event!
  [event]
  (workspace-project-append-event! event))

(defn workspace-outline-append-event!
  [event]
  (workspace-project-append-event! event))

(defn workspace-project-next-seq
  [project-id]
  (let [path (workspace-event-log-path)]
    (if (not path)
        1
        (let loop ((records (if (fs/exists? path)
                                (events-file-records path 0)
                                '()))
                   (max-seq 0))
          (if (empty? records)
              (+ max-seq 1)
              (let [record (first records)
                    kind (or (json-field-value record "entity_kind" "") "")
                    entity-id (or (json-field-value record "entity_id" "") "")
                    entity-seq (or (json-field-value record "entity_seq" 0) 0)]
                (loop (rest records)
                      (if (and (string=? kind "project")
                               (string=? entity-id project-id)
                               (> entity-seq max-seq))
                          entity-seq
                          max-seq))))))))

(defn workspace-project-create!
  [conn name use?]
  (let [workspace-id (or (workspace-status-workspace-id conn) "")
        actor-id (or (workspace-status-current-actor-id conn) "")
        name (or name "")
        meta (workspace-project-create-context)
        event-id (or (json-field-value meta "eventId" "") "")
        project-id (or (json-field-value meta "projectId" "") "")
        issued-at (or (json-field-value meta "issuedAt" "") "")
        issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
        project (workspace-project-record project-id name "" false issued-at-unixms actor-id issued-at)
        event-seq (workspace-project-next-seq project-id)
        event (vector
               (cons 'eventId event-id)
               (cons 'workspaceId workspace-id)
               (cons 'replicaId (workspace-replica-id))
               (cons 'entityKind "project")
               (cons 'entityId project-id)
               (cons 'entitySeq event-seq)
               (cons 'type "project.create")
               (cons 'issuedAt issued-at)
               (cons 'actorId actor-id)
               (cons 'payload project)
               (cons 'localStatus "local")
               (cons 'serverStatus "pending"))]
    (if (string=? name "")
        (error "project name is required" name)
        #t)
    (if (string=? workspace-id "")
        (error "ro workspace id is unavailable" workspace-id)
        #t)
    (if (string=? actor-id "")
        (error "no current actor" actor-id)
        #t)
    (workspace-project-save! conn project)
    (workspace-project-append-event! event)
    (when use?
      (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)"
                  "current_project_id"
                  project-id))
    project))

(defn workspace-project-archive!
  [conn project-id archived?]
  (let [project-id (or project-id "")
        current (workspace-project-by-id conn project-id)]
    (if (not current)
        #f
        (let [meta (workspace-event-context)
              workspace-id (or (workspace-status-workspace-id conn) "")
              actor-id (or (workspace-status-current-actor-id conn) "")
              event-id (or (json-field-value meta "eventId" "") "")
              issued-at (or (json-field-value meta "issuedAt" "") "")
              issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
              updated (workspace-project-record-archived current archived? issued-at-unixms)
              event-seq (workspace-project-next-seq project-id)
              event (vector
                     (cons 'eventId event-id)
                     (cons 'workspaceId workspace-id)
                     (cons 'replicaId (workspace-replica-id))
                     (cons 'entityKind "project")
                     (cons 'entityId project-id)
                     (cons 'entitySeq event-seq)
                     (cons 'type "project.archive")
                     (cons 'issuedAt issued-at)
                     (cons 'actorId actor-id)
                     (cons 'payload (vector (cons 'archived archived?)))
                     (cons 'localStatus "local")
                     (cons 'serverStatus "pending"))]
          (if (string=? workspace-id "")
              (error "ro workspace id is unavailable" workspace-id)
              #t)
          (if (string=? actor-id "")
              (error "no current actor" actor-id)
              #t)
          (workspace-project-save! conn updated)
          (workspace-project-append-event! event)
          (when (and archived?
                     (string=? project-id (or (workspace-status-current-project-id conn) "")))
            (db/execute conn "delete from state_meta where k=?1" "current_project_id"))
          updated))))

(defn workspace-project-use!
  [conn project-id]
  (let ((project (workspace-project-by-id conn project-id)))
    (if (not project)
        #f
        (begin
          (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)"
                      "current_project_id"
                      project-id)
          project))))

(defn workspace-outline-create-context
  []
  (let [result
        (proc/exec
         "python3"
         "-c"
         "from datetime import datetime, timezone; import json, uuid; now=datetime.now(timezone.utc); print(json.dumps({'eventId':'evt-' + uuid.uuid4().hex,'outlineId':'out-' + uuid.uuid4().hex[:8],'issuedAt':now.isoformat(timespec='microseconds').replace('+00:00','Z'),'issuedAtUnixms':int(now.timestamp()*1000)}, ensure_ascii=False))")
        exit (or (get result :exit) 1)]
    (if (= exit 0)
        (call-with-input-string
         (or (get result :out) "")
         (fn [port]
           (json/json-read port)))
        (error "unable to generate outline metadata" result))))

(defn workspace-outline-next-seq
  [outline-id]
  (let ((path (workspace-event-log-path)))
    (if (not path)
        1
        (let loop ((records (if (fs/exists? path)
                                (events-file-records path 0)
                                '()))
                   (max-seq 0))
          (if (empty? records)
              (+ max-seq 1)
              (let ((record (first records))
                    (kind (or (json-field-value record "entity_kind" "") ""))
                    (entity-id (or (json-field-value record "entity_id" "") ""))
                    (entity-seq (or (json-field-value record "entity_seq" 0) 0)))
                (loop (rest records)
                      (if (and (string=? kind "outline")
                               (string=? entity-id outline-id)
                               (> entity-seq max-seq))
                          entity-seq
                          max-seq))))))))

(defn workspace-outline-record
  [outline-id project-id name description archived status-defs updated-at-unixms]
  (vector
   (cons 'id outline-id)
   (cons 'projectId project-id)
   (cons 'name name)
   (cons 'description description)
   (cons 'archived archived)
   (cons 'statusDefs status-defs)
   (cons 'updatedAtUnixms updated-at-unixms)))

(defn workspace-outline-record-archived
  [outline archived updated-at-unixms]
  (if outline
      (workspace-outline-record
       (or (json-field-value outline "id" "") "")
       (or (json-field-value outline "projectId" "") "")
       (or (json-field-value outline "name" "") "")
       (or (json-field-value outline "description" "") "")
       archived
       (or (json-field-value outline "statusDefs" '()) '())
       updated-at-unixms)
      #f))

(defn workspace-outline-save!
  [conn outline]
  (let [outline-id (or (json-field-value outline "id" "") "")
        project-id (or (json-field-value outline "projectId" "") "")
        name (or (json-field-value outline "name" "") "")
        description (or (json-field-value outline "description" "") "")
        archived (or (json-field-value outline "archived" false) false)
        status-defs (or (json-field-value outline "statusDefs" '()) '())
        updated-at-unixms (or (json-field-value outline "updatedAtUnixms" 0) 0)
        json-text (json-write-text outline)
        status-defs-json (json-write-text status-defs)]
    (db/execute
     conn
     "insert or replace into outlines(id, project_id, name, description, archived, status_defs_json, json, updated_at_unixms) values(?1, ?2, ?3, ?4, ?5, ?6, ?7, ?8)"
     outline-id
     project-id
     name
     description
     (if archived 1 0)
     status-defs-json
     json-text
     updated-at-unixms)
    outline))

(defn workspace-outline-by-id
  [conn outline-id]
  (let ((rows
         (db/map-row
          (fn [json-text]
            (item-json-record json-text))
          conn
          "select json from outlines where id = ?1 and archived = 0 limit 1"
          outline-id)))
    (if (or (not rows)
            (null? rows))
        #f
        (car (seq rows)))))

(defn workspace-outline-by-id-any
  [conn outline-id]
  (let ((rows
         (db/map-row
          (fn [json-text]
            (item-json-record json-text))
          conn
          "select json from outlines where id = ?1 limit 1"
          outline-id)))
    (if (or (not rows)
            (null? rows))
        #f
        (car (seq rows)))))

(defn workspace-outlines-by-project
  [conn project-id]
  (db/map-row
   (fn [json-text]
     (item-json-record json-text))
   conn
   "select json from outlines where project_id = ?1 and archived = 0 order by updated_at_unixms desc, id desc"
   project-id))

(defn workspace-outlines
  [conn]
  (let loop ((projects (workspace-projects conn))
             (acc '()))
    (if (empty? projects)
        acc
        (let ((project-id (or (json-field-value (first projects) "id" "") ""))
              (outlines (if (string=? project-id)
                          '()
                          (workspace-outlines-by-project conn project-id))))
          (loop (rest projects)
                (append acc outlines))))))

(defn workspace-outline-write-event!
  [conn outline-id event-type payload]
  (let [workspace-id (or (workspace-status-workspace-id conn) "")
        actor-id (or (workspace-status-current-actor-id conn) "")
        meta (workspace-event-context)
        event-id (or (json-field-value meta "eventId" "") "")
        issued-at (or (json-field-value meta "issuedAt" "") "")
        issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
        event-seq (workspace-outline-next-seq outline-id)
        event (vector
               (cons 'eventId event-id)
               (cons 'workspaceId workspace-id)
               (cons 'replicaId (workspace-replica-id))
               (cons 'entityKind "outline")
               (cons 'entityId outline-id)
               (cons 'entitySeq event-seq)
               (cons 'type event-type)
               (cons 'issuedAt issued-at)
               (cons 'actorId actor-id)
               (cons 'payload payload)
               (cons 'localStatus "local")
               (cons 'serverStatus "pending"))]
    (if (string=? workspace-id "")
        (error "ro workspace id is unavailable" workspace-id)
        #t)
    (if (string=? actor-id "")
        (error "no current actor" actor-id)
        #t)
    (workspace-outline-append-event! event)
    event))

(defn workspace-outline-create!
  [conn project-id name]
  (let [workspace-id (or (workspace-status-workspace-id conn) "")
        actor-id (or (workspace-status-current-actor-id conn) "")
        project-id (or project-id "")
        name (or name "")
        current (workspace-project-by-id conn project-id)]
    (if (string=? workspace-id "")
        (error "ro workspace id is unavailable" workspace-id)
        #t)
    (if (string=? actor-id "")
        (error "no current actor" actor-id)
        #t)
    (if (not current)
        #f
        (let [meta (workspace-outline-create-context)
              event-id (or (json-field-value meta "eventId" "") "")
              outline-id (or (json-field-value meta "outlineId" "") "")
              issued-at (or (json-field-value meta "issuedAt" "") "")
              issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
              outline (workspace-outline-record
                       outline-id
                       project-id
                       name
                       ""
                       false
                       (ro-outlines/outline-default-status-defs)
                       issued-at-unixms)
              event-seq (workspace-outline-next-seq outline-id)
              event (vector
                     (cons 'eventId event-id)
                     (cons 'workspaceId workspace-id)
                     (cons 'replicaId (workspace-replica-id))
                     (cons 'entityKind "outline")
                     (cons 'entityId outline-id)
                     (cons 'entitySeq event-seq)
                     (cons 'type "outline.create")
                     (cons 'issuedAt issued-at)
                     (cons 'actorId actor-id)
                     (cons 'payload outline)
                     (cons 'localStatus "local")
                     (cons 'serverStatus "pending"))]
          (workspace-outline-save! conn outline)
          (workspace-outline-append-event! event)
          outline))))

(defn workspace-outline-archive!
  [conn outline-id archived?]
  (let [outline-id (or outline-id "")
        current (workspace-outline-by-id-any conn outline-id)]
    (if (not current)
        #f
        (let [meta (workspace-event-context)
              workspace-id (or (workspace-status-workspace-id conn) "")
              actor-id (or (workspace-status-current-actor-id conn) "")
              event-id (or (json-field-value meta "eventId" "") "")
              issued-at (or (json-field-value meta "issuedAt" "") "")
              issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
              updated (workspace-outline-record-archived current archived? issued-at-unixms)
              event-seq (workspace-outline-next-seq outline-id)
              event (vector
                     (cons 'eventId event-id)
                     (cons 'workspaceId workspace-id)
                     (cons 'replicaId (workspace-replica-id))
                     (cons 'entityKind "outline")
                     (cons 'entityId outline-id)
                     (cons 'entitySeq event-seq)
                     (cons 'type "outline.archive")
                     (cons 'issuedAt issued-at)
                     (cons 'actorId actor-id)
                     (cons 'payload (vector (cons 'archived archived?)))
                     (cons 'localStatus "local")
                     (cons 'serverStatus "pending"))]
          (if (string=? workspace-id "")
              (error "ro workspace id is unavailable" workspace-id)
              #t)
          (if (string=? actor-id "")
              (error "no current actor" actor-id)
              #t)
          (workspace-outline-save! conn updated)
          (workspace-outline-append-event! event)
          updated))))

(defn workspace-outline-status-add!
  [conn outline-id label]
  (let [outline-id (or outline-id "")
        current (workspace-outline-by-id conn outline-id)
        status-defs (if current
                      (or (json-field-value current "statusDefs" '()) '())
                      '())]
    (if (not current)
        #f
        (let ((duplicate?
               (let loop ((xs (seq status-defs)))
                 (cond
                   (empty? xs) false
                   (ro-outlines/outline-status-def-label-match? (first xs) label) true
                   :else (loop (rest xs))))))
          (if duplicate?
              (error "status label already exists on this outline" outline-id)
              (let [next-defs (ro-outlines/outline-status-defs-add status-defs label)
                    meta (workspace-event-context)
                    workspace-id (or (workspace-status-workspace-id conn) "")
                    actor-id (or (workspace-status-current-actor-id conn) "")
                    event-id (or (json-field-value meta "eventId" "") "")
                    issued-at (or (json-field-value meta "issuedAt" "") "")
                    issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
                    updated (workspace-outline-record
                             outline-id
                             (or (json-field-value current "projectId" "") "")
                             (or (json-field-value current "name" "") "")
                             (or (json-field-value current "description" "") "")
                             (or (json-field-value current "archived" false) false)
                             next-defs
                             issued-at-unixms)
                    status-id (ro-outlines/outline-status-id-from-label label)
                    event-seq (workspace-outline-next-seq outline-id)
                    event (vector
                           (cons 'eventId event-id)
                           (cons 'workspaceId workspace-id)
                           (cons 'replicaId (workspace-replica-id))
                           (cons 'entityKind "outline")
                           (cons 'entityId outline-id)
                           (cons 'entitySeq event-seq)
                           (cons 'type "outline.status.add")
                           (cons 'issuedAt issued-at)
                           (cons 'actorId actor-id)
                           (cons 'payload (vector
                                           (cons 'id status-id)
                                           (cons 'label label)
                                           (cons 'isEndState false)
                                           (cons 'requiresNote false)))
                           (cons 'localStatus "local")
                           (cons 'serverStatus "pending"))]
                (if (string=? workspace-id "")
                    (error "ro workspace id is unavailable" workspace-id)
                    #t)
                (if (string=? actor-id "")
                    (error "no current actor" actor-id)
                    #t)
                (workspace-outline-save! conn updated)
                (workspace-outline-append-event! event)
                updated))))))

(defn workspace-outline-status-update!
  [conn outline-id status-id label end-state? requires-note?]
  (let [outline-id (or outline-id "")
        status-id (or status-id "")
        current (workspace-outline-by-id conn outline-id)
        status-defs (if current
                      (or (json-field-value current "statusDefs" '()) '())
                      '())]
    (if (not current)
        #f
        (let [next-defs
              (ro-outlines/outline-status-defs-update
               status-defs
               status-id
               label
               end-state?
               requires-note?)]
          (if (not next-defs)
              #f
              (let [meta (workspace-event-context)
                    workspace-id (or (workspace-status-workspace-id conn) "")
                    actor-id (or (workspace-status-current-actor-id conn) "")
                    event-id (or (json-field-value meta "eventId" "") "")
                    issued-at (or (json-field-value meta "issuedAt" "") "")
                    issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
                    updated (workspace-outline-record
                             outline-id
                             (or (json-field-value current "projectId" "") "")
                             (or (json-field-value current "name" "") "")
                             (or (json-field-value current "description" "") "")
                             (or (json-field-value current "archived" false) false)
                             next-defs
                             issued-at-unixms)
                    payload (vector
                             (cons 'id status-id)
                             (cons 'label label)
                             (cons 'isEndState (if end-state? true false))
                             (cons 'requiresNote (if requires-note? true false))
                             (cons 'ts issued-at))
                    event-seq (workspace-outline-next-seq outline-id)
                    event (vector
                           (cons 'eventId event-id)
                           (cons 'workspaceId workspace-id)
                           (cons 'replicaId (workspace-replica-id))
                           (cons 'entityKind "outline")
                           (cons 'entityId outline-id)
                           (cons 'entitySeq event-seq)
                           (cons 'type "outline.status.update")
                           (cons 'issuedAt issued-at)
                           (cons 'actorId actor-id)
                           (cons 'payload payload)
                           (cons 'localStatus "local")
                           (cons 'serverStatus "pending"))]
                (if (string=? workspace-id "")
                    (error "ro workspace id is unavailable" workspace-id)
                    #t)
                (if (string=? actor-id "")
                    (error "no current actor" actor-id)
                    #t)
                (workspace-outline-save! conn updated)
                (workspace-outline-append-event! event)
                updated))))))

(defn workspace-outline-status-remove!
  [conn outline-id status-id]
  (let [outline-id (or outline-id "")
        status-id (or status-id "")
        current (workspace-outline-by-id conn outline-id)
        status-defs (if current
                      (or (json-field-value current "statusDefs" '()) '())
                      '())
        in-use? (> (or (db/first-result
                        conn
                        "select count(*) from items where outline_id = ?1 and status_id = ?2 and archived = 0"
                        outline-id
                        status-id)
                       0)
                   0)]
    (cond
      (not current)
      #f

      in-use?
      (error "cannot remove status: in use by items" outline-id status-id)

      :else
      (let ((next-defs (ro-outlines/outline-status-defs-remove status-defs status-id)))
        (if (not next-defs)
            #f
            (let [meta (workspace-event-context)
                  workspace-id (or (workspace-status-workspace-id conn) "")
                  actor-id (or (workspace-status-current-actor-id conn) "")
                  event-id (or (json-field-value meta "eventId" "") "")
                  issued-at (or (json-field-value meta "issuedAt" "") "")
                  issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
                  updated (workspace-outline-record
                           outline-id
                           (or (json-field-value current "projectId" "") "")
                           (or (json-field-value current "name" "") "")
                           (or (json-field-value current "description" "") "")
                           (or (json-field-value current "archived" false) false)
                           next-defs
                           issued-at-unixms)
                  event-seq (workspace-outline-next-seq outline-id)
                  event (vector
                         (cons 'eventId event-id)
                         (cons 'workspaceId workspace-id)
                         (cons 'replicaId (workspace-replica-id))
                         (cons 'entityKind "outline")
                         (cons 'entityId outline-id)
                         (cons 'entitySeq event-seq)
                         (cons 'type "outline.status.remove")
                         (cons 'issuedAt issued-at)
                         (cons 'actorId actor-id)
                         (cons 'payload (vector (cons 'id status-id)))
                         (cons 'localStatus "local")
                         (cons 'serverStatus "pending"))]
              (if (string=? workspace-id "")
                  (error "ro workspace id is unavailable" workspace-id)
                  #t)
              (if (string=? actor-id "")
                  (error "no current actor" actor-id)
                  #t)
              (workspace-outline-save! conn updated)
              (workspace-outline-append-event! event)
              updated))))))

(defn workspace-outline-status-reorder!
  [conn outline-id labels]
  (let [outline-id (or outline-id "")
        current (workspace-outline-by-id conn outline-id)
        status-defs (if current
                      (or (json-field-value current "statusDefs" '()) '())
                      '())
        next-defs (if current
                    (ro-outlines/outline-status-defs-reorder status-defs labels)
                    #f)]
    (if (not current)
        #f
        (if (not next-defs)
            #f
            (let [meta (workspace-event-context)
                  workspace-id (or (workspace-status-workspace-id conn) "")
                  actor-id (or (workspace-status-current-actor-id conn) "")
                  event-id (or (json-field-value meta "eventId" "") "")
                  issued-at (or (json-field-value meta "issuedAt" "") "")
                  issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
                  updated (workspace-outline-record
                           outline-id
                           (or (json-field-value current "projectId" "") "")
                           (or (json-field-value current "name" "") "")
                           (or (json-field-value current "description" "") "")
                           (or (json-field-value current "archived" false) false)
                           next-defs
                           issued-at-unixms)
                  labels (if (vector? labels) labels labels)
                  event-seq (workspace-outline-next-seq outline-id)
                  event (vector
                         (cons 'eventId event-id)
                         (cons 'workspaceId workspace-id)
                         (cons 'replicaId (workspace-replica-id))
                         (cons 'entityKind "outline")
                         (cons 'entityId outline-id)
                         (cons 'entitySeq event-seq)
                         (cons 'type "outline.status.reorder")
                         (cons 'issuedAt issued-at)
                         (cons 'actorId actor-id)
                         (cons 'payload (vector (cons 'labels labels)))
                         (cons 'localStatus "local")
                         (cons 'serverStatus "pending"))]
                (if (string=? workspace-id "")
                    (error "ro workspace id is unavailable" workspace-id)
                    #t)
              (if (string=? actor-id "")
                  (error "no current actor" actor-id)
                  #t)
              (workspace-outline-save! conn updated)
              (workspace-outline-append-event! event)
              updated)))))

(defn workspace-outlines-list-output
  [outlines]
  (ro-outlines/outlines-list-output outlines))

(defn workspace-outline-show-output
  [outline]
  (ro-outlines/outlines-show-output outline))

(defn workspace-outline-status-list-output
  [outline]
  (ro-outlines/outlines-status-list-output
   (or (json-field-value outline "statusDefs" '()) '())))

(defn workspace-worklog-create-context
  []
  (let ((result
         (proc/exec
          "python3"
          "-c"
          "from datetime import datetime, timezone; import json, uuid; now=datetime.now(timezone.utc); print(json.dumps({'eventId':'evt-' + uuid.uuid4().hex,'worklogId':'worklog-' + uuid.uuid4().hex[:8],'issuedAt':now.isoformat(timespec='microseconds').replace('+00:00','Z'),'issuedAtUnixms':int(now.timestamp()*1000)}, ensure_ascii=False))"))
        (exit (or (get result :exit) 1)))
    (if (= exit 0)
        (call-with-input-string
         (or (get result :out) "")
         (fn [port]
           (json/json-read port)))
        (error "unable to generate worklog metadata" result))))

(defn workspace-worklog-next-seq
  [worklog-id]
  (let ((path (workspace-event-log-path)))
    (if (not path)
        1
        (let loop ((records (if (fs/exists? path)
                                (events-file-records path 0)
                                '()))
                   (max-seq 0))
          (if (empty? records)
              (+ max-seq 1)
              (let ((record (first records))
                    (kind (or (json-field-value record "entity_kind" "") ""))
                    (entity-id (or (json-field-value record "entity_id" "") ""))
                    (entity-seq (or (json-field-value record "entity_seq" 0) 0)))
                (loop (rest records)
                      (if (and (string=? kind "worklog")
                               (string=? entity-id worklog-id)
                               (> entity-seq max-seq))
                          entity-seq
                          max-seq))))))))

(defn workspace-worklog-record
  [worklog-id entity-kind entity-id body author-id created-at updated-at updated-at-unixms]
  (vector
   (cons 'id worklog-id)
   (cons 'entityKind entity-kind)
   (cons 'entityId entity-id)
   (cons 'body body)
   (cons 'authorId author-id)
   (cons 'createdAt created-at)
   (cons 'updatedAt updated-at)
   (cons 'updatedAtUnixms updated-at-unixms)))

(defn workspace-worklog-save!
  [conn worklog]
  (let ((worklog-id (or (json-field-value worklog "id" "") ""))
        (entity-kind (or (json-field-value worklog "entityKind" "") ""))
        (entity-id (or (json-field-value worklog "entityId" "") ""))
        (author-id (or (json-field-value worklog "authorId" "") ""))
        (updated-at-unixms (or (json-field-value worklog "updatedAtUnixms" 0) 0))
        (json-text (json-write-text worklog)))
    (db/execute
     conn
     "insert or replace into worklog(id, entity_kind, entity_id, author_id, created_at_unixms, json, updated_at_unixms) values(?1, ?2, ?3, ?4, ?5, ?6, ?7)"
     worklog-id
     entity-kind
     entity-id
     author-id
     updated-at-unixms
     json-text
     updated-at-unixms)
    worklog))

(defn workspace-worklog-records
  [conn item-id limit offset]
  (db/map-row
   (fn [json-text]
     (call-with-input-string
      json-text
      (fn [port]
        (json/json-read port))))
   conn
   "select json from worklog where entity_kind = 'item' and entity_id = ?1 order by created_at_unixms asc, id asc limit ?2 offset ?3"
   item-id
   limit
   offset))

(defn workspace-worklog-list-output
  [conn item-id limit offset]
  (json-write-output
   (vector
    (cons 'data (workspace-worklog-records conn item-id limit offset)))))

(defn workspace-worklog-add!
  [conn item-id body]
  (let ((item-id (or item-id ""))
        (current (workspace-item-by-id conn item-id)))
    (if (not current)
        false
        (let ((workspace-id (or (workspace-status-workspace-id conn) ""))
               (actor-id (or (workspace-status-current-actor-id conn) ""))
               (body (or body ""))
               (body-text (str/trim (or body ""))))
          (if (string=? workspace-id "")
              (error "ro workspace id is unavailable" workspace-id)
              true)
          (if (string=? actor-id "")
              (error "no current actor" actor-id)
              true)
          (if (string=? body-text "")
              (error "worklog body is required" body)
              true)
          (let [meta (workspace-worklog-create-context)
                event-id (or (json-field-value meta "eventId" "") "")
                worklog-id (or (json-field-value meta "worklogId" "") "")
                issued-at (or (json-field-value meta "issuedAt" "") "")
                issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
                worklog (workspace-worklog-record
                         worklog-id
                         "item"
                         item-id
                         body
                         actor-id
                         issued-at
                         issued-at
                         issued-at-unixms)
                event-seq (workspace-worklog-next-seq worklog-id)
                event (vector
                       (cons 'eventId event-id)
                       (cons 'workspaceId workspace-id)
                       (cons 'replicaId (workspace-replica-id))
                       (cons 'entityKind "worklog")
                       (cons 'entityId worklog-id)
                       (cons 'entitySeq event-seq)
                       (cons 'type "worklog.add")
                       (cons 'parents (list item-id))
                       (cons 'issuedAt issued-at)
                       (cons 'actorId actor-id)
                       (cons 'payload worklog)
                       (cons 'localStatus "local")
                       (cons 'serverStatus "pending"))]
            (workspace-worklog-save! conn worklog)
            (workspace-item-append-event! event)
            worklog)))))

(defn workspace-status-visible-worklog-count
  [conn current-write-actor-id]
  (db/first-result
   conn
   "select count(*) from worklog where entity_kind = 'item' and author_id in (select id from actors where coalesce(nullif(trim(json_extract(json, '$.userId')), ''), id) = ?1)"
   current-write-actor-id))

(defn actor-record
  [id name kind user-id session]
  (vector
   (cons 'id id)
   (cons 'name name)
   (cons 'kind kind)
   (cons 'userId user-id)
   (cons 'session session)))

(defn workspace-actors
  [conn]
  (db/map-row
   (fn [id name kind user-id session]
     (actor-record id name kind user-id session))
   conn
   "select id, coalesce(json_extract(json, '$.name'), id), coalesce(json_extract(json, '$.kind'), ''), coalesce(json_extract(json, '$.userId'), ''), coalesce(json_extract(json, '$.session'), '') from actors order by case lower(coalesce(json_extract(json, '$.kind'), '')) when 'human' then 0 when 'agent' then 1 else 2 end, lower(coalesce(json_extract(json, '$.name'), id)), id"))

(defn workspace-actor-by-id
  [conn actor-id]
  (let [rows
        (db/map-row
         (fn [id name kind user-id session]
           (actor-record id name kind user-id session))
         conn
         "select id, coalesce(json_extract(json, '$.name'), id), coalesce(json_extract(json, '$.kind'), ''), coalesce(json_extract(json, '$.userId'), ''), coalesce(json_extract(json, '$.session'), '') from actors where id = ?1 limit 1"
         actor-id)]
    (if (or (not rows)
            (null? rows))
        #f
        (car (seq rows)))))

(defn item-json-record
  [json-text]
  (call-with-input-string
   json-text
   (fn [port]
     (json/json-read port))))

(defn workspace-item-by-id
  [conn item-id]
  (let [rows
        (db/map-row
         (fn [json-text]
           (item-json-record json-text))
         conn
         "select json from items where id = ?1 limit 1"
         item-id)]
    (if (or (not rows)
            (null? rows))
        #f
        (car (seq rows)))))

(defn workspace-item-children
  [conn item-id]
  (db/map-row
   (fn [json-text]
     (item-json-record json-text))
   conn
   "select json from items where parent_id = ?1 and archived = 0 order by lower(rank) asc, id asc"
   item-id))

(defn workspace-item-deps
  [conn item-id]
  (db/map-row
   (fn [json-text]
     (item-json-record json-text))
   conn
   "select json from deps where from_item_id = ?1 or to_item_id = ?1 order by updated_at_unixms desc, id desc"
   item-id))

(defn workspace-outline-status-defs-json
  [conn outline-id]
  (db/first-result
   conn
   "select status_defs_json from outlines where id = ?1 limit 1"
   outline-id))

(defn workspace-outline-end-status-ids
  [conn outline-id]
  (let ((json-text (workspace-outline-status-defs-json conn outline-id)))
    (if (or (not json-text)
            (string=? (str/trim (or json-text "")) ""))
        '()
        (let ((defs
               (call-with-input-string
                json-text
                (fn [port]
                  (json/json-read port)))))
          (##core#let loop ((xs (seq defs))
                            (acc '()))
            (cond
              (empty? xs) (reverse acc)
              (or (json-field-value (car xs) "isEndState" false) false)
              (let ((status-id (or (json-field-value (car xs) "id" "") "")))
                (if (string=? status-id "")
                    (loop (cdr xs) acc)
                    (loop (cdr xs) (cons status-id acc))))
              :else
              (loop (cdr xs) acc)))))))

(defn workspace-item-status
  [item]
  (or (json-first-field-value item (list "status" "statusId") "") ""))

(defn workspace-item-archived?
  [item]
  (or (json-field-value item "archived" false) false))

(defn workspace-item-child-summary
  [conn item]
  (let [item-id (or (json-field-value item "id" "") "")
        comments-count
        (workspace-item-count
         conn
         "select count(*) from comments where entity_kind = 'item' and entity_id = ?1"
         item-id)
        worklog-count
        (workspace-item-count
         conn
         "select count(*) from worklog where entity_kind = 'item' and entity_id = ?1"
         item-id)
        has-children? (> (workspace-item-count conn "select count(*) from items where parent_id = ?1 and archived = 0" item-id) 0)]
    (ro-items/item-show-summary item comments-count worklog-count has-children?)))

(defn workspace-item-counts
  [children end-status-ids]
  (let loop ((xs children)
             (total 0)
             (archived 0)
             (done 0))
    (if (empty? xs)
        (let ((open (- total archived done)))
          (vector
           (cons 'total total)
           (cons 'open open)
           (cons 'done done)
           (cons 'archived archived)))
        (let [child (first xs)
              child-archived (workspace-item-archived? child)
              child-status (workspace-item-status child)
              child-done (and (not child-archived)
                              (member child-status end-status-ids))]
          (loop (rest xs)
                (+ total 1)
                (if child-archived (+ archived 1) archived)
                (if child-done (+ done 1) done))))))

(defn workspace-item-count
  [conn sql item-id]
  (or (db/first-result conn sql item-id) 0))

(defn workspace-item-summary
  [conn item current-write-actor-id]
  (let [item-id (or (json-field-value item "id" "") "")
        comments-count
        (workspace-item-count
         conn
         "select count(*) from comments where entity_kind = 'item' and entity_id = ?1"
         item-id)
        worklog-count
        (if (string=? (or current-write-actor-id "") "")
            0
            (db/first-result
             conn
             "select count(*) from worklog where entity_kind = 'item' and entity_id = ?1 and author_id in (select id from actors where coalesce(nullif(trim(json_extract(json, '$.userId')), ''), id) = ?2)"
             item-id
             current-write-actor-id))
        has-children? (> (workspace-item-count conn "select count(*) from items where parent_id = ?1 and archived = 0" item-id) 0)]
    (ro-items/item-show-summary item comments-count worklog-count has-children?)))

(defn workspace-item-id
  [item]
  (or (json-field-value item "id" "") ""))

(defn workspace-item-outline-id
  [item]
  (or (json-field-value item "outlineId" "") ""))

(defn workspace-item-parent-id
  [item]
  (or (json-field-value item "parentId" "") ""))

(defn workspace-item-rank
  [item]
  (or (json-field-value item "rank" "") ""))

(defn workspace-item-created-at
  [item]
  (or (json-field-value item "createdAt" "") ""))

(defn workspace-item-assigned-actor-id
  [item]
  (or (json-field-value item "assignedActorId" "") ""))

(defn workspace-item-on-hold?
  [item]
  (or (json-field-value item "onHold" false) false))

(defn workspace-item-status-order
  [status]
  (cond
    (string=? status "done") 0
    (string=? status "doing") 1
    (string=? status "todo") 2
    (string=? status "") 3
    :else 4))

(defn workspace-item-order<?
  [left right]
  (let [left-rank (workspace-item-rank left)
        right-rank (workspace-item-rank right)]
    (cond
      (string<? left-rank right-rank) true
      (string<? right-rank left-rank) false
      :else false)))

(defn workspace-item-order-outline-items
  [items]
  (let [present (make-hash-table)]
    (let loop-present ((xs items))
      (if (empty? xs)
          (let [children (make-hash-table)]
            (letrec ((build-groups
                      (fn [xs roots]
                        (if (empty? xs)
                            (vector roots children)
                            (let [item (first xs)
                                  parent-id (workspace-item-parent-id item)]
                              (if (or (string=? parent-id "")
                                      (not (hash-table-ref/default present parent-id #f)))
                                  (build-groups (rest xs) (cons item roots))
                                  (let [current-children
                                        (hash-table-ref/default children parent-id '())]
                                    (hash-table-set! children parent-id
                                                     (cons item current-children))
                                    (build-groups (rest xs) roots)))))))
                     (walk
                      (fn [nodes acc]
                        (let loop ((xs (seq nodes))
                                   (acc acc))
                          (if (empty? xs)
                              acc
                              (let [item (first xs)
                                    item-id (workspace-item-id item)
                                    raw-children
                                    (hash-table-ref/default children item-id '())
                                    child-items
                                    (if (or (nil? raw-children)
                                            (null? raw-children))
                                        '()
                                        (cluck-sort-list raw-children
                                                         workspace-item-order<?))
                                    acc-with-item (cons item acc)
                                    acc-after-children (walk child-items acc-with-item)]
                                (loop (rest xs) acc-after-children)))))))
              (let [built (build-groups items '())
                    roots (vector-ref built 0)
                    sorted-roots (cluck-sort-list roots workspace-item-order<?)]
                (reverse (walk sorted-roots '())))))
          (let ((item-id (workspace-item-id (first xs))))
            (if (not (string=? item-id ""))
                (hash-table-set! present item-id #t))
            (loop-present (rest xs)))))))

(defn workspace-item-order-rows
  [rows]
  (let [outline-id-set (make-hash-table)
        outline-ids '()
        by-outline (make-hash-table)]
    (let loop ((xs rows))
      (if (empty? xs)
          (let [sorted-outline-ids (cluck-sort-list outline-ids string<?)]
            (let loop-outlines ((oids sorted-outline-ids)
                                (acc '()))
              (if (empty? oids)
                  (reverse acc)
                  (let [outline-id (first oids)
                        outline-items
                        (hash-table-ref/default by-outline outline-id '())
                        ordered-items
                        (workspace-item-order-outline-items outline-items)]
                    (let loop-items ((ys (seq ordered-items))
                                     (next-acc acc))
                      (if (empty? ys)
                          (loop-outlines (rest oids) next-acc)
                          (loop-items (rest ys)
                                      (cons (first ys) next-acc))))))))
          (let [item (first xs)
                outline-id (workspace-item-outline-id item)
                current-items (hash-table-ref/default by-outline outline-id '())]
            (if (not (hash-table-ref/default outline-id-set outline-id #f))
                (begin
                  (hash-table-set! outline-id-set outline-id #t)
                  (set! outline-ids (cons outline-id outline-ids))))
            (hash-table-set! by-outline outline-id (cons item current-items))
            (loop (rest xs)))))))

(defn workspace-item-ready-blocking-set
  [conn outline-end-status-cache item-cache]
  (let [blocking-set (make-hash-table)
        deps-rows
        (db/map-row
         (fn [from-id to-id]
           (cons from-id to-id))
         conn
         "select from_item_id, to_item_id from deps where type = 'blocks'")]
    (let loop ((xs deps-rows))
      (if (empty? xs)
          blocking-set
          (let [dep (first xs)
                from-id (or (car dep) "")
                to-id (or (cdr dep) "")
                other (hash-table-ref/default item-cache to-id #f)
                other-outline-id (and other (workspace-item-outline-id other))
                other-status (and other (workspace-item-status other))
                other-end-status-ids
                (and other
                     (hash-table-ref/default outline-end-status-cache other-outline-id '()))]
            (if (and (not (string=? from-id ""))
                     (not (string=? to-id ""))
                     other
                     other-outline-id
                     other-status
                     (not (member other-status other-end-status-ids)))
                (hash-table-set! blocking-set from-id #t))
            (loop (rest xs)))))))

(defn workspace-item-ready-class
  [item outline-end-status-cache blocking-set current-actor-id current-actor-kind]
  (let [outline-id (workspace-item-outline-id item)
        status (workspace-item-status item)
        assigned-actor-id (workspace-item-assigned-actor-id item)
        end-status-ids
        (hash-table-ref/default outline-end-status-cache outline-id '())
        item-id (workspace-item-id item)]
    (and (not (workspace-item-archived? item))
         (not (workspace-item-on-hold? item))
         (not (member status end-status-ids))
         (not (hash-table-ref/default blocking-set item-id #f))
         (cond
           (and (not (string=? assigned-actor-id ""))
                (string=? assigned-actor-id current-actor-id)
                (string=? current-actor-kind "agent"))
           'mine

           (string=? assigned-actor-id "")
           'out

           :else
           #f))))

(defn workspace-status-output
  []
  (let [workspace-name (or (workspace-current-name) "")
        workspace-root (or (workspace-current-path) "")]
    (if (and (not (string=? workspace-name ""))
             (not (string=? workspace-root "")))
        (let [conn (open-workspace-db)
              workspace-id (or (workspace-status-workspace-id conn) "")
              current-actor-id (or (workspace-status-current-actor-id conn) "")
              current-project-id (or (workspace-status-current-project-id conn) "")
              actor-count (workspace-status-count conn "select count(*) from actors")
              project-count (workspace-status-count conn "select count(*) from projects where archived = 0")
              outline-count (workspace-status-count conn "select count(*) from outlines where archived = 0")
              item-count (workspace-status-count conn "select count(*) from items where archived = 0")
              dep-count (workspace-status-count conn "select count(*) from deps")
              comment-count (workspace-status-count conn "select count(*) from comments where entity_kind = 'item'")
              discussion-count (workspace-status-count conn "select count(*) from discussions")
              actor (workspace-actor-by-id conn current-actor-id)
              current-write-actor-id (ro-workspace/workspace-current-write-actor-id actor current-actor-id)
              worklog-count (workspace-status-visible-worklog-count conn current-write-actor-id)
              attachment-count (workspace-status-count conn "select count(*) from attachments")]
          (ro-workspace/workspace-status-output
           workspace-name
           workspace-id
           current-actor-id
           current-project-id
           actor-count
           project-count
           outline-count
           item-count
           dep-count
           comment-count
           discussion-count
           worklog-count
           attachment-count))
        (error "ro workspace current is unavailable" workspace-json-path))))

(defn identity-list-output
  []
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [conn (open-workspace-db)
              current-actor-id (or (workspace-status-current-actor-id conn) "")
              actors (workspace-actors conn)]
          (ro-workspace/identity-list-output
           current-actor-id
           actors)))))

(defn identity-whoami-output
  []
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [conn (open-workspace-db)
              current-actor-id (or (workspace-status-current-actor-id conn) "")]
          (if (string=? current-actor-id "")
              (error "no current actor" current-actor-id)
              (let ((actor (workspace-actor-by-id conn current-actor-id)))
                (if actor
                    (ro-workspace/identity-whoami-output actor)
                    (error "actor not found" current-actor-id))))))))

(defn print-help
  []
  (display root-help-output)
  root-help-output)

(defn print-docs-help
  []
  (display docs-help-output)
  docs-help-output)

(defn print-docs
  []
  (display docs-output)
  docs-output)

(defn print-docs-topic
  [topic raw?]
  (let ((markdown (ro-docs/docs-topic-markdown topic)))
    (if markdown
        (if raw?
            (begin
              (display markdown)
              markdown)
            (let ((output (ro-docs/docs-topic-output topic)))
              (display output)
              output))
        (begin
          (display "unknown docs topic: " (current-error-port))
          (display (pr-str topic) (current-error-port))
          (newline (current-error-port))
          2))))

(defn completion-output
  [shell]
  (cond
    (string=? shell "bash") completion-bash-output
    (string=? shell "zsh") completion-zsh-output
    (string=? shell "fish") completion-fish-output
    :else false))

(defn print-completion-help
  []
  (display completion-help-output)
  completion-help-output)

(defn print-completion-output
  [shell]
  (let [output (completion-output shell)]
    (if output
        (begin
          (display output)
          output)
        (error "ro completion expects bash, zsh, or fish" shell))))

(defn completion-main
  [args]
  (cond
    (empty? args) (print-completion-help)
    (completion-help-request? args) (print-completion-help)
    (empty? (rest args)) (print-completion-output (first args))
    :else (error "ro completion expects bash, zsh, or fish" args)))

(defn print-workspace-help
  []
  (display workspace-help-output)
  workspace-help-output)

(defn print-workspace-subhelp
  [usage-output show-root?]
  (display usage-output (current-error-port))
  (if show-root?
      (begin
        (display workspace-help-output)
        (flush-output (current-output-port)))
      #t)
  1)

(defn print-workspace-current
  []
  (let ((output (workspace-current-output)))
    (display output)
    output))

(defn print-workspace-list
  []
  (let ((output (workspace-list-output)))
    (display output)
    output))

(defn print-workspace-add
  [name dir kind use?]
  (let [workspace-root (or (if (string=? (or dir "") "")
                               (current-directory)
                               dir)
                           "")
        layout (workspace-ensure-local-layout! workspace-root)
        actual-path (or (json-field-value layout "dir" workspace-root) workspace-root)
        result (workspace-registry-upsert! name actual-path kind use?)
        current? (first result)
        output
        (json-write-output
         (vector
          (cons 'data
                (vector
                 (cons 'workspace name)
                 (cons 'dir actual-path)
                 (cons 'kind kind)
                 (cons 'used current?)))))]
    (display output)
    output))

(defn print-workspace-init
  [name dir use?]
  (let [workspace-root (or (if (string=? (or dir "") "")
                               (current-directory)
                               dir)
                           "")
        layout (workspace-ensure-local-layout! workspace-root)
        actual-path (or (json-field-value layout "dir" workspace-root) workspace-root)
        result (workspace-registry-upsert! name actual-path "local" use?)
        current? (first result)
        output
        (json-write-output
         (vector
          (cons 'data
                (vector
                 (cons 'workspace name)
                 (cons 'dir actual-path)
                 (cons 'kind "local")
                 (cons 'used current?)))))]
    (display output)
    output))

(defn print-workspace-use
  [name]
  (let [root (workspace-registry-root)
        detail (workspace-registry-detail root name)]
    (if (not detail)
        (begin
          (display "workspace not found\n" (current-error-port))
          1)
        (let [path (or (workspace-detail-value detail "path") "")
              kind (or (workspace-detail-value detail "kind") "")
              output (json-write-output
                       (vector
                        (cons 'data
                              (vector
                               (cons 'workspace name)
                               (cons 'dir path)))))]
          (workspace-registry-upsert! name path kind true)
          (display output)
          output))))

(defn print-init-help
  []
  (display workspace-help-output)
  workspace-help-output)

(defn print-init-output
  []
  (let [name "default"
        workspace-root (current-directory)
        layout (workspace-ensure-local-layout! workspace-root)
        actual-path (or (json-field-value layout "dir" workspace-root) workspace-root)
        result (workspace-registry-upsert! name actual-path "local" true)
        current? (first result)
        output
        (json-write-output
         (vector
          (cons 'data
                (vector
                 (cons 'workspace name)
                 (cons 'dir actual-path)
                 (cons 'kind "local")
                 (cons 'used current?)))))]
    (display output)
    output))

