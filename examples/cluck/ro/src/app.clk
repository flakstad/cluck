(defn print-publish-help
  []
  (display publish-help-output)
  publish-help-output)

(defn publish-md-escape
  [value]
  (let [text (str value)]
    (list->string
     (let loop ((chars (string->list text))
                (acc '()))
       (if (empty? chars)
           (reverse acc)
           (let [ch (first chars)]
             (if (char=? ch #\return)
                 (loop (rest chars) acc)
                 (loop (rest chars) (cons ch acc)))))))))

(defn publish-write-file!
  [path text overwrite?]
  (if (and (not overwrite?)
           (fs/exists? path))
      (error "file exists (use --overwrite)" path)
      (begin
        (ensure-directory! (fs/dirname path))
        (fs/spit path text)
        path)))

(defn publish-item-path
  [to-dir item-id]
  (fs/path to-dir "items" (string-append item-id ".md")))

(defn publish-outline-index-path
  [to-dir outline-id]
  (fs/path to-dir "outlines" outline-id "index.md"))

(defn publish-outline-item-path
  [to-dir outline-id item-id]
  (fs/path to-dir "outlines" outline-id "items" (string-append item-id ".md")))

(defn publish-item-markdown
  [conn item include-archived? include-worklog?]
  (let [item-id (workspace-item-id item)
        outline-id (or (json-field-value item "outlineId" "") "")
        project-id (or (json-field-value item "projectId" "") "")
        title (publish-md-escape (or (json-field-value item "title" "") item-id))
        description (str/trim (publish-md-escape (or (json-field-value item "description" "") "")))
        status (str/trim (or (workspace-item-status item) ""))
        archived? (workspace-item-archived? item)
        tags (or (json-field-value item "tags" '()) '())
        comments (workspace-comment-records conn item-id 200 0)
        current-actor-id (or (workspace-status-current-actor-id conn) "")
        current-write-actor-id (workspace-current-write-actor-id conn current-actor-id)
        worklog (if (and include-worklog?
                         (not (string=? current-write-actor-id "")))
                    (workspace-worklog-records conn item-id 500 0)
                    '())
        lines (list (string-append "# " title) "")]
    (if (not (string=? status ""))
        (set! lines (append lines (list (string-append "- Status: `" (publish-md-escape status) "`"))))
        #t)
    (if (not (string=? project-id ""))
        (set! lines (append lines (list (string-append "- Project: `" (publish-md-escape project-id) "`"))))
        #t)
    (if (not (string=? outline-id ""))
        (set! lines (append lines (list (string-append "- Outline: `" (publish-md-escape outline-id) "`"))))
        #t)
    (set! lines (append lines (list (string-append "- Item: `" (publish-md-escape item-id) "`"))))
    (if archived?
        (set! lines (append lines (list "- Archived: `true`")))
        #t)
    (if (not (empty? tags))
        (set! lines
              (append
               lines
               (list
                (string-append "- Tags: "
                               (str/join " "
                                         (map (fn [tag]
                                                (string-append "#" (str/trim (str tag))))
                                              tags))))))
        #t)
    (set! lines (append lines (list "")))
    (if (and archived? (not include-archived?))
        (set! lines (append lines (list "> Archived item (use --include-archived)." "")))
        #t)
    (if (not (string=? description ""))
        (set! lines (append lines (list description "")))
        #t)
    (if (not (empty? comments))
        (begin
          (set! lines (append lines (list "## Comments" "")))
          (for-each
           (fn [comment]
             (let [body (str/trim (publish-md-escape (or (json-field-value comment "body" "") "")))
                   created-at (str/trim (or (json-field-value comment "createdAt" "") ""))
                   author-id (str/trim (or (json-field-value comment "authorId" "") ""))]
               (if (not (string=? body ""))
                   (set! lines
                         (append
                          lines
                          (list
                           (string-append "- "
                                          (if (string=? created-at "") "" (string-append created-at " "))
                                          (if (string=? author-id "") "" (string-append "`" author-id "` "))
                                          body))))
                   #t)))
           comments)
          (set! lines (append lines (list ""))))
        #t)
    (if (and include-worklog? (not (empty? worklog)))
        (begin
          (set! lines (append lines (list "## Worklog" "")))
          (for-each
           (fn [entry]
             (let [body (str/trim (publish-md-escape (or (json-field-value entry "body" "") "")))
                   created-at (str/trim (or (json-field-value entry "createdAt" "") ""))
                   author-id (str/trim (or (json-field-value entry "authorId" "") ""))]
               (if (not (string=? body ""))
                   (set! lines
                         (append
                          lines
                          (list
                           (string-append "- "
                                          (if (string=? created-at "") "" (string-append created-at " "))
                                          (if (string=? author-id "") "" (string-append "`" author-id "` "))
                                          body))))
                   #t)))
           worklog)
          (set! lines (append lines (list ""))))
        #t)
    (string-append (str/join "\n" lines) "\n")))

(defn workspace-outline-items
  [conn outline-id]
  (let [rows
        (db/map-row
         (fn [json-text]
           (item-json-record json-text))
         conn
         "select json from items where outline_id = ?1 order by lower(rank) asc, id asc"
         outline-id)]
    (workspace-item-order-rows rows)))

(defn publish-outline-index-markdown
  [conn outline items include-archived?]
  (let [outline-id (or (json-field-value outline "id" "") "")
        title (publish-md-escape (or (json-field-value outline "name" "") outline-id))
        project-id (str/trim (or (json-field-value outline "projectId" "") ""))
        lines (list (string-append "# Outline: " title) "")]
    (if (not (string=? project-id ""))
        (set! lines (append lines (list (string-append "- Project: `" (publish-md-escape project-id) "`"))))
        #t)
    (set! lines (append lines (list (string-append "- Outline: `" (publish-md-escape outline-id) "`") "" "## Items" "")))
    (for-each
     (fn [item]
       (if (or include-archived?
               (not (workspace-item-archived? item)))
           (let [item-id (workspace-item-id item)
                 item-title (publish-md-escape (or (json-field-value item "title" "") ""))
                 status (str/trim (or (workspace-item-status item) ""))]
             (set! lines
                   (append
                    lines
                    (list
                     (string-append "- `"
                                    item-id
                                    "` "
                                    (if (string=? status "")
                                        ""
                                        (string-append "[" (publish-md-escape status) "] "))
                                    item-title)))))
           #t))
     items)
    (string-append (str/join "\n" (append lines (list ""))) "\n")))

(defn publish-write-item!
  [conn item-id to-dir include-archived? include-worklog? overwrite?]
  (let [item (workspace-item-by-id conn item-id)]
    (if (not item)
        false
        (let [path (publish-item-path to-dir item-id)
              markdown (publish-item-markdown conn item include-archived? include-worklog?)]
          (list->vector
           (list (publish-write-file! path markdown overwrite?)))))))

(defn publish-write-outline!
  [conn outline-id to-dir include-archived? include-worklog? overwrite?]
  (let [outline (workspace-outline-by-id conn outline-id)]
    (if (not outline)
        false
        (let [items (workspace-outline-items conn outline-id)
              index-path (publish-outline-index-path to-dir outline-id)
              index-markdown (publish-outline-index-markdown conn outline items include-archived?)]
          (publish-write-file! index-path index-markdown overwrite?)
          (let loop ((xs items)
                     (written (list index-path)))
            (if (empty? xs)
                (list->vector (reverse written))
                (let [item (first xs)]
                  (if (and (not include-archived?)
                           (workspace-item-archived? item))
                      (loop (rest xs) written)
                      (let [item-id (workspace-item-id item)
                            path (publish-outline-item-path to-dir outline-id item-id)
                            markdown (publish-item-markdown conn item include-archived? include-worklog?)]
                        (publish-write-file! path markdown overwrite?)
                        (loop (rest xs) (cons path written)))))))))))

(defn print-publish-item
  [item-id to-dir include-archived? include-worklog? overwrite?]
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [conn (open-workspace-db)
              written (publish-write-item! conn item-id to-dir include-archived? include-worklog? overwrite?)]
          (db/finalize! conn)
          (if (not written)
              (begin
                (display "item not found\n" (current-error-port))
                1)
              (let [output (json-write-output
                            (vector
                             (cons 'data
                                   (vector
                                    (cons 'written (vector->list written))
                                    (cons 'count (length (vector->list written)))))))]
                (display output)
                output))))))

(defn print-publish-outline
  [outline-id to-dir include-archived? include-worklog? overwrite?]
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [conn (open-workspace-db)
              written (publish-write-outline! conn outline-id to-dir include-archived? include-worklog? overwrite?)]
          (db/finalize! conn)
          (if (not written)
              (begin
                (display "outline not found\n" (current-error-port))
                1)
              (let [output (json-write-output
                            (vector
                             (cons 'data
                                   (vector
                                    (cons 'written (vector->list written))
                                    (cons 'count (length (vector->list written)))))))]
                (display output)
                output))))))

(defn publish-run-effect
  [effect]
  (let [op (pr-str (vector-ref effect 0))
        args (vector-ref effect 1)]
    (cond
      (string=? op ":publish/help")
      (print-publish-help)

      (string=? op ":publish/item")
      (print-publish-item (or (get args :item-id) "")
                          (or (get args :to-dir) "")
                          (or (get args :include-archived?) false)
                          (or (get args :include-worklog?) false)
                          (or (get args :overwrite?) true))

      (string=? op ":publish/outline")
      (print-publish-outline (or (get args :outline-id) "")
                             (or (get args :to-dir) "")
                             (or (get args :include-archived?) false)
                             (or (get args :include-worklog?) false)
                             (or (get args :overwrite?) true))

      :else
      (error "unsupported publish effect" effect))))

(defn workspace-today-iso
  []
  (let [result (proc/exec "python3" "-c" "from datetime import date; print(date.today().isoformat())")]
    (str/trim (or (get result :out) ""))))

(defn workspace-first-project
  [conn]
  (let [projects (workspace-projects conn)]
    (if (empty? projects) false (first projects))))

(defn workspace-default-capture-outline
  [conn]
  (let [current-project-id (or (workspace-status-current-project-id conn) "")
        project (if (string=? current-project-id "")
                  (workspace-first-project conn)
                  (workspace-project-by-id conn current-project-id))
        project-id (or (and project (json-field-value project "id" "")) "")]
    (if (string=? project-id "")
        false
        (workspace-project-first-outline conn project-id))))

(defn workspace-capture-title
  [url selection]
  (let [selection (str/trim (or selection ""))
        url (str/trim (or url ""))]
    (cond
      (not (string=? selection "")) selection
      (not (string=? url "")) url
      :else "Captured")))

(defn workspace-capture-description
  [url selection]
  (let [parts '()
        selection (str/trim (or selection ""))
        url (str/trim (or url ""))]
    (if (not (string=? url ""))
        (set! parts (append parts (list (string-append "URL: " url)))))
    (if (not (string=? selection ""))
        (set! parts (append parts (list "" selection))))
    (str/join "\n" parts)))

(defn workspace-capture!
  [conn url selection]
  (let [outline (workspace-default-capture-outline conn)]
    (if (not outline)
        false
        (workspace-item-create! conn
                                (workspace-capture-title url selection)
                                ""
                                (or (json-field-value outline "id" "") "")
                                (or (json-field-value outline "projectId" "") "")))))

(defn workspace-items-all
  [conn]
  (db/map-row
   (fn [json-text] (item-json-record json-text))
   conn
   "select json from items where archived = 0"))

(defn attachment-basename
  [path]
  (let [result (proc/exec "python3" "-c" "import os,sys; print(os.path.basename(sys.argv[1]))" path)]
    (str/trim (or (get result :out) ""))))

(defn attachment-size-bytes
  [path]
  (let [result (proc/exec "python3" "-c" "import os,sys; print(os.path.getsize(sys.argv[1]))" path)]
    (string->number (str/trim (or (get result :out) "0")))))

(defn attachment-copy-file!
  [source dest]
  (let [result (proc/exec "python3" "-c" "import os,shutil,sys; os.makedirs(os.path.dirname(sys.argv[2]), exist_ok=True); shutil.copy2(sys.argv[1], sys.argv[2])" source dest)]
    (= 0 (or (get result :exit) 1))))

(defn attachment-export-file!
  [source dest]
  (attachment-copy-file! source dest))

(defn workspace-attachment-create-context
  []
  (let [result
        (proc/exec
         "python3"
         "-c"
         "from datetime import datetime, timezone; import json, uuid; now=datetime.now(timezone.utc); print(json.dumps({'eventId':'evt-' + uuid.uuid4().hex,'attachmentId':'att-' + uuid.uuid4().hex[:8],'issuedAt':now.isoformat(timespec='microseconds').replace('+00:00','Z'),'issuedAtUnixms':int(now.timestamp()*1000)}, ensure_ascii=False))")
        exit (or (get result :exit) 1)]
    (if (= exit 0)
        (call-with-input-string (or (get result :out) "") (fn [port] (json/json-read port)))
        (error "unable to generate attachment metadata" result))))

(defn workspace-attachment-record
  [attachment-id entity-kind entity-id original-name size-bytes path title alt updated-at updated-at-unixms]
  (vector
   (cons 'id attachment-id)
   (cons 'entityKind entity-kind)
   (cons 'entityId entity-id)
   (cons 'originalName original-name)
   (cons 'sizeBytes size-bytes)
   (cons 'path path)
   (cons 'title title)
   (cons 'alt alt)
   (cons 'updatedAt updated-at)
   (cons 'updatedAtUnixms updated-at-unixms)))

(defn workspace-attachment-save!
  [conn attachment]
  (let [attachment-id (or (json-field-value attachment "id" "") "")
        entity-kind (or (json-field-value attachment "entityKind" "") "")
        entity-id (or (json-field-value attachment "entityId" "") "")
        original-name (or (json-field-value attachment "originalName" "") "")
        size-bytes (or (json-field-value attachment "sizeBytes" 0) 0)
        updated-at-unixms (or (json-field-value attachment "updatedAtUnixms" 0) 0)
        json-text (json-write-text attachment)]
    (db/execute conn
                "insert or replace into attachments(id, entity_kind, entity_id, original_name, size_bytes, json, updated_at_unixms) values(?1, ?2, ?3, ?4, ?5, ?6, ?7)"
                attachment-id entity-kind entity-id original-name size-bytes json-text updated-at-unixms)
    attachment))

(defn workspace-attachment-by-id
  [conn attachment-id]
  (let [rows (db/map-row (fn [json-text] (call-with-input-string json-text (fn [port] (json/json-read port))))
                         conn
                         "select json from attachments where id = ?1 limit 1"
                         attachment-id)]
    (if (empty? rows) false (first rows))))

(defn workspace-attachment-records
  [conn entity-id]
  (db/map-row
   (fn [json-text] (call-with-input-string json-text (fn [port] (json/json-read port))))
   conn
   "select json from attachments where entity_id = ?1 order by updated_at_unixms asc, id asc"
   entity-id))

(defn workspace-attachment-path
  [attachment]
  (let [path (or (json-field-value attachment "path" "") "")
        workspace-root (or (workspace-current-path) "")]
    (if (or (string=? path "")
            (str/starts-with? path "/"))
        path
        (fs/path workspace-root path))))

(defn workspace-attachment-add!
  [conn entity-id source-path kind title alt max-mb link? copy?]
  (let [entity-kind (if (not (string=? (str/trim (or kind "")) ""))
                        kind
                        (if (str/starts-with? (or entity-id "") "cmt-") "comment" "item"))
        entity-ok? (if (string=? entity-kind "comment")
                       (workspace-comment-by-id conn entity-id)
                       (workspace-item-by-id conn entity-id))]
    (if (or (not entity-ok?)
            (not (fs/exists? source-path)))
        false
        (let [size-bytes (or (attachment-size-bytes source-path) 0)
              max-bytes (if (> (or max-mb 0) 0) (* max-mb 1024 1024) 0)]
          (if (and (> max-bytes 0) (> size-bytes max-bytes))
              (error "attachment exceeds max size" source-path)
              (let [meta (workspace-attachment-create-context)
                    attachment-id (or (json-field-value meta "attachmentId" "") "")
                    event-id (or (json-field-value meta "eventId" "") "")
                    issued-at (or (json-field-value meta "issuedAt" "") "")
                    issued-at-unixms (or (json-field-value meta "issuedAtUnixms" 0) 0)
                    original-name (attachment-basename source-path)
                    rel-path (if link?
                                 source-path
                                 (fs/path "attachments" (string-append attachment-id "--" original-name)))]
                (when (not link?)
                  (if (not (attachment-copy-file! source-path (fs/path (workspace-current-path) rel-path)))
                      (error "failed to copy attachment" source-path)
                      true))
                (let [attachment (workspace-attachment-record attachment-id entity-kind entity-id original-name size-bytes rel-path (or title "") (or alt "") issued-at issued-at-unixms)
                      event (vector
                             (cons 'eventId event-id)
                             (cons 'workspaceId (or (workspace-status-workspace-id conn) ""))
                             (cons 'replicaId (workspace-replica-id))
                             (cons 'entityKind "attachment")
                             (cons 'entityId attachment-id)
                             (cons 'entitySeq 1)
                             (cons 'type "attachment.add")
                             (cons 'parents (list entity-id))
                             (cons 'issuedAt issued-at)
                             (cons 'actorId (or (workspace-status-current-actor-id conn) ""))
                             (cons 'payload attachment)
                             (cons 'localStatus "local")
                             (cons 'serverStatus "pending"))]
                  (workspace-attachment-save! conn attachment)
                  (workspace-item-append-event! event)
                  attachment)))))))

(defn workspace-attachment-list-output
  [conn entity-id]
  (json-write-output (vector (cons 'data (workspace-attachment-records conn entity-id)))))

(defn workspace-clock-state
  [conn]
  (let [item-id (workspace-state-meta-value conn "clock_running_item_id" "")
        started-at (workspace-state-meta-value conn "clock_started_at" "")
        actor-id (workspace-state-meta-value conn "clock_actor_id" "")
        item (if (string=? item-id "")
                 (vector
                  (cons 'id "")
                  (cons 'projectId "")
                  (cons 'outlineId "")
                  (cons 'parentId "")
                  (cons 'status "")
                  (cons 'title "")
                  (cons 'description "")
                  (cons 'priority false)
                  (cons 'onHold false)
                  (cons 'assignedActorId "")
                  (cons 'dueDate "")
                  (cons 'scheduleDate "")
                  (cons 'tags '())
                  (cons 'itemKind "")
                  (cons 'childrenKind "")
                  (cons 'commentsCount 0)
                  (cons 'worklogCount 0)
                  (cons 'hasChildren false))
                 (or (workspace-item-by-id conn item-id) false))]
    (vector
     (cons 'running (not (string=? item-id "")))
     (cons 'itemId item-id)
     (cons 'actorId actor-id)
     (cons 'startedAt started-at)
     (cons 'elapsedMinutes 0)
     (cons 'item item))))

(defn workspace-clock-hints
  [state]
  (let [running? (or (json-field-value state "running" false) false)
        item-id (or (json-field-value state "itemId" "") "")]
    (if running?
        (append
         (list "ro clock out --body \"...\"")
         (if (string=? item-id "")
             '()
             (list (string-append "ro items show " item-id)
                   (string-append "ro worklog list " item-id))))
        (list "ro items ready" "ro clock in <item-id>"))))

(defn workspace-clock-status-output
  [conn]
  (let [state (workspace-clock-state conn)]
    (json-write-output
     (vector
      (cons 'data state)
      (cons '_hints (workspace-clock-hints state))))))

(defn workspace-clock-in!
  [conn item-id]
  (let [current (workspace-clock-state conn)]
    (cond
      (not (workspace-item-by-id conn item-id)) false
      (and (or (json-field-value current "running" false) false)
           (not (string=? (or (json-field-value current "itemId" "") "") item-id)))
      (error "clock already running" item-id)
      (or (json-field-value current "running" false) false)
      current
      :else
      (let [meta (workspace-event-context)
            started-at (or (json-field-value meta "issuedAt" "") "")
            actor-id (or (workspace-status-current-actor-id conn) "")]
        (if (string=? actor-id "")
            (error "missing current actor" actor-id)
            true)
        (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)" "clock_running_item_id" item-id)
        (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)" "clock_started_at" started-at)
        (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)" "clock_actor_id" actor-id)
        (workspace-clock-state conn)))))

(defn workspace-clock-out!
  [conn body]
  (let [state (workspace-clock-state conn)
        running? (or (json-field-value state "running" false) false)]
    (if (not running?)
        false
        (let [item-id (or (json-field-value state "itemId" "") "")
              started-at (or (json-field-value state "startedAt" "") "")
              actor-id (or (json-field-value state "actorId" "") "")
              meta (workspace-event-context)
              ended-at (or (json-field-value meta "issuedAt" "") "")
              worklog-body (if (string=? (str/trim (or body "")) "")
                               "Clocked time"
                               body)
              worklog-meta (workspace-worklog-create-context)
              worklog-id (or (json-field-value worklog-meta "worklogId" "") "")
              worklog (vector
                       (cons 'id worklog-id)
                       (cons 'entityKind "item")
                       (cons 'entityId item-id)
                       (cons 'body worklog-body)
                       (cons 'authorId actor-id)
                       (cons 'kind "clock")
                       (cons 'startedAt started-at)
                       (cons 'endedAt ended-at)
                       (cons 'durationMinutes 0)
                       (cons 'createdAt ended-at)
                       (cons 'updatedAt ended-at)
                       (cons 'updatedAtUnixms (or (json-field-value meta "issuedAtUnixms" 0) 0)))]
          (workspace-worklog-save! conn worklog)
          (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)" "clock_running_item_id" "")
          (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)" "clock_started_at" "")
          (db/execute conn "insert or replace into state_meta(k, v) values(?1, ?2)" "clock_actor_id" "")
          (vector
           (cons 'clock (workspace-clock-state conn))
           (cons 'worklog worklog))))))

(defn workspace-clock-out-output
  [conn body]
  (let [result (workspace-clock-out! conn body)]
    (if result
        (json-write-output
         (vector
          (cons 'data result)
          (cons '_hints
                (let [clock-state (or (json-field-value result "clock" false) false)
                      item-id (if clock-state (or (json-field-value clock-state "itemId" "") "") "")]
                  (append
                   (list "ro items ready" "ro clock in <item-id>")
                   (if (string=? item-id "")
                       '()
                       (list (string-append "ro worklog list " item-id))))))))
        false)))

(defn workspace-item-active?
  [conn item today end-status-ids]
  (let [archived? (or (json-field-value item "archived" false) false)
        on-hold? (or (json-field-value item "onHold" false) false)
        status-id (or (json-field-value item "statusId" "") "")
        due-date (or (json-field-value item "dueDate" "") "")
        schedule-date (or (json-field-value item "scheduleDate" "") "")
        priority? (or (json-field-value item "priority" false) false)]
    (and (not archived?)
         (not on-hold?)
         (not (member status-id end-status-ids))
         (or (and (not (string=? due-date "")) (string<=? due-date today))
             (and (not (string=? schedule-date "")) (string<=? schedule-date today))
             priority?))))

(defn workspace-agenda-items
  [conn]
  (let [today (workspace-today-iso)
        items (workspace-items-all conn)
        end-cache {}
        selected
        (filter (fn [item]
                  (let [outline-id (or (json-field-value item "outlineId" "") "")
                        end-status-ids (workspace-outline-end-status-ids conn outline-id)]
                    (workspace-item-active? conn item today end-status-ids)))
                items)]
    (cluck-sort-list selected workspace-item-order<?)))

(defn workspace-agenda-output
  [conn]
  (let [today (workspace-today-iso)
        items (workspace-agenda-items conn)
        current-actor-id (or (workspace-status-current-actor-id conn) "")
        current-write-actor-id (workspace-current-write-actor-id conn current-actor-id)
        summaries (map (fn [item] (workspace-item-summary conn item current-write-actor-id)) items)]
    (json-write-output
     (vector
      (cons 'data
            (vector
             (cons 'today today)
             (cons 'items summaries)
             (cons 'meta (vector (cons 'counts (vector (cons 'total (length summaries))))))))
      (cons '_hints (list "ro items ready" "ro items show <item-id>" "ro web"))))))

(defn print-capture-help [] (display capture-help-output) capture-help-output)
(defn print-attachments-help [] (display attachments-help-output) attachments-help-output)
(defn print-clock-help [] (display clock-help-output) clock-help-output)
(defn print-agenda-help [] (display agenda-help-output) agenda-help-output)

(defn print-capture-run
  [url selection no-output?]
  (let [conn (open-workspace-db)
        item (workspace-capture! conn url selection)]
    (if (not item)
        (begin (db/finalize! conn) (display "capture target unavailable\n" (current-error-port)) 1)
        (let [output (json-write-output (vector (cons 'data item)))]
          (db/finalize! conn)
          (if no-output? 0 (begin (display output) output))))))

(defn print-attachments-list
  [entity-id]
  (let [conn (open-workspace-db)
        output (workspace-attachment-list-output conn entity-id)]
    (db/finalize! conn)
    (display output)
    output))

(defn print-attachments-add
  [entity-id path kind title alt max-mb link? copy?]
  (let [conn (open-workspace-db)
        attachment (workspace-attachment-add! conn entity-id path kind title alt max-mb link? copy?)]
    (if (not attachment)
        (begin (db/finalize! conn) (display "unable to add attachment\n" (current-error-port)) 1)
        (let [output (json-write-output (vector (cons 'data attachment)))]
          (db/finalize! conn)
          (display output)
          output))))

(defn print-attachments-open
  [attachment-id print-path?]
  (let [conn (open-workspace-db)
        attachment (workspace-attachment-by-id conn attachment-id)]
    (if (not attachment)
        (begin (db/finalize! conn) (display "attachment not found\n" (current-error-port)) 1)
        (let [path (workspace-attachment-path attachment)]
          (db/finalize! conn)
          (if print-path?
              (begin (display (string-append path "\n")) path)
              (let [result (proc/exec "open" path)]
                (display (json-write-output (vector (cons 'data (vector (cons 'opened path))))))
                path))))))

(defn print-attachments-export
  [attachment-id dest-path]
  (let [conn (open-workspace-db)
        attachment (workspace-attachment-by-id conn attachment-id)]
    (if (not attachment)
        (begin (db/finalize! conn) (display "attachment not found\n" (current-error-port)) 1)
        (let [source (workspace-attachment-path attachment)]
          (if (not (attachment-export-file! source dest-path))
              (begin (db/finalize! conn) (display "failed to export attachment\n" (current-error-port)) 1)
              (let [output (json-write-output (vector (cons 'data (vector (cons 'exportedTo dest-path)))))]
                (db/finalize! conn)
                (display output)
                output))))))

(defn print-clock-status
  []
  (let [conn (open-workspace-db)
        output (workspace-clock-status-output conn)]
    (db/finalize! conn)
    (display output)
    output))

(defn print-clock-in
  [item-id]
  (let [conn (open-workspace-db)
        state (workspace-clock-in! conn item-id)]
    (if (not state)
        (begin (db/finalize! conn) (display "item not found\n" (current-error-port)) 1)
        (let [output (json-write-output
                      (vector
                       (cons 'data state)
                       (cons '_hints (workspace-clock-hints state))))]
          (db/finalize! conn)
          (display output)
          output))))

(defn print-clock-out
  [body]
  (let [conn (open-workspace-db)
        output (workspace-clock-out-output conn body)]
    (if output
        (begin
          (db/finalize! conn)
          (display output)
          output)
        (begin
          (db/finalize! conn)
          (display "no running clock\n" (current-error-port))
          1))))

(defn print-agenda-show
  []
  (let [result (proc/exec
                "python3"
                "-c"
                (string-append
                 "import sqlite3, json, sys;"
                 "from datetime import date, datetime, timedelta, timezone;"
                 "db=sqlite3.connect(sys.argv[1]);"
                 "today=date.today(); due_end=today + timedelta(days=7); sched_end=today + timedelta(days=3);"
                 "projects={row[0]: row[1] for row in db.execute(\"select id, name from projects\")};"
                 "outlines={}; end_status={};\n"
                 "for oid, name, defs_json in db.execute(\"select id, name, status_defs_json from outlines\"):\n"
                 " outlines[oid]=name\n"
                 " ids=set()\n"
                 " try:\n"
                 "  defs=json.loads(defs_json or '[]')\n"
                 " except Exception:\n"
                 "  defs=[]\n"
                 " for entry in defs:\n"
                 "  if entry.get('isEndState'):\n"
                 "   ids.add(str(entry.get('id') or ''))\n"
                 " end_status[oid]=ids\n"
                 "clock_item=(db.execute(\"select v from state_meta where k='clock_running_item_id' limit 1\").fetchone() or [''])[0]\n"
                 "def parse_date(v):\n"
                 " if not v:\n"
                 "  return None\n"
                 " txt=str(v).strip()\n"
                 " if not txt:\n"
                 "  return None\n"
                 " try:\n"
                 "  return date.fromisoformat(txt[:10])\n"
                 " except Exception:\n"
                 "  return None\n"
                 "def latest_worked(item_id):\n"
                 " row=db.execute(\"select json_extract(json, '$.updatedAt'), updated_at_unixms from worklog where entity_kind='item' and entity_id=? order by updated_at_unixms desc, id desc limit 1\", (item_id,)).fetchone()\n"
                 " return row if row else ('', 0)\n"
                 "items=[]; counts={'total':0,'priority':0,'due':0,'scheduled':0}\n"
                 "for (item_id, raw_json) in db.execute(\"select id, json from items where archived=0\"):\n"
                 " item=json.loads(raw_json)\n"
                 " if item.get('archived') or item.get('onHold'):\n"
                 "  continue\n"
                 " outline_id=str(item.get('outlineId') or '')\n"
                 " status_id=str(item.get('statusId') or item.get('status') or '')\n"
                 " if status_id and status_id in end_status.get(outline_id, set()):\n"
                 "  continue\n"
                 " due=parse_date(item.get('dueDate') or item.get('due'))\n"
                 " sched=parse_date(item.get('scheduleDate') or item.get('schedule'))\n"
                 " prio=bool(item.get('priority'))\n"
                 " due_in=bool(due and due <= due_end)\n"
                 " sched_in=bool(sched and sched <= sched_end)\n"
                 " if not (prio or due_in or sched_in):\n"
                 "  continue\n"
                 " if due_in and sched_in:\n"
                 "  match_kind='due' if due <= sched else 'scheduled'\n"
                 " elif due_in:\n"
                 "  match_kind='due'\n"
                 " elif sched_in:\n"
                 "  match_kind='scheduled'\n"
                 " else:\n"
                 "  match_kind='priority'\n"
                 " if prio: counts['priority'] += 1\n"
                 " if due_in: counts['due'] += 1\n"
                 " if sched_in: counts['scheduled'] += 1\n"
                 " counts['total'] += 1\n"
                 " comments_count=(db.execute(\"select count(*) from comments where entity_kind='item' and entity_id=?\", (item_id,)).fetchone() or [0])[0]\n"
                 " worklog_count=(db.execute(\"select count(*) from worklog where entity_kind='item' and entity_id=?\", (item_id,)).fetchone() or [0])[0]\n"
                 " child_count=(db.execute(\"select count(*) from items where parent_id=? and archived=0\", (item_id,)).fetchone() or [0])[0]\n"
                 " blocked_by=(db.execute(\"select count(*) from deps where to_item_id=? and type='blocks'\", (item_id,)).fetchone() or [0])[0]\n"
                 " open_discussions=(db.execute(\"select count(*) from discussions where entity_kind='item' and entity_id=? and state='open'\", (item_id,)).fetchone() or [0])[0]\n"
                 " last_worked_at, last_worked_ms = latest_worked(item_id)\n"
                 " worked_recently=bool(last_worked_ms and last_worked_ms >= int((datetime.now(timezone.utc).timestamp() - 7*86400) * 1000))\n"
                 " rank=str(item.get('rank') or '')\n"
                 " sort_date=(due if match_kind=='due' else sched if match_kind=='scheduled' else date.max)\n"
                 " kind_rank={'due':0,'scheduled':1,'priority':2}[match_kind]\n"
                 " prio_rank=0 if prio else 1\n"
                 " item_out={\n"
                 "  'id': item_id,\n"
                 "  'projectId': str(item.get('projectId') or ''),\n"
                 "  'projectName': projects.get(str(item.get('projectId') or ''), ''),\n"
                 "  'outlineId': outline_id,\n"
                 "  'outlineName': outlines.get(outline_id, ''),\n"
                 "  'parentId': str(item.get('parentId') or ''),\n"
                 "  'status': str(item.get('status') or status_id),\n"
                 "  'title': str(item.get('title') or ''),\n"
                 "  'description': str(item.get('description') or ''),\n"
                 "  'priority': prio,\n"
                 "  'onHold': bool(item.get('onHold')),\n"
                 "  'assignedActorId': str(item.get('assignedActorId') or ''),\n"
                 "  'dueDate': str(item.get('dueDate') or ''),\n"
                 "  'scheduleDate': str(item.get('scheduleDate') or ''),\n"
                 "  'tags': item.get('tags') or [],\n"
                 "  'itemKind': str(item.get('itemKind') or ''),\n"
                 "  'childrenKind': str(item.get('childrenKind') or ''),\n"
                 "  'commentsCount': comments_count,\n"
                 "  'worklogCount': worklog_count,\n"
                 "  'hasChildren': bool(child_count),\n"
                 "  'matchKind': match_kind,\n"
                 "  'blockedByCount': blocked_by,\n"
                 "  'openDiscussionsCount': open_discussions,\n"
                 "  'runningClock': item_id == clock_item,\n"
                 "  'workedRecently': worked_recently,\n"
                 "  'lastWorkedAt': str(last_worked_at or '')\n"
                 " }\n"
                 " items.append((sort_date.isoformat() if sort_date != date.max else '9999-12-31', kind_rank, prio_rank, item_out['projectId'], outline_id, rank, item_id, item_out))\n"
                 "items.sort(key=lambda row: row[:7])\n"
                 "data_items=[row[7] for row in items]\n"
                 "out={'data': {'today': today.isoformat(), 'items': data_items, 'groups': [], 'meta': {'view': {'id': 'today', 'label': 'Today', 'summary': 'Default agenda: due <= 7d, scheduled <= 3d, and priority items.', 'groupBy': 'none', 'sortBy': 'urgency', 'default': True}, 'query': {'kind': 'default', 'description': 'Active items matching the default agenda windows.', 'dueDays': 7, 'scheduleDays': 3, 'includeAssigned': True, 'includeOnHold': False, 'requiresIncompleteDependencies': False, 'requiresOpenDiscussions': False, 'workedDays': 0}, 'counts': counts, 'windows': {'dueDays': 7, 'scheduleDays': 3, 'workedDays': 0}}}, '_hints': ['ro agenda list-views', 'ro agenda explain today', 'ro agenda run today --pretty', 'ro items show <item-id>']};"
                 "print(json.dumps(out, ensure_ascii=False));")
                (workspace-db-path))]
    (if (= 0 (or (get result :exit) 1))
        (let [output (string-append (or (get result :out) "") (if (str/ends-with? (or (get result :out) "") "\n") "" "\n"))]
          (display output)
          output)
        (begin (display (or (get result :err) "failed agenda query\n") (current-error-port)) 1))))

(defn capture-run-effect
  [effect]
  (let [op (pr-str (vector-ref effect 0))
        args (vector-ref effect 1)]
    (cond
      (string=? op ":capture/help") (print-capture-help)
      (string=? op ":capture/run") (print-capture-run (or (get args :url) "")
                                                      (or (get args :selection) "")
                                                      (or (get args :no-output?) false))
      :else (error "unsupported capture effect" effect))))

(defn attachments-run-effect
  [effect]
  (let [op (pr-str (vector-ref effect 0))
        args (vector-ref effect 1)]
    (cond
      (string=? op ":attachments/help") (print-attachments-help)
      (string=? op ":attachments/add") (print-attachments-add (or (get args :entity-id) "")
                                                              (or (get args :path) "")
                                                              (or (get args :kind) "")
                                                              (or (get args :title) "")
                                                              (or (get args :alt) "")
                                                              (or (get args :max-mb) 0)
                                                              (or (get args :link?) false)
                                                              (or (get args :copy?) false))
      (string=? op ":attachments/list") (print-attachments-list (or (get args :entity-id) ""))
      (string=? op ":attachments/open") (print-attachments-open (or (get args :attachment-id) "")
                                                                (or (get args :print-path?) false))
      (string=? op ":attachments/export") (print-attachments-export (or (get args :attachment-id) "")
                                                                    (or (get args :dest-path) ""))
      :else (error "unsupported attachments effect" effect))))

(defn clock-run-effect
  [effect]
  (let [op (pr-str (vector-ref effect 0))
        args (vector-ref effect 1)]
    (cond
      (string=? op ":clock/help") (print-clock-help)
      (string=? op ":clock/status") (print-clock-status)
      (string=? op ":clock/in") (print-clock-in (or (get args :item-id) ""))
      (string=? op ":clock/out") (print-clock-out (or (get args :body) ""))
      :else (error "unsupported clock effect" effect))))

(defn agenda-run-effect
  [effect]
  (let [op (pr-str (vector-ref effect 0))]
    (cond
      (string=? op ":agenda/help") (print-agenda-help)
      (string=? op ":agenda/show") (print-agenda-show)
      :else (error "unsupported agenda effect" effect))))

(defn run-effects-generic
  [effects runner]
  (let loop ((xs (or effects '()))
             (result 0))
    (if (empty? xs) result (loop (rest xs) (runner (first xs))))))

(def events-default-limit 200)

(defn print-events-help
  []
  (display events-help-output)
  events-help-output)

(defn print-events-list
  [limit]
  (let ((output (events-list-output limit)))
    (display output)
    output))

(defn workspace-item-edge-other-done?
  [conn other-item]
  (let [outline-id (or (json-field-value other-item "outlineId" "") "")
        status (workspace-item-status other-item)
        end-status-ids (workspace-outline-end-status-ids conn outline-id)]
    (and (not (string=? outline-id ""))
         (member status end-status-ids))))

(defn workspace-item-edge-for
  [conn current-item-id item-cache end-status-cache dep]
  (let [dep-type (or (json-first-field-value dep (list "type" "typ") "") "")
        from-id (or (json-first-field-value dep (list "fromItemId" "from_item_id") "") "")
        to-id (or (json-first-field-value dep (list "toItemId" "to_item_id") "") "")
        out? (string=? from-id current-item-id)
        in? (string=? to-id current-item-id)
        other-id (cond
                   (and (string=? dep-type "blocks") out?) to-id
                   (and (string=? dep-type "blocks") in?) from-id
                   (string=? dep-type "related")
                   (if (string=? to-id current-item-id) from-id to-id)
                   :else "")
        direction (cond
                    (and (string=? dep-type "blocks") out?) "out"
                    (and (string=? dep-type "blocks") in?) "in"
                    (string=? dep-type "related")
                    (if (string=? to-id current-item-id) "in" "out")
                    :else "")]
    (if (or (string=? dep-type "")
            (string=? other-id "")
            (string=? direction ""))
        #f
        (let [cached-other (hash-table-ref/default item-cache other-id #f)
              other (if cached-other
                        cached-other
                        (let [lookup (workspace-item-by-id conn other-id)]
                          (when lookup
                            (hash-table-set! item-cache other-id lookup))
                          lookup))]
          (if (or (not other)
                  (workspace-item-archived? other))
              #f
              (let [other-outline-id (or (json-field-value other "outlineId" "") "")
                    other-end-status-ids
                    (hash-table-ref/default end-status-cache other-outline-id #f)
                    other-end-status-ids
                    (if other-end-status-ids
                        other-end-status-ids
                        (let [lookup (workspace-outline-end-status-ids conn other-outline-id)]
                          (hash-table-set! end-status-cache other-outline-id lookup)
                          lookup))
                    other-done (and (not (string=? other-outline-id ""))
                                    (member (workspace-item-status other)
                                            other-end-status-ids))]
                (vector
                 (cons 'type dep-type)
                 (cons 'direction direction)
                 (cons 'other other)
                 (cons 'otherDone (if other-done #t #f)))))))))

(defn workspace-item-show-output
  [conn item-id]
  (let [item (workspace-item-by-id conn item-id)]
    (if (not item)
        #f
        (let [outline-id (or (json-field-value item "outlineId" "") "")
              current-actor-id (or (workspace-status-current-actor-id conn) "")
              current-write-actor-id (workspace-current-write-actor-id conn current-actor-id)
              children (workspace-item-children conn item-id)
              children-summaries (map (fn [child]
                                        (workspace-item-child-summary conn child))
                                      children)
              end-status-ids (workspace-outline-end-status-ids conn outline-id)
              children-counts (workspace-item-counts children end-status-ids)
              item-cache (make-hash-table)
              end-status-cache (make-hash-table)
              deps-rows (workspace-item-deps conn item-id)
              worklog-count
              (if (string=? current-write-actor-id "")
                  0
                  (db/first-result
                   conn
                   "select count(*) from worklog where entity_kind = 'item' and entity_id = ?1 and author_id in (select id from actors where coalesce(nullif(trim(json_extract(json, '$.userId')), ''), id) = ?2)"
                   item-id
                   current-write-actor-id))
              has-children? (not (empty? children))]
          (hash-table-set! item-cache item-id item)
          (hash-table-set! end-status-cache outline-id end-status-ids)
          (let loop ((xs deps-rows)
                     (blocks-in '())
                     (blocks-out '())
                     (related '()))
            (if (empty? xs)
                (let [blocks-in (reverse blocks-in)
                      blocks-out (reverse blocks-out)
                      related (reverse related)
                      deps (vector
                            (cons 'blocks
                                  (vector
                                   (cons 'incoming blocks-in)
                                   (cons 'outgoing blocks-out)))
                            (cons 'related related))
                      comments-count
                      (workspace-item-count
                       conn
                       "select count(*) from comments where entity_kind = 'item' and entity_id = ?1"
                       item-id)
                      discussions-count
                      (workspace-item-count
                       conn
                       "select count(*) from discussions where entity_kind = 'item' and entity_id = ?1"
                       item-id)
                      meta-blocks-in (count blocks-in)
                      meta-blocks-out (count blocks-out)]
                  (ro-items/items-show-output
                   item
                   children-summaries
                   children-counts
                   deps
                   comments-count
                   discussions-count
                   meta-blocks-in
                   meta-blocks-out
                   worklog-count
                   has-children?))
                (let ((edge (workspace-item-edge-for conn item-id item-cache end-status-cache (first xs))))
                  (if (not edge)
                      (loop (rest xs) blocks-in blocks-out related)
                      (let ((edge-type (or (json-field-value edge "type" "") ""))
                            (edge-direction (or (json-field-value edge "direction" "") "")))
                        (cond
                          (and (string=? edge-type "blocks")
                               (string=? edge-direction "in"))
                          (loop (rest xs) (cons edge blocks-in) blocks-out related)

                          (and (string=? edge-type "blocks")
                               (string=? edge-direction "out"))
                          (loop (rest xs) blocks-in (cons edge blocks-out) related)

                          (string=? edge-type "related")
                          (loop (rest xs) blocks-in blocks-out (cons edge related))

                          :else
                          (loop (rest xs) blocks-in blocks-out related)))))))))))

(defn workspace-item-list-output
  [conn project-id outline-id status]
  (let [status (if (string=? (or status "") "none")
                 ""
                 (or status ""))
        current-actor-id (or (workspace-status-current-actor-id conn) "")
        current-write-actor-id (workspace-current-write-actor-id conn current-actor-id)
        current-actor (workspace-actor-by-id conn current-actor-id)
        current-actor-kind (or (and current-actor (json-field-value current-actor "kind" "")) "")
        rows
        (db/map-row
         (fn [json-text]
           (item-json-record json-text))
         conn
         "select json from items where (?1 = '' or project_id = ?1) and (?2 = '' or outline_id = ?2) and (?3 = '' or status_id = ?3)"
         (or project-id "")
         (or outline-id "")
         status)
        visible-rows
        (let loop ((xs rows)
                   (acc '()))
          (if (empty? xs)
              (reverse acc)
              (let ((item (first xs)))
                (if (workspace-item-archived? item)
                    (loop (rest xs) acc)
                    (loop (rest xs) (cons item acc))))))
        ordered-rows (workspace-item-order-rows visible-rows)
        items (map (fn [item]
                     (workspace-item-summary conn item current-write-actor-id))
                   ordered-rows)]
    (ro-items/items-list-output items)))

(defn workspace-item-ready-output
  [conn]
  (let [current-actor-id (or (workspace-status-current-actor-id conn) "")
        current-write-actor-id (workspace-current-write-actor-id conn current-actor-id)
        current-actor (workspace-actor-by-id conn current-actor-id)
        current-actor-kind (or (and current-actor (json-field-value current-actor "kind" "")) "")
        rows
        (db/map-row
         (fn [json-text]
           (item-json-record json-text))
         conn
         "select json from items where archived = 0 order by updated_at_unixms desc")
        visible-rows
        (let loop ((xs rows)
                   (acc '()))
          (if (empty? xs)
              (reverse acc)
              (let ((item (first xs)))
                (if (workspace-item-archived? item)
                    (loop (rest xs) acc)
                    (loop (rest xs) (cons item acc))))))
        item-cache (make-hash-table)
        outline-rows
        (db/map-row
         (fn [id status-defs-json]
           (cons id status-defs-json))
         conn
         "select id, status_defs_json from outlines")
        outline-end-status-cache (make-hash-table)]
    (let loop-items ((xs visible-rows))
      (if (empty? xs)
          #t
          (begin
            (hash-table-set! item-cache (workspace-item-id (first xs)) (first xs))
            (loop-items (rest xs)))))
    (let loop-outlines ((xs outline-rows))
      (if (empty? xs)
          #t
        (let [row (first xs)
              outline-id (or (car row) "")
              status-defs-json (or (cdr row) "")]
            (if (string=? outline-id "")
                (loop-outlines (rest xs))
                (let ((defs (if (string=? status-defs-json "")
                                '()
                                (call-with-input-string
                                 status-defs-json
                                 (fn [port]
                                   (json/json-read port))))))
                  (hash-table-set!
                   outline-end-status-cache
                   outline-id
                   (let loop-defs ((ds (seq defs))
                                   (acc '()))
                     (cond
                       (empty? ds) (reverse acc)
                       (or (json-field-value (car ds) "isEndState" false) false)
                       (let ((status-id (or (json-field-value (car ds) "id" "") "")))
                         (if (string=? status-id "")
                             (loop-defs (cdr ds) acc)
                             (loop-defs (cdr ds) (cons status-id acc))))
                       :else
                       (loop-defs (cdr ds) acc))))
                  (loop-outlines (rest xs)))))))
        (let ((blocking-set
               (workspace-item-ready-blocking-set
                conn
                outline-end-status-cache
                item-cache)))
      (let loop ((xs visible-rows)
                 (mine-items '())
                 (out-items '()))
        (if (empty? xs)
            (ro-items/items-ready-output
             (map (fn [item]
                    (workspace-item-summary conn item current-write-actor-id))
                  (append (reverse mine-items)
                          (reverse out-items))))
            (let [item (first xs)
                  bucket
                  (workspace-item-ready-class
                   item
                   outline-end-status-cache
                   blocking-set
                   current-actor-id
                   current-actor-kind)]
              (cond
                (eq? bucket 'mine)
                (loop (rest xs) (cons item mine-items) out-items)

                (eq? bucket 'out)
                (loop (rest xs) mine-items (cons item out-items))

                :else
                (loop (rest xs) mine-items out-items))))))))

(defn workspace-item-event-issued-at
  [record]
  (let ((issued-at (or (json-field-value record "issued_at" "") "")))
    (if (str/includes? issued-at ".")
        (string-append (first (str/split issued-at ".")) "Z")
        issued-at)))

(defn workspace-item-events-output
  [workspace-root item-id limit]
  (let ((events-root (fs/path workspace-root "events"))
        (records (events-records (fs/path workspace-root "events") 0)))
    (let loop ((xs records)
               (acc '()))
      (if (empty? xs)
          (let [ordered acc
                limited (if (> limit 0)
                          (take limit ordered)
                          ordered)
                events
                (map (fn [record]
                       (vector
                        (cons 'eventId (or (json-field-value record "event_id" "") ""))
                        (cons 'workspaceId (or (json-field-value record "workspace_id" "") ""))
                        (cons 'replicaId (or (json-field-value record "replica_id" "") ""))
                        (cons 'entityKind (or (json-field-value record "entity_kind" "") ""))
                        (cons 'entityId (or (json-field-value record "entity_id" "") ""))
                        (cons 'entitySeq (or (json-field-value record "entity_seq" 0) 0))
                        (cons 'typ (or (json-field-value record "typ" "") ""))
                        (cons 'parents (or (json-field-value record "parents" '()) '()))
                        (cons 'issuedAt (workspace-item-event-issued-at record))
                        (cons 'actorId (or (json-field-value record "actor_id" "") ""))
                        (cons 'payload (or (json-field-value record "payload" '()) '()))
                        (cons 'localStatus (or (json-field-value record "local_status" "local") "local"))
                        (cons 'serverStatus (or (json-field-value record "server_status" "pending") "pending"))))
                     limited)]
            (ro-items/items-events-output events))
          (let ((record (first xs)))
            (let ((entity-kind (or (json-first-field-value record (list "entityKind" "entity_kind") "") ""))
                  (entity-id (or (json-first-field-value record (list "entityId" "entity_id") "") "")))
              (if (and (string=? entity-kind "item")
                       (string=? entity-id item-id))
                  (loop (rest xs) (cons record acc))
                  (loop (rest xs) acc))))))))

(defn print-unsupported-flag
  []
  (display "unsupported flag\n" (current-error-port))
  1)

(defn events-directory-files
  [events-root]
  (if (fs/directory? events-root)
      (let loop ((entries (directory events-root))
                 (acc '()))
        (if (empty? entries)
            (reverse acc)
            (let ((entry (car entries)))
              (if (and (str/starts-with? entry "events.")
                       (str/ends-with? entry ".jsonl"))
                  (loop (cdr entries)
                        (cons (fs/path events-root entry) acc))
                  (loop (cdr entries) acc)))))
      '()))

(defn events-file-records
  [path limit]
  (call-with-input-file
   path
   (fn [port]
     (let loop ((line-number 1)
                (records '())
                (count 0))
       (let ((line (read-line port)))
         (if (eof-object? line)
             (reverse records)
             (if (and (> limit 0)
                      (>= count limit))
                 (reverse records)
                 (if (str/blank? line)
                     (loop (+ line-number 1) records count)
                     (loop (+ line-number 1)
                           (cons (ro-events/event-line->record path line-number line) records)
                           (+ count 1))))))))))

(defn events-records
  [events-root limit]
  (let loop ((files (cluck-sort-list (events-directory-files events-root) string<?))
             (records '()))
    (if (empty? files)
        records
        (let ((next-records
               (ro-events/events-merge-record-lists
                records
                (events-file-records (car files) limit))))
          (loop (cdr files) next-records)))))

(defn events-list-output
  [limit]
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [events-root (fs/path workspace-root "events")
              time-db (db/open-database ":memory:")
              records (events-records events-root limit)
              limited (if (> limit 0)
                        (take limit records)
                        records)
              output-records
              (map (fn [record]
                     (ro-events/event-materialize-record
                      (fn [issued-at]
                        (db/first-result
                         time-db
                         "select cast(round((julianday(?1) - 2440587.5) * 86400000.0) as integer)"
                         issued-at))
                      record))
                   limited)
              output
              (json-write-output
               (vector
                (cons 'data output-records)
                (cons '_hints '())))]
          (db/finalize! time-db)
          output))))

(defn status-main
  [args]
  (let ((plan (ro-workspace/status-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'help)
      (print-status-help)

      (eq? (vector-ref plan 0) 'status)
      (print-status)

      (eq? (vector-ref plan 0) 'error)
      (error (vector-ref plan 1) (vector-ref plan 2))

      :else
      (error "ro status expects no arguments" args))))

(defn init-main
  [args]
  (let ((plan (ro-workspace/init-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'help)
      (print-init-help)

      (eq? (vector-ref plan 0) 'init)
      (print-init-output)

      (eq? (vector-ref plan 0) 'error)
      (error (vector-ref plan 1) (vector-ref plan 2))

      :else
      (error "ro init expects no arguments" args))))

(defn identity-main
  [args]
  (let ((plan (ro-workspace/identity-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'help)
      (print-identity-help)

      (eq? (vector-ref plan 0) 'list)
      (print-identity-list)

      (eq? (vector-ref plan 0) 'whoami)
      (print-identity-whoami)

      (eq? (vector-ref plan 0) 'create)
      (print-identity-create (vector-ref plan 1)
                             (vector-ref plan 2)
                             (vector-ref plan 3)
                             (vector-ref plan 4))

      (eq? (vector-ref plan 0) 'use)
      (print-identity-use (vector-ref plan 1))

      (eq? (vector-ref plan 0) 'agent-ensure)
      (print-identity-agent-ensure (vector-ref plan 1)
                                   (vector-ref plan 2)
                                   (vector-ref plan 3)
                                   (vector-ref plan 4))

      (eq? (vector-ref plan 0) 'error)
      (error (vector-ref plan 1) (vector-ref plan 2))

      :else
      (error "unsupported identity subcommand" args))))

(defn agent-run-effect
  [effect]
  (let [op (pr-str (vector-ref effect 0))
        args (vector-ref effect 1)]
    (cond
      (string=? op ":agent/help")
      (begin
        (display agent-help-output)
        agent-help-output)

      (string=? op ":agent/prepare")
      (print-agent-prepare (or (get args :item-id) "")
                           (or (get args :session) "")
                           (or (get args :name) "")
                           (or (get args :user) "")
                           (or (get args :take-assigned?) false))

      (string=? op ":agent/start")
      (print-agent-start (or (get args :item-id) "")
                         (or (get args :session) "")
                         (or (get args :name) "")
                         (or (get args :user) "")
                         (or (get args :take-assigned?) false)
                         (or (get args :launch?) false)
                         (or (get args :spawn-agent-runtime?) false)
                         (or (get args :profile) "")
                         (or (get args :backend) "")
                         (or (get args :tool) "")
                         (or (get args :cwd) "")
                         (or (get args :tmux-session) "")
                         (or (get args :worktree) "")
                         (or (get args :prompt) "")
                         (or (get args :attach?) false))

      (string=? op ":agent/open")
      (print-agent-open (or (get args :item-id) "")
                        (or (get args :session) "")
                        (or (get args :print-command?) false))

      :else
      (error "unsupported agent effect" effect))))

(defn agent-main
  [args]
  (let ((plan (ro-agent/agent-main-plan args)))
    (if (not (get plan :ok? false))
        (begin
          (display (string-append (or (get plan :error) "unsupported agent subcommand") "\n")
                   (current-error-port))
          1)
        (run-effects-generic (get plan :effects '()) agent-run-effect))))

(defn projects-main
  [args]
  (let ((plan (ro-projects/projects-main-plan args)))
    (if (not (get plan :ok? false))
        (begin
          (display (get plan :error "") (current-error-port))
          (newline (current-error-port))
          1)
        (projects-run-effects (get plan :effects '())))))

(defn workspace-main
  [args]
  (let ((plan (ro-workspace/workspace-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'help)
      (print-workspace-help)

      (eq? (vector-ref plan 0) 'subhelp-root)
      (print-workspace-subhelp (vector-ref plan 1) #t)

      (eq? (vector-ref plan 0) 'subhelp)
      (print-workspace-subhelp (vector-ref plan 1) #f)

      (eq? (vector-ref plan 0) 'current)
      (print-workspace-current)

      (eq? (vector-ref plan 0) 'list)
      (print-workspace-list)

      (eq? (vector-ref plan 0) 'add)
      (print-workspace-add (vector-ref plan 1)
                           (vector-ref plan 2)
                           (vector-ref plan 3)
                           (vector-ref plan 4))

      (eq? (vector-ref plan 0) 'forget)
      (print-workspace-forget (vector-ref plan 1))

      (eq? (vector-ref plan 0) 'init)
      (print-workspace-init (vector-ref plan 1)
                            (vector-ref plan 2)
                            (vector-ref plan 3))

      (eq? (vector-ref plan 0) 'use)
      (print-workspace-use (vector-ref plan 1))

      (eq? (vector-ref plan 0) 'archive)
      (print-workspace-archive (vector-ref plan 1) true)

      (eq? (vector-ref plan 0) 'unarchive)
      (print-workspace-archive (vector-ref plan 1) false)

      (eq? (vector-ref plan 0) 'rename)
      (print-workspace-rename (vector-ref plan 1)
                              (vector-ref plan 2))

      (eq? (vector-ref plan 0) 'delete)
      (print-workspace-delete (vector-ref plan 1)
                              (vector-ref plan 2)
                              (vector-ref plan 3))

      (eq? (vector-ref plan 0) 'export)
      (print-workspace-export (vector-ref plan 1)
                              (vector-ref plan 2)
                              (vector-ref plan 3))

      (eq? (vector-ref plan 0) 'import)
      (print-workspace-import (vector-ref plan 1)
                              (vector-ref plan 2)
                              (vector-ref plan 3)
                              (vector-ref plan 4)
                              (vector-ref plan 5))

      (eq? (vector-ref plan 0) 'migrate)
      (print-workspace-migrate)

      (eq? (vector-ref plan 0) 'error)
      (error (vector-ref plan 1) (vector-ref plan 2))

      :else
      (error "ro workspace commands are not implemented yet" args))))

