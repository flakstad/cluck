                (get-environment-variable "RO_AGENT_USER")
                "")))

(defn agent-runtime-dir
  []
  (fs/path (workspace-config-dir) "agent-runtimes"))

(defn agent-runtime-path
  [session]
  (fs/path (agent-runtime-dir) (string-append session ".json")))

(defn agent-runtime-record
  [item-id session cwd tmux-session profile backend tool prompt worktree]
  (let [attach-command (string-append "cd " (or cwd ".") " && exec ${SHELL:-/bin/zsh}")]
    (vector
     (cons 'itemId item-id)
     (cons 'session session)
     (cons 'state "prepared")
     (cons 'cwd cwd)
     (cons 'profile profile)
     (cons 'backend backend)
     (cons 'tool tool)
     (cons 'prompt prompt)
     (cons 'worktree worktree)
     (cons 'actions
           (vector
            (cons 'attach
                  (vector
                   (cons 'command attach-command)
                   (cons 'displayCommand attach-command)
                   (cons 'sessionName (if (string=? (or tmux-session "") "")
                                          session
                                          tmux-session)))))))))

(defn agent-runtime-save!
  [runtime]
  (let [session (or (json-field-value runtime "session" "") "")
        path (agent-runtime-path session)]
    (workspace-write-json-file! path runtime)
    path))

(defn agent-runtime-load
  [session]
  (workspace-read-json-file (agent-runtime-path session)))

(defn agent-runtime-attach-command
  [runtime]
  (let [actions (or (json-field-value runtime "actions" false) false)
        attach (and actions (json-field-value actions "attach" false))]
    (or (and attach (json-field-value attach "command" ""))
        "")))

(defn agent-runtime-find-by-item
  [item-id]
  (let [dir (agent-runtime-dir)]
    (if (not (fs/directory? dir))
        false
        (let [result (proc/exec "python3" "-c" "import json,os,sys; d=sys.argv[1]; item=sys.argv[2];\nfor name in sorted(os.listdir(d)):\n p=os.path.join(d,name)\n if not os.path.isfile(p):\n  continue\n try:\n  data=json.load(open(p))\n except Exception:\n  continue\n if str(data.get('itemId','')).strip()==item:\n  print(p)\n  break" dir item-id)
              path (str/trim (or (get result :out) ""))]
          (if (string=? path "")
              false
              (workspace-read-json-file path))))))

(defn print-agent-prepare
  [item-id session name user-id take-assigned?]
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [conn (open-workspace-db)
              session (agent-session-key session)
              actor (workspace-agent-ensure! conn
                                             session
                                             (agent-display-name session name)
                                             (agent-user-id user-id)
                                             true)
              item (workspace-item-claim! conn item-id take-assigned?)
              output (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'actor actor)
                              (cons 'item item)))
                       (cons 'meta
                             (vector
                              (cons 'itemId item-id)
                              (cons 'session session)
                              (cons 'launched false)
                              (cons 'assignedActorId
                                    (or (and item (json-field-value item "assignedActorId" "")) ""))))
                       (cons '_hints
                             (list "ro identity whoami"
                                   (string-append "ro agent open --session " session " --print-command")
                                   (string-append "ro worklog add " item-id " --body \"...\"")))))]
          (if (not item)
              (begin
                (db/finalize! conn)
                (display "item not found\n" (current-error-port))
                1)
              (begin
                (db/finalize! conn)
                (display output)
                output))))))

(defn print-agent-start
  [item-id session name user-id take-assigned? launch? spawn-agent-runtime? profile backend tool cwd tmux-session worktree prompt attach?]
  (if (not launch?)
      (print-agent-prepare item-id session name user-id take-assigned?)
      (let [workspace-root (or (workspace-current-path) "")]
        (if (string=? workspace-root "")
            (error "ro workspace current is unavailable" workspace-json-path)
            (if (not spawn-agent-runtime?)
                (begin
                  (display "refusing to spawn agent runtime without --spawn-agent-runtime\n" (current-error-port))
                  1)
                (let [conn (open-workspace-db)
                      session (agent-session-key session)
                      actor (workspace-agent-ensure! conn
                                                     session
                                                     (agent-display-name session name)
                                                     (agent-user-id user-id)
                                                     true)
                      item (workspace-item-claim! conn item-id take-assigned?)]
                  (if (not item)
                      (begin
                        (db/finalize! conn)
                        (display "item not found\n" (current-error-port))
                        1)
                      (let [runtime (agent-runtime-record item-id
                                                         session
                                                         (if (string=? (str/trim (or worktree "")) "")
                                                             (if (string=? (str/trim (or cwd "")) "")
                                                                 workspace-root
                                                                 cwd)
                                                             worktree)
                                                         tmux-session
                                                         profile
                                                         backend
                                                         tool
                                                         prompt
                                                         worktree)
                            _ (agent-runtime-save! runtime)
                            output (json-write-output
                                    (vector
                                     (cons 'data
                                           (vector
                                            (cons 'actor actor)
                                            (cons 'item item)
                                            (cons 'runtime runtime)
                                            (cons 'attachRequested attach?)
                                            (cons 'opened false)))
                                     (cons 'meta
                                           (vector
                                            (cons 'itemId item-id)
                                            (cons 'session session)
                                            (cons 'launched true)
                                            (cons 'assignedActorId
                                                  (or (and item (json-field-value item "assignedActorId" "")) ""))))
                                     (cons '_hints
                                           (list (string-append "ro agent open --session " session)
                                                 (string-append "ro worklog add " item-id " --body \"...\"")
                                                 (agent-runtime-attach-command runtime)))))]
                        (db/finalize! conn)
                        (display output)
                        output))))))))

(defn print-agent-open
  [item-id session print-command?]
  (let [runtime (if (not (string=? (str/trim (or session "")) ""))
                  (agent-runtime-load session)
                  (agent-runtime-find-by-item item-id))]
    (if (not runtime)
        (begin
          (display "no saved runtime found\n" (current-error-port))
          1)
        (let [command (agent-runtime-attach-command runtime)
              output (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'runtime runtime)
                              (cons 'command command)
                              (cons 'displayCommand command)
                              (cons 'opened (if print-command? false true))))
                       (cons '_hints
                             (list (string-append "ro agent open --session "
                                                  (or (json-field-value runtime "session" "") "")
                                                  " --print-command")))))]
          (display output)
          output))))

