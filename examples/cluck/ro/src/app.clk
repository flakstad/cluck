(defn workspace-item-edge-other-done?
  [conn other-item]
  (let* ((outline-id (or (json-field-value other-item "outlineId" "") ""))
         (status (workspace-item-status other-item))
         (end-status-ids (workspace-outline-end-status-ids conn outline-id)))
    (and (not (string=? outline-id ""))
         (member status end-status-ids))))

(defn workspace-item-edge-for
  [conn current-item-id item-cache end-status-cache dep]
  (let* ((dep-type (or (json-first-field-value dep (list "type" "typ") "") ""))
         (from-id (or (json-first-field-value dep (list "fromItemId" "from_item_id") "") ""))
         (to-id (or (json-first-field-value dep (list "toItemId" "to_item_id") "") ""))
         (out? (string=? from-id current-item-id))
         (in? (string=? to-id current-item-id))
         (other-id (cond
                     (and (string=? dep-type "blocks") out?) to-id
                     (and (string=? dep-type "blocks") in?) from-id
                     (string=? dep-type "related")
                     (if (string=? to-id current-item-id) from-id to-id)
                     :else ""))
         (direction (cond
                      (and (string=? dep-type "blocks") out?) "out"
                      (and (string=? dep-type "blocks") in?) "in"
                      (string=? dep-type "related")
                      (if (string=? to-id current-item-id) "in" "out")
                      :else "")))
    (if (or (string=? dep-type "")
            (string=? other-id "")
            (string=? direction ""))
        #f
        (let* ((cached-other (hash-table-ref/default item-cache other-id #f))
               (other (if cached-other
                          cached-other
                          (let ((lookup (workspace-item-by-id conn other-id)))
                            (when lookup
                              (hash-table-set! item-cache other-id lookup))
                            lookup))))
          (if (or (not other)
                  (workspace-item-archived? other))
              #f
              (let* ((other-outline-id (or (json-field-value other "outlineId" "") ""))
                     (other-end-status-ids
                      (hash-table-ref/default end-status-cache other-outline-id #f))
                     (other-end-status-ids
                      (if other-end-status-ids
                          other-end-status-ids
                          (let ((lookup (workspace-outline-end-status-ids conn other-outline-id)))
                            (hash-table-set! end-status-cache other-outline-id lookup)
                            lookup)))
                     (other-done (and (not (string=? other-outline-id ""))
                                      (member (workspace-item-status other)
                                              other-end-status-ids))))
                (vector
                 (cons 'type dep-type)
                 (cons 'direction direction)
                 (cons 'other other)
                 (cons 'otherDone (if other-done #t #f)))))))))

(defn workspace-item-show-output
  [conn item-id]
  (let* ((item (workspace-item-by-id conn item-id)))
    (if (not item)
        #f
        (let* ((outline-id (or (json-field-value item "outlineId" "") ""))
               (children (workspace-item-children conn item-id))
               (children-summaries (map (lambda (child)
                                          (workspace-item-child-summary conn child))
                                        children))
               (end-status-ids (workspace-outline-end-status-ids conn outline-id))
               (children-counts (workspace-item-counts children end-status-ids))
               (item-cache (make-hash-table))
               (end-status-cache (make-hash-table))
               (deps-rows (workspace-item-deps conn item-id))
               (worklog-count
                (workspace-item-count
                 conn
                 "select count(*) from worklog where entity_kind = 'item' and entity_id = ?1"
                 item-id))
               (has-children? (not (empty? children))))
          (hash-table-set! item-cache item-id item)
          (hash-table-set! end-status-cache outline-id end-status-ids)
          (let loop ((xs deps-rows)
                     (blocks-in '())
                     (blocks-out '())
                     (related '()))
            (if (empty? xs)
                (let* ((blocks-in (reverse blocks-in))
                       (blocks-out (reverse blocks-out))
                       (related (reverse related))
                       (deps (vector
                              (cons 'blocks
                                    (vector
                                     (cons 'out blocks-out)
                                     (cons 'in blocks-in)))
                              (cons 'related related)))
                       (comments-count
                        (workspace-item-count
                         conn
                         "select count(*) from comments where entity_kind = 'item' and entity_id = ?1"
                         item-id))
                       (discussions-count
                        (workspace-item-count
                         conn
                         "select count(*) from discussions where entity_kind = 'item' and entity_id = ?1"
                         item-id))
                       (meta-blocks-in (count blocks-in))
                       (meta-blocks-out (count blocks-out)))
                  (ro-items/items-show-output
                   item
                   children-summaries
                   children-counts
                   deps
                   comments-count
                   discussions-count
                   meta-blocks-in
                   meta-blocks-out
                   worklog-count
                   has-children?))
                (let ((edge (workspace-item-edge-for conn item-id item-cache end-status-cache (first xs))))
                  (if (not edge)
                      (loop (rest xs) blocks-in blocks-out related)
                      (let ((edge-type (or (json-field-value edge "type" "") ""))
                            (edge-direction (or (json-field-value edge "direction" "") "")))
                        (cond
                          (and (string=? edge-type "blocks")
                               (string=? edge-direction "in"))
                          (loop (rest xs) (cons edge blocks-in) blocks-out related)

                          (and (string=? edge-type "blocks")
                               (string=? edge-direction "out"))
                          (loop (rest xs) blocks-in (cons edge blocks-out) related)

                          (string=? edge-type "related")
                          (loop (rest xs) blocks-in blocks-out (cons edge related))

                          :else
                          (loop (rest xs) blocks-in blocks-out related)))))))))))

(defn workspace-item-list-output
  [conn project-id outline-id status]
  (let* ((status (if (string=? (or status "") "none")
                     ""
                     (or status "")))
         (rows
          (db/map-row
           (lambda (json-text)
             (item-json-record json-text))
           conn
           "select json from items where archived = 0 and (?1 = '' or project_id = ?1) and (?2 = '' or outline_id = ?2) and (?3 = '' or status_id = ?3) order by project_id asc, outline_id asc, parent_id asc, lower(rank) asc, id asc"
           (or project-id "")
           (or outline-id "")
           status)))
    (ro-items/items-list-output rows)))

(defn workspace-item-ready-output
  [conn]
  (let* ((current-actor-id (or (workspace-status-current-actor-id conn) ""))
         (actor (workspace-actor-by-id conn current-actor-id))
         (actor-kind (or (json-field-value actor "kind" "") ""))
         (is-agent? (string=? actor-kind "agent"))
         (blocked-rows
          (db/map-row
           (lambda (from-item-id) from-item-id)
           conn
           "select distinct from_item_id from deps where type = 'blocks'"))
         (blocked-set (make-hash-table)))
    (let loop-blocked ((xs blocked-rows))
      (if (empty? xs)
          #t
          (begin
            (hash-table-set! blocked-set (first xs) #t)
            (loop-blocked (rest xs)))))
    (let* ((outline-rows
            (db/map-row
             (lambda (id status-defs-json)
               (cons id status-defs-json))
             conn
             "select id, status_defs_json from outlines"))
           (outline-end-status-cache (make-hash-table)))
      (let loop-outlines ((xs outline-rows))
        (if (empty? xs)
            #t
            (let* ((row (first xs))
                   (outline-id (or (car row) ""))
                   (status-defs-json (or (cdr row) "")))
              (if (string=? outline-id "")
                  (loop-outlines (rest xs))
                  (let ((defs (if (string=? status-defs-json "")
                                  '()
                                  (call-with-input-string
                                   status-defs-json
                                   (lambda (port)
                                     (json/json-read port))))))
                    (hash-table-set!
                     outline-end-status-cache
                     outline-id
                     (let loop-defs ((ds (seq defs))
                                     (acc '()))
                       (cond
                         (empty? ds) (reverse acc)
                         (or (json-field-value (car ds) "isEndState" false) false)
                         (let ((status-id (or (json-field-value (car ds) "id" "") "")))
                           (if (string=? status-id "")
                               (loop-defs (cdr ds) acc)
                               (loop-defs (cdr ds) (cons status-id acc))))
                         :else
                         (loop-defs (cdr ds) acc))))
                    (loop-outlines (rest xs)))))))
      (let* ((rows
              (db/map-row
               (lambda (json-text)
                 (item-json-record json-text))
               conn
               "select json from items where archived = 0 and on_hold = 0 order by updated_at_unixms desc"))
             (mine '())
             (out '()))
        (let loop ((xs rows))
          (if (empty? xs)
              (let ((items (if (empty? mine)
                               (reverse out)
                               (append (reverse mine) (reverse out)))))
                (ro-items/items-ready-output items))
              (let* ((item (first xs))
                     (id (or (json-field-value item "id" "") ""))
                     (outline-id (or (json-field-value item "outlineId" "") ""))
                     (status (workspace-item-status item))
                     (assigned-to (or (json-field-value item "assignedActorId" "") ""))
                     (assigned-to-me? (and (not (string=? assigned-to ""))
                                           (string=? assigned-to current-actor-id)))
                     (outline-end-status-ids
                      (hash-table-ref/default outline-end-status-cache outline-id '())))
                (if (or (string=? id "")
                        (hash-table-ref/default blocked-set id #f)
                        (member status outline-end-status-ids)
                        (and (not (string=? assigned-to ""))
                             (not (and is-agent? assigned-to-me?))))
                    (loop (rest xs))
                    (if (and is-agent? assigned-to-me?)
                        (loop (rest xs) (cons item mine) out)
                        (loop (rest xs) mine (cons item out)))))))))))

(defn workspace-item-events-output
  [workspace-root item-id limit]
  (let ((events-root (fs/path workspace-root "events"))
        (records (events-records (fs/path workspace-root "events") 0)))
    (let loop ((xs records)
               (acc '()))
      (if (empty? xs)
          (let ((ordered (reverse acc))
                (limited (if (> limit 0)
                             (take limit (reverse acc))
                             (reverse acc))))
            (ro-items/items-events-output limited))
          (let ((record (first xs)))
            (let ((entity-kind (or (json-first-field-value record (list "entityKind" "entity_kind") "") ""))
                  (entity-id (or (json-first-field-value record (list "entityId" "entity_id") "") "")))
              (if (and (string=? entity-kind "item")
                       (string=? entity-id item-id))
                  (loop (rest xs) (cons record acc))
                  (loop (rest xs) acc))))))))

(defn print-unsupported-flag
  []
  (display "unsupported flag\n" (current-error-port))
  1)

(defn events-directory-files
  [events-root]
  (if (fs/directory? events-root)
      (let loop ((entries (directory events-root))
                 (acc '()))
        (if (empty? entries)
            (reverse acc)
            (let ((entry (car entries)))
              (if (and (str/starts-with? entry "events.")
                       (str/ends-with? entry ".jsonl"))
                  (loop (cdr entries)
                        (cons (fs/path events-root entry) acc))
                  (loop (cdr entries) acc)))))
      '()))

(defn events-file-records
  [path limit]
  (call-with-input-file
   path
   (lambda (port)
     (let loop ((line-number 1)
                (records '())
                (count 0))
       (let ((line (read-line port)))
         (if (eof-object? line)
             (reverse records)
             (if (and (> limit 0)
                      (>= count limit))
                 (reverse records)
                 (if (str/blank? line)
                     (loop (+ line-number 1) records count)
                     (loop (+ line-number 1)
                           (cons (ro-events/event-line->record path line-number line) records)
                           (+ count 1))))))))))

(defn events-records
  [events-root limit]
  (let loop ((files (cluck-sort-list (events-directory-files events-root) string<?))
             (records '()))
    (if (empty? files)
        records
        (let ((next-records
               (ro-events/events-merge-record-lists
                records
                (events-file-records (car files) limit))))
          (loop (cdr files) next-records)))))

(defn events-list-output
  [limit]
  (let* ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let* ((events-root (fs/path workspace-root "events"))
               (time-db (db/open-database ":memory:"))
               (records (events-records events-root limit))
               (limited (if (> limit 0)
                            (take limit records)
                            records))
               (output-records (map (lambda (record)
                                      (ro-events/event-materialize-record
                                       (lambda (issued-at)
                                         (db/first-result
                                          time-db
                                          "select cast(round((julianday(?1) - 2440587.5) * 86400000.0) as integer)"
                                          issued-at))
                                       record))
                                    limited))
               (output
                (json-write-output
                 (vector
                  (cons 'data output-records)
                  (cons '_hints '())))))
          (db/finalize! time-db)
          output))))

(defn status-main
  [args]
  (let ((plan (ro-workspace/status-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'help)
      (print-status-help)

      (eq? (vector-ref plan 0) 'status)
      (print-status)

      (eq? (vector-ref plan 0) 'error)
      (error (vector-ref plan 1) (vector-ref plan 2))

      :else
      (error "ro status expects no arguments" args))))

