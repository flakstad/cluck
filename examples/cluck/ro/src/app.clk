(defn sync-main
  [args]
  (let ((plan (ro-sync/sync-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'help)
      (begin
        (print-sync-help)
        (flush-output (current-output-port))
        1)

      (eq? (vector-ref plan 0) 'status)
      (print-sync-status)

      (eq? (vector-ref plan 0) 'remotes)
      (print-sync-remotes)

      (eq? (vector-ref plan 0) 'reindex)
      (print-sync-reindex-output)

      (eq? (vector-ref plan 0) 'error)
      (begin
        (print-sync-help)
        (print-unsupported-sync-subcommand))

      :else
      (error "ro sync commands are not implemented yet" args))))

(defn print-doctor-help
  []
  (display doctor-help-output)
  doctor-help-output)

(defn doctor-main-run
  [kind plan args]
  (let [fail? (vector-ref plan 1)
        write? (vector-ref plan 2)
        force? (vector-ref plan 3)
        workspace-root (or (workspace-current-path) "")
        issues (doctor-scan-report workspace-root)
        has-errors (ro-doctor/doctor-has-errors? issues)]
    (cond
      (eq? kind 'report)
      (let ((output
             (json-write-output
              (vector
               (cons 'data issues)
               (cons 'meta
                     (vector
                      (cons 'issues (count issues))
                      (cons 'hasErrors has-errors)))
               (cons '_hints (list "ro doctor summary"
                                   "ro doctor dedupe"
                                   "ro reindex"))))))
        (display output)
        (if (and fail? has-errors) 2 0))

      (eq? kind 'summary)
      (let ((summary (ro-doctor/doctor-summary-from-issues issues))
            (output
             (json-write-output
              (vector
               (cons 'data summary)
               (cons 'meta
                     (vector
                      (cons 'issues (count issues))
                      (cons 'hasErrors has-errors)))
               (cons '_hints (list "ro doctor"
                                   "ro doctor --fail"
                                   "ro status"))))))
        (display output)
        (if (and fail? has-errors) 2 0))

      (eq? kind 'dedupe)
      (if (and write? (not force?))
          (begin
            (display "refusing to rewrite canonical event logs without --force\n" (current-error-port))
            (display "run dry-run first: ro doctor dedupe\n" (current-error-port))
            1)
          (let [dedupe-plan (ro-doctor/doctor-dedupe-plan-from-issues issues)
                result (doctor-apply-dedupe dedupe-plan write?)
                summary (ro-doctor/doctor-summary-from-issues issues)
                output
                (json-write-output
                 (vector
                  (cons 'data
                        (vector
                         (cons 'doctorSummary summary)
                         (cons 'dedupe result)))
                  (cons 'meta
                        (vector
                         (cons 'issues (count issues))
                         (cons 'hasErrors has-errors)))
                  (cons '_hints (if write?
                                    (list "ro reindex"
                                          "ro doctor --fail"
                                          "ro status")
                                    (list "ro doctor dedupe --write --force"
                                          "ro doctor --fail"
                                          "ro status")))))]
            (display output)
            (if (and fail? has-errors) 2 0)))

      :else
      (error "ro doctor commands are not implemented yet" args))))

(defn doctor-dedupe-rewrite-file!
  [path remove-lines]
  (let [backup-path (string-append path ".dedupe.bak")
        original (fs/slurp path)
        lines (str/split-lines original)
        remove-set (let ((table (make-hash-table)))
                     (let loop ((xs remove-lines))
                       (if (empty? xs)
                           table
                           (begin
                             (hash-table-set! table (first xs) #t)
                             (loop (rest xs))))))
        kept (let loop ((xs lines) (line-no 1) (acc '()))
               (if (empty? xs)
                   (reverse acc)
                   (if (hash-table-ref/default remove-set line-no #f)
                       (loop (rest xs) (+ line-no 1) acc)
                       (loop (rest xs) (+ line-no 1) (cons (first xs) acc)))))
        output (if (empty? kept)
                 ""
                 (string-append (str/join "\n" kept) "\n"))]
    (if (fs/exists? backup-path)
        (fs/delete! backup-path)
        #t)
    (fs/spit backup-path original)
    (fs/spit path output)
    backup-path))

(defn doctor-apply-dedupe
  [plan write?]
  (let [files (or (json-field-value plan "files" '()) '())
        updated-files '()
        removed-lines 0]
    (let loop ((xs files))
      (if (empty? xs)
          #t
          (let [file (first xs)
                path (or (json-field-value file "path" "") "")
                remove-lines (or (json-field-value file "removeLines" '()) '())
                remove-count (or (json-field-value file "removeCount" 0) 0)
                event-ids (or (json-field-value file "eventIds" '()) '())
                backup-path (if (and write?
                                     (not (str/blank? path))
                                     (> remove-count 0))
                              (doctor-dedupe-rewrite-file! path remove-lines)
                              "")]
            (if (and write?
                     (not (str/blank? path))
                     (> remove-count 0))
                (set! removed-lines (+ removed-lines remove-count))
                (set! removed-lines (+ removed-lines remove-count)))
            (set! updated-files
                  (cons (list->vector
                         (list (cons 'path path)
                               (cons 'removeCount remove-count)
                               (cons 'removeLines remove-lines)
                               (cons 'eventIds event-ids)
                               (cons 'backupPath backup-path)))
                        updated-files))
            (loop (rest xs)))))
    (set! updated-files (cluck-sort-list updated-files ro-doctor/doctor-dedupe-file<?))
    (list->vector
     (list (cons 'write write?)
           (cons 'duplicateIssueCount (or (json-field-value plan "duplicateIssueCount" 0) 0))
           (cons 'fileCount (count updated-files))
           (cons 'removedLines removed-lines)
           (cons 'files updated-files)))))

(defn doctor-scan-report
  [workspace-root]
  (let ((issues '())
        (seen (make-hash-table)))
    (if (string=? (or workspace-root "") "")
        issues
        (let loop-files ((files (cluck-sort-list
                                 (events-directory-files (fs/path workspace-root "events"))
                                 string<?)))
          (if (empty? files)
              (reverse issues)
              (let ((path (first files)))
                (if (not (fs/file? path))
                    (begin
                      (set! issues
                            (cons (ro-doctor/doctor-make-issue
                                   "error"
                                   "events_read_failed"
                                   "failed to read event log"
                                   path
                                   0
                                   ""
                                   ""
                                   ""
                                   ""
                                   ""
                                   "")
                                  issues))
                      (loop-files (rest files)))
                    (handle-exceptions exn
                        (begin
                          (set! issues
                                (cons (ro-doctor/doctor-make-issue
                                       "error"
                                       "events_read_failed"
                                       "failed to read event log"
                                       path
                                       0
                                       ""
                                       ""
                                       ""
                                       ""
                                       ""
                                       "")
                                      issues))
                          (loop-files (rest files)))
                      (call-with-input-file
                       path
                       (fn [port]
                         (let loop-lines ((line-no 1))
                           (let ((line (read-line port)))
                             (if (eof-object? line)
                                 (loop-files (rest files))
                                 (let ((trimmed (str/trim line)))
                                   (if (str/blank? trimmed)
                                       (loop-lines (+ line-no 1))
                                       (if (or (str/starts-with? trimmed "<<<<<<<")
                                               (str/starts-with? trimmed "=======")
                                               (str/starts-with? trimmed ">>>>>>>"))
                                           (begin
                                             (set! issues
                                                   (cons (ro-doctor/doctor-make-issue
                                                          "error"
                                                          "merge_marker"
                                                          "git merge conflict marker in events log"
                                                          path
                                                          line-no
                                                          ""
                                                          ""
                                                          ""
                                                          ""
                                                          ""
                                                          "")
                                                         issues))
                                             (loop-lines (+ line-no 1)))
                                           (let ((record (ro-doctor/doctor-parse-event-record path line-no trimmed)))
                                             (if (not record)
                                                 (begin
                                                   (set! issues
                                                         (cons (ro-doctor/doctor-make-issue
                                                                "error"
                                                                "malformed_json"
                                                                "malformed JSON"
                                                                path
                                                                line-no
                                                                ""
                                                                ""
                                                                ""
                                                                ""
                                                                ""
                                                                "")
                                                               issues))
                                                   (loop-lines (+ line-no 1)))
                                                 (let [event-id (or (json-field-value record "eventId" "") "")
                                                       parents (or (json-field-value record "parents" '()) '())]
                                                   (if (and (not (str/blank? event-id))
                                                            (hash-table-ref/default seen event-id #f))
                                                       (let ((prev (hash-table-ref/default seen event-id #f)))
                                                         (set! issues
                                                               (cons (ro-doctor/doctor-issue-from-record
                                                                      record
                                                                      "error"
                                                                      "duplicate_event_id"
                                                                      (string-append "duplicate eventId "
                                                                                     (pr-str event-id)
                                                                                     " (also in "
                                                                                     (str (first prev))
                                                                                     ":"
                                                                                     (str (first (rest prev)))
                                                                                     ")"))
                                                                     issues))))
                                                   (if (not (str/blank? event-id))
                                                       (hash-table-set! seen event-id (list path line-no))
                                                       #t)
                                                   (if (> (count parents) 1)
                                                       (set! issues
                                                             (cons (ro-doctor/doctor-issue-from-record
                                                                    record
                                                                    "warn"
                                                                    "multiple_parents"
                                                                    (string-append "event has "
                                                                                   (str (count parents))
                                                                                   " parents"))
                                                                   issues))
                                                       #t)
                                                   (loop-lines (+ line-no 1)))))))))))))))))))))

(defn doctor-main
  [args]
  (let [plan (ro-doctor/doctor-main-plan args)
        kind (vector-ref plan 0)]
    (cond
      (eq? kind 'help)
      (begin
        (print-doctor-help)
        0)

      (or (eq? kind 'report)
          (eq? kind 'summary)
          (eq? kind 'dedupe))
      (doctor-main-run kind plan args)

      (eq? kind 'error)
      (begin
        (display (vector-ref plan 1) (current-error-port))
        (newline (current-error-port))
        (print-doctor-help)
        1)

      :else
      (error "ro doctor commands are not implemented yet" args))))

(defn main
  [args]
  (let ((route (ro-route/main-route args)))
    (let ((kind (vector-ref route 0))
          (route-args (vector-ref route 1)))
      (cond
      (eq? kind 'help) (print-help)
        (eq? kind 'init) (init-main route-args)
      (eq? kind 'completion) (completion-main route-args)
      (eq? kind 'status) (status-main route-args)
      (eq? kind 'identity) (identity-main route-args)
      (eq? kind 'agent) (agent-main route-args)
      (eq? kind 'projects) (projects-main route-args)
      (eq? kind 'outlines) (outlines-main route-args)
      (eq? kind 'items) (items-main route-args)
      (eq? kind 'tasks) (items-main route-args)
      (eq? kind 'item) (item-main route-args)
      (eq? kind 'capture) (capture-main route-args)
      (eq? kind 'attachments) (attachments-main route-args)
      (eq? kind 'comments) (comments-main route-args)
      (eq? kind 'discuss) (discuss-main route-args)
      (eq? kind 'deps) (deps-main route-args)
      (eq? kind 'publish) (publish-main route-args)
      (eq? kind 'clock) (clock-main route-args)
      (eq? kind 'agenda) (agenda-main route-args)
      (eq? kind 'worklog) (worklog-main route-args)
      (eq? kind 'workspace) (workspace-main route-args)
      (eq? kind 'events) (events-main route-args)
      (eq? kind 'doctor) (doctor-main route-args)
      (eq? kind 'reindex) (reindex-main route-args)
        (eq? kind 'sync) (sync-main route-args)
        (eq? kind 'docs) (docs-main route-args)
        :else (error "ro CLI commands are not implemented yet" route-args)))))

