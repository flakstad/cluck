                             ""))
         (layout (workspace-ensure-local-layout! workspace-root))
         (actual-path (or (json-field-value layout "dir" workspace-root) workspace-root))
         (result (workspace-registry-upsert! name actual-path kind use?))
         (current? (first result))
         (output
          (json-write-output
           (vector
            (cons 'data
                  (vector
                   (cons 'workspace name)
                   (cons 'dir actual-path)
                   (cons 'kind kind)
                   (cons 'used current?)))))))
