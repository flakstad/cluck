  sync-help-output)

(defn print-unsupported-sync-subcommand
  []
  (display "unsupported sync subcommand\n" (current-error-port))
  1)

(defn git-run-text
  [args]
  (let ((result (proc/exec "git" args)))
    (if (= 0 (or (get result :exit) 1))
        (str/trim (or (get result :out) ""))
        #f)))

(defn git-sync-status
  [root]
  (let* ((trimmed-root (or (str/trim root) "")))
    (if (string=? trimmed-root "")
        (ro-sync/git-sync-empty-status)
        (let ((repo-root (git-run-text (list "-C" trimmed-root "rev-parse" "--show-toplevel"))))
          (if (not repo-root)
              (ro-sync/git-sync-empty-status)
              (let* ((branch (or (git-run-text (list "-C" repo-root "rev-parse" "--abbrev-ref" "HEAD")) ""))
                     (head (or (git-run-text (list "-C" repo-root "rev-parse" "--short" "HEAD")) ""))
                     (upstream (or (git-run-text (list "-C" repo-root "rev-parse" "--abbrev-ref" "--symbolic-full-name" "@{u}")) ""))
                     (status-out (or (git-run-text (list "-C" repo-root "status" "--porcelain=v1")) ""))
                     (status-flags (ro-sync/git-status-flags status-out))
                     (dirty (first status-flags))
                     (unmerged (first (rest status-flags)))
                     (tracked-out (or (git-run-text (list "-C" repo-root "status" "--porcelain=v1" "--untracked-files=no")) ""))
                     (tracked-flags (ro-sync/git-status-flags tracked-out))
                     (dirty-tracked (first tracked-flags))
                     (in-progress-kind (cond
                                         (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "MERGE_HEAD")) "merge"
                                         (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "REBASE_HEAD")) "rebase"
                                         (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "CHERRY_PICK_HEAD")) "cherry-pick"
                                         (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "REVERT_HEAD")) "revert"
                                         :else ""))
                     (in-progress (not (string=? in-progress-kind "")))
                     (upstream-remote (if (string=? upstream "")
                                          ""
                                          (first (str/split upstream "/"))))
                     (upstream-remote-url (if (string=? upstream-remote "")
                                              ""
                                              (or (git-run-text (list "-C" repo-root "remote" "get-url" upstream-remote)) "")))
                     (ahead-behind (if (string=? upstream "")
                                       (list 0 0)
                                       (ro-sync/git-ahead-behind
                                        (git-run-text (list "-C" repo-root "rev-list" "--left-right" "--count" "HEAD...@{u}")))))
                     (ahead (first ahead-behind))
                     (behind (first (rest ahead-behind))))
                (list->vector
                 (list (cons 'upstreamRemote upstream-remote)
                       (cons 'dirty dirty)
                       (cons 'behind behind)
                       (cons 'inProgress in-progress)
                       (cons 'isRepo true)
                       (cons 'upstreamRemoteURL upstream-remote-url)
                       (cons 'head head)
                       (cons 'root repo-root)
                       (cons 'ahead ahead)
                       (cons 'unmerged unmerged)
                       (cons 'inProgressKind in-progress-kind)
                       (cons 'dirtyTracked dirty-tracked)
                       (cons 'branch branch)
                       (cons 'upstream upstream)))))))))

(defn git-sync-remotes
  [root]
  (let ((out (git-run-text (list "-C" root "remote"))))
    (if (not out)
        '()
        (##core#let loop ((lines (str/split-lines out))
                          (acc '()))
          (if (empty? lines)
              (reverse acc)
              (let* ((name (str/trim (first lines)))
                     (fetch-url (if (string=? name "")
                                    ""
                                    (or (git-run-text (list "-C" root "remote" "get-url" name)) "")))
                     (push-url (if (string=? name "")
                                   ""
                                   (or (git-run-text (list "-C" root "remote" "get-url" "--push" name)) ""))))
                (if (string=? name "")
                    (loop (rest lines) acc)
                    (loop (rest lines)
                          (cons (list->vector
                                 (list (cons 'name name)
                                       (cons 'fetchUrl fetch-url)
                                       (cons 'pushUrl push-url)))
                                acc)))))))))

(defn print-sync-status
  []
  (let ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let ((output
               (json-write-output
                (vector
                 (cons 'data (git-sync-status workspace-root))
                 (cons '_hints (list "git status"
                                     "ro sync remotes"))))))
          (display output)
          output))))

(defn print-sync-remotes
  []
  (let ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let ((status (git-sync-status workspace-root)))
          (if (not (json-field-value status "isRepo" false))
              (error "sync remotes: not a git repository" workspace-root)
              (let ((output
                     (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'dir (json-field-value status "root" ""))
                              (cons 'branch (json-field-value status "branch" ""))
                              (cons 'upstream (json-field-value status "upstream" ""))
                              (cons 'remotes (git-sync-remotes workspace-root))))
                       (cons '_hints (list "git remote -v"
                                           "ro sync status"))))))
                (display output)
                output))))))

(defn reindex-file-counts
  [path]
  (call-with-input-file
   path
   (lambda (port)
     (let loop ((applied 0)
                (skipped 0))
       (let ((line (read-line port)))
         (if (eof-object? line)
             (list applied skipped)
             (if (str/blank? line)
                 (loop applied skipped)
                (handle-exceptions exn
                     (loop applied (+ skipped 1))
                   (let* ((raw-event (call-with-input-string line
                                      (lambda (event-port)
                                        (json/json-read event-port))))
                          (event-type (or (json-first-field-value raw-event (list "type" "typ") "") "")))
                     (if (ro-reindex/reindex-type-recognized? event-type)
                         (loop (+ applied 1) skipped)
                         (loop applied (+ skipped 1))))))))))))

(defn reindex-counts
  [workspace-root]
  (let loop ((files (cluck-sort-list (events-directory-files (fs/path workspace-root "events")) string<?))
             (applied 0)
             (skipped 0))
    (if (empty? files)
        (list applied skipped)
        (let* ((counts (reindex-file-counts (first files)))
               (next-applied (+ applied (first counts)))
               (next-skipped (+ skipped (first (rest counts)))))
          (loop (rest files) next-applied next-skipped)))))

(defn print-reindex-output
  []
  (let ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let* ((counts (reindex-counts workspace-root))
               (applied (first counts))
               (skipped (first (rest counts)))
               (output
                (json-write-output
                 (vector
                  (cons 'data
                        (vector
                         (cons 'dir workspace-root)
                         (cons 'applied applied)
                         (cons 'skipped skipped)))
                  (cons '_hints (list "ro status"
                                      "ro doctor --fail"))))))
          (display output)
          output))))

(defn print-sync-reindex-output
  []
  (let ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let* ((counts (reindex-counts workspace-root))
               (applied (first counts))
               (skipped (first (rest counts)))
               (output
                (json-write-output
                 (vector
                  (cons 'data
                        (vector
                         (cons 'dir workspace-root)
                         (cons 'applied applied)
                         (cons 'skipped skipped)))
                  (cons '_hints (list "ro sync status"
                                      "ro status"))))))
          (display output)
          output))))

(defn reindex-main
  [args]
  (let ((plan (ro-reindex/reindex-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'reindex)
      (print-reindex-output)

      (eq? (vector-ref plan 0) 'help)
      (print-reindex-help)

      (eq? (vector-ref plan 0) 'error)
      (begin
        (display (vector-ref plan 1) (current-error-port))
        (newline (current-error-port))
        (print-reindex-help)
        1)

      :else
      (error "ro reindex commands are not implemented yet" args))))

(defn sync-main
  [args]
  (let ((plan (ro-sync/sync-main-plan args)))
    (cond
      (eq? (vector-ref plan 0) 'help)
      (begin
        (print-sync-help)
        (flush-output (current-output-port))
        1)

      (eq? (vector-ref plan 0) 'status)
      (print-sync-status)

      (eq? (vector-ref plan 0) 'remotes)
      (print-sync-remotes)

      (eq? (vector-ref plan 0) 'reindex)
      (print-sync-reindex-output)

      (eq? (vector-ref plan 0) 'error)
      (begin
        (print-sync-help)
        (print-unsupported-sync-subcommand))

      :else
      (error "ro sync commands are not implemented yet" args))))

(defn print-doctor-help
  []
  (display doctor-help-output)
  doctor-help-output)

(defn doctor-main-run
  [kind plan args]
  (let* ((fail? (vector-ref plan 1))
         (write? (vector-ref plan 2))
         (force? (vector-ref plan 3))
         (workspace-root (or (workspace-current-path) ""))
         (issues (doctor-scan-report workspace-root))
         (has-errors (ro-doctor/doctor-has-errors? issues)))
    (cond
      (eq? kind 'report)
      (let ((output
             (json-write-output
              (vector
               (cons 'data issues)
               (cons 'meta
                     (vector
                      (cons 'issues (count issues))
                      (cons 'hasErrors has-errors)))
               (cons '_hints (list "ro doctor summary"
                                   "ro doctor dedupe"
                                   "ro reindex"))))))
        (display output)
        (if (and fail? has-errors) 2 0))

      (eq? kind 'summary)
      (let ((summary (ro-doctor/doctor-summary-from-issues issues))
            (output
             (json-write-output
              (vector
               (cons 'data summary)
               (cons 'meta
                     (vector
                      (cons 'issues (count issues))
                      (cons 'hasErrors has-errors)))
               (cons '_hints (list "ro doctor"
                                   "ro doctor --fail"
                                   "ro status"))))))
        (display output)
        (if (and fail? has-errors) 2 0))

      (eq? kind 'dedupe)
      (if (and write? (not force?))
          (begin
            (display "refusing to rewrite canonical event logs without --force\n" (current-error-port))
            (display "run dry-run first: ro doctor dedupe\n" (current-error-port))
            1)
          (let* ((dedupe-plan (ro-doctor/doctor-dedupe-plan-from-issues issues))
                 (result (doctor-apply-dedupe dedupe-plan write?))
                 (summary (ro-doctor/doctor-summary-from-issues issues))
                 (output
                  (json-write-output
                   (vector
                    (cons 'data
                          (vector
                           (cons 'doctorSummary summary)
                           (cons 'dedupe result)))
                    (cons 'meta
                          (vector
                           (cons 'issues (count issues))
                           (cons 'hasErrors has-errors)))
                    (cons '_hints (if write?
                                      (list "ro reindex"
                                            "ro doctor --fail"
                                            "ro status")
                                      (list "ro doctor dedupe --write --force"
                                            "ro doctor --fail"
                                            "ro status")))))))
            (display output)
            (if (and fail? has-errors) 2 0)))

      :else
      (error "ro doctor commands are not implemented yet" args))))

(defn doctor-dedupe-rewrite-file!
  [path remove-lines]
  (let* ((backup-path (string-append path ".dedupe.bak"))
         (original (fs/slurp path))
         (lines (str/split-lines original))
         (remove-set (let ((table (make-hash-table)))
                       (let loop ((xs remove-lines))
                         (if (empty? xs)
                             table
                             (begin
                               (hash-table-set! table (first xs) #t)
                               (loop (rest xs)))))))
         (kept (let loop ((xs lines) (line-no 1) (acc '()))
                 (if (empty? xs)
                     (reverse acc)
                     (if (hash-table-ref/default remove-set line-no #f)
                         (loop (rest xs) (+ line-no 1) acc)
                         (loop (rest xs) (+ line-no 1) (cons (first xs) acc))))))
         (output (if (empty? kept)
                     ""
                     (string-append (str/join "\n" kept) "\n"))))
    (if (fs/exists? backup-path)
        (fs/delete! backup-path)
        #t)
    (fs/spit backup-path original)
    (fs/spit path output)
    backup-path))

(defn doctor-apply-dedupe
  [plan write?]
  (let* ((files (or (json-field-value plan "files" '()) '()))
         (updated-files '())
         (removed-lines 0))
    (let loop ((xs files))
      (if (empty? xs)
          #t
          (let* ((file (first xs))
                 (path (or (json-field-value file "path" "") ""))
                 (remove-lines (or (json-field-value file "removeLines" '()) '()))
                 (remove-count (or (json-field-value file "removeCount" 0) 0))
                 (event-ids (or (json-field-value file "eventIds" '()) '()))
                 (backup-path (if (and write?
                                       (not (str/blank? path))
                                       (> remove-count 0))
                                  (doctor-dedupe-rewrite-file! path remove-lines)
                                  "")))
            (if (and write?
                     (not (str/blank? path))
                     (> remove-count 0))
                (set! removed-lines (+ removed-lines remove-count))
                (set! removed-lines (+ removed-lines remove-count)))
            (set! updated-files
                  (cons (list->vector
                         (list (cons 'path path)
                               (cons 'removeCount remove-count)
                               (cons 'removeLines remove-lines)
                               (cons 'eventIds event-ids)
                               (cons 'backupPath backup-path)))
                        updated-files))
            (loop (rest xs)))))
    (set! updated-files (cluck-sort-list updated-files ro-doctor/doctor-dedupe-file<?))
    (list->vector
     (list (cons 'write write?)
           (cons 'duplicateIssueCount (or (json-field-value plan "duplicateIssueCount" 0) 0))
           (cons 'fileCount (count updated-files))
           (cons 'removedLines removed-lines)
           (cons 'files updated-files)))))

(defn doctor-scan-report
  [workspace-root]
  (let ((issues '())
        (seen (make-hash-table)))
    (if (string=? (or workspace-root "") "")
        issues
        (let loop-files ((files (cluck-sort-list
                                 (events-directory-files (fs/path workspace-root "events"))
                                 string<?)))
          (if (empty? files)
              (reverse issues)
              (let ((path (first files)))
                (if (not (fs/file? path))
                    (begin
                      (set! issues
                            (cons (ro-doctor/doctor-make-issue
                                   "error"
                                   "events_read_failed"
                                   "failed to read event log"
                                   path
                                   0
                                   ""
                                   ""
                                   ""
                                   ""
                                   ""
                                   "")
                                  issues))
                      (loop-files (rest files)))
                    (handle-exceptions exn
                        (begin
                          (set! issues
                                (cons (ro-doctor/doctor-make-issue
                                       "error"
                                       "events_read_failed"
                                       "failed to read event log"
                                       path
                                       0
                                       ""
                                       ""
                                       ""
                                       ""
                                       ""
                                       "")
                                      issues))
                          (loop-files (rest files)))
                      (call-with-input-file
                       path
                       (lambda (port)
                         (let loop-lines ((line-no 1))
                           (let ((line (read-line port)))
                             (if (eof-object? line)
                                 (loop-files (rest files))
                                 (let ((trimmed (str/trim line)))
                                   (if (str/blank? trimmed)
                                       (loop-lines (+ line-no 1))
                                       (if (or (str/starts-with? trimmed "<<<<<<<")
                                               (str/starts-with? trimmed "=======")
                                               (str/starts-with? trimmed ">>>>>>>"))
                                           (begin
                                             (set! issues
                                                   (cons (ro-doctor/doctor-make-issue
                                                          "error"
                                                          "merge_marker"
                                                          "git merge conflict marker in events log"
                                                          path
                                                          line-no
                                                          ""
                                                          ""
                                                          ""
                                                          ""
                                                          ""
                                                          "")
                                                         issues))
                                             (loop-lines (+ line-no 1)))
                                           (let ((record (ro-doctor/doctor-parse-event-record path line-no trimmed)))
                                             (if (not record)
                                                 (begin
                                                   (set! issues
                                                         (cons (ro-doctor/doctor-make-issue
                                                                "error"
                                                                "malformed_json"
                                                                "malformed JSON"
                                                                path
                                                                line-no
                                                                ""
                                                                ""
                                                                ""
                                                                ""
                                                                ""
                                                                "")
                                                               issues))
                                                   (loop-lines (+ line-no 1)))
                                                 (let* ((event-id (or (json-field-value record "eventId" "") ""))
                                                        (parents (or (json-field-value record "parents" '()) '())))
                                                   (if (and (not (str/blank? event-id))
                                                            (hash-table-ref/default seen event-id #f))
                                                       (let ((prev (hash-table-ref/default seen event-id #f)))
                                                         (set! issues
                                                               (cons (ro-doctor/doctor-issue-from-record
                                                                      record
                                                                      "error"
                                                                      "duplicate_event_id"
                                                                      (string-append "duplicate eventId "
                                                                                     (pr-str event-id)
                                                                                     " (also in "
                                                                                     (str (first prev))
                                                                                     ":"
                                                                                     (str (first (rest prev)))
                                                                                     ")"))
                                                                     issues))))
                                                   (if (not (str/blank? event-id))
                                                       (hash-table-set! seen event-id (list path line-no))
                                                       #t)
                                                   (if (> (count parents) 1)
                                                       (set! issues
                                                             (cons (ro-doctor/doctor-issue-from-record
                                                                    record
                                                                    "warn"
                                                                    "multiple_parents"
                                                                    (string-append "event has "
                                                                                   (str (count parents))
                                                                                   " parents"))
                                                                   issues))
                                                       #t)
                                                   (loop-lines (+ line-no 1)))))))))))))))))))))

(defn doctor-main
  [args]
  (let* ((plan (ro-doctor/doctor-main-plan args))
         (kind (vector-ref plan 0)))
    (cond
      (eq? kind 'help)
      (begin
        (print-doctor-help)
        0)

      (or (eq? kind 'report)
          (eq? kind 'summary)
          (eq? kind 'dedupe))
      (doctor-main-run kind plan args)

      (eq? kind 'error)
      (begin
        (display (vector-ref plan 1) (current-error-port))
        (newline (current-error-port))
        (print-doctor-help)
        1)

      :else
      (error "ro doctor commands are not implemented yet" args))))

(defn main
  [args]
  (let ((route (ro-route/main-route args)))
    (let ((kind (vector-ref route 0))
          (route-args (vector-ref route 1)))
      (cond
      (eq? kind 'help) (print-help)
        (eq? kind 'init) (init-main route-args)
      (eq? kind 'completion) (completion-main route-args)
      (eq? kind 'status) (status-main route-args)
      (eq? kind 'identity) (identity-main route-args)
      (eq? kind 'projects) (projects-main route-args)
      (eq? kind 'items) (items-main route-args)
      (eq? kind 'tasks) (items-main route-args)
      (eq? kind 'item) (item-main route-args)
      (eq? kind 'workspace) (workspace-main route-args)
      (eq? kind 'events) (events-main route-args)
      (eq? kind 'doctor) (doctor-main route-args)
      (eq? kind 'reindex) (reindex-main route-args)
        (eq? kind 'sync) (sync-main route-args)
        (eq? kind 'docs) (docs-main route-args)
        :else (error "ro CLI commands are not implemented yet" route-args)))))

