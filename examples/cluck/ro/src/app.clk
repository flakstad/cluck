(defn discuss-run-effect
  [effect]
  (let ((op (pr-str (vector-ref effect 0)))
        (args (vector-ref effect 1)))
    (cond
      (string=? op ":discuss/help")
      (print-discuss-help)

      (string=? op ":discuss/list")
      (print-discuss-list (or (get args :item-id) "")
                          (or (get args :state) "open")
                          (or (get args :limit) 200)
                          (or (get args :offset) 0))

      (string=? op ":discuss/show")
      (print-discuss-show (or (get args :discussion-id) ""))

      (string=? op ":discuss/start")
      (print-discuss-start (or (get args :item-id) "")
                           (or (get args :body) "")
                           (or (get args :comment-id) ""))

      (string=? op ":discuss/promote")
      (print-discuss-promote (or (get args :item-id) "")
                             (or (get args :comment-id) ""))

      (string=? op ":discuss/resolve")
      (print-discuss-update (or (get args :discussion-id) "") "resolved" (or (get args :body) ""))

      (string=? op ":discuss/reopen")
      (print-discuss-update (or (get args :discussion-id) "") "open" (or (get args :body) ""))

      :else
      (error "unsupported discuss effect" effect))))

(defn discuss-run-effects
  [effects]
  (let loop ((xs (or effects '()))
             (result 0))
    (if (empty? xs)
        result
        (loop (rest xs) (discuss-run-effect (first xs))))))

