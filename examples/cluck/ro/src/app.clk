(defn print-docs-topic
  [topic raw?]
  (let ((markdown (ro-docs/docs-topic-markdown topic)))
    (if markdown
        (if raw?
            (begin
              (display markdown)
              markdown)
            (let ((output (ro-docs/docs-topic-output topic)))
              (display output)
              output))
        (begin
          (display "unknown docs topic: " (current-error-port))
          (display (pr-str topic) (current-error-port))
          (newline (current-error-port))
          2))))

(defn completion-output
  [shell]
  (cond
    (string=? shell "bash") completion-bash-output
    (string=? shell "zsh") completion-zsh-output
    (string=? shell "fish") completion-fish-output
    :else false))

(defn print-completion-help
  []
  (display completion-help-output)
  completion-help-output)

(defn print-completion-output
  [shell]
  (let [output (completion-output shell)]
    (if output
        (begin
          (display output)
          output)
        (error "ro completion expects bash, zsh, or fish" shell))))

(defn completion-main
  [args]
  (cond
    (empty? args) (print-completion-help)
    (completion-help-request? args) (print-completion-help)
    (empty? (rest args)) (print-completion-output (first args))
    :else (error "ro completion expects bash, zsh, or fish" args)))

