;; Cluck Ro CLI spike.
;;
;; This first slice captures the root command surface and prints the canonical
;; top-level help text. Command handling will expand slice by slice under tests.

(ns cluck.examples.ro.app
  (:require [cluck.io :as io]
            [cluck.fs :as fs]
            [cluck.string :as str]
            [json :as json]
            [sqlite3 :as db]))

