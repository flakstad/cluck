(defn outlines-run-effect
  [effect]
  (let ((op (pr-str (vector-ref effect 0)))
        (args (vector-ref effect 1)))
    (cond
      (string=? op ":outlines/help")
      (print-outlines-help)

      (string=? op ":outlines/create")
      (print-outlines-create (or (get args :project-id) "")
                             (or (get args :name) ""))

      (string=? op ":outlines/list")
      (print-outlines-list (or (get args :project-id) ""))

      (string=? op ":outlines/show")
      (print-outlines-show (or (get args :outline-id) ""))

      (string=? op ":outlines/archive")
      (print-outlines-archive (or (get args :outline-id) "")
                              (or (get args :archived) false))

      (string=? op ":outlines/status-list")
      (print-outlines-status-list (or (get args :outline-id) ""))

      (string=? op ":outlines/status-add")
      (print-outlines-status-add (or (get args :outline-id) "")
                                 (or (get args :label) ""))

      (string=? op ":outlines/status-update")
      (print-outlines-status-update (or (get args :outline-id) "")
                                    (or (get args :status-id) "")
                                    (or (get args :label) "")
                                    (or (get args :end-state?) false)
                                    (or (get args :requires-note?) false))

      (string=? op ":outlines/status-remove")
      (print-outlines-status-remove (or (get args :outline-id) "")
                                    (or (get args :status-id) ""))

      (string=? op ":outlines/status-reorder")
      (print-outlines-status-reorder (or (get args :outline-id) "")
                                     (or (get args :labels) '()))

      :else
      (error "unsupported outlines effect" effect))))

(defn outlines-run-effects
  [effects]
  (let loop ((xs (or effects '()))
             (result 0))
    (cond
      (empty? xs)
      result

      :else
      (loop (rest xs)
            (outlines-run-effect (first xs))))))

(defn outlines-main
  [args]
  (let ((plan (ro-outlines/outlines-main-plan args)))
    (if (not (get plan :ok? false))
        (begin
          (display (get plan :error "") (current-error-port))
          (newline (current-error-port))
          1)
        (outlines-run-effects (get plan :effects '())))))

