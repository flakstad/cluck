                               false false false (or kind "") false "" "" "" "" "" ""))))

(defn workspace-item-set-due!
  [conn item-id date]
  (let [item (workspace-item-by-id conn item-id)]
    (if (not item)
        false
        (workspace-item-touch! conn item
                               ""
                               (or (json-field-value item "assignedActorId" "") "")
                               (or (json-field-value item "archived" false) false)
                               (or date "") false false false false "" "" "" "" "" ""))))

(defn workspace-item-set-schedule!
  [conn item-id date time]
  (let [item (workspace-item-by-id conn item-id)
        schedule (if (string=? (str/trim (or time "")) "")
                     (or date "")
                     (string-append (or date "") " " (or time "")))]
    (if (not item)
        false
        (workspace-item-touch! conn item
                               ""
                               (or (json-field-value item "assignedActorId" "") "")
                               (or (json-field-value item "archived" false) false)
                               false schedule false false false "" "" "" "" "" ""))))

(defn tag-tokenize
  [text]
  (let loop ((xs (str/split (str/trim (or text "")) " "))
             (acc '()))
    (if (empty? xs)
        (reverse acc)
        (let [token (str/trim (or (first xs) ""))]
          (if (string=? token "")
              (loop (rest xs) acc)
              (loop (rest xs) (cons token acc)))))))

(defn workspace-item-tags-add!
  [conn item-id tag]
  (let [item (workspace-item-by-id conn item-id)
        tag (str/trim (or tag ""))]
    (if (or (not item) (string=? tag ""))
        false
        (let [tags (or (json-field-value item "tags" '()) '())
              next-tags (if (member tag tags) tags (append tags (list tag)))]
          (workspace-item-touch! conn item
                                 ""
                                 (or (json-field-value item "assignedActorId" "") "")
                                 (or (json-field-value item "archived" false) false)
                                 false false next-tags false false "" "" "" "" "" "")))))

(defn workspace-item-tags-remove!
  [conn item-id tag]
  (let [item (workspace-item-by-id conn item-id)
        tag (str/trim (or tag ""))]
    (if (or (not item) (string=? tag ""))
        false
        (let [tags (or (json-field-value item "tags" '()) '())
              next-tags (filter (fn [entry] (not (string=? entry tag))) tags)]
          (workspace-item-touch! conn item
                                 ""
                                 (or (json-field-value item "assignedActorId" "") "")
                                 (or (json-field-value item "archived" false) false)
                                 false false next-tags false false "" "" "" "" "" "")))))

(defn workspace-item-tags-set!
  [conn item-id tags-text]
  (let [item (workspace-item-by-id conn item-id)]
    (if (not item)
        false
        (workspace-item-touch! conn item
                               ""
                               (or (json-field-value item "assignedActorId" "") "")
                               (or (json-field-value item "archived" false) false)
                               false false (tag-tokenize tags-text) false false "" "" "" "" "" ""))))

(defn workspace-item-move!
  [conn item-id before-id after-id]
  (let [item (workspace-item-by-id conn item-id)
        anchor (if (not (string=? (or before-id "") ""))
                   (workspace-item-by-id conn before-id)
                   (workspace-item-by-id conn after-id))]
    (if (or (not item) (not anchor))
        false
        (let [anchor-rank (or (json-field-value anchor "rank" "") "")
              next-rank (if (not (string=? (or before-id "") ""))
                            (string-append anchor-rank "-0")
                            (string-append anchor-rank "-1"))]
          (workspace-item-touch! conn item
                                 ""
                                 (or (json-field-value item "assignedActorId" "") "")
                                 (or (json-field-value item "archived" false) false)
                                 false false false false false
                                 (or (json-field-value anchor "parentId" "") "")
                                 (or (json-field-value item "outlineId" "") "")
                                 (or (json-field-value item "projectId" "") "")
                                 next-rank
                                 ""
                                 "")))))

(defn workspace-item-set-parent!
  [conn item-id parent-id]
  (let [item (workspace-item-by-id conn item-id)
        parent (workspace-item-by-id conn parent-id)]
    (if (or (not item) (not parent))
        false
        (let [outline-id (or (json-field-value parent "outlineId" "") "")
              project-id (or (json-field-value parent "projectId" "") "")
              rank (workspace-item-next-rank conn outline-id parent-id (or (json-field-value item "updatedAtUnixms" 0) 0))]
          (workspace-item-touch! conn item
                                 ""
                                 (or (json-field-value item "assignedActorId" "") "")
                                 (or (json-field-value item "archived" false) false)
                                 false false false false false
                                 parent-id
                                 outline-id
                                 project-id
                                 rank
                                 ""
                                 "")))))

(defn workspace-item-move-outline!
  [conn item-id outline-id]
  (let [item (workspace-item-by-id conn item-id)
        outline (workspace-outline-by-id conn outline-id)]
    (if (or (not item) (not outline))
        false
        (let [project-id (or (json-field-value outline "projectId" "") "")
              rank (workspace-item-next-rank conn outline-id "" (or (json-field-value item "updatedAtUnixms" 0) 0))
              status (workspace-item-first-status conn outline-id)]
          (workspace-item-touch! conn item
                                 status
                                 (or (json-field-value item "assignedActorId" "") "")
                                 (or (json-field-value item "archived" false) false)
                                 false false false false false
                                 ""
                                 outline-id
                                 project-id
                                 rank
                                 ""
                                 "")))))

(defn workspace-item-children
  [conn item-id]
  (db/map-row
   (fn [json-text]
     (item-json-record json-text))
   conn
   "select json from items where parent_id = ?1 and archived = 0 order by lower(rank) asc, id asc"
   item-id))

(defn workspace-item-deps
  [conn item-id]
  (db/map-row
   (fn [json-text]
     (item-json-record json-text))
   conn
   "select json from deps where from_item_id = ?1 or to_item_id = ?1 order by updated_at_unixms desc, id desc"
   item-id))

(defn workspace-outline-status-defs-json
  [conn outline-id]
  (let [rows
        (db/map-row
         (fn [value] value)
         conn
         "select status_defs_json from outlines where id = ?1 limit 1"
         outline-id)]
    (if (or (not rows)
            (null? rows))
        ""
        (or (car (seq rows)) ""))))

(defn workspace-outline-end-status-ids
  [conn outline-id]
  (let ((json-text (workspace-outline-status-defs-json conn outline-id)))
    (if (or (not json-text)
            (string=? (str/trim (or json-text "")) ""))
        '()
        (let ((defs
               (call-with-input-string
                json-text
                (fn [port]
                  (json/json-read port)))))
          (##core#let loop ((xs (seq defs))
                            (acc '()))
            (cond
              (empty? xs) (reverse acc)
              (or (json-field-value (car xs) "isEndState" false) false)
              (let ((status-id (or (json-field-value (car xs) "id" "") "")))
                (if (string=? status-id "")
                    (loop (cdr xs) acc)
                    (loop (cdr xs) (cons status-id acc))))
              :else
              (loop (cdr xs) acc)))))))

(defn workspace-item-status
  [item]
  (or (json-first-field-value item (list "status" "statusId") "") ""))

(defn workspace-item-archived?
  [item]
  (or (json-field-value item "archived" false) false))

(defn workspace-item-child-summary
  [conn item]
  (let [item-id (or (json-field-value item "id" "") "")
        comments-count
        (workspace-item-count
         conn
         "select count(*) from comments where entity_kind = 'item' and entity_id = ?1"
         item-id)
        worklog-count
        (workspace-item-count
         conn
         "select count(*) from worklog where entity_kind = 'item' and entity_id = ?1"
         item-id)
        has-children? (> (workspace-item-count conn "select count(*) from items where parent_id = ?1 and archived = 0" item-id) 0)]
    (ro-items/item-show-summary item comments-count worklog-count has-children?)))

(defn workspace-item-counts
  [children end-status-ids]
  (let loop ((xs children)
             (total 0)
             (archived 0)
             (done 0))
    (if (empty? xs)
        (let ((open (- total archived done)))
          (vector
           (cons 'total total)
           (cons 'open open)
           (cons 'done done)
           (cons 'archived archived)))
        (let [child (first xs)
              child-archived (workspace-item-archived? child)
              child-status (workspace-item-status child)
              child-done (and (not child-archived)
                              (member child-status end-status-ids))]
          (loop (rest xs)
                (+ total 1)
                (if child-archived (+ archived 1) archived)
                (if child-done (+ done 1) done))))))

(defn workspace-item-count
  [conn sql item-id]
  (or (db/first-result conn sql item-id) 0))

(defn workspace-item-summary
  [conn item current-write-actor-id]
  (let [item-id (or (json-field-value item "id" "") "")
        comments-count
        (workspace-item-count
         conn
         "select count(*) from comments where entity_kind = 'item' and entity_id = ?1"
         item-id)
        worklog-count
        (if (string=? (or current-write-actor-id "") "")
            0
            (db/first-result
             conn
             "select count(*) from worklog where entity_kind = 'item' and entity_id = ?1 and author_id in (select id from actors where coalesce(nullif(trim(json_extract(json, '$.userId')), ''), id) = ?2)"
             item-id
             current-write-actor-id))
        has-children? (> (workspace-item-count conn "select count(*) from items where parent_id = ?1 and archived = 0" item-id) 0)]
    (ro-items/item-show-summary item comments-count worklog-count has-children?)))

(defn workspace-item-id
  [item]
  (or (json-field-value item "id" "") ""))

(defn workspace-item-outline-id
  [item]
  (or (json-field-value item "outlineId" "") ""))

(defn workspace-item-parent-id
  [item]
  (or (json-field-value item "parentId" "") ""))

(defn workspace-item-rank
  [item]
  (or (json-field-value item "rank" "") ""))

(defn workspace-item-created-at
  [item]
  (or (json-field-value item "createdAt" "") ""))

(defn workspace-item-assigned-actor-id
  [item]
  (or (json-field-value item "assignedActorId" "") ""))

(defn workspace-item-on-hold?
  [item]
  (or (json-field-value item "onHold" false) false))

(defn workspace-item-status-order
  [status]
  (cond
    (string=? status "done") 0
    (string=? status "doing") 1
    (string=? status "todo") 2
    (string=? status "") 3
    :else 4))

(defn workspace-item-order<?
  [left right]
  (let [left-rank (workspace-item-rank left)
        right-rank (workspace-item-rank right)]
    (cond
      (string<? left-rank right-rank) true
      (string<? right-rank left-rank) false
      :else false)))

(defn workspace-item-order-outline-items
  [items]
  (let [present (make-hash-table)]
    (let loop-present ((xs items))
      (if (empty? xs)
          (let [children (make-hash-table)]
            (letrec ((build-groups
                      (fn [xs roots]
                        (if (empty? xs)
                            (vector roots children)
                            (let [item (first xs)
                                  parent-id (workspace-item-parent-id item)]
                              (if (or (string=? parent-id "")
                                      (not (hash-table-ref/default present parent-id #f)))
                                  (build-groups (rest xs) (cons item roots))
                                  (let [current-children
                                        (hash-table-ref/default children parent-id '())]
                                    (hash-table-set! children parent-id
                                                     (cons item current-children))
                                    (build-groups (rest xs) roots)))))))
                     (walk
                      (fn [nodes acc]
                        (let loop ((xs (seq nodes))
                                   (acc acc))
                          (if (empty? xs)
                              acc
                              (let [item (first xs)
                                    item-id (workspace-item-id item)
                                    raw-children
                                    (hash-table-ref/default children item-id '())
                                    child-items
                                    (if (or (nil? raw-children)
                                            (null? raw-children))
                                        '()
                                        (cluck-sort-list raw-children
                                                         workspace-item-order<?))
                                    acc-with-item (cons item acc)
                                    acc-after-children (walk child-items acc-with-item)]
                                (loop (rest xs) acc-after-children)))))))
              (let [built (build-groups items '())
                    roots (vector-ref built 0)
                    sorted-roots (cluck-sort-list roots workspace-item-order<?)]
                (reverse (walk sorted-roots '())))))
          (let ((item-id (workspace-item-id (first xs))))
            (if (not (string=? item-id ""))
                (hash-table-set! present item-id #t))
            (loop-present (rest xs)))))))

(defn workspace-item-order-rows
  [rows]
  (let [outline-id-set (make-hash-table)
        outline-ids '()
        by-outline (make-hash-table)]
    (let loop ((xs rows))
      (if (empty? xs)
          (let [sorted-outline-ids (cluck-sort-list outline-ids string<?)]
            (let loop-outlines ((oids sorted-outline-ids)
                                (acc '()))
              (if (empty? oids)
                  (reverse acc)
                  (let [outline-id (first oids)
                        outline-items
                        (hash-table-ref/default by-outline outline-id '())
                        ordered-items
                        (workspace-item-order-outline-items outline-items)]
                    (let loop-items ((ys (seq ordered-items))
                                     (next-acc acc))
                      (if (empty? ys)
                          (loop-outlines (rest oids) next-acc)
                          (loop-items (rest ys)
                                      (cons (first ys) next-acc))))))))
          (let [item (first xs)
                outline-id (workspace-item-outline-id item)
                current-items (hash-table-ref/default by-outline outline-id '())]
            (if (not (hash-table-ref/default outline-id-set outline-id #f))
                (begin
                  (hash-table-set! outline-id-set outline-id #t)
                  (set! outline-ids (cons outline-id outline-ids))))
            (hash-table-set! by-outline outline-id (cons item current-items))
            (loop (rest xs)))))))

(defn workspace-item-ready-blocking-set
  [conn outline-end-status-cache item-cache]
  (let [blocking-set (make-hash-table)
        deps-rows
        (db/map-row
         (fn [from-id to-id]
           (cons from-id to-id))
         conn
         "select from_item_id, to_item_id from deps where type = 'blocks'")]
    (let loop ((xs deps-rows))
      (if (empty? xs)
          blocking-set
          (let [dep (first xs)
                from-id (or (car dep) "")
                to-id (or (cdr dep) "")
                other (hash-table-ref/default item-cache to-id #f)
                other-outline-id (and other (workspace-item-outline-id other))
                other-status (and other (workspace-item-status other))
                other-end-status-ids
                (and other
                     (hash-table-ref/default outline-end-status-cache other-outline-id '()))]
            (if (and (not (string=? from-id ""))
                     (not (string=? to-id ""))
                     other
                     other-outline-id
                     other-status
                     (not (member other-status other-end-status-ids)))
                (hash-table-set! blocking-set from-id #t))
            (loop (rest xs)))))))

(defn workspace-item-ready-class
  [item outline-end-status-cache blocking-set current-actor-id current-actor-kind]
  (let [outline-id (workspace-item-outline-id item)
        status (workspace-item-status item)
        assigned-actor-id (workspace-item-assigned-actor-id item)
        end-status-ids
        (hash-table-ref/default outline-end-status-cache outline-id '())
        item-id (workspace-item-id item)]
    (and (not (workspace-item-archived? item))
         (not (workspace-item-on-hold? item))
         (not (member status end-status-ids))
         (not (hash-table-ref/default blocking-set item-id #f))
         (cond
           (and (not (string=? assigned-actor-id ""))
                (string=? assigned-actor-id current-actor-id)
                (string=? current-actor-kind "agent"))
           'mine

           (string=? assigned-actor-id "")
           'out

           :else
           #f))))

(defn workspace-status-output
  []
  (let [workspace-name (or (workspace-current-name) "")
        workspace-root (or (workspace-current-path) "")]
    (if (and (not (string=? workspace-name ""))
             (not (string=? workspace-root "")))
        (let [conn (open-workspace-db)
              workspace-id (or (workspace-status-workspace-id conn) "")
              current-actor-id (or (workspace-status-current-actor-id conn) "")
              current-project-id (or (workspace-status-current-project-id conn) "")
              actor-count (workspace-status-count conn "select count(*) from actors")
              project-count (workspace-status-count conn "select count(*) from projects where archived = 0")
              outline-count (workspace-status-count conn "select count(*) from outlines where archived = 0")
              item-count (workspace-status-count conn "select count(*) from items where archived = 0")
              dep-count (workspace-status-count conn "select count(*) from deps")
              comment-count (workspace-status-count conn "select count(*) from comments where entity_kind = 'item'")
              discussion-count (workspace-status-count conn "select count(*) from discussions")
              actor (workspace-actor-by-id conn current-actor-id)
              current-write-actor-id (ro-workspace/workspace-current-write-actor-id actor current-actor-id)
              worklog-count (workspace-status-visible-worklog-count conn current-write-actor-id)
              attachment-count (workspace-status-count conn "select count(*) from attachments")]
          (ro-workspace/workspace-status-output
           workspace-name
           workspace-id
           current-actor-id
           current-project-id
           actor-count
           project-count
           outline-count
           item-count
           dep-count
           comment-count
           discussion-count
           worklog-count
           attachment-count))
        (error "ro workspace current is unavailable" workspace-json-path))))

(defn identity-list-output
  []
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [conn (open-workspace-db)
              current-actor-id (or (workspace-status-current-actor-id conn) "")
              actors (workspace-actors conn)]
          (ro-workspace/identity-list-output
           current-actor-id
           actors)))))

(defn identity-whoami-output
  []
  (let [workspace-root (or (workspace-current-path) "")]
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let [conn (open-workspace-db)
              current-actor-id (or (workspace-status-current-actor-id conn) "")]
          (if (string=? current-actor-id "")
              (error "no current actor" current-actor-id)
              (let ((actor (workspace-actor-by-id conn current-actor-id)))
                (if actor
                    (ro-workspace/identity-whoami-output actor)
                    (error "actor not found" current-actor-id))))))))

