(defn agent-session-key
  [explicit-session]
  (let [explicit-session (str/trim (or explicit-session ""))
        from-env (str/trim (or (get-environment-variable "RO_AGENT_SESSION") ""))]
    (cond
      (not (string=? explicit-session "")) explicit-session
      (not (string=? from-env "")) from-env
      :else (string-append "ags-" (number->string (current-seconds))))))

(defn agent-display-name
  [session explicit-name]
  (let [name (str/trim (or explicit-name
                           (get-environment-variable "RO_AGENT_NAME")
                           ""))]
    (if (string=? name "")
        (string-append session " Agent")
        name)))

