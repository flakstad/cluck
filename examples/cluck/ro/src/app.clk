(defn print-workspace-add
  [name dir kind use?]
  (let [workspace-root (or (if (string=? (or dir "") "")
                               (current-directory)
                               dir)
                           "")
        layout (workspace-ensure-local-layout! workspace-root)
        actual-path (or (json-field-value layout "dir" workspace-root) workspace-root)
        result (workspace-registry-upsert! name actual-path kind use?)
        current? (first result)
        output
        (json-write-output
         (vector
          (cons 'data
                (vector
                 (cons 'workspace name)
                 (cons 'dir actual-path)
                 (cons 'kind kind)
                 (cons 'used current?)))))]
    (display output)
    output))

(defn print-workspace-init
  [name dir use?]
  (let [workspace-root (or (if (string=? (or dir "") "")
                               (fs/path (workspace-config-dir) "workspaces" name)
                               dir)
                           "")
        layout (workspace-ensure-local-layout! workspace-root)
        actual-path (or (json-field-value layout "dir" workspace-root) workspace-root)
        result (workspace-registry-upsert! name actual-path "local" use?)
        current? (first result)
        output
        (json-write-output
         (vector
          (cons 'data
                (vector
                 (cons 'workspace name)
                 (cons 'dir actual-path)
                 (cons 'kind "local")
                 (cons 'used current?)))))]
    (display output)
    output))

(defn print-workspace-use
  [name]
  (let [root (workspace-registry-root)
        detail (workspace-registry-detail root name)]
    (if (not detail)
        (begin
          (display "workspace not found\n" (current-error-port))
          1)
        (let [path (or (workspace-detail-value detail "path") "")
              kind (or (workspace-detail-value detail "kind") "")
              output (json-write-output
                       (vector
                        (cons 'data
                              (vector
                               (cons 'workspace name)
                               (cons 'dir path)))))]
          (workspace-registry-upsert! name path kind true)
          (display output)
          output))))

(defn print-workspace-forget
  [name]
  (let [removed? (workspace-registry-forget! name)
        output (json-write-output
                (vector
                 (cons 'data
                       (vector
                        (cons 'workspace name)
                        (cons 'removed removed?)))
                 (cons '_hints (list "ro workspace list"))))]
    (display output)
    output))

(defn print-workspace-archive
  [name archived?]
  (let [detail (workspace-registry-detail (workspace-registry-root) name)]
    (if (not detail)
        (begin
          (display "workspace not found\n" (current-error-port))
          1)
        (let [archived (workspace-registry-archive! name archived?)
              output (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'workspace name)
                              (cons 'archived archived)))
                       (cons '_hints
                             (if archived?
                                 (list "ro workspace list --include-archived"
                                       (string-append "ro workspace unarchive " name))
                                 (list "ro workspace list"
                                       (string-append "ro workspace archive " name))))))]
          (display output)
          output))))

(defn print-workspace-rename
  [from to]
  (if (not (workspace-registry-rename! from to))
      (begin
        (display "workspace not found\n" (current-error-port))
        1)
      (let [output (json-write-output
                    (vector
                     (cons 'data
                           (vector
                            (cons 'from from)
                            (cons 'to to)))))]
        (display output)
        output)))

(defn print-workspace-delete
  [name yes? force-legacy?]
  (let [root (workspace-registry-root)
        detail (workspace-registry-detail root name)
        legacy-dir (fs/path (workspace-config-dir) "workspaces" name)]
    (cond
      (not yes?)
      (begin
        (display "refusing to delete without --yes\n" (current-error-port))
        1)

      (and detail
           (not force-legacy?)
           (not (string=? (workspace-canonical-path legacy-dir)
                          (workspace-canonical-path (or (workspace-detail-value detail "path") "")))))
      (begin
        (display "workspace is registered to a different path; pass --force-legacy\n" (current-error-port))
        1)

      (not (fs/exists? legacy-dir))
      (begin
        (display "workspace directory does not exist\n" (current-error-port))
        1)

      :else
      (begin
        (workspace-delete-tree! legacy-dir)
        (when (and detail
                   (string=? (workspace-canonical-path legacy-dir)
                             (workspace-canonical-path (or (workspace-detail-value detail "path") ""))))
          (workspace-registry-forget! name))
        (let [output (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'workspace name)
                              (cons 'deleted true)
                              (cons 'dir (workspace-canonical-path legacy-dir))))))]
          (display output)
          output)))))

(defn print-workspace-export
  [to-dir events? force?]
  (let [workspace-root (workspace-registry-current-root)
        target (workspace-canonical-path to-dir)]
    (ensure-directory! target)
    (if (and (not force?)
             (not (empty? (directory target))))
        (begin
          (display "target directory is not empty\n" (current-error-port))
          1)
        (let [conn (open-workspace-db)
              state-path (fs/path target "state.json")
              events-path (fs/path target "events.jsonl")
              manifest-path (fs/path target "manifest.json")
              state (workspace-export-state conn)
              events-jsonl (if (and events?
                                    (workspace-event-log-path)
                                    (fs/exists? (workspace-event-log-path)))
                               (fs/slurp (workspace-event-log-path))
                               "")
              output (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'to target)
                              (cons 'statePath state-path)
                              (cons 'eventsPath (if events? events-path ""))
                              (cons 'eventsCount (if events? (count (str/split-lines events-jsonl)) 0))
                              (cons 'workspaceDir workspace-root)))))]
          (fs/spit state-path (string-append (json-write-text state) "\n"))
          (when events?
            (fs/spit events-path events-jsonl))
          (fs/spit manifest-path
                   (string-append
                    (json-write-text
                     (vector
                      (cons 'version 1)
                      (cons 'workspace (vector (cons 'dir workspace-root)))
                      (cons 'files
                            (if events?
                                (vector (cons 'state "state.json")
                                        (cons 'events "events.jsonl"))
                                (vector (cons 'state "state.json"))))))
                    "\n"))
          (db/finalize! conn)
          (display output)
          output))))

(defn print-workspace-import
  [name from-dir force? use? events?]
  (let [workspace-root (fs/path (workspace-config-dir) "workspaces" name)
        source (workspace-canonical-path from-dir)
        events-path (fs/path source "events.jsonl")]
    (cond
      (and (fs/exists? workspace-root) (not force?))
      (begin
        (display "workspace already exists (pass --force to replace it)\n" (current-error-port))
        1)

      :else
      (let [layout (if (and (fs/exists? workspace-root) force?)
                     (begin
                       (workspace-delete-tree! workspace-root)
                       (workspace-ensure-local-layout! workspace-root))
                     (workspace-ensure-local-layout! workspace-root))
            actual-path (or (json-field-value layout "dir" workspace-root) workspace-root)
            result (workspace-registry-upsert! name actual-path "local" use?)]
        (when (and events? (fs/exists? events-path))
          (fs/spit (or (json-field-value layout "eventLogPath" "") "") (fs/slurp events-path)))
        (let [output (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'workspace name)
                              (cons 'dir actual-path)
                              (cons 'from source)
                              (cons 'eventsCount (if (and events? (fs/exists? events-path))
                                                     (count (str/split-lines (fs/slurp events-path)))
                                                     0))
                              (cons 'used (first result))))))]
          (display output)
          output)))))

