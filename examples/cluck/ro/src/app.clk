(defn print-unsupported-sync-subcommand
  []
  (display "unsupported sync subcommand\n" (current-error-port))
  1)

(defn git-run-text
  [args]
  (let ((result (proc/exec "git" args)))
    (if (= 0 (or (get result :exit) 1))
        (str/trim (or (get result :out) ""))
        #f)))

(defn git-sync-status
  [root]
  (let [trimmed-root (or (str/trim root) "")]
    (if (string=? trimmed-root "")
        (ro-sync/git-sync-empty-status)
        (let ((repo-root (git-run-text (list "-C" trimmed-root "rev-parse" "--show-toplevel"))))
          (if (not repo-root)
              (ro-sync/git-sync-empty-status)
              (let [branch (or (git-run-text (list "-C" repo-root "rev-parse" "--abbrev-ref" "HEAD")) "")
                    head (or (git-run-text (list "-C" repo-root "rev-parse" "--short" "HEAD")) "")
                    upstream (or (git-run-text (list "-C" repo-root "rev-parse" "--abbrev-ref" "--symbolic-full-name" "@{u}")) "")
                    status-out (or (git-run-text (list "-C" repo-root "status" "--porcelain=v1")) "")
                    status-flags (ro-sync/git-status-flags status-out)
                    dirty (first status-flags)
                    unmerged (first (rest status-flags))
                    tracked-out (or (git-run-text (list "-C" repo-root "status" "--porcelain=v1" "--untracked-files=no")) "")
                    tracked-flags (ro-sync/git-status-flags tracked-out)
                    dirty-tracked (first tracked-flags)
                    in-progress-kind (cond
                                        (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "MERGE_HEAD")) "merge"
                                        (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "REBASE_HEAD")) "rebase"
                                        (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "CHERRY_PICK_HEAD")) "cherry-pick"
                                        (git-run-text (list "-C" repo-root "rev-parse" "--verify" "-q" "REVERT_HEAD")) "revert"
                                        :else "")
                    in-progress (not (string=? in-progress-kind ""))
                    upstream-remote (if (string=? upstream "")
                                        ""
                                        (first (str/split upstream "/")))
                    upstream-remote-url (if (string=? upstream-remote "")
                                            ""
                                            (or (git-run-text (list "-C" repo-root "remote" "get-url" upstream-remote)) ""))
                    ahead-behind (if (string=? upstream "")
                                      (list 0 0)
                                      (ro-sync/git-ahead-behind
                                       (git-run-text (list "-C" repo-root "rev-list" "--left-right" "--count" "HEAD...@{u}"))))
                    ahead (first ahead-behind)
                    behind (first (rest ahead-behind))]
                (list->vector
                 (list (cons 'upstreamRemote upstream-remote)
                       (cons 'dirty dirty)
                       (cons 'behind behind)
                       (cons 'inProgress in-progress)
                       (cons 'isRepo true)
                       (cons 'upstreamRemoteURL upstream-remote-url)
                       (cons 'head head)
                       (cons 'root repo-root)
                       (cons 'ahead ahead)
                       (cons 'unmerged unmerged)
                       (cons 'inProgressKind in-progress-kind)
                       (cons 'dirtyTracked dirty-tracked)
                       (cons 'branch branch)
                       (cons 'upstream upstream)))))))))

(defn git-sync-remotes
  [root]
  (let [out (git-run-text (list "-C" root "remote"))]
    (if (not out)
        '()
        (##core#let loop ((lines (str/split-lines out))
                          (acc '()))
          (if (empty? lines)
              (reverse acc)
              (let [name (str/trim (first lines))
                    fetch-url (if (string=? name "")
                                  ""
                                  (or (git-run-text (list "-C" root "remote" "get-url" name)) ""))
                    push-url (if (string=? name "")
                                 ""
                                 (or (git-run-text (list "-C" root "remote" "get-url" "--push" name)) ""))]
                (if (string=? name "")
                    (loop (rest lines) acc)
                    (loop (rest lines)
                          (cons (list->vector
                                 (list (cons 'name name)
                                       (cons 'fetchUrl fetch-url)
                                       (cons 'pushUrl push-url)))
                                acc)))))))))

(defn print-sync-status
  []
  (let ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let ((output
               (json-write-output
                (vector
                 (cons 'data (git-sync-status workspace-root))
                 (cons '_hints (list "git status"
                                     "ro sync remotes"))))))
          (display output)
          output))))

(defn print-sync-remotes
  []
  (let ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let ((status (git-sync-status workspace-root)))
          (if (not (json-field-value status "isRepo" false))
              (error "sync remotes: not a git repository" workspace-root)
              (let ((output
                     (json-write-output
                      (vector
                       (cons 'data
                             (vector
                              (cons 'dir (json-field-value status "root" ""))
                              (cons 'branch (json-field-value status "branch" ""))
                              (cons 'upstream (json-field-value status "upstream" ""))
                              (cons 'remotes (git-sync-remotes workspace-root))))
                       (cons '_hints (list "git remote -v"
                                           "ro sync status"))))))
                (display output)
                output))))))

(defn reindex-file-counts
  [path]
  (call-with-input-file
   path
   (fn [port]
     (let loop ((applied 0)
                (skipped 0))
       (let ((line (read-line port)))
         (if (eof-object? line)
             (list applied skipped)
             (if (str/blank? line)
                 (loop applied skipped)
                (handle-exceptions exn
                     (loop applied (+ skipped 1))
                   (let ((raw-event (call-with-input-string line
                                      (fn [event-port]
                                        (json/json-read event-port))))
                          (event-type (or (json-first-field-value raw-event (list "type" "typ") "") "")))
                     (if (ro-reindex/reindex-type-recognized? event-type)
                         (loop (+ applied 1) skipped)
                         (loop applied (+ skipped 1))))))))))))

(defn reindex-counts
  [workspace-root]
  (let loop ((files (cluck-sort-list (events-directory-files (fs/path workspace-root "events")) string<?))
             (applied 0)
             (skipped 0))
    (if (empty? files)
        (list applied skipped)
        (let ((counts (reindex-file-counts (first files)))
              (next-applied (+ applied (first counts)))
              (next-skipped (+ skipped (first (rest counts)))))
          (loop (rest files) next-applied next-skipped)))))

(defn print-reindex-output
  []
  (let ((workspace-root (or (workspace-current-path) "")))
    (if (string=? workspace-root "")
        (error "ro workspace current is unavailable" workspace-json-path)
        (let ((counts (reindex-counts workspace-root))
              (applied (first counts))
              (skipped (first (rest counts)))
              (output
               (json-write-output
                (vector
                 (cons 'data
                       (vector
                        (cons 'dir workspace-root)
                        (cons 'applied applied)
                        (cons 'skipped skipped)))
                 (cons '_hints (list "ro status"
                                     "ro doctor --fail"))))))
          (display output)
          output))))

