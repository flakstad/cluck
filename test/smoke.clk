(load-file "examples/cluck/changelog/main.clk")
(in-ns 'cluck.examples.changelog)
(let [old-log changelog-git-log
      old-branch changelog-git-branch
      sample-log "a1b2c3\tfeat: add parser\nb2c3d4\tfix: handle nil\nc3d4e5\tdocs: update readme\n"]
  (dynamic-wind
    (lambda ()
      (set! changelog-git-log (lambda (range) sample-log))
      (set! changelog-git-branch (lambda () "main")))
    (lambda ()
      (assert-str= "changelog main"
                   (string-append
                    "Cluck git changelog\n"
                    "Branch: main\n"
                    "Range: HEAD~3..HEAD\n"
                    "Commits: 3\n"
                    "\n"
                    "Features (1)\n"
                    "- a1b2c3 feat: add parser\n"
                    "\n"
                    "Fixes (1)\n"
                    "- b2c3d4 fix: handle nil\n"
                    "\n"
                    "Docs (1)\n"
                    "- c3d4e5 docs: update readme\n"
                    "\n")
                   (capture-output
                    (lambda ()
                      (main (list "HEAD~3..HEAD"))))))
    (lambda ()
      (set! changelog-git-log old-log)
      (set! changelog-git-branch old-branch))))
(in-ns 'cluck.smoke)

(load-file "examples/cluck/weather/main.clk")
(in-ns 'cluck.examples.weather)
(let [old-fetch fetch-report
      payload {:nearest_area [{:areaName [{:value "Skatval"}]
                               :region [{:value "Trondheim"}]
                               :country [{:value "Norway"}]}]
               :current_condition [{:temp_C "3"
                                    :FeelsLikeC "0"
                                    :weatherDesc [{:value "Partly Cloudy"}]
                                    :windspeedKmph "18"
                                    :humidity "87"}]
               :weather [{:date "2026-04-08"
                          :mintempC "-1"
                          :maxtempC "4"
                          :hourly [{:chanceofrain "20"
                                    :weatherDesc [{:value "Light Rain"}]}]}]}]
  (dynamic-wind
    (lambda () (set! fetch-report (lambda (location) payload)))
    (lambda ()
      (assert-str= "weather main"
                   "Skatval, Trondheim, Norway\nCurrent: 3°C, feels like 0°C, partly cloudy, wind 5.0 m/s, humidity 87\nForecast:\n2026-04-08 -1°/4°C  light rain  rain 20\n"
                   (capture-output
                    (lambda ()
                      (main (list "Skatval"))))))
    (lambda ()
      (set! fetch-report old-fetch))))
(in-ns 'cluck.smoke)

(ns cluck.smoke.ns-options
  (:require [cluck.math :refer :all :exclude [square]]))

(define (ns-smoke-pass label)
  (println "ok" label)
  true)

(define (ns-assert-true label value)
  (if value
      (ns-smoke-pass label)
      (error (string-append "smoke test failed: "
                            label
                            " expected truthy value"))))

(define (ns-assert-num= label expected actual)
  (if (= expected actual)
      (ns-smoke-pass label)
      (error (string-append "smoke test failed: "
                            label
                            " expected "
                            (str expected)
                            " got "
                            (str actual)))))

(ns-assert-num= "require exclude sum-of-squares" 14 (sum-of-squares [1 2 3]))
(ns-assert-true "require exclude missing" (not (ns-resolve (current-ns) 'square)))
(load-file "test/cluck/test/persistent.clk")
(in-ns 'user)

(println "smoke tests passed")
