;; Smoke tests for cluck.
;; Load this after src/cluck-init.scm or via test/run.scm.

(ns cluck.smoke
  (:require [cluck.edn :as edn]))

(define (smoke-pass label)
  (println "ok" label)
  true)

(define (smoke-fail label expected actual)
  (error (string-append "smoke test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (assert-true label value)
  (if value
      (smoke-pass label)
      (smoke-fail label "truthy value" (pr-str value))))

(define (assert-str= label expected actual)
  (if (string=? expected actual)
      (smoke-pass label)
      (smoke-fail label expected actual)))

(define (assert-num= label expected actual)
  (if (= expected actual)
      (smoke-pass label)
      (smoke-fail label (str expected) (str actual))))

(define (capture-output thunk)
  (let [port (open-output-string)]
    (parameterize ((current-output-port port))
      (thunk))
    (get-output-string port)))

(define (string-prefix? prefix s)
  (let [plen (string-length prefix)
        slen (string-length s)]
    (and (<= plen slen)
         (string=? prefix (substring s 0 plen)))))

(define (set-cookie->cookie-header set-cookie)
  (if (or (not set-cookie) (not (str/includes? set-cookie ";")))
      set-cookie
      (first (str/split set-cookie ";"))))

(def sample
  (edn/read-string "{:a [1 2] :b #{3}}"))

(defn add2 "Add 2 to X." [x]
  (+ x 2))

(assert-str= "keyword printer" ":foo" (pr-str :foo))
(assert-str= "vector printer" "[1 2 3]" (pr-str [1 2 3]))
(assert-str= "map printer" "{:a [1 2] :b #{3}}" (pr-str sample))
(assert-str= "println" "hello world\n"
             (capture-output (lambda () (println "hello" "world"))))
(assert-str= "println nil" "nil\n"
             (capture-output (lambda () (println nil))))
(assert-str= "format basic" "hello world 3"
             (format "hello %s %d" "world" 3))
(assert-true "format %d rejects 3.0"
             (handle-exceptions exn
                 #t
               (begin
                 (format "%d" 3.0)
                 #f)))
(assert-str= "format decimals" "3.14"
             (format "%.2f" 3.14159))
(assert-str= "format nil" "nil"
             (format "%s" nil))
(assert-num= "parse-long" 42 (parse-long "42"))
(assert-num= "parse-double" 42.5 (parse-double "42.5"))
(assert-str= "type vector" "vector" (pr-str (type [1 2 3])))
(assert-str= "type map" "cluck.map" (pr-str (type {:a 1})))
(assert-str= "type atom" "cluck.atom" (pr-str (type (atom 1))))
(assert-str= "type list" "list" (pr-str (type (rest [1 2 3]))))
(assert-str= "vec" "[1 2 3]" (pr-str (vec '(1 2 3))))
(assert-str= "vec nil" "[]" (pr-str (vec nil)))
(let [a (atom 1)]
  (assert-num= "atom deref" 1 (deref a))
  (assert-num= "swap!" 3 (swap! a + 2))
  (assert-num= "reset!" 7 (reset! a 7))
  (assert-true "compare-and-set! success" (compare-and-set! a 7 8))
  (assert-true "compare-and-set! fail" (not (compare-and-set! a 7 9))))
(assert-true "unspecified?" (unspecified? (void)))
(assert-num= "and" 3 (and true 3))
(assert-str= "and false" "false" (pr-str (and true false 3)))
(assert-num= "or" 3 (or false nil 3))
(assert-str= "if nil result" "nil" (pr-str (if false 1 nil)))
(assert-str= "cond nil result" "nil" (pr-str (cond false 1 :else nil)))
(assert-num= "cond-> no clauses" 3 (cond-> 3))
(assert-num= "cond-> threaded inc" 3 (cond-> 1 true inc false inc true inc))
(assert-str= "cond-> map threading" "{:a 1 :b 2}"
             (pr-str (cond-> {:a 1}
                             true (assoc :b 2)
                             false (assoc :c 3))))
(assert-str= "cond->> threaded sequence" "(2 4)"
             (pr-str (cond->> [1 2 3]
                              true (map inc)
                              true (filter even?))))
(assert-num= "-> keyword lookup" 3 (-> {:a {:b 3}} :a :b))
(assert-num= "->> keyword lookup" 3 (->> {:a {:b 3}} :a :b))
(assert-num= "cond-> keyword lookup" 3 (cond-> {:a {:b 3}} true :a true :b))
(assert-num= "cond->> keyword lookup" 3 (cond->> {:a {:b 3}} true :a true :b))
(assert-num= "some-> map lookup" 3 (some-> {:a {:b 3}} :a :b))
(assert-str= "some-> nil" "nil" (pr-str (some-> nil inc inc)))
(assert-num= "some->> threaded sequence" 2 (some->> [1 2 3] (map inc) first))
(assert-num= "some->> keyword lookup" 3 (some->> {:a {:b 3}} :a :b))
(assert-str= "some->> nil" "nil" (pr-str (some->> nil (map inc) first)))
(assert-num= "case match" 2 (case :b :a 1 :b 2 3))
(assert-str= "case default" "other" (case :c :a "one" :b "two" "other"))
(assert-num= "case symbol key" 2 (case 'foo foo 2 bar 1 3))
(assert-true "case no match throws"
             (handle-exceptions exn
                 #t
               (begin
                 (case :c :a 1 :b 2)
                 #f)))
(assert-num= "defn" 5 (add2 3))
(assert-num= "let" 3 (let [x 1 y 2] (+ x y)))
(assert-num= "let vector destructuring" 3 (let [[a b] [1 2]] (+ a b)))
(assert-str= "let vector rest" "(2 3)" (pr-str (let [[a & rest] [1 2 3]] rest)))
(assert-num= "let map destructuring" 3 (let [{:keys [a b]} {:a 1 :b 2}] (+ a b)))
(assert-num= "let map as" 1 (count (let [{:as m :keys [a]} {:a 1}] m)))
(assert-str= "mapv" "[2 3 4]" (pr-str (mapv inc [1 2 3])))
(assert-str= "filterv" "[2 4]" (pr-str (filterv even? [1 2 3 4])))
(assert-str= "keep" "(2 4)" (pr-str (keep (fn [x] (if (even? x) x nil)) [1 2 3 4])))
(assert-str= "map-indexed" "([0 1] [1 2] [2 3])" (pr-str (map-indexed (fn [i x] [i x]) [1 2 3])))
(assert-str= "mapcat" "(1 1 2 2)" (pr-str (mapcat (fn [x] [x x]) [1 2])))
(assert-str= "merge" "{:a 1 :b 2}" (pr-str (merge {:a 1} {:b 2})))
(assert-str= "merge-with" "{:a 3 :b 2}" (pr-str (merge-with + {:a 1} {:a 2 :b 2})))
(assert-num= "get-in" 3 (get-in {:a {:b 3}} [:a :b]))
(assert-str= "assoc-in" "{:a {:b 2}}" (pr-str (assoc-in {} [:a :b] 2)))
(assert-str= "update" "{:a 2}" (pr-str (update {:a 1} :a inc)))
(assert-str= "select-keys" "{:a 1 :c 3}" (pr-str (select-keys {:a 1 :b 2 :c 3} [:a :c])))
(assert-str= "zipmap" "{:a 1 :b 2}" (pr-str (zipmap [:a :b] [1 2])))
(assert-str= "apply" "10" (pr-str (apply + 1 2 [3 4])))
(assert-num= "partial" 6 ((partial + 1 2) 3))
(assert-num= "comp" 9 ((comp inc inc inc) 6))
(assert-str= "remove" "(1 3)" (pr-str (remove even? [1 2 3 4])))
(assert-num= "keys count" 2 (count (keys sample)))
(assert-num= "vals count" 2 (count (vals sample)))
(load-file "ring/test.clk")
(in-ns 'cluck.smoke)
(require [ring.adapter.spiffy :as ring-adapter]
         [ring.request :as request]
         [ring.response :as response])
(require [cluck.core :as core])
(assert-true "core namespace exists" (find-ns 'cluck.core))
(assert-true "core publics include map" (contains? (ns-publics 'cluck.core) 'map))
(assert-true "core publics include set" (contains? (ns-publics 'cluck.core) 'set))
(assert-true "core publics include hash-map" (contains? (ns-publics 'cluck.core) 'hash-map))
(assert-str= "core hash-map" "{:a 1}" (pr-str (hash-map :a 1)))
(assert-str= "core set" "#{1 2}" (pr-str (set 1 2)))
(assert-str= "core disj" "#{1}" (pr-str (disj #{1 2 3} 2 3)))
(require [cluck.mutable :refer [mutable-map
                                mutable-map?
                                mutable-map-table
                                mutable-set
                                mutable-set?
                                mutable-set-table
                                persistent-map
                                persistent
                                freeze-set]])
(let [m (mutable-map)]
  (assert-true "mutable namespace exists" (find-ns 'cluck.mutable))
  (assert-true "mutable map?" (mutable-map? m))
  (hash-table-set! (mutable-map-table m) :a 1)
  (hash-table-set! (mutable-map-table m) :b 2)
  (hash-table-delete! (mutable-map-table m) :a)
  (assert-str= "mutable persistent map" "{:b 2}" (pr-str (persistent-map m)))
  (assert-str= "mutable persistent dispatcher map" "{:b 2}" (pr-str (persistent m))))
(let [s (mutable-set 1 2)]
  (assert-true "mutable set?" (mutable-set? s))
  (hash-table-set! (mutable-set-table s) 3 #t)
  (hash-table-set! (mutable-set-table s) 4 #t)
  (hash-table-delete! (mutable-set-table s) 1)
  (assert-str= "mutable freeze set" "#{2 3 4}" (pr-str (freeze-set s)))
  (assert-str= "mutable persistent dispatcher set" "#{2 3 4}" (pr-str (persistent s))))
(let [core-file "build/cluck-core-smoke.txt"]
  (spit core-file "a\nb\n")
  (assert-str= "core slurp" "a\nb\n" (slurp core-file)))
(require [cluck.string :as str])
(assert-true "string blank? nil" (str/blank? nil))
(assert-true "string blank? spaces" (str/blank? "   "))
(assert-str= "string trim" "hello" (str/trim "  hello  "))
(assert-str= "string lower-case" "cluck" (str/lower-case "Cluck"))
(assert-str= "string upper-case" "CLUCK" (str/upper-case "Cluck"))
(assert-str= "string capitalize" "Cluck" (str/capitalize "cLUCK"))
(assert-true "string includes?" (str/includes? "cluck" "lu"))
(assert-true "string includes? missing" (not (str/includes? "cluck" "zz")))
(assert-str= "string split" "(\"a\" \"b\" \"c\")" (pr-str (str/split "a,b,c" ",")))
(assert-str= "string join" "a,b,c" (str/join "," '("a" "b" "c")))
(assert-str= "string split-lines" "(\"a\" \"b\")" (pr-str (str/split-lines "a\nb")))
(assert-true "string starts-with?" (str/starts-with? "cluck" "cl"))
(assert-true "string ends-with?" (str/ends-with? "cluck" "uck"))
(assert-true "comment" (unspecified? (comment (error "boom"))))
(assert-num= "reader discard" 4 (+ 1 #_2 3))
(require [cluck.io :as io])
(assert-str= "io port->string" "abc"
             (io/port->string (open-input-string "abc")))
(assert-str= "io with-input-string" "abc"
             (io/with-input-string "abc"
               (fn [in] (io/port->string in))))
(assert-str= "io copy" "abc"
             (io/with-output-string
               (fn [out] (io/copy (open-input-string "abc") out))))
(let [io-file "build/cluck-io-smoke.txt"]
  (io/spit io-file "a\nb\n")
  (assert-str= "io slurp path" "a\nb\n" (io/slurp io-file))
  (assert-str= "io read-lines path" "(\"a\" \"b\")" (pr-str (io/read-lines io-file)))
  (assert-str= "io write-lines port" "a\nb\n"
               (io/with-output-string
                 (fn [out] (io/write-lines out '("a" "b")))))
  (fs/delete! io-file))
(require [cluck.fs :as fs])
(assert-str= "fs path" "build/cluck-fs-smoke.txt" (fs/path "build" "cluck-fs-smoke.txt"))
(assert-str= "fs basename" "cluck-fs-smoke.txt" (fs/basename "build/cluck-fs-smoke.txt"))
(assert-str= "fs dirname" "build/" (fs/dirname "build/cluck-fs-smoke.txt"))
(assert-str= "fs extension" "txt" (fs/extension "build/cluck-fs-smoke.txt"))
(assert-true "fs absolute?" (fs/absolute? "/tmp"))
(assert-true "fs exists? README" (fs/exists? "README.md"))
(let [tmp (fs/path "build" "cluck-fs-smoke.txt")]
  (fs/spit tmp "one\ntwo\n")
  (assert-str= "fs slurp" "one\ntwo\n" (fs/slurp tmp))
  (assert-true "fs file?" (fs/file? tmp))
(assert-true "fs directory?" (fs/directory? "build"))
(assert-true "fs delete!" (fs/delete! tmp))
(assert-true "fs delete! missing" (not (fs/delete! tmp))))
(assert-true "core delete!" (fs/delete! "build/cluck-core-smoke.txt"))
(load-file "examples/cluck/outline/main.clk")
(in-ns 'cluck.examples.outline)
(assert-true "outline namespace exists" (find-ns 'cluck.examples.outline))
(let [outline-sample "# Title\n\n## Section\ntext\n### Detail\n"]
  (assert-num= "outline headings" 3 (count (outline-entries outline-sample)))
  (let [first-heading (first (outline-entries outline-sample))]
    (assert-num= "outline first line" 1 (get first-heading :line))
    (assert-num= "outline first level" 1 (get first-heading :level))
    (assert-str= "outline first title" "Title" (get first-heading :title))))
(in-ns 'cluck.smoke)
(require [cluck.process :as proc])
(assert-true "process namespace exists" (find-ns 'cluck.process))
(assert-str= "process sh" "hello" (get (proc/sh "printf hello") :out))
(assert-num= "process sh exit" 0 (get (proc/sh "true") :exit))
(assert-str= "process exec" "hello" (get (proc/exec "printf" ["hello"]) :out))
(assert-num= "process system" 0 (proc/system "true"))
(load-file "examples/cluck/changelog/main.clk")
(in-ns 'cluck.examples.changelog)
(assert-true "changelog namespace exists" (find-ns 'cluck.examples.changelog))
(let [sample-log "a1b2c3\tfeat: add parser\nb2c3d4\tfix: handle nil\nc3d4e5\tdocs: update readme\n"]
  (let [entries (changelog-entries sample-log)]
    (assert-num= "changelog entries count" 3 (count entries))
    (assert-str= "changelog first kind" "feat" (get (first entries) :kind))
    (assert-str= "changelog second label" "Fixes" (changelog-kind-label (get (nth entries 1) :kind)))
    (assert-str= "changelog third subject" "docs: update readme" (get (nth entries 2) :subject))))
(in-ns 'cluck.smoke)
(load-file "examples/cluck/link-check/main.clk")
(in-ns 'cluck.examples.link-check)
(assert-true "links namespace exists" (find-ns 'cluck.examples.link-check))
(let [link-file "build/cluck-link-check-smoke.md"]
  (fs/spit link-file "[ok](../README.md)\n[broken](missing.md)\n")
  (let [matches (scan-file link-file)]
    (assert-num= "link checker matches count" 1 (count matches))
    (assert-str= "link checker broken target" "missing.md" (get (first matches) :target))
    (assert-str= "link checker broken basename" "missing.md" (fs/basename (get (first matches) :resolved))))
  (assert-true "link delete!" (fs/delete! link-file)))
(in-ns 'cluck.smoke)
(load-file "examples/cluck/todo/main.clk")
(in-ns 'cluck.examples.todo)
(assert-true "todo namespace exists" (find-ns 'cluck.examples.todo))
(let [todo-file "build/cluck-todo-smoke.txt"]
  (fs/spit todo-file "alpha\nTODO fix this\nbeta FIXME later\n")
  (let [matches (scan-file todo-file)]
    (assert-num= "todo matches count" 2 (count matches))
    (assert-str= "todo first marker" "TODO" (get (first matches) :marker))
    (assert-str= "todo second marker" "FIXME" (get (nth matches 1) :marker)))
  (assert-true "todo delete!" (fs/delete! todo-file)))
(in-ns 'cluck.smoke)
(require [cluck.set :as sets])
(assert-str= "set union" "#{1 2 3}" (pr-str (sets/union #{1 2} #{2 3})))
(assert-str= "set intersection" "#{2}" (pr-str (sets/intersection #{1 2} #{2 3})))
(assert-str= "set difference" "#{1}" (pr-str (sets/difference #{1 2 3} #{2 3})))
(assert-true "set subset?" (sets/subset? #{1 2} #{1 2 3}))
(assert-true "set superset?" (sets/superset? #{1 2 3} #{1 2}))
(require [cluck.edn :as edn])
(assert-str= "edn read-string" "{:a 1}" (pr-str (edn/read-string "{:a 1}")))
(load-file "examples/cluck/weather/main.clk")
(in-ns 'cluck.examples.weather)
(assert-true "weather namespace exists" (find-ns 'cluck.examples.weather))
(assert-true "weather url alias"
             (handle-exceptions exn
                 #f
               (begin
                 (weather-url "Oslo")
                 #t)))
(assert-str= "doc weather main"
             "weather/main\n\nFetch and print a weather forecast for LOCATION.\n"
             (capture-output (lambda () (doc weather/main))))
(assert-str= "weather usage"
             "Usage: cluck-weather <location>\nExample: cluck-weather Oslo\n"
             (capture-output (lambda () (main '()))))
(in-ns 'cluck.smoke)
(load-file "examples/cluck/text-report/main.clk")
(in-ns 'cluck.examples.text-report)
(assert-true "text-report namespace exists" (find-ns 'cluck.examples.text-report))
(let [stats (report-stats "a\n\nb")]
  (assert-num= "text-report lines" 3 (get stats :lines))
  (assert-num= "text-report blank lines" 1 (get stats :blank-lines))
  (assert-num= "text-report characters" 4 (get stats :characters))
  (assert-num= "text-report longest line" 1 (get stats :longest-line)))
(in-ns 'cluck.smoke)
(assert-str= "doc core namespace map"
             "cluck.core/map\n\nApply F to each element of COLL and return a list of the results.\n"
             (capture-output (lambda () (doc cluck.core/map))))
(assert-str= "doc and"
             "and\n\nEvaluate forms left to right and return the last truthy value, or the first falsey value.\n"
             (capture-output (lambda () (doc and))))
(assert-str= "doc case"
             "case\n\nCompare x against literal clauses and return the matching expression or trailing default.\n"
             (capture-output (lambda () (doc case))))
(assert-str= "doc cond->"
             "cond->\n\nThread x through forms as the second argument when the corresponding test is truthy.\n"
             (capture-output (lambda () (doc cond->))))
(assert-str= "doc cond->>"
             "cond->>\n\nThread x through forms as the last argument when the corresponding test is truthy.\n"
             (capture-output (lambda () (doc cond->>))))
(assert-str= "doc some->"
             "some->\n\nThread x through forms as the second argument, returning nil if any step is nil.\n"
             (capture-output (lambda () (doc some->))))
(assert-str= "doc some->>"
             "some->>\n\nThread x through forms as the last argument, returning nil if any step is nil.\n"
             (capture-output (lambda () (doc some->>))))
(assert-str= "doc or"
             "or\n\nEvaluate forms left to right and return the first truthy value, or false.\n"
             (capture-output (lambda () (doc or))))
(assert-str= "doc string join"
             "str/join\n\nJoin COLL with SEP and return a string.\n"
             (capture-output (lambda () (doc str/join))))
(assert-str= "doc edn read-string"
             "edn/read-string\n\nRead one EDN form from STRING.\n"
             (capture-output (lambda () (doc edn/read-string))))
(assert-true "defn doc output shows procedure"
             (string-prefix? "#<procedure"
                              (capture-output
                               (lambda ()
                                 (begin
                                   (defn doc-test "Quiet doc." [x] x)
                                   (cluck-repl-print-results doc-test))))))
(assert-str= "doc core get"
             "get\n\nLook up KEY in MAP, SET, VECTOR, or sequence-backed collection.\n"
             (capture-output (lambda () (doc get))))
(assert-str= "doc core take"
             "take\n\nReturn the first N items from COLL.\n"
             (capture-output (lambda () (doc take))))
(assert-str= "doc core frequencies"
             "frequencies\n\nReturn a persistent map of item frequencies from COLL.\n"
             (capture-output (lambda () (doc frequencies))))
(assert-true "empty? vector" (empty? []))
(assert-true "empty? list" (empty? '()))
(assert-num= "fn vector destructuring" 3 ((fn [[a b]] (+ a b)) [1 2]))
(assert-num= "fn map destructuring" 3 ((fn [{:keys [a b]}] (+ a b)) {:a 1 :b 2}))
(defn pair-sum [[a b]]
  (+ a b))
(assert-num= "defn destructuring" 5 (pair-sum [2 3]))
(assert-num= "assoc/get" 2 (-> {:a 1} (assoc :b 2) (get :b)))
(let [m (core/hash-map)
      m2 (core/assoc m :a 1 :b 2 :c 3)]
  (assert-str= "assoc original map mutated" "{:a 1 :b 2 :c 3}" (core/pr-str m))
  (assert-num= "assoc multi map a" 1 (core/get m2 :a))
  (assert-num= "assoc multi map b" 2 (core/get m2 :b))
  (assert-num= "assoc multi map c" 3 (core/get m2 :c)))
(let [v [0 0 0]
      v2 (assoc v 0 1 1 2 2 3)]
  (assert-str= "assoc multi vector" "[1 2 3]" (pr-str v2))
  (assert-str= "assoc original vector stays" "[0 0 0]" (pr-str v)))
(assert-num= "keyword lookup" 1 (:a {:a 1}))
(assert-num= "keyword lookup default" 0 (:a {:b 2} 0))
(assert-str= "thread-last map" "(2 3 4)" (pr-str (->> [1 2 3] (map inc))))
(assert-num= "cond" 2 (cond false 1 :else 2))
(assert-str= "take" "(1 2)" (pr-str (take 2 [1 2 3 4])))
(assert-str= "drop" "(3 4)" (pr-str (drop 2 [1 2 3 4])))
(assert-str= "take-nth" "(1 3 5)" (pr-str (take-nth 2 [1 2 3 4 5])))
(assert-str= "take-while" "(1 2)" (pr-str (take-while (lambda (x) (< x 3)) [1 2 3 1])))
(assert-str= "drop-while" "(3 1)" (pr-str (drop-while (lambda (x) (< x 3)) [1 2 3 1])))
(assert-str= "split-at left" "(1 2)" (pr-str (first (split-at 2 [1 2 3 4]))))
(assert-str= "split-at right" "(3 4)" (pr-str (nth (split-at 2 [1 2 3 4]) 1)))
(assert-str= "interleave" "(1 2 3 4 5 6)" (pr-str (interleave [1 3 5] [2 4 6])))
(assert-num= "last" 4 (last [1 2 3 4]))
(assert-str= "butlast" "(1 2 3)" (pr-str (butlast [1 2 3 4])))
(assert-str= "concat" "(1 2 3 4)" (pr-str (concat [1 2] [3 4])))
(assert-str= "interpose" "(1 0 2 0 3)" (pr-str (interpose 0 [1 2 3])))
(assert-str= "distinct" "(1 2 3)" (pr-str (distinct [1 2 1 3 2 1])))
(assert-str= "dedupe" "(1 2 1)" (pr-str (dedupe [1 1 2 2 1])))
(assert-str= "split-with left" "(1 2)" (pr-str (first (split-with (lambda (x) (< x 3)) [1 2 3 1]))))
(assert-str= "split-with right" "(3 1)" (pr-str (nth (split-with (lambda (x) (< x 3)) [1 2 3 1]) 1)))
(assert-str= "partition-by" "([1 1] [2 2] [1])" (pr-str (partition-by identity [1 1 2 2 1])))
(assert-str= "reductions" "(1 3 6)" (pr-str (reductions + [1 2 3])))
(assert-str= "reductions init" "(0 1 3 6)" (pr-str (reductions + 0 [1 2 3])))
(assert-str= "flatten" "(1 2 3 4 5)" (pr-str (flatten [1 [2 [3 4]] 5])))
(assert-num= "partition count" 2 (count (partition 2 [1 2 3 4])))
(assert-str= "partition first" "[1 2]" (pr-str (first (partition 2 [1 2 3 4]))))
(assert-num= "partition-all count" 3 (count (partition-all 2 [1 2 3 4 5])))
(assert-str= "partition-all last" "[5]" (pr-str (nth (partition-all 2 [1 2 3 4 5]) 2)))
(let [freqs (frequencies [1 2 1 3 2 1])]
  (assert-num= "frequencies 1" 3 (get freqs 1))
  (assert-num= "frequencies 2" 2 (get freqs 2))
  (assert-num= "frequencies 3" 1 (get freqs 3)))
(let [grouped (group-by even? [1 2 3 4 5])]
  (assert-num= "group-by odd count" 3 (count (get grouped false)))
  (assert-num= "group-by even count" 2 (count (get grouped true))))
(assert-true "contains?" (contains? (get sample :b) 3))
(assert-num= "seq map count" 2 (count (seq sample)))
(assert-true "seq map entry vector" (vector? (first (seq sample))))

(def smoke-ns-value 123)
(require [cluck.walk :as walk])
(assert-true "walk namespace exists" (find-ns 'cluck.walk))
(assert-str= "walk postwalk"
             "{:a 2 :b [3 4]}"
             (pr-str (walk/postwalk (fn [x] (if (number? x) (inc x) x))
                                    {:a 1 :b [2 3]})))
(assert-str= "walk prewalk"
             "[2 [4]]"
             (pr-str (walk/prewalk (fn [x] (if (number? x) (* x 2) x))
                                   [1 [2]])))
(assert-str= "walk keywordize-keys"
             "{:a 1 :b {:c 2}}"
             (pr-str (walk/keywordize-keys {"a" 1 :b {"c" 2}})))
(assert-str= "walk stringify-keys"
             "{\"a\" 1 \"b\" {\"c\" 2}}"
             (pr-str (walk/stringify-keys {:a 1 :b {:c 2}})))
(require [cluck.math :as math])
(assert-true "math namespace exists" (find-ns 'cluck.math))
(assert-num= "math abs" 7 (math/abs -7))
(assert-num= "math sqrt" 3 (math/sqrt 9))
(assert-num= "math pow" 8 (math/pow 2 3))
(assert-num= "math floor" 3 (math/floor 3.9))
(assert-num= "math ceil" 4 (math/ceil 3.1))
(assert-num= "math mod" 1 (math/mod 7 3))
(assert-num= "math rem" 1 (math/rem 7 3))
(assert-num= "math log10" 2 (math/log10 100))
(assert-num= "math signum" -1 (math/signum -8))
(assert-num= "require square" 25 (math/square 5))
(assert-num= "require sum-of-squares" 14 (math/sum-of-squares [1 2 3]))
(assert-str= "doc alias square"
             "math/square\n\nReturn X squared.\n"
             (capture-output (lambda () (doc math/square))))
(let [math-square (ns-resolve 'math 'square)]
  (assert-num= "require alias ns-resolve" 16 (math-square 4)))
(assert-true "ns current" (equal? (current-ns) 'cluck.smoke))
(assert-num= "ns publics" 123 (get (ns-publics (current-ns)) 'smoke-ns-value))

