                  (assert-str= "todo report"
                               "TODO markers: 2\ncluck-example-todo.txt:2 [TODO] TODO fix this\ncluck-example-todo.txt:3 [FIXME] beta FIXME later\n"
                               (capture-output
                                (lambda ()
                                  (main (list "cluck-example-todo.txt")))))
                  (assert-num= "todo scan-file count"
                               2
                               (count (scan-file "cluck-example-todo.txt")))))
(in-ns 'cluck.smoke)

