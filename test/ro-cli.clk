  (:require [cluck.fs :as fs]
            [cluck.process :as proc]
            [cluck.string :as str]
            [json :as json]
            [cluck.test.support :refer [assert-str=
                                        assert-num=
                                        assert-true
                                        pass
                                        fail
                                        capture-output
                                        capture-error-output]]))

