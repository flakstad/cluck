    (assert-num= (string-append label " exit parity")
                 (get odin :exit)
                 (get cluck :exit))))

(defn reindex-output-summary
  [output]
  (let ((data (ro-json-json-field-value output "data" '()))
        (hints (ro-json-json-field-value output "_hints" '())))
    (vector
     (cons 'data
           (vector
            (cons 'applied (ro-json-json-field-value data "applied" 0))
            (cons 'skipped (ro-json-json-field-value data "skipped" 0))))
     (cons '_hints hints))))

(defn assert-cli-json-summary-parity-in-config
  [label cluck-config-dir odin-config-dir args]
  (let [cluck (run-cluck-ro-in-config cluck-config-dir args)
        odin (run-odin-ro-in-config odin-config-dir args)
        cluck-out (get cluck :out "")
        odin-out (get odin :out "")]
    (assert-json= (string-append label " stdout json parity")
                  (reindex-output-summary (json/json-read (open-input-string odin-out)))
                  (reindex-output-summary (json/json-read (open-input-string cluck-out))))
    (assert-num= (string-append label " exit parity")
                 (get odin :exit)
                 (get cluck :exit))))

