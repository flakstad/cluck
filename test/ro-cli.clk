(def app-events-help-output app/events-help-output)
(def app-doctor-help-output app/doctor-help-output)
(def app-reindex-help-output app/reindex-help-output)
(def app-sync-help-output app/sync-help-output)
(def app-status-help-output app/status-help-output)
(def app-status-output app/workspace-status-output)
(def app-identity-help-output app/identity-help-output)
(def app-identity-list-output app/identity-list-output)
(def app-identity-whoami-output app/identity-whoami-output)
(def app-workspace-current-output app/workspace-current-output)
(def app-workspace-list-output app/workspace-list-output)
(def app-workspace-help-output app/workspace-help-output)
(def ro-json-json-field-value ro-json/json-field-value)
(def app-projects-help-output app/projects-help-output)
(def app-projects-list-output app/projects-list-output)
(def app-projects-current-output app/projects-current-output)
(def app-print-projects-list app/print-projects-list)
(def app-print-projects-current app/print-projects-current)
(def app-items-help-output app/items-help-output)
(def app-main app/main)
(def app-workspace-item-order<? app/workspace-item-order<?)
(def order-item-a (vector (cons 'rank "a")))
(def order-item-b (vector (cons 'rank "b")))
(def order-item-equal-left (vector (cons 'rank "u")))
(def order-item-equal-right (vector (cons 'rank "u")))
(assert-true "workspace item order compares rank"
             (app-workspace-item-order<? order-item-a order-item-b))
(assert-true "workspace item order keeps equal ranks tied left"
             (not (app-workspace-item-order<? order-item-equal-left order-item-equal-right)))
(assert-true "workspace item order keeps equal ranks tied right"
             (not (app-workspace-item-order<? order-item-equal-right order-item-equal-left)))
(def current-project-output
  (capture-output (fn [] (app-main '("projects" "current")))))
(def current-project-output-data
  (json/json-read (open-input-string current-project-output)))
(def current-project-id
  (ro-json-json-field-value
   (ro-json-json-field-value current-project-output-data "data" '())
   "projectId"
   ""))
(def live-items-list-output
  (capture-output (fn [] (app-main '("items" "list" "--format" "json")))))
(def live-items-list-output-data
  (json/json-read (open-input-string live-items-list-output)))
(def live-items-list
  (ro-json-json-field-value live-items-list-output-data "data" '()))
(def live-root-item
  (if (empty? live-items-list)
      false
      (first live-items-list)))
(def live-root-children
  (and live-root-item
       (ro-json-json-field-value
        (ro-json-json-field-value live-root-item "children" '())
        "items"
        '())))
(def live-item-record
  (cond
    (and live-root-children (not (empty? live-root-children)))
    (first live-root-children)

    live-root-item
    live-root-item

    :else
    false))
(def live-item-id
  (and live-item-record
       (ro-json-json-field-value live-item-record "id" "")))
(assert-true "live item id available"
             (and live-item-id (not (string=? live-item-id ""))))
(def run-live-parity?
  (not (string=? (or (get-environment-variable "RO_CLI_SKIP_LIVE") "") "1")))

(def fixture-root "test/fixtures/ro")
(def root-help-fixture "root-help")
(def ro-standalone-built? #f)

(defn fixture-path
  [case-name ext]
  (fs/path fixture-root (string-append case-name "." ext)))

(defn read-fixture
  [case-name]
  (fs/slurp (fixture-path case-name "stdout")))

(defn read-fixture-err
  [case-name]
  (fs/slurp (fixture-path case-name "stderr")))

(def ro-standalone-path "build/ro-standalone")
(def ro-standalone-build-args
  (list "-static"
        "-deployed"
        "-k"
        "-v"
        "-O2"
        "-strip"
        "-o"
        ro-standalone-path
        "examples/cluck/ro/run-standalone.scm"
        "-L"
        "-lncurses"
        "-L"
        "-lsqlite3"))

(defn ensure-ro-standalone!
  []
  (if ro-standalone-built?
      ro-standalone-path
      (let ((compile-result (proc/exec "csc" ro-standalone-build-args)))
        (if (= 0 (get compile-result :exit 1))
            (begin
              (set! ro-standalone-built? #t)
              ro-standalone-path)
            (error "failed to build ro-standalone" (get compile-result :out ""))))))

(defn run-cluck-ro
  [args]
  (proc/exec (ensure-ro-standalone!) args))

(defn run-odin-ro
  [args]
  (proc/exec "ro" args))

(defn run-clj-ro
  [args]
  (proc/exec "/Users/andreas/Projects/ro/ro-clj/bin/ro" args))

(defn ready-summary-output
  [binary]
  (get
   (proc/exec
    "python3"
    "-c"
    (string-append
     "import json,subprocess,sys;"
     "p=subprocess.run(sys.argv[1:],capture_output=True,text=True);"
     "if p.returncode!=0:"
     " sys.stderr.write(p.stderr);"
     " sys.stdout.write(p.stdout);"
     " sys.exit(p.returncode);"
     "obj=json.loads(p.stdout);"
     "items=obj.get('data',[]);"
     "summary={'count':len(items),'first_ids':[item.get('id','') for item in items[:5]],'_hints':obj.get('_hints',[])};"
     "print(json.dumps(summary,sort_keys=True,separators=(',', ':'),ensure_ascii=False))")
    binary
    "items"
    "ready"
    "--format"
    "json")
   :out
   ""))

(defn temp-dir
  [prefix]
  (let [result
        (proc/exec
         "python3"
         "-c"
         (string-append "import tempfile; print(tempfile.mkdtemp(prefix='"
                        prefix
                        "'))"))
        path (str/trim (get result :out ""))]
    path))

(defn temp-file-path
  [prefix suffix]
  (let [dir (temp-dir prefix)]
    (fs/path dir (string-append "value" suffix))))

(defn run-ro-in-config
  [binary config-dir args]
  (proc/exec
   "env"
   (cons (string-append "RO_CONFIG_DIR=" config-dir)
         (cons binary args))))

(defn run-cluck-ro-in-config
  [config-dir args]
  (run-ro-in-config (ensure-ro-standalone!) config-dir args))

(defn cluck-json-output-in-config
  [config-dir args]
  (json/json-read
   (open-input-string
    (get (run-cluck-ro-in-config config-dir args) :out ""))))

(defn json-output-field
  [output key default]
  (ro-json-json-field-value (ro-json-json-field-value output "data" '())
                            key
                            default))

(defn run-odin-ro-in-config
  [config-dir args]
  (run-ro-in-config "ro" config-dir args))

(def live-workspace-output
  (app-workspace-current-output))
(def live-workspace-output-data
  (json/json-read (open-input-string live-workspace-output)))
(def live-workspace-name
  (json-output-field live-workspace-output-data "workspace" ""))
(def live-workspace-root
  (json-output-field live-workspace-output-data "dir" ""))

(defn clone-workspace-root
  [source-root prefix]
  (let [dest (temp-dir prefix)
        result
        (proc/exec
         "python3"
         "-c"
         (string-append
          "import os, shutil, subprocess, sys\n"
          "src, dst = sys.argv[1], sys.argv[2]\n"
          "for name in ('meta', '.ro', 'events'):\n"
          "    src_path = os.path.join(src, name)\n"
          "    if not os.path.exists(src_path):\n"
          "        continue\n"
          "    dst_path = os.path.join(dst, name)\n"
          "    if os.path.isdir(src_path) and not os.path.islink(src_path):\n"
          "        shutil.copytree(src_path, dst_path, dirs_exist_ok=True)\n"
          "    else:\n"
          "        os.makedirs(os.path.dirname(dst_path), exist_ok=True)\n"
          "        shutil.copy2(src_path, dst_path)\n"
          "subprocess.run(['git', 'init', '-q'], cwd=dst, check=True)\n")
         source-root
         dest)]
    (if (= 0 (get result :exit 1))
        dest
        (error "failed to clone workspace root"
               (get result :out "")
               (get result :err "")))))

(defn prepare-isolated-workspace-config
  [prefix]
  (let [config-dir (temp-dir (string-append prefix "-config-"))
        workspace-root (clone-workspace-root live-workspace-root
                                             (string-append prefix "-workspace-"))
        workspace-name (string-append live-workspace-name "-" prefix)
        result
        (run-odin-ro-in-config
         config-dir
         (list "workspace"
               "add"
               workspace-name
               "--dir"
               workspace-root
               "--use"))]
    (if (= 0 (get result :exit 1))
        config-dir
        (error "failed to prepare isolated workspace config"
               (get result :out "")
               (get result :err "")))))

(defn json-key-text
  [key]
  (cond
    (string? key) key
    (keyword? key) (name key)
    (symbol? key) (symbol->string key)
    :else (str key)))

(defn json-object-like?
  [value]
  (let [items (cond
                (vector? value) (vector->list value)
                (pair? value) (seq value)
                :else '())]
    (and (not (empty? items))
         (every? pair? items))))

(defn normalize-json-value
  [value]
  (cond
    (json-object-like? value)
    (let [items (cond
                  (vector? value) (vector->list value)
                  (pair? value) (seq value)
                  :else '())
          sorted (cluck-sort-list items
                                  (fn [a b]
                                    (string<? (json-key-text (car a))
                                              (json-key-text (car b)))))]
      (map (fn [entry]
             (let [key (car entry)
                   normalized-value
                   (if (and (string? key)
                            (string=? key "payload_json")
                            (string? (cdr entry)))
                       (normalize-json-value
                        (json/json-read
                         (open-input-string (cdr entry))))
                       (normalize-json-value (cdr entry)))]
               (cons key normalized-value)))
           sorted))

    (vector? value)
    (map normalize-json-value (vector->list value))

    (pair? value)
    (map normalize-json-value (seq value))

    :else value))

(defn canonical-json-output
  [text]
  (let [path (temp-file-path "cluck-ro-json-" ".json")
        result (begin
                 (fs/spit path text)
                 (proc/exec
                  "python3"
                  "-c"
                  (string-append
                   "import json,sys\n"
                   "def norm(v):\n"
                   "  if isinstance(v,dict):\n"
                   "    out={}\n"
                   "    for k in sorted(v.keys(), key=lambda x: str(x)):\n"
                   "      val=v[k]\n"
                   "      if k=='payload_json' and isinstance(val,str):\n"
                   "        try:\n"
                   "          val=norm(json.loads(val))\n"
                   "        except Exception:\n"
                   "          pass\n"
                   "      else:\n"
                   "        val=norm(val)\n"
                   "      out[k]=val\n"
                   "    return out\n"
                   "  if isinstance(v,list):\n"
                   "    return [norm(x) for x in v]\n"
                   "  return v\n"
                   "obj=json.load(open(sys.argv[1], encoding='utf-8'))\n"
                   "sys.stdout.write(json.dumps(norm(obj), separators=(',', ':'), ensure_ascii=False))")
                  path))]
    (if (= 0 (get result :exit 1))
        (get result :out "")
        (error "failed to canonicalize json output"
               (get result :out "")
               (get result :err "")))))

(defn assert-json=
  [label expected actual]
  (if (equal? (normalize-json-value expected)
              (normalize-json-value actual))
      (pass label)
      (fail label expected actual)))

(defn assert-cli-json-parity
  [label args]
  (let [cluck (run-cluck-ro args)
        odin (run-odin-ro args)
        cluck-out (get cluck :out "")
        odin-out (get odin :out "")
        cluck-err (get cluck :err "")
        odin-err (get odin :err "")]
    (assert-str= (string-append label " stdout json parity")
                 (canonical-json-output odin-out)
                 (canonical-json-output cluck-out))
    (assert-str= (string-append label " stderr parity")
                 odin-err
                 cluck-err)
    (assert-num= (string-append label " exit parity")
                 (get odin :exit)
                 (get cluck :exit))))

(defn assert-cli-json-parity-against
  [label run-reference args]
  (let [cluck (run-cluck-ro args)
        reference (run-reference args)
        cluck-out (get cluck :out "")
        reference-out (get reference :out "")
        cluck-err (get cluck :err "")
        reference-err (get reference :err "")]
    (assert-str= (string-append label " stdout json parity")
                 (canonical-json-output reference-out)
                 (canonical-json-output cluck-out))
    (assert-str= (string-append label " stderr parity")
                 reference-err
                 cluck-err)
    (assert-num= (string-append label " exit parity")
                 (get reference :exit)
                 (get cluck :exit))))

(defn assert-cli-case
  [label case-name args]
  (let [fixture-out (read-fixture case-name)
        cluck (run-cluck-ro args)
        odin (run-odin-ro args)
        cluck-err (get cluck :err "")
        odin-err (get odin :err "")]
    (assert-str= (string-append label " fixture")
                 fixture-out
                 (get cluck :out))
    (assert-str= (string-append label " stdout parity")
                 (get odin :out)
                 (get cluck :out))
    (assert-str= (string-append label " stderr parity")
                 odin-err
                 cluck-err)
    (assert-num= (string-append label " exit parity")
                 (get odin :exit)
                 (get cluck :exit))))

(defn assert-cli-case-err
  [label case-name args]
  (let [fixture-out (read-fixture-err case-name)
        cluck (run-cluck-ro args)
        odin (run-odin-ro args)
        cluck-out (get cluck :out "")
        odin-out (get odin :out "")
        cluck-err (get cluck :err "")
        odin-err (get odin :err "")]
    (assert-str= (string-append label " fixture")
                 fixture-out
                 cluck-out)
    (assert-str= (string-append label " stdout parity")
                 odin-out
                 cluck-out)
    (assert-str= (string-append label " stderr parity")
                 odin-err
                 cluck-err)
    (assert-num= (string-append label " exit parity")
                 (get odin :exit)
                 (get cluck :exit))))

(defn assert-cli-fixture-case-err
  [label case-name args expected-exit]
  (let [fixture-out (read-fixture-err case-name)
        cluck (run-cluck-ro args)
        cluck-out (get cluck :out "")
        cluck-err (get cluck :err "")]
    (assert-str= (string-append label " fixture")
                 fixture-out
                 cluck-out)
    (assert-str= (string-append label " stderr empty")
                 ""
                 cluck-err)
    (assert-num= (string-append label " exit")
                 expected-exit
                 (get cluck :exit))))

(defn assert-cli-parity
  [label args]
  (let [cluck (run-cluck-ro args)
        odin (run-odin-ro args)
        cluck-out (get cluck :out "")
        odin-out (get odin :out "")
        cluck-err (get cluck :err "")
        odin-err (get odin :err "")]
    (assert-str= (string-append label " stdout parity")
                 odin-out
                 cluck-out)
    (assert-str= (string-append label " stderr parity")
                 odin-err
                 cluck-err)
    (assert-num= (string-append label " exit parity")
                 (get odin :exit)
                 (get cluck :exit))))

