(defn assert-cli-json-parity-in-config
  [label cluck-config-dir odin-config-dir args]
  (let [cluck (run-cluck-ro-in-config cluck-config-dir args)
        odin (run-odin-ro-in-config odin-config-dir args)
        cluck-out (get cluck :out "")
        odin-out (get odin :out "")]
    (assert-str= (string-append label " stdout json parity")
                 (canonical-json-output odin-out)
