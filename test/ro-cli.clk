(define workspace-init-root-dir (temp-dir "cluck-ro-init-workspace-"))
(define workspace-init-cluck-config-dir (temp-dir "cluck-ro-init-config-cluck-"))
(define workspace-init-output
  (cluck-json-output-in-config workspace-init-cluck-config-dir
                               (list "workspace"
                                     "init"
                                     "testws"
                                     "--dir"
                                     workspace-init-root-dir
                                     "--use")))
(assert-str= "workspace init workspace"
             "testws"
             (json-output-field workspace-init-output "workspace" ""))
(assert-str= "workspace init kind"
             "local"
             (json-output-field workspace-init-output "kind" ""))
(assert-true "workspace init used"
             (json-output-field workspace-init-output "used" false))
(define workspace-init-created-dir
  (json-output-field workspace-init-output "dir" ""))
(assert-true "workspace init created workspace meta"
             (fs/file? (fs/path workspace-init-created-dir "meta" "workspace.json")))
(assert-true "workspace init created device file"
             (fs/file? (fs/path workspace-init-created-dir ".ro" "device.json")))
(assert-true "workspace init created sqlite file"
             (fs/file? (fs/path workspace-init-created-dir ".ro" "index.sqlite")))
(define workspace-use-after-init-output
  (cluck-json-output-in-config workspace-init-cluck-config-dir
                               (list "workspace"
                                     "use"
                                     "testws")))
(assert-str= "workspace use after init workspace"
             "testws"
             (json-output-field workspace-use-after-init-output "workspace" ""))
(assert-str= "workspace use after init dir"
             workspace-init-created-dir
             (json-output-field workspace-use-after-init-output "dir" ""))

(define workspace-add-root-dir (temp-dir "cluck-ro-add-workspace-"))
(define workspace-add-cluck-config-dir (temp-dir "cluck-ro-add-config-cluck-"))
(define workspace-add-output
  (cluck-json-output-in-config workspace-add-cluck-config-dir
                               (list "workspace"
                                     "add"
                                     "git-workspace"
                                     "--dir"
                                     workspace-add-root-dir
                                     "--kind"
                                     "git"
                                     "--use")))
(assert-str= "workspace add workspace"
             "git-workspace"
             (json-output-field workspace-add-output "workspace" ""))
(assert-str= "workspace add kind"
             "git"
             (json-output-field workspace-add-output "kind" ""))
(assert-true "workspace add used"
             (json-output-field workspace-add-output "used" false))
(define workspace-add-created-dir
  (json-output-field workspace-add-output "dir" ""))
(assert-true "workspace add created workspace meta"
             (fs/file? (fs/path workspace-add-created-dir "meta" "workspace.json")))
(assert-true "workspace add created device file"
             (fs/file? (fs/path workspace-add-created-dir ".ro" "device.json")))
(assert-true "workspace add created sqlite file"
             (fs/file? (fs/path workspace-add-created-dir ".ro" "index.sqlite")))
(define workspace-use-after-add-output
  (cluck-json-output-in-config workspace-add-cluck-config-dir
                               (list "workspace"
                                     "use"
                                     "git-workspace")))
(assert-str= "workspace use after add workspace"
             "git-workspace"
             (json-output-field workspace-use-after-add-output "workspace" ""))
(assert-str= "workspace use after add dir"
             workspace-add-created-dir
             (json-output-field workspace-use-after-add-output "dir" ""))

(if run-live-parity?
    (begin
      (assert-cli-json-parity "items show" '("items" "show" "item-vvo" "--format" "json"))
      (assert-cli-json-parity "item shortcut" '("item-vvo" "--format" "json"))
      (assert-cli-json-parity "items list" '("items" "list" "--format" "json"))
      (assert-cli-json-parity "items ready" '("items" "ready" "--format" "json"))
      (assert-cli-json-parity "items events" '("items" "events" "item-vvo" "--format" "json"))
      (assert-cli-json-parity "events list" '("events" "list" "--limit" "3"))
      (assert-cli-json-parity "doctor" '("doctor"))
      (assert-cli-json-parity "doctor --fail" '("doctor" "--fail"))
      (assert-cli-json-parity "doctor summary" '("doctor" "summary"))
      (assert-cli-json-parity "doctor summary --fail" '("doctor" "summary" "--fail"))
      (assert-cli-json-parity "doctor dedupe" '("doctor" "dedupe"))
      (assert-cli-json-parity "doctor dedupe --write --force" '("doctor" "dedupe" "--write" "--force"))
      (assert-cli-json-parity "reindex" '("reindex"))
      (assert-cli-json-parity "sync status" '("sync" "status"))
      (assert-cli-json-parity "sync status --help" '("sync" "status" "--help"))
      (assert-cli-json-parity "sync remotes" '("sync" "remotes"))
      (assert-cli-json-parity "sync remotes --help" '("sync" "remotes" "--help"))
      (assert-cli-json-parity "sync reindex" '("sync" "reindex"))
      (assert-cli-json-parity "sync reindex --help" '("sync" "reindex" "--help"))
      (assert-cli-parity "status" '("status"))
      (assert-cli-parity "identity list" '("identity" "list"))
      (assert-cli-parity "identity whoami" '("identity" "whoami"))
      (assert-cli-parity "workspace current" '("workspace" "current"))
      (assert-cli-parity "workspace list" '("workspace" "list"))
      (assert-cli-json-parity "projects list" '("projects" "list"))
      (assert-cli-json-parity "projects list --help" '("projects" "list" "--help"))
      (assert-cli-parity "projects use current project" '("projects" "use" "proj-d1743158"))
      (assert-cli-parity "projects use --help" '("projects" "use" "--help"))
      (assert-cli-parity "projects use help" '("projects" "use" "help"))
      (assert-cli-json-parity "projects current" '("projects" "current"))
      (assert-cli-json-parity "projects current --help" '("projects" "current" "--help")))
    (pass "skipped live Odin parity"))
