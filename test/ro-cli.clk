;; CLI contract tests for the Ro spike.

(ns cluck.test.ro-cli
  (:require [cluck.fs :as fs]
            [cluck.process :as proc]
            [cluck.string :as str]
            [json :as json]
            [cluck.examples.ro.app :as app]
            [cluck.examples.ro.core.json :as ro-json]
            [cluck.test.support :refer [assert-str=
                                        assert-num=
                                        assert-true
                                        pass
                                        fail
                                        capture-output
                                        capture-error-output]]))
(def app-help-request? app/help-request?)
(def app-root-help-output app/root-help-output)
(def app-docs-help-output app/docs-help-output)
(def app-docs-output app/docs-output)
(def app-docs-topic-markdown app/docs-topic-markdown)
