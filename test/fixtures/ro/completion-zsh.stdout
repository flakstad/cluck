#compdef ro

_ro() {
  local -a top docs_topics
  top=(agent attachments capture comments completion deps docs doctor help identity init items reindex status sync tasks worklog workspace)
  docs_topics=(cli getting-started output-contract storage identity-ownership agent-runtimes sync doctor-reindex)

  if (( CURRENT == 2 )); then
    _describe 'command' top
    return
  fi

  case ${words[2]} in
    docs) _describe 'docs topic' docs_topics ;;
  esac
}

compdef _ro ro
