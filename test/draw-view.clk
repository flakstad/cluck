;; Focused draw-view probe for the SDL3 example.

(in-ns 'cluck.examples.draw)

(define (draw-view-pass label)
  (println "ok" label)
  true)

(define (draw-view-fail label expected actual)
  (error (string-append "draw view test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (draw-view-assert-true label value)
  (if value
      (draw-view-pass label)
      (draw-view-fail label "truthy value" (pr-str value))))

(define (draw-view-assert-str= label expected actual)
  (if (string=? expected actual)
      (draw-view-pass label)
      (draw-view-fail label expected actual)))

(define (draw-view-assert-num= label expected actual)
  (if (= expected actual)
      (draw-view-pass label)
      (draw-view-fail label expected actual)))

(draw-view-assert-true "draw namespace exists" (find-ns 'cluck.examples.draw))

(draw-view-assert-str= "screen point converts to world at default zoom"
                       "[12.0 34.0 1.0]"
                       (pr-str (draw-event-point (default-state)
                                                "SDL_EVENT_MOUSE_MOTION x=12.0 y=34.0")))

(let [state (assoc (default-state)
                   :view-x 10.0
                   :view-y 20.0
                   :zoom 2.0)]
  (draw-view-assert-str= "world point converts to screen with viewport"
                         "[10 12 1.0]"
                         (pr-str (draw-world-point->screen-point state [15 26 1.0])))
  (draw-view-assert-num= "screen brush size scales with zoom"
                         8
                         (draw-point-screen-size state [15 26 1.0] 4))
  (draw-view-assert-str= "event point uses viewport transform"
                         "[17.0 32.0 1.0]"
                         (pr-str (draw-event-point state
                                                  "SDL_EVENT_MOUSE_MOTION x=14.0 y=24.0"))))

(let [state (assoc (default-state)
                   :ctrl-down? true
                   :mouse-screen-x 100.0
                   :mouse-screen-y 50.0)
      anchor (draw-screen-point->world-point state [100.0 50.0 1.0])
      zoomed (draw-handle-view-key! state "=")]
  (draw-view-assert-true "ctrl plus changes zoom"
                         (> (draw-view-zoom zoomed) 1.0))
  (draw-view-assert-str= "ctrl plus keeps pointer anchored"
                         "[100 50 1.0]"
                         (pr-str (draw-world-point->screen-point zoomed anchor))))

(let [plain (draw-handle-view-key! (default-state) "=")]
  (draw-view-assert-num= "plain equals does not zoom without ctrl"
                         1.0
                         (draw-view-zoom plain)))

(let [panned (draw-handle-view-key! (assoc (default-state)
                                           :view-x 10.0
                                           :view-y 20.0
                                           :zoom 2.0)
                                    "h")]
  (draw-view-assert-num= "pan left updates view-x"
                         -22.0
                         (draw-view-x panned)))

(let [state (default-state)
      wheel-zoomed (draw-zoom-at-core! state 1.0 100.0 50.0)
      anchor (draw-screen-point->world-point state [100.0 50.0 1.0])]
  (draw-view-assert-true "wheel zoom changes zoom"
                         (> (draw-view-zoom wheel-zoomed) 1.0))
  (draw-view-assert-str= "wheel zoom keeps cursor anchored"
                         "[100 50 1.0]"
                         (pr-str (draw-world-point->screen-point wheel-zoomed anchor))))

(let [panning (draw-pan-core! (assoc (default-state)
                                     :panning? true
                                     :pan-last-x 10.0
                                     :pan-last-y 20.0
                                     :view-x 10.0
                                     :view-y 20.0
                                     :zoom 2.0)
                              [14.0 24.0])]
  (draw-view-assert-num= "pan drag updates view-x"
                         8.0
                         (draw-view-x panning))
  (draw-view-assert-num= "pan drag updates view-y"
                         18.0
                         (draw-view-y panning)))

(let [started (draw-start-stroke (assoc (default-state)
                                        :view-x 100.0
                                        :view-y 200.0
                                        :zoom 2.0)
                                 [150.0 240.0 1.0]
                                 [100.0 80.0]
                                 :mouse)
      finished (draw-finish-stroke started
                                   [170.0 260.0 1.0]
                                   [140.0 120.0])
      stroke (first (get finished :strokes))]
  (draw-view-assert-str= "zoomed stroke keeps world start point"
                         "[150.0 240.0 1.0]"
                         (pr-str (first (get stroke :points))))
  (draw-view-assert-str= "zoomed stroke keeps world end point"
                         "[170.0 260.0 1.0]"
                         (pr-str (last (get stroke :points)))))
