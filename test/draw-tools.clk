;; Focused draw-tools probe for the SDL3 example.

(in-ns 'cluck.examples.draw)

(define (draw-tools-pass label)
  (println "ok" label)
  true)

(define (draw-tools-fail label expected actual)
  (error (string-append "draw tools test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (draw-tools-assert-true label value)
  (if value
      (draw-tools-pass label)
      (draw-tools-fail label "truthy value" (pr-str value))))

(define (draw-tools-assert-str= label expected actual)
  (if (string=? expected actual)
      (draw-tools-pass label)
      (draw-tools-fail label expected actual)))

(define (draw-tools-assert-num= label expected actual)
  (if (= expected actual)
      (draw-tools-pass label)
      (draw-tools-fail label expected actual)))

(define (draw-tools-base-state)
  {:title "Cluck Draw"
   :width 1280
   :height 720
  :background [24 24 28]
  :brush-color [245 245 245]
  :brush-size 2
  :pen-pressure 1.0
  :window-focused? true
  :eraser? false
  :running? true
   :frame 0
   :mouse-x 0
   :mouse-y 0
   :pointer-down? false
   :debug-panel? false
   :history []
   :strokes [[1 2] [3 4]]
   :active-stroke false
   :last-key ""
   :last-text ""
   :last-event ""
   :recent-events []})

(draw-tools-assert-true "describe-state includes tool"
                        (str/includes? (describe-state (default-state)) "tool brush"))
(draw-tools-assert-true "describe-state includes undo count"
                        (str/includes? (describe-state (default-state)) "undo 0"))
(draw-tools-assert-num= "brush radius" 2 (draw-brush-radius 2))

(let [cleared (draw-clear-strokes! (draw-tools-base-state))]
    (draw-tools-assert-true "clear strokes"
                            (and (empty? (get cleared :strokes))
                                 (not (get cleared :active-stroke))
                                 (not (get cleared :pointer-down?))))
    (draw-tools-assert-num= "clear adds undo history" 1 (count (get cleared :history)))
    (let [restored (draw-undo-stroke! cleared)]
      (draw-tools-assert-num= "undo restores strokes after clear"
                              2
                              (count (get restored :strokes)))))

  (let [size-state (draw-set-brush-size! (default-state) 6)]
    (draw-tools-assert-num= "brush size preset" 6 (get size-state :brush-size))
    (draw-tools-assert-num= "brush size adds undo history" 1 (count (get size-state :history)))
    (let [restored (draw-undo-stroke! size-state)]
      (draw-tools-assert-num= "undo restores brush size" 2 (get restored :brush-size))))

  (let [eraser-state (draw-toggle-eraser! (default-state))]
    (draw-tools-assert-true "toggle eraser" (get eraser-state :eraser?))
    (draw-tools-assert-num= "eraser adds undo history" 1 (count (get eraser-state :history)))
    (draw-tools-assert-str= "eraser color"
                            "[24 24 28]"
                            (pr-str (draw-stroke-color eraser-state)))
    (let [restored (draw-undo-stroke! eraser-state)]
      (draw-tools-assert-true "undo restores eraser off"
                              (not (get restored :eraser?))))

  (let [clear-by-key (draw-handle-tool-key! (draw-tools-base-state) "c")]
    (draw-tools-assert-true "clear key dispatch"
                            (and (empty? (get clear-by-key :strokes))
                                 (not (get clear-by-key :active-stroke))
                                 (not (get clear-by-key :pointer-down?))))
    (let [undo-by-key (draw-handle-tool-key! clear-by-key "u")]
      (draw-tools-assert-num= "undo key dispatch"
                              2
                              (count (get undo-by-key :strokes)))))

  (let [tool-state (draw-handle-tool-key! (default-state) "3")]
    (draw-tools-assert-str= "brush size key preset"
                            "12"
                            (str (get tool-state :brush-size))))

  (let [base (default-state)
        one (draw-start-stroke base [10.0 10.0 1.0] [10.0 10.0] :mouse)
        one (draw-finish-stroke one [20.0 20.0 1.0] [20.0 20.0])
        two (draw-start-stroke one [30.0 30.0 1.0] [30.0 30.0] :mouse)
        two (draw-finish-stroke two [40.0 40.0 1.0] [40.0 40.0])
        undone (draw-undo-stroke! two)]
    (draw-tools-assert-num= "undo removes most recent stroke"
                            1
                            (count (get undone :strokes)))
    (draw-tools-assert-num= "undo keeps prior history chain"
                            1
                            (count (get undone :history))))

  (let [started (draw-start-stroke (default-state)
                                   [10.0 10.0 1.0]
                                   [10.0 10.0]
                                   :mouse)
        extended (draw-extend-stroke started
                                     [20.0 20.0 1.0]
                                     [20.0 20.0])
        finished (draw-finish-stroke extended
                                     [30.0 30.0 1.0]
                                     [30.0 30.0])
        stroke (first (get finished :strokes))
        resized (draw-set-brush-size! finished 6)
        resized-stroke (first (get resized :strokes))]
    (draw-tools-assert-num= "finished stroke keeps full point history"
                            3
                            (count (get stroke :points)))
    (draw-tools-assert-num= "brush change keeps stroke point history"
                            3
                            (count (get resized-stroke :points))))

  (let [stroke (draw-stroke-record [[10.0 10.0 1.0]]
                                   [255 255 255]
                                   6)
        points (draw-append-stroke-point (default-state)
                                         stroke
                                         [11.0 10.0 1.0])]
    (draw-tools-assert-num= "close active sample is ignored"
                            1
                            (count points))
    (draw-tools-assert-str= "close active sample keeps prior point"
                            "[10.0 10.0 1.0]"
                            (pr-str (first points))))

  (let [stroke (draw-stroke-record [[10.0 10.0 1.0]
                                    [20.0 10.0 1.0]]
                                   [255 255 255]
                                   6)
        points (draw-append-stroke-point (default-state)
                                         stroke
                                         [21.0 10.0 1.0])]
    (draw-tools-assert-num= "close trailing sample keeps point count stable"
                            2
                            (count points))
    (draw-tools-assert-str= "close trailing sample keeps committed endpoint"
                            "[20.0 10.0 1.0]"
                            (pr-str (last points))))

  (let [stroke (draw-stroke-record [[10.0 10.0 1.0]]
                                   [255 255 255]
                                   6)
        points (draw-append-stroke-point (default-state)
                                         stroke
                                         [20.0 10.0 1.0])]
    (draw-tools-assert-num= "distant active sample appends"
                            2
                            (count points)))

  (let [original-segment sdl/render-soft-segment!
        original-brush-ready draw-brush-texture-ready?
        original-strip-ready draw-strip-texture-ready?
        original-brush draw-brush-texture
        original-strip draw-strip-texture
        calls []]
    (set! draw-brush-texture-ready?
          (fn []
            true))
    (set! draw-strip-texture-ready?
          (fn []
            true))
    (set! draw-brush-texture
          (fn []
            'brush))
    (set! draw-strip-texture
          (fn []
            'strip))
    (set! sdl/render-soft-segment!
          (fn [renderer strip brush x1 y1 size1 alpha1 x2 y2 size2 alpha2 r g b]
            (set! calls (conj calls [strip brush x1 y1 size1 alpha1 x2 y2 size2 alpha2 r g b]))
            true))
    (draw-render-stroke-segments! 'renderer
                                  (default-state)
                                  [[10 10 0.25] [20 20 0.75] [30 30 1.0]]
                                  2)
    (draw-tools-assert-num= "stroke segment renderer call count"
                            2
                            (count calls))
    (draw-tools-assert-str= "stroke segment renderer uses cached strip"
                            "strip"
                            (str (nth (first calls) 0)))
    (draw-tools-assert-true "stroke segment renderer reflects growing pressure"
                            (< (nth (first calls) 5)
                               (nth (last calls) 9)))
    (set! sdl/render-soft-segment! original-segment)
    (set! draw-brush-texture-ready? original-brush-ready)
    (set! draw-strip-texture-ready? original-strip-ready)
    (set! draw-brush-texture original-brush)
    (set! draw-strip-texture original-strip)))

(let [original-ready draw-brush-texture-ready?
      original-brush draw-brush-texture
      original-color sdl/set-texture-color-mod!
      original-alpha sdl/set-texture-alpha-mod!
      original-render sdl/render-texture-at!
      color-calls []
      alpha-calls []
      render-calls []]
  (set! draw-brush-texture-ready?
        (lambda ()
          true))
  (set! draw-brush-texture
        (lambda ()
          'brush))
  (set! sdl/set-texture-color-mod!
        (lambda (texture r g b)
          (set! color-calls (conj color-calls [texture r g b]))
          true))
  (set! sdl/set-texture-alpha-mod!
        (lambda (texture alpha)
          (set! alpha-calls (conj alpha-calls [texture alpha]))
          true))
  (set! sdl/render-texture-at!
        (lambda (renderer texture x y w h)
          (set! render-calls (conj render-calls [texture x y w h]))
          true))
  (draw-with-stroke-color [120 160 200]
    (lambda ()
      (draw-render-soft-brush! 'renderer
                               (default-state)
                               [20 24 0.5]
                               6)))
  (draw-tools-assert-num= "soft brush color mod count"
                          1
                          (count color-calls))
  (draw-tools-assert-num= "soft brush alpha mod count"
                          1
                          (count alpha-calls))
  (draw-tools-assert-num= "soft brush render count"
                          1
                          (count render-calls))
  (draw-tools-assert-str= "soft brush color mod value"
                          "[brush 120 160 200]"
                          (pr-str (first color-calls)))
  (draw-tools-assert-true "soft brush render has positive size"
                          (> (nth (first render-calls) 3) 0))
  (set! draw-brush-texture-ready? original-ready)
  (set! draw-brush-texture original-brush)
  (set! sdl/set-texture-color-mod! original-color)
  (set! sdl/set-texture-alpha-mod! original-alpha)
  (set! sdl/render-texture-at! original-render))
