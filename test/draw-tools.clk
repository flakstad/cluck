;; Focused draw-tools probe for the SDL3 example.

(in-ns 'cluck.examples.draw)

(define (draw-tools-pass label)
  (println "ok" label)
  true)

(define (draw-tools-fail label expected actual)
  (error (string-append "draw tools test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (draw-tools-assert-true label value)
  (if value
      (draw-tools-pass label)
      (draw-tools-fail label "truthy value" (pr-str value))))

(define (draw-tools-assert-false label value)
  (if (not value)
      (draw-tools-pass label)
      (draw-tools-fail label "falsey value" (pr-str value))))

(define (draw-tools-assert-str= label expected actual)
  (if (string=? expected actual)
      (draw-tools-pass label)
      (draw-tools-fail label expected actual)))

(define (draw-tools-assert-num= label expected actual)
  (if (= expected actual)
      (draw-tools-pass label)
      (draw-tools-fail label expected actual)))

(define (draw-tools-base-state)
  (draw-normalize-state
    {:title "Cluck Draw"
     :width 1280
     :height 720
     :background [24 24 28]
     :brush-color [245 245 245]
     :brush-size 2
     :pen-pressure 1.0
     :window-focused? true
     :eraser? false
     :running? true
     :frame 0
     :mouse-x 0
     :mouse-y 0
     :pointer-down? false
     :debug-panel? false
     :history []
     :strokes [{:points [[1 2 1.0] [3 4 1.0]]
                :color [245 245 245]
                :size 2}]
     :active-stroke false
     :last-key ""
     :last-text ""
     :last-event ""
     :recent-events []}))

(draw-tools-assert-true "describe-state includes tool"
                        (str/includes? (describe-state (default-state)) "tool ink"))
(draw-tools-assert-true "describe-state includes undo count"
                        (str/includes? (describe-state (default-state)) "undo 0"))
(draw-tools-assert-num= "brush radius" 2 (draw-brush-radius 2))

(let [cleared (draw-clear-strokes! (draw-tools-base-state))]
    (draw-tools-assert-true "clear strokes"
                            (and (empty? (get cleared :strokes))
                                 (not (get cleared :active-stroke))
                                 (not (get cleared :pointer-down?))))
    (draw-tools-assert-num= "clear adds undo history" 1 (count (get cleared :history)))
    (let [restored (draw-undo-stroke! cleared)]
      (draw-tools-assert-num= "undo restores strokes after clear"
                              1
                              (count (get restored :strokes)))))

  (let [size-state (draw-set-brush-size! (default-state) 6)]
    (draw-tools-assert-num= "brush size preset" 6 (get size-state :brush-size))
    (draw-tools-assert-num= "brush size adds undo history" 1 (count (get size-state :history)))
    (let [restored (draw-undo-stroke! size-state)]
      (draw-tools-assert-num= "undo restores brush size" 2 (get restored :brush-size))))

  (let [eraser-state (draw-toggle-eraser! (default-state))]
    (draw-tools-assert-true "toggle eraser" (get eraser-state :eraser?))
    (draw-tools-assert-num= "eraser adds undo history" 1 (count (get eraser-state :history)))
    (draw-tools-assert-str= "eraser color"
                            "[24 24 28]"
                            (pr-str (draw-stroke-color eraser-state)))
    (let [restored (draw-undo-stroke! eraser-state)]
      (draw-tools-assert-true "undo restores eraser off"
                              (not (get restored :eraser?))))

  (let [clear-by-key (draw-handle-tool-key! (draw-tools-base-state) "c")]
    (draw-tools-assert-true "clear key dispatch"
                            (and (empty? (get clear-by-key :strokes))
                                 (not (get clear-by-key :active-stroke))
                                 (not (get clear-by-key :pointer-down?))))
    (let [undo-by-key (draw-handle-tool-key! clear-by-key "u")]
      (draw-tools-assert-num= "undo key dispatch"
                              1
                              (count (get undo-by-key :strokes)))))

  (let [tool-state (draw-handle-tool-key! (default-state) "3")]
    (draw-tools-assert-str= "brush size key preset"
                            "12"
                            (str (get tool-state :brush-size))))

  (let [box-state (draw-handle-tool-key! (default-state) "b")
        rect-state (draw-handle-tool-key! (default-state) "r")
        text-state (draw-handle-tool-key! (default-state) "t")
        select-state (draw-handle-tool-key! (default-state) "v")
        arrow-state (draw-handle-tool-key! (default-state) "a")
        frame-state (draw-handle-tool-key! (default-state) "f")
        box-snapshot (edn/read-string (pr-str box-state))
        ink-state (draw-handle-tool-key! box-state "i")]
    (draw-tools-assert-str= "rectangle tool key preset"
                            "rectangle"
                            (draw-tool-mode box-snapshot))
    (draw-tools-assert-str= "rectangle alias key preset"
                            "rectangle"
                            (draw-tool-mode rect-state))
    (draw-tools-assert-str= "text tool key preset"
                            "text"
                            (draw-tool-mode text-state))
    (draw-tools-assert-str= "selection tool key preset"
                            "select"
                            (draw-tool-mode select-state))
    (draw-tools-assert-str= "arrow tool key preset"
                            "arrow"
                            (draw-tool-mode arrow-state))
    (draw-tools-assert-str= "frame tool key ignored from active tool surface"
                            "ink"
                            (draw-tool-mode frame-state))
    (draw-tools-assert-str= "ink tool key preset"
                            "ink"
                            (draw-tool-mode ink-state)))

  (let [base (default-state)
        one (draw-start-stroke base [10.0 10.0 1.0] [10.0 10.0] :mouse)
        one (draw-finish-stroke one [20.0 20.0 1.0] [20.0 20.0])
        two (draw-start-stroke one [30.0 30.0 1.0] [30.0 30.0] :mouse)
        two (draw-finish-stroke two [40.0 40.0 1.0] [40.0 40.0])
        undone (draw-undo-stroke! two)]
    (draw-tools-assert-num= "undo removes most recent stroke"
                            1
                            (count (get undone :strokes)))
    (draw-tools-assert-num= "undo keeps prior history chain"
                            1
                            (count (get undone :history))))

  (let [started (draw-start-stroke (default-state)
                                   [10.0 10.0 1.0]
                                   [10.0 10.0]
                                   :mouse)
        extended (draw-extend-stroke started
                                     [20.0 20.0 1.0]
                                     [20.0 20.0])
        finished (draw-finish-stroke extended
                                     [30.0 30.0 1.0]
                                     [30.0 30.0])
        stroke (first (get finished :strokes))
        resized (draw-set-brush-size! finished 6)
        resized-stroke (first (get resized :strokes))]
    (draw-tools-assert-num= "finished stroke keeps full point history"
                            3
                            (count (get stroke :points)))
    (draw-tools-assert-num= "brush change keeps stroke point history"
                            3
                            (count (get resized-stroke :points))))

  (let [box-tool (draw-set-tool-core! (default-state) :box)
        started (draw-start-box box-tool
                                [10.0 20.0 1.0]
                                [10.0 20.0])
        extended (draw-extend-box started
                                  [40.0 70.0 1.0]
                                  [40.0 70.0])
        finished (draw-finish-box extended
                                  [40.0 70.0 1.0]
                                  [40.0 70.0])
        finished-snapshot (edn/read-string (pr-str finished))
        element (first (get finished-snapshot :elements))
        undone (draw-undo-stroke! finished)]
    (draw-tools-assert-str= "finished rectangle switches tool mode stays rectangle"
                            "rectangle"
                            (draw-tool-mode finished-snapshot))
    (draw-tools-assert-num= "box finish adds element"
                            1
                            (count (get finished-snapshot :elements)))
    (draw-tools-assert-str= "box finish element kind"
                            ":box"
                            (pr-str (get element :kind)))
    (draw-tools-assert-num= "box finish width"
                            30.0
                            (get element :width))
    (draw-tools-assert-num= "box finish height"
                            50.0
                            (get element :height))
    (draw-tools-assert-num= "box finish does not add stroke view"
                            0
                            (count (get finished-snapshot :strokes)))
    (draw-tools-assert-num= "undo removes box element"
                            0
                            (count (get undone :elements))))

  (let [arrow-tool (draw-set-tool-core! (default-state) :arrow)
        started (draw-start-arrow arrow-tool
                                  [10.0 20.0 1.0]
                                  [10.0 20.0])
        extended (draw-extend-arrow started
                                    [50.0 70.0 1.0]
                                    [50.0 70.0])
        finished (draw-finish-arrow extended
                                    [50.0 70.0 1.0]
                                    [50.0 70.0])
        finished-snapshot (edn/read-string (pr-str finished))
        element (first (get finished-snapshot :elements))
        undone (draw-undo-stroke! finished)]
    (draw-tools-assert-str= "finished arrow keeps tool mode"
                            "arrow"
                            (draw-tool-mode finished-snapshot))
    (draw-tools-assert-num= "arrow finish adds element"
                            1
                            (count (get finished-snapshot :elements)))
    (draw-tools-assert-str= "arrow finish element kind"
                            ":arrow"
                            (pr-str (get element :kind)))
    (draw-tools-assert-str= "arrow finish start point"
                            "[10.0 20.0 1.0]"
                            (pr-str (get element :start)))
    (draw-tools-assert-str= "arrow finish end point"
                            "[50.0 70.0 1.0]"
                            (pr-str (get element :end)))
    (draw-tools-assert-num= "undo removes arrow element"
                            0
                            (count (get undone :elements))))

  (let [frame-tool (draw-set-tool-core! (default-state) :frame)
        started (draw-start-frame frame-tool
                                  [10.0 20.0 1.0]
                                  [10.0 20.0])
        extended (draw-extend-frame started
                                    [60.0 90.0 1.0]
                                    [60.0 90.0])
        finished (draw-finish-frame extended
                                    [60.0 90.0 1.0]
                                    [60.0 90.0])
        finished-snapshot (edn/read-string (pr-str finished))
        element (first (get finished-snapshot :elements))
        undone (draw-undo-stroke! finished)]
    (draw-tools-assert-str= "finished frame keeps tool mode"
                            "frame"
                            (draw-tool-mode finished-snapshot))
    (draw-tools-assert-num= "frame finish adds element"
                            1
                            (count (get finished-snapshot :elements)))
    (draw-tools-assert-str= "frame finish element kind"
                            ":frame"
                            (pr-str (get element :kind)))
    (draw-tools-assert-num= "frame finish width"
                            50.0
                            (get element :width))
    (draw-tools-assert-num= "frame finish height"
                            70.0
                            (get element :height))
    (draw-tools-assert-num= "undo removes frame element"
                            0
                            (count (get undone :elements))))

  (let [text-tool (draw-set-tool-core! (default-state) :text)
        started (draw-start-text text-tool
                                 [25.0 35.0 1.0]
                                 [25.0 35.0])
        extended (draw-extend-text started
                                   [40.0 55.0 1.0]
                                   [40.0 55.0])
        finished (draw-finish-text extended
                                   [40.0 55.0 1.0]
                                   [40.0 55.0])
        finished-snapshot (edn/read-string (pr-str finished))
        element (first (get finished-snapshot :elements))
        undone (draw-undo-stroke! finished)]
    (draw-tools-assert-str= "finished text keeps tool mode"
                            "text"
                            (draw-tool-mode finished-snapshot))
    (draw-tools-assert-num= "text finish adds element"
                            1
                            (count (get finished-snapshot :elements)))
    (draw-tools-assert-str= "text finish element kind"
                            ":text"
                            (pr-str (get element :kind)))
    (draw-tools-assert-num= "text finish x"
                            40.0
                            (get element :x))
    (draw-tools-assert-num= "text finish y"
                            55.0
                            (get element :y))
    (draw-tools-assert-str= "text finish default label"
                            "Text"
                            (get element :text))
    (draw-tools-assert-num= "undo removes text element"
                            0
                            (count (get undone :elements))))

  (let [base (draw-sync-elements
               (draw-set-tool-core! (default-state) :select)
               [{:kind :box
                 :x 10.0
                 :y 20.0
                 :width 30.0
                 :height 40.0
                 :color [255 255 255]
                 :size 2}
                {:kind :ink
                 :points [[100.0 100.0 1.0] [120.0 100.0 1.0]]
                 :color [255 255 255]
                 :size 2}])
        box-drag (draw-start-selection-drag base
                                            [15.0 25.0 1.0]
                                            [15.0 25.0]
                                            :mouse)
        moved (draw-extend-selection-drag box-drag
                                          [25.0 35.0 1.0]
                                          [25.0 35.0])
        finished (draw-finish-selection-drag moved
                                             [25.0 35.0 1.0]
                                             [25.0 35.0])
        finished-snapshot (edn/read-string (pr-str finished))
        moved-box (first (get finished-snapshot :elements))
        undone (draw-undo-stroke! finished)
        restored-box (first (get undone :elements))
        ink-hit (draw-start-selection-drag base
                                           [110.0 100.0 1.0]
                                           [110.0 100.0]
                                           :mouse)]
    (draw-tools-assert-num= "selection picks one box"
                            1
                            (count (draw-selected-element-ids box-drag)))
    (draw-tools-assert-num= "selection drag moves box x"
                            20.0
                            (get moved-box :x))
    (draw-tools-assert-num= "selection drag moves box y"
                            30.0
                            (get moved-box :y))
    (draw-tools-assert-false "selection drag clears active drag on finish"
                             (get finished-snapshot :active-selection-drag))
    (draw-tools-assert-num= "undo restores moved box x"
                            10.0
                            (get restored-box :x))
    (draw-tools-assert-num= "selection can hit ink elements"
                            1
                            (count (draw-selected-element-ids ink-hit))))

  (let [base (draw-sync-elements
               (draw-set-tool-core! (default-state) :select)
               [{:kind :arrow
                 :start [10.0 20.0 1.0]
                 :end [40.0 60.0 1.0]
                 :color [255 255 255]
                 :size 2}])
        selected (draw-start-selection-drag base
                                            [15.0 25.0 1.0]
                                            [15.0 25.0]
                                            :mouse)
        moved (draw-extend-selection-drag selected
                                          [25.0 35.0 1.0]
                                          [25.0 35.0])
        finished (draw-finish-selection-drag moved
                                             [25.0 35.0 1.0]
                                             [25.0 35.0])
        moved-arrow (first (get finished :elements))]
    (draw-tools-assert-num= "selection can hit arrow elements"
                            1
                            (count (draw-selected-element-ids selected)))
    (draw-tools-assert-str= "selection drag moves arrow start"
                            "[20.0 30.0 1.0]"
                            (pr-str (get moved-arrow :start)))
    (draw-tools-assert-str= "selection drag moves arrow end"
                            "[50.0 70.0 1.0]"
                            (pr-str (get moved-arrow :end))))

  (let [base (draw-sync-elements
               (draw-set-tool-core! (default-state) :select)
               [{:kind :frame
                 :x 10.0
                 :y 20.0
                 :width 30.0
                 :height 40.0
                 :color [255 255 255]
                 :size 2}])
        selected (draw-start-selection-drag base
                                            [15.0 25.0 1.0]
                                            [15.0 25.0]
                                            :mouse)
        moved (draw-extend-selection-drag selected
                                          [25.0 35.0 1.0]
                                          [25.0 35.0])
        finished (draw-finish-selection-drag moved
                                             [25.0 35.0 1.0]
                                             [25.0 35.0])
        moved-frame (first (get finished :elements))]
    (draw-tools-assert-num= "selection can hit frame elements"
                            1
                            (count (draw-selected-element-ids selected)))
    (draw-tools-assert-num= "selection drag moves frame x"
                            20.0
                            (get moved-frame :x))
    (draw-tools-assert-num= "selection drag moves frame y"
                            30.0
                            (get moved-frame :y)))

  (let [base (draw-sync-elements
               (draw-set-tool-core! (default-state) :select)
               [{:kind :box
                 :x 10.0
                 :y 20.0
                 :width 30.0
                 :height 40.0
                 :color [255 255 255]
                 :size 2}
                {:kind :box
                 :x 70.0
                 :y 90.0
                 :width 20.0
                 :height 30.0
                 :color [255 255 255]
                 :size 2}])
        first (draw-start-selection-interaction base
                                                [15.0 25.0 1.0]
                                                [15.0 25.0]
                                                :mouse
                                                false)
        second (draw-start-selection-interaction first
                                                 [75.0 95.0 1.0]
                                                 [75.0 95.0]
                                                 :mouse
                                                 true)
        moved (draw-extend-selection-drag second
                                          [85.0 105.0 1.0]
                                          [85.0 105.0])
        finished (draw-finish-selection-drag moved
                                             [85.0 105.0 1.0]
                                             [85.0 105.0])
        elements (get finished :elements)
        moved-first (nth elements 0)
        moved-second (nth elements 1)]
    (draw-tools-assert-num= "shift selection adds second element"
                            2
                            (count (draw-selected-element-ids second)))
    (draw-tools-assert-num= "multi-select drag moves first box x"
                            20.0
                            (get moved-first :x))
    (draw-tools-assert-num= "multi-select drag moves first box y"
                            30.0
                            (get moved-first :y))
    (draw-tools-assert-num= "multi-select drag moves second box x"
                            80.0
                            (get moved-second :x))
    (draw-tools-assert-num= "multi-select drag moves second box y"
                            100.0
                            (get moved-second :y)))

  (let [base (draw-sync-elements
               (draw-set-tool-core! (default-state) :select)
               [{:kind :text
                 :x 20.0
                 :y 30.0
                 :text "Text"
                 :color [255 255 255]
                 :size 2}])
        selected (draw-start-selection-drag base
                                            [22.0 32.0 1.0]
                                            [22.0 32.0]
                                            :mouse)
        moved (draw-extend-selection-drag selected
                                          [42.0 52.0 1.0]
                                          [42.0 52.0])
        finished (draw-finish-selection-drag moved
                                             [42.0 52.0 1.0]
                                             [42.0 52.0])
        moved-text (first (get finished :elements))]
    (draw-tools-assert-num= "selection can hit text elements"
                            1
                            (count (draw-selected-element-ids selected)))
    (draw-tools-assert-num= "selection drag moves text x"
                            40.0
                            (get moved-text :x))
    (draw-tools-assert-num= "selection drag moves text y"
                            50.0
                            (get moved-text :y)))

  (let [stroke (draw-stroke-record [[10.0 10.0 1.0]]
                                   [255 255 255]
                                   6)
        points (draw-append-stroke-point (default-state)
                                         stroke
                                         [11.0 10.0 1.0])]
    (draw-tools-assert-num= "close active sample is ignored"
                            1
                            (count points))
    (draw-tools-assert-str= "close active sample keeps prior point"
                            "[10.0 10.0 1.0]"
                            (pr-str (first points))))

  (let [stroke (draw-stroke-record [[10.0 10.0 1.0]
                                    [20.0 10.0 1.0]]
                                   [255 255 255]
                                   6)
        points (draw-append-stroke-point (default-state)
                                         stroke
                                         [21.0 10.0 1.0])]
    (draw-tools-assert-num= "close trailing sample keeps point count stable"
                            2
                            (count points))
    (draw-tools-assert-str= "close trailing sample keeps committed endpoint"
                            "[20.0 10.0 1.0]"
                            (pr-str (last points))))

  (let [stroke (draw-stroke-record [[10.0 10.0 1.0]]
                                   [255 255 255]
                                   6)
        points (draw-append-stroke-point (default-state)
                                         stroke
                                         [20.0 10.0 1.0])]
    (draw-tools-assert-num= "distant active sample appends"
                            2
                            (count points)))

  (let [original-segment sdl/render-soft-segment!
        original-brush-ready draw-brush-texture-ready?
        original-strip-ready draw-strip-texture-ready?
        original-brush draw-brush-texture
        original-strip draw-strip-texture
        calls []]
    (set! draw-brush-texture-ready?
          (fn []
            true))
    (set! draw-strip-texture-ready?
          (fn []
            true))
    (set! draw-brush-texture
          (fn []
            'brush))
    (set! draw-strip-texture
          (fn []
            'strip))
    (set! sdl/render-soft-segment!
          (fn [renderer strip brush x1 y1 size1 alpha1 x2 y2 size2 alpha2 r g b]
            (set! calls (conj calls [strip brush x1 y1 size1 alpha1 x2 y2 size2 alpha2 r g b]))
            true))
    (draw-render-stroke-segments! 'renderer
                                  (default-state)
                                  [[10 10 0.25] [20 20 0.75] [30 30 1.0]]
                                  2)
    (draw-tools-assert-num= "stroke segment renderer call count"
                            2
                            (count calls))
    (draw-tools-assert-str= "stroke segment renderer uses cached strip"
                            "strip"
                            (str (nth (first calls) 0)))
    (draw-tools-assert-true "stroke segment renderer reflects growing pressure"
                            (< (nth (first calls) 5)
                               (nth (last calls) 9)))
    (set! sdl/render-soft-segment! original-segment)
    (set! draw-brush-texture-ready? original-brush-ready)
    (set! draw-strip-texture-ready? original-strip-ready)
    (set! draw-brush-texture original-brush)
    (set! draw-strip-texture original-strip)))

(let [original-ready draw-brush-texture-ready?
      original-brush draw-brush-texture
      original-color sdl/set-texture-color-mod!
      original-alpha sdl/set-texture-alpha-mod!
      original-render sdl/render-texture-at!
      color-calls []
      alpha-calls []
      render-calls []]
  (set! draw-brush-texture-ready?
        (lambda ()
          true))
  (set! draw-brush-texture
        (lambda ()
          'brush))
  (set! sdl/set-texture-color-mod!
        (lambda (texture r g b)
          (set! color-calls (conj color-calls [texture r g b]))
          true))
  (set! sdl/set-texture-alpha-mod!
        (lambda (texture alpha)
          (set! alpha-calls (conj alpha-calls [texture alpha]))
          true))
  (set! sdl/render-texture-at!
        (lambda (renderer texture x y w h)
          (set! render-calls (conj render-calls [texture x y w h]))
          true))
  (draw-with-stroke-color [120 160 200]
    (lambda ()
      (draw-render-soft-brush! 'renderer
                               (default-state)
                               [20 24 0.5]
                               6)))
  (draw-tools-assert-num= "soft brush color mod count"
                          1
                          (count color-calls))
  (draw-tools-assert-num= "soft brush alpha mod count"
                          1
                          (count alpha-calls))
  (draw-tools-assert-num= "soft brush render count"
                          1
                          (count render-calls))
  (draw-tools-assert-str= "soft brush color mod value"
                          "[brush 120 160 200]"
                          (pr-str (first color-calls)))
  (draw-tools-assert-true "soft brush render has positive size"
                          (> (nth (first render-calls) 3) 0))
  (set! draw-brush-texture-ready? original-ready)
  (set! draw-brush-texture original-brush)
  (set! sdl/set-texture-color-mod! original-color)
  (set! sdl/set-texture-alpha-mod! original-alpha)
  (set! sdl/render-texture-at! original-render))
