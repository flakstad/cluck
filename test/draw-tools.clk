;; Focused draw-tools probe for the SDL3 example.

(in-ns 'cluck.examples.draw)

(define (draw-tools-pass label)
  (println "ok" label)
  true)

(define (draw-tools-fail label expected actual)
  (error (string-append "draw tools test failed: "
                        label
                        " expected "
                        (str expected)
                        " got "
                        (str actual))))

(define (draw-tools-assert-true label value)
  (if value
      (draw-tools-pass label)
      (draw-tools-fail label "truthy value" (pr-str value))))

(define (draw-tools-assert-str= label expected actual)
  (if (string=? expected actual)
      (draw-tools-pass label)
      (draw-tools-fail label expected actual)))

(draw-tools-assert-true "describe-state includes tool"
                        (str/includes? (describe-state (default-state)) "tool brush"))
(draw-tools-assert-true "describe-state includes size"
                        (str/includes? (describe-state (default-state)) "size 2"))

(let [state {:title "Cluck Draw"
             :width 1280
             :height 720
             :background [24 24 28]
             :brush-color [245 245 245]
             :brush-size 2
             :eraser? false
             :running? true
             :frame 0
             :mouse-x 0
             :mouse-y 0
             :pointer-down? false
             :debug-panel? false
             :strokes [[1 2]]
             :active-stroke {:points [[1 2]]
                             :color [245 245 245]
                             :size 2}
             :last-key ""
             :last-text ""
             :last-event ""
             :recent-events []}
      finished-state (assoc (default-state)
                            :strokes [[1 2] [3 4]]
                            :pointer-down? false)]
  (let [cleared (draw-clear-strokes! state)]
    (draw-tools-assert-true "clear strokes"
                            (and (empty? (get cleared :strokes))
                                 (not (get cleared :active-stroke))
                                 (not (get cleared :pointer-down?)))))
  (let [cleared-by-key (draw-handle-tool-key! state "c")]
    (draw-tools-assert-true "clear key dispatch"
                            (and (empty? (get cleared-by-key :strokes))
                                 (not (get cleared-by-key :active-stroke))
                                 (not (get cleared-by-key :pointer-down?)))))
  (let [undone-active (draw-undo-stroke! state)]
    (draw-tools-assert-true "undo active clears active"
                            (and (not (get undone-active :active-stroke))
                                 (not (get undone-active :pointer-down?)))))
  (let [undone (draw-undo-stroke! finished-state)]
    (draw-tools-assert-str= "undo finished stroke count"
                            "1"
                            (str (count (get undone :strokes)))))
  (let [tool-state (draw-handle-tool-key! (default-state) "e")]
    (draw-tools-assert-true "toggle eraser"
                            (get tool-state :eraser?))
    (draw-tools-assert-str= "eraser color"
                            "[24 24 28]"
                            (pr-str (draw-stroke-color tool-state))))
  (let [undo-by-key (draw-handle-tool-key! (assoc (default-state)
                                                  :strokes [[1 2] [3 4]]
                                                  :pointer-down? false)
                                       "u")]
    (draw-tools-assert-str= "undo key dispatch"
                            "1"
                            (str (count (get undo-by-key :strokes)))))
  (let [size-state (draw-handle-tool-key! (default-state) "3")]
    (draw-tools-assert-str= "brush size preset"
                            "12"
                            (str (get size-state :brush-size)))))
