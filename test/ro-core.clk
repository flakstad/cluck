(assert-plan-case-table
 "core remaining planner"
 (list
  {:label "comments add help"
   :plan-fn ro-comments-comments-main-plan
   :args '("add" "--help")
   :expected "{:ok? true, :effects [[:comments/help {}]]}"}
  {:label "events help"
   :plan-fn ro-events-events-main-plan
   :args '()
   :expected "{:ok? true, :effects [[:events/help {}]]}"}
  {:label "events list"
   :plan-fn ro-events-events-main-plan
   :args '("list")
   :expected "{:ok? true, :effects [[:events/list {:limit 200}]]}"}
  {:label "events list help"
   :plan-fn ro-events-events-main-plan
   :args '("list" "--help")
   :expected "{:ok? true, :effects [[:events/unsupported-flag {}]]}"}
  {:label "events list missing limit"
   :plan-fn ro-events-events-main-plan
   :args '("list" "--limit")
   :expected "{:ok? false, :error \"ro events list expects a value after --limit\", :command (\"list\" \"--limit\")}"}
  {:label "reindex run"
   :plan-fn ro-reindex-reindex-main-plan
   :args '()
   :expected "{:ok? true, :effects [[:reindex/run {}]]}"}
  {:label "reindex help"
   :plan-fn ro-reindex-reindex-main-plan
   :args '("--help")
   :expected "{:ok? true, :effects [[:reindex/help {}]]}"}
  {:label "reindex error"
   :plan-fn ro-reindex-reindex-main-plan
   :args '("bogus")
   :expected "{:ok? false, :error \"unexpected reindex argument\", :command (\"bogus\")}"}
  {:label "sync help"
   :plan-fn ro-sync-sync-main-plan
   :args '()
   :expected "{:ok? true, :effects [[:sync/help {}]]}"}
  {:label "sync status"
   :plan-fn ro-sync-sync-main-plan
   :args '("status")
   :expected "{:ok? true, :effects [[:sync/status {}]]}"}
  {:label "sync status help"
   :plan-fn ro-sync-sync-main-plan
   :args '("status" "--help")
   :expected "{:ok? true, :effects [[:sync/status {}]]}"}
  {:label "sync remotes"
   :plan-fn ro-sync-sync-main-plan
   :args '("remotes")
   :expected "{:ok? true, :effects [[:sync/remotes {}]]}"}
  {:label "sync remotes help"
   :plan-fn ro-sync-sync-main-plan
   :args '("remotes" "--help")
   :expected "{:ok? true, :effects [[:sync/remotes {}]]}"}
  {:label "sync reindex help"
   :plan-fn ro-sync-sync-main-plan
   :args '("reindex" "--help")
   :expected "{:ok? true, :effects [[:sync/reindex {}]]}"}
  {:label "sync unsupported"
   :plan-fn ro-sync-sync-main-plan
   :args '("pull")
   :expected "{:ok? false, :error \"unsupported sync subcommand\", :command (\"pull\")}"}
  {:label "doctor report"
   :plan-fn ro-doctor-doctor-main-plan
   :args '()
   :expected "{:ok? true, :effects [[:doctor/run {:kind :report, :fail? false, :write? false, :force? false}]]}"}
  {:label "doctor help"
   :plan-fn ro-doctor-doctor-main-plan
   :args '("--help")
   :expected "{:ok? true, :effects [[:doctor/help {}]]}"}
  {:label "doctor summary"
   :plan-fn ro-doctor-doctor-main-plan
   :args '("summary" "--fail")
   :expected "{:ok? true, :effects [[:doctor/run {:kind :summary, :fail? true, :write? false, :force? false}]]}"}
  {:label "doctor summary flag"
   :plan-fn ro-doctor-doctor-main-plan
   :args '("--summary" "--fail")
   :expected "{:ok? true, :effects [[:doctor/run {:kind :summary, :fail? true, :write? false, :force? false}]]}"}
  {:label "doctor dedupe"
   :plan-fn ro-doctor-doctor-main-plan
   :args '("dedupe" "--write" "--force")
   :expected "{:ok? true, :effects [[:doctor/run {:kind :dedupe, :fail? false, :write? true, :force? true}]]}"}))

(assert-plan-pr-str=
 "core doctor runtime dry-run refusal"
 "{:ok? false, :error \"refusing to rewrite canonical event logs without --force\"}"
 (ro-doctor-doctor-runtime-plan {:kind :dedupe
                                 :fail? false
                                 :write? true
                                 :force? false}
                                '()))
