(define docs-output-data
  (output-data ro-help-docs-output))
(define docs-topics
  (ro-json-json-field-value docs-output-data "topics" '()))

(assert-num= "core docs topic count"
             8
             (count docs-topics))
(assert-str= "core docs first topic"
             "cli"
             (first-entry docs-topics))
(assert-str= "core docs cli markdown"
             "# Ro CLI (ro)\n\n`ro` is the primary CLI entrypoint.\n\n- `ro status` prints workspace counts and the selected actor.\n- `ro items ready` finds the next actionable items.\n- `ro <item-id>` is shorthand for `ro items show <item-id>`.\n- `ro docs <topic>` prints long-form docs for the CLI surface.\n\nUse `--format json|edn` to control output, and `--pretty` for human-readable JSON."
             (ro-docs-docs-topic-markdown "cli"))
(define docs-topic-output-data
  (output-data (ro-docs-docs-topic-output "output-contract")))
(assert-str= "core docs topic output topic"
             "output-contract"
             (ro-json-json-field-value docs-topic-output-data "topic" ""))
(assert-str= "core docs topic output markdown"
             "# Output contract\n\nMost commands return a stable envelope with a `data` field.\n\n- Default format: JSON\n- Alternate format: EDN via `--format edn`\n- `--pretty` pretty-prints JSON for human inspection\n- Commands may add `_hints` with suggested next steps"
             (ro-json-json-field-value docs-topic-output-data "markdown" ""))

