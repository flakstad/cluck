(def sample-event-line
  "{\"eventId\":\"evt-1\",\"workspaceId\":\"ws-1\",\"replicaId\":\"rep-1\",\"entityKind\":\"item\",\"entityId\":\"item-1\",\"entitySeq\":2,\"type\":\"item.create\",\"parents\":[\"parent-1\"],\"issuedAt\":\"2026-01-02T03:04:05Z\",\"actorId\":\"act-1\",\"payload\":{\"title\":\"Hello world\"},\"localStatus\":\"local\",\"serverStatus\":\"pending\",\"rejectionReason\":\"\",\"publishedAtUnixms\":123,\"hasPublishedAt\":true}")

