(assert-true "core help request empty args" (ro-help-help-request? '()))
(assert-true "core help request help" (ro-help-help-request? '("help")))
(assert-true "core help request --help" (ro-help-help-request? '("--help")))
(assert-true "core help request -h" (ro-help-help-request? '("-h")))
(assert-true "core help request rejects item commands"
             (not (ro-help-help-request? '("items"))))
(define parsed-angle-args
  (ro-cli-cmdspec-parse-arg-names "create <item-id> <name>"))
(assert-json= "core cli cmdspec parse angle flags"
              '("create")
              (first parsed-angle-args))
(assert-str= "core cli cmdspec parse angle argdoc"
             " <item-id> <name>"
             (first (rest parsed-angle-args)))
(assert-str= "core cli cmdspec parse angle first argname"
             "item-id"
             (name (first (first (rest (rest parsed-angle-args))))))
(assert-str= "core cli cmdspec parse angle second argname"
             "name"
             (name (first (rest (first (rest (rest parsed-angle-args)))))))
(define parsed-upper-args
  (ro-cli-cmdspec-parse-arg-names "--input, -i FILE"))
(assert-json= "core cli cmdspec parse upper flags"
              '("--input" "-i")
              (first parsed-upper-args))
(assert-str= "core cli cmdspec parse upper argdoc"
             " FILE"
             (first (rest parsed-upper-args)))
(assert-str= "core cli cmdspec parse upper argname"
             "file"
             (name (first (first (rest (rest parsed-upper-args))))))
(define prepared-cmdpairs
  (ro-cli-cmdspec-prepare-cmdpairs
   ["docs" {:kind 'docs}
    "show ITEM-ID" {:kind 'show}]))
(assert-str= "core cli cmdspec prepare first name"
             "docs"
             (first (first prepared-cmdpairs)))
(assert-str= "core cli cmdspec prepare first kind"
             "docs"
             (symbol->string (:kind (first (rest (first prepared-cmdpairs))))))
(assert-str= "core cli cmdspec prepare second name"
             "show"
             (first (first (rest prepared-cmdpairs))))
(assert-str= "core cli cmdspec prepare second argdoc"
             " ITEM-ID"
             (:argdoc (first (rest (first (rest prepared-cmdpairs))))))
(assert-str= "core cli cmdspec prepare second argname"
             "item-id"
             (name (first (:argnames (first (rest (first (rest prepared-cmdpairs))))))))
(define parsed-verbose-flag
  (ro-cli-parse-flagstr "-v, --verbose" {:doc "Verbose"}))
(assert-str= "core cli flag parse key"
             "verbose"
             (name (:key parsed-verbose-flag)))
(assert-num= "core cli flag parse argcnt"
             0
             (:argcnt parsed-verbose-flag))
(assert-json= "core cli flag parse flags"
              '("-v" "--verbose")
              (:flags parsed-verbose-flag))
(define parsed-input-flag
  (ro-cli-parse-flagstr "--input FILE" {:doc "Input"}))
(assert-str= "core cli flag parse argdoc"
             " FILE"
             (:argdoc parsed-input-flag))
(assert-str= "core cli flag parse argname"
             "file"
             (name (first (:args parsed-input-flag))))
(assert-num= "core cli prepare flagpairs count"
             2
             (count (ro-cli-prepare-flagpairs
                     ["-v, --verbose" {:doc "Verbose"}
                      "--input FILE" {:doc "Input"}])))
(define parsed-flagmap
  (ro-cli-parse-flagstrs
   (ro-cli-prepare-flagpairs
    ["-v, --verbose" {:doc "Verbose"}
     "--input FILE" {:doc "Input"}])))
(assert-true "core cli flagmap has help short"
             (not (equal? #f (alist-get parsed-flagmap "-h"))))
(assert-true "core cli flagmap has help long"
             (not (equal? #f (alist-get parsed-flagmap "--help"))))
(assert-str= "core cli flagmap verbose key"
             "verbose"
             (name (:key (cdr (alist-get parsed-flagmap "--verbose")))))
(assert-str= "core cli flagmap input key"
             "input"
             (name (:key (cdr (alist-get parsed-flagmap "--input")))))
(assert-str= "core cli ro spec first prepared command"
             "help"
             (first (first (ro-cli-cmdspec-prepare-cmdpairs (:commands ro-cli-ro-root-command-spec)))))
(assert-json= "core cli completion candidates top level"
              '("agenda" "agent" "attachments")
              (take 3 (ro-cli-shell-completion-candidates '())))
(assert-json= "core cli completion candidates docs"
              '("cli" "getting-started" "output-contract")
              (take 3 (ro-cli-shell-completion-candidates '("docs" ""))))
(assert-str= "core cli dispatch help kind"
             "help"
             (symbol->string (first (ro-cli-dispatch-top-level '("--help")))))
(assert-str= "core cli dispatch docs kind"
             "docs"
             (symbol->string (first (ro-cli-dispatch-top-level '("docs" "cli")))))
(assert-str= "core cli dispatch item kind"
             "item"
             (symbol->string (first (ro-cli-dispatch-top-level '("item-123")))))
(assert-str= "core cli dispatch error kind"
             "error"
             (symbol->string (first (ro-cli-dispatch-top-level '("--unknown")))))
(define prepared-cli-sample
  (ro-cli-prepare-command-spec
   {:name "sample"
    :commands ["show ITEM-ID" {:kind 'show}
               "list" {:kind 'list}]
    :usage-lines ["sample show <item-id>"
                  "sample list"]}))
(define prepared-workspace-spec
  (ro-cli-top-level-command-spec "workspace"))
(define dispatched-workspace-add
  (ro-cli-dispatch prepared-workspace-spec
                   '("add" "alpha" "--dir" "/tmp/alpha" "--use")))
(define dispatched-workspace-add-missing-dir
  (ro-cli-dispatch prepared-workspace-spec
                   '("add" "alpha")))
(define dispatched-workspace-help
  (ro-cli-dispatch prepared-workspace-spec
                   '("add" "--help")))
(define dispatched-docs-topic
  (ro-cli-dispatch (ro-cli-top-level-command-spec "docs")
                   '("getting-started" "--raw")))
(define dispatched-docs-error
  (ro-cli-dispatch (ro-cli-top-level-command-spec "docs")
                   '("getting-started" "--bogus")))
(define dispatched-events-limit
  (ro-cli-dispatch (ro-cli-top-level-command-spec "events")
                   '("list" "--limit" "5")))
(define dispatched-events-limit-invalid
  (ro-cli-dispatch (ro-cli-top-level-command-spec "events")
                   '("list" "--limit" "bogus")))
(define dispatched-doctor-summary-default
  (ro-cli-dispatch (ro-cli-top-level-command-spec "doctor")
                   '("--summary" "--fail")))
(assert-str= "core cli prepared sample first command"
             "show"
             (first (first (:commands prepared-cli-sample))))
(assert-str= "core cli prepared workspace child name"
             "add"
             (:name (:spec dispatched-workspace-add)))
(assert-str= "core cli prepared workspace add arg"
             "alpha"
             (get (:arguments dispatched-workspace-add) :name ""))
(assert-str= "core cli prepared workspace add dir"
             "/tmp/alpha"
             (get (:flags dispatched-workspace-add) :dir ""))
(assert-true "core cli prepared workspace add use"
             (get (:flags dispatched-workspace-add) :use false))
(assert-str= "core cli prepared workspace missing dir status"
             "error"
             (name (:status dispatched-workspace-add-missing-dir)))
(assert-str= "core cli prepared workspace missing dir reason"
             "missing-required-flag"
             (name (:reason dispatched-workspace-add-missing-dir)))
(assert-str= "core cli prepared workspace help status"
             "help"
             (name (:status dispatched-workspace-help)))
(assert-str= "core cli prepared docs status"
             "ok"
             (name (:status dispatched-docs-topic)))
(assert-str= "core cli prepared docs topic"
             "getting-started"
             (first (:positionals dispatched-docs-topic)))
(assert-true "core cli prepared docs raw"
             (get (:flags dispatched-docs-topic) :raw false))
(assert-str= "core cli prepared docs error status"
             "error"
             (name (:status dispatched-docs-error)))
(assert-str= "core cli prepared docs error reason"
             "unknown-flag"
             (name (:reason dispatched-docs-error)))
(assert-str= "core cli prepared events parsed limit status"
             "ok"
             (name (:status dispatched-events-limit)))
(assert-num= "core cli prepared events parsed limit"
             5
             (get (:flags dispatched-events-limit) :limit 0))
(assert-str= "core cli prepared events invalid limit status"
             "error"
             (name (:status dispatched-events-limit-invalid)))
(assert-str= "core cli prepared events invalid limit reason"
             "invalid-flag-value"
             (name (:reason dispatched-events-limit-invalid)))
(assert-str= "core cli prepared doctor default summary status"
             "ok"
             (name (:status dispatched-doctor-summary-default)))
(assert-str= "core cli prepared doctor default summary spec"
             "doctor"
             (:name (:spec dispatched-doctor-summary-default)))
(assert-true "core cli prepared doctor default summary flag"
             (get (:flags dispatched-doctor-summary-default) :summary false))
(assert-json= "core cli generic render workspace add help"
              '("ro add"
                ""
                "usage:"
                "  ro workspace add <name> --dir <path> [--kind git] [--use]")
              (ro-cli-render-command-help (:spec dispatched-workspace-help)))
(assert-json= "core cli generic completion workspace root"
              '("add" "archive" "current" "delete" "export" "forget" "import" "init" "list" "migrate" "rename" "unarchive" "use")
              (ro-cli-completion-candidates prepared-workspace-spec '()))
(assert-json= "core cli generic completion docs topics"
              '("cli" "getting-started" "output-contract")
              (take 3 (ro-cli-completion-candidates ro-cli-prepared-root-command-spec
                                                    '("docs" ""))))
(define docs-command-spec
  (ro-cli-command-spec-for-name "docs"))
(assert-str= "core cli spec docs kind"
             "docs"
             (symbol->string (get docs-command-spec :kind)))
(assert-json= "core cli spec help lines docs"
              '("  ro docs"
                "  ro docs <topic>"
                "  ro docs <topic> --raw")
              (ro-cli-command-spec-help-lines docs-command-spec))
(assert-json= "core cli command help lines sync"
              '("ro sync"
                ""
                "usage:"
                "  ro sync status"
                "  ro sync remotes"
                "  ro sync setup [--remote-url <url>] [--remote-name <name>] [--commit] [--push] [--message <msg>]"
                "  ro sync pull"
                "  ro sync reindex"
                "  ro sync push [--message <msg>] [--pull=false]"
                "  ro sync resolve")
              (ro-cli-command-help-lines "sync"))
(assert-str= "core cli root help first"
             "  ro help                   # show this help"
             (first (ro-cli-root-help-command-lines)))
(assert-str= "core cli top command first"
             "agenda"
             (first (ro-cli-top-command-names)))
(assert-str= "core cli completion command line starts agent"
             "agenda"
             (first (str/split (ro-cli-completion-command-line) " ")))
(assert-true "core cli docs topics line contains sync"
             (not (equal? #f (member "sync" (str/split (ro-cli-docs-topics-line) " ")))))
(assert-true "core command registry knows help"
             (ro-commands-command-known? "help"))
(assert-true "core command registry knows tasks"
             (ro-commands-command-known? "tasks"))
