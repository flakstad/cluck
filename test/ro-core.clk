(defn parse-output
  [output]
  (json/json-read (open-input-string output)))

(defn output-data
  [output]
  (ro-json-json-field-value (parse-output output) "data" '()))

(defn first-entry
  [value]
  (cond
    (vector? value) (vector-ref value 0)
    (pair? value) (car (seq value))
    :else value))

(def sample-detail
  (vector (cons 'name "alpha")
          (cons 'path "/tmp/alpha")))

(def sample-workspace-root
  (vector
   (cons 'data
         (vector (cons 'currentWorkspace "alpha")))
   (cons 'meta
         (vector (cons 'details
                       (vector sample-detail))))))

(def sample-agent
  (vector (cons 'id "actor-1")
          (cons 'name "Agent One")
          (cons 'kind "agent")
          (cons 'userId "human-1")
          (cons 'session "sess-1")))

(def sample-human
  (vector (cons 'id "human-1")
          (cons 'name "Human One")
          (cons 'kind "human")
          (cons 'userId "")
          (cons 'session "")))

(def sample-actors
  (list sample-agent sample-human))

(def sample-project
  (vector (cons 'id "proj-1")
          (cons 'name "Project One")
          (cons 'description "The project")
          (cons 'archived #f)
          (cons 'updatedAtUnixms 123)))

(def sample-project-alpha
  (vector (cons 'id "proj-0")
          (cons 'name "Annet")
          (cons 'description "")
          (cons 'archived #f)
          (cons 'updatedAtUnixms 122)))

(def sample-item-show
  (vector (cons 'id "item-1")
          (cons 'projectId "proj-1")
          (cons 'outlineId "out-1")
          (cons 'parentId "parent-1")
          (cons 'status "doing")
          (cons 'title "Item One")
          (cons 'description "The item")
          (cons 'priority false)
          (cons 'onHold false)
          (cons 'assignedActorId "act-1")
          (cons 'dueDate "")
          (cons 'scheduleDate "")
          (cons 'tags (vector "tag-1"))
          (cons 'itemKind "")
          (cons 'childrenKind "")
          (cons 'commentsCount 2)
          (cons 'worklogCount 15)
          (cons 'hasChildren true)
          (cons 'rank "000123")
          (cons 'ownerActorId "act-owner")
          (cons 'createdBy "act-created")
          (cons 'createdAt "2026-04-10T00:00:00Z")
          (cons 'updatedAt "2026-04-10T01:00:00Z")))

(assert-true "core help request empty args" (ro-help-help-request? '()))
(assert-true "core help request help" (ro-help-help-request? '("help")))
(assert-true "core help request --help" (ro-help-help-request? '("--help")))
(assert-true "core help request -h" (ro-help-help-request? '("-h")))
(assert-true "core help request rejects item commands"
             (not (ro-help-help-request? '("items"))))
(assert-true "core command registry knows help"
             (ro-commands-command-known? "help"))
(assert-true "core command registry knows tasks"
             (ro-commands-command-known? "tasks"))
(assert-true "core command registry implements init"
             (ro-commands-command-implemented? 'init))
(assert-true "core command registry implements projects"
             (ro-commands-command-implemented? 'projects))
(assert-true "core command registry implements items"
             (ro-commands-command-implemented? 'items))
(assert-str= "core command registry root help first"
             "  ro help                   # show this help"
             (first ro-commands-command-root-help-lines))
(assert-str= "core command registry top command first"
             "agent"
             (first ro-commands-command-top-commands))
(assert-str= "core command registry kind tasks"
             "tasks"
             (symbol->string (ro-commands-command-kind-for-name "tasks")))
(assert-str= "core items help output starts with ro items"
             "ro items"
             (first (str/split-lines ro-items-items-help-output)))
(define sample-item-show-summary
  (ro-items-item-show-summary sample-item-show 2 15 true))
(assert-str= "core item show summary title"
             "Item One"
             (ro-json-json-field-value sample-item-show-summary "title" ""))
(assert-str= "core item show summary omits rank"
             ""
             (ro-json-json-field-value sample-item-show-summary "rank" ""))
(assert-num= "core item show summary worklog count"
             15
             (ro-json-json-field-value sample-item-show-summary "worklogCount" 0))

(define help-route (ro-route-main-route '()))
(define docs-route (ro-route-main-route '("docs")))
(define projects-route (ro-route-main-route '("projects")))
(define init-route (ro-route-main-route '("init")))
(define tasks-route (ro-route-main-route '("tasks")))
(define item-route (ro-route-main-route '("item-vvo")))
(define formatted-item-route (ro-route-main-route '("--format" "json" "item-vvo")))
(define completion-route (ro-route-main-route '("completion" "bash")))

(assert-str= "core route empty args"
             "help"
             (symbol->string (vector-ref help-route 0)))
(assert-num= "core route empty args payload count"
             0
             (count (vector-ref help-route 1)))
(assert-str= "core route docs"
             "docs"
             (symbol->string (vector-ref docs-route 0)))
(assert-num= "core route docs payload count"
             0
             (count (vector-ref docs-route 1)))
(assert-str= "core route projects"
             "projects"
             (symbol->string (vector-ref projects-route 0)))
(assert-num= "core route projects payload count"
             0
             (count (vector-ref projects-route 1)))
(assert-str= "core route init"
             "init"
             (symbol->string (vector-ref init-route 0)))
(assert-num= "core route init payload count"
             0
             (count (vector-ref init-route 1)))
(assert-str= "core route tasks"
             "tasks"
             (symbol->string (vector-ref tasks-route 0)))
(assert-num= "core route tasks payload count"
             0
             (count (vector-ref tasks-route 1)))
(assert-str= "core route item lookup"
             "item"
             (symbol->string (vector-ref item-route 0)))
(assert-num= "core route item lookup payload count"
             1
             (count (vector-ref item-route 1)))
(assert-str= "core route formatted item lookup"
             "item"
             (symbol->string (vector-ref formatted-item-route 0)))
(assert-num= "core route formatted item payload count"
             1
             (count (vector-ref formatted-item-route 1)))
(assert-str= "core route completion"
             "completion"
             (symbol->string (vector-ref completion-route 0)))
(assert-str= "core route completion payload"
             "bash"
             (first-entry (vector-ref completion-route 1)))

(def sample-event-line
  "{\"eventId\":\"evt-1\",\"workspaceId\":\"ws-1\",\"replicaId\":\"rep-1\",\"entityKind\":\"item\",\"entityId\":\"item-1\",\"entitySeq\":2,\"type\":\"item.create\",\"parents\":[\"parent-1\"],\"issuedAt\":\"2026-01-02T03:04:05Z\",\"actorId\":\"act-1\",\"payload\":{\"title\":\"Hello world\"},\"localStatus\":\"local\",\"serverStatus\":\"pending\",\"rejectionReason\":\"\",\"publishedAtUnixms\":123,\"hasPublishedAt\":true}")

(def sample-event-line-later
  "{\"eventId\":\"evt-2\",\"workspaceId\":\"ws-1\",\"replicaId\":\"rep-1\",\"entityKind\":\"item\",\"entityId\":\"item-2\",\"entitySeq\":3,\"type\":\"item.set_title\",\"parents\":[],\"issuedAt\":\"2026-01-03T03:04:05Z\",\"actorId\":\"act-2\",\"payload\":{\"title\":\"Later\"},\"localStatus\":\"local\",\"serverStatus\":\"pending\",\"rejectionReason\":\"\",\"publishedAtUnixms\":456,\"hasPublishedAt\":true}")

(define sample-event-record
  (ro-events-event-line->record "events.1.jsonl" 7 sample-event-line))

(define sample-doctor-record
  (ro-doctor-doctor-parse-event-record "events.1.jsonl" 7 sample-event-line))

(define sample-doctor-issue-from-record
  (ro-doctor-doctor-issue-from-record sample-event-record
                                      "error"
                                      "malformed_json"
                                      "malformed JSON"))

(assert-str= "core events record path"
             "events.1.jsonl"
             (ro-json-json-field-value sample-event-record "path" ""))
(assert-num= "core events record line"
             7
             (ro-json-json-field-value sample-event-record "line" 0))
(assert-str= "core events record event id"
             "evt-1"
             (ro-json-json-field-value sample-event-record "event_id" ""))
(assert-str= "core events record payload title"
             "Hello world"
             (ro-json-json-field-value (ro-json-json-field-value sample-event-record "payload" '())
                                       "title"
                                       ""))

(assert-str= "core doctor parse record event id"
             "evt-1"
             (ro-json-json-field-value sample-doctor-record "eventId" ""))
(assert-str= "core doctor issue from record path"
             "events.1.jsonl"
             (ro-json-json-field-value sample-doctor-issue-from-record "path" ""))
(assert-str= "core doctor issue from record level"
             "error"
             (ro-json-json-field-value sample-doctor-issue-from-record "level" ""))

(define sample-materialized-event
  (ro-events-event-materialize-record
   (lambda (issued-at) 4242)
   sample-event-record))

(assert-num= "core events materialized issued at"
             4242
             (ro-json-json-field-value sample-materialized-event "issued_at_unixms" 0))
(assert-str= "core events materialized payload json"
             "{\"title\":\"Hello world\"}"
             (ro-json-json-field-value sample-materialized-event "payload_json" ""))

(assert-true "core events record ordering"
             (ro-events-event-record<?
              sample-event-record
              (ro-events-event-line->record "events.1.jsonl" 8 sample-event-line-later)))

(define sorted-event-records
  (ro-events-events-sort-records
   (list (ro-events-event-line->record "events.1.jsonl" 8 sample-event-line-later)
         sample-event-record)))

(assert-str= "core events sort first id"
             "evt-1"
             (ro-json-json-field-value (first-entry sorted-event-records)
                                       "event_id"
                                       ""))

(assert-true "core sync status line unmerged UU"
             (ro-sync-git-status-line-unmerged? "UU"))
(assert-true "core sync status line unmerged DD"
             (ro-sync-git-status-line-unmerged? "DD"))

(define sync-status-flags
  (ro-sync-git-status-flags " M app.clk\nUU merge.clk\n"))
(define sync-ahead-behind
  (ro-sync-git-ahead-behind "3 5"))
(define sync-empty-status
  (ro-sync-git-sync-empty-status))

(assert-true "core sync status dirty flag"
             (first-entry sync-status-flags))
(assert-true "core sync status unmerged flag"
             (first-entry (rest sync-status-flags)))
(assert-num= "core sync ahead count"
             3
             (first-entry sync-ahead-behind))
(assert-num= "core sync behind count"
             5
             (first-entry (rest sync-ahead-behind)))
(assert-true "core sync empty status repo flag"
             (not (ro-json-json-field-value sync-empty-status "isRepo" true)))

(assert-str= "core reindex first recognized type"
             "identity.create"
             (first-entry ro-reindex-reindex-recognized-types))
(assert-true "core reindex recognizes item.create"
             (ro-reindex-reindex-type-recognized? "item.create"))
(assert-true "core reindex recognizes project.set_description"
             (ro-reindex-reindex-type-recognized? "project.set_description"))
(assert-true "core reindex rejects unknown type"
             (not (ro-reindex-reindex-type-recognized? "bogus.type")))

(assert-str= "core doctor event entity kind"
             "item"
             (ro-doctor-doctor-event-entity-kind "item.create"))

(define sample-doctor-issue-1
  (vector (cons 'level "error")
          (cons 'code "duplicate_event_id")
          (cons 'message "duplicate event id")
          (cons 'path "events/one.jsonl")
          (cons 'line 4)
          (cons 'eventId "evt-1")
          (cons 'entityKind "item")
          (cons 'entityId "item-1")
          (cons 'type "item.create")))

(define sample-doctor-issue-2
  (vector (cons 'level "error")
          (cons 'code "duplicate_event_id")
          (cons 'message "duplicate event id")
          (cons 'path "events/one.jsonl")
          (cons 'line 9)
          (cons 'eventId "evt-1")
          (cons 'entityKind "item")
          (cons 'entityId "item-2")
          (cons 'type "item.set_title")))

(define sample-doctor-issue-3
  (vector (cons 'level "warn")
          (cons 'code "multiple_parents")
          (cons 'message "event has 2 parents")
          (cons 'path "events/two.jsonl")
          (cons 'line 12)
          (cons 'eventId "evt-2")
          (cons 'entityKind "item")
          (cons 'entityId "item-3")
          (cons 'type "item.set_title")))

(define sample-doctor-issues
  (list sample-doctor-issue-1
        sample-doctor-issue-2
        sample-doctor-issue-3))

(define sample-doctor-summary
  (ro-doctor-doctor-summary-from-issues sample-doctor-issues))

(define sample-doctor-dedupe-plan
  (ro-doctor-doctor-dedupe-plan-from-issues sample-doctor-issues))

(assert-true "core doctor has errors"
             (ro-doctor-doctor-has-errors? sample-doctor-issues))
(assert-true "core doctor ignores warning-only issues"
             (not (ro-doctor-doctor-has-errors? (list sample-doctor-issue-3))))
(assert-num= "core doctor summary total"
             3
             (ro-json-json-field-value sample-doctor-summary "total" 0))
(assert-num= "core doctor summary error count"
             2
             (ro-json-json-field-value
              (first-entry (ro-json-json-field-value sample-doctor-summary "byLevel" '()))
              "count"
              0))
(assert-num= "core doctor summary duplicate code count"
             2
             (ro-json-json-field-value
              (first-entry (ro-json-json-field-value sample-doctor-summary "byCode" '()))
              "count"
              0))
(assert-str= "core doctor summary top duplicate event id"
             "evt-1"
             (ro-json-json-field-value
              (first-entry (ro-json-json-field-value sample-doctor-summary "topDuplicateEventIds" '()))
              "eventId"
              ""))
(assert-num= "core doctor dedupe duplicate issue count"
             2
             (ro-json-json-field-value sample-doctor-dedupe-plan "duplicateIssueCount" 0))
(assert-num= "core doctor dedupe file count"
             1
             (ro-json-json-field-value sample-doctor-dedupe-plan "fileCount" 0))
(assert-num= "core doctor dedupe removed lines"
             2
             (ro-json-json-field-value sample-doctor-dedupe-plan "removedLines" 0))
(assert-str= "core doctor dedupe file path"
             "events/one.jsonl"
             (ro-json-json-field-value
              (first-entry (ro-json-json-field-value sample-doctor-dedupe-plan "files" '()))
              "path"
              ""))
(assert-num= "core doctor dedupe remove count"
             2
             (ro-json-json-field-value
              (first-entry (ro-json-json-field-value sample-doctor-dedupe-plan "files" '()))
              "removeCount"
              0))

(assert-str= "core completion bash dispatch"
             ro-help-completion-bash-output
             (ro-help-completion-output "bash"))
(assert-str= "core completion zsh dispatch"
             ro-help-completion-zsh-output
             (ro-help-completion-output "zsh"))
(assert-str= "core completion fish dispatch"
             ro-help-completion-fish-output
             (ro-help-completion-output "fish"))
(assert-true "core completion rejects unknown shell"
             (not (ro-help-completion-output "powershell")))

(assert-str= "core compact json text"
             "{\"a\":\"b c\",\"nested\":{\"x\":1}}"
             (ro-json-compact-json-text "{ \"a\" : \"b c\" , \"nested\" : { \"x\" : 1 } }"))

(assert-true "core workspace current info"
             (equal? (ro-workspace-current-info sample-workspace-root)
                     (cons "alpha" "/tmp/alpha")))
(assert-str= "core workspace current name"
             "alpha"
             (ro-workspace-current-name sample-workspace-root))
(assert-str= "core workspace current path"
             "/tmp/alpha"
             (ro-workspace-current-path sample-workspace-root))

(define workspace-current-output-value
  (ro-workspace-current-output "alpha" "/tmp/alpha"))
(define workspace-current-output-data
  (output-data workspace-current-output-value))

(assert-str= "core workspace current output workspace"
             "alpha"
             (ro-json-json-field-value workspace-current-output-data "workspace" ""))
(assert-str= "core workspace current output dir"
             "/tmp/alpha"
             (ro-json-json-field-value workspace-current-output-data "dir" ""))

(define sample-project-summary
  (ro-projects-project-summary sample-project))

(assert-str= "core projects summary id"
             "proj-1"
             (ro-json-json-field-value sample-project-summary "id" ""))
(assert-str= "core projects summary name"
             "Project One"
             (ro-json-json-field-value sample-project-summary "name" ""))
(assert-str= "core projects summary description"
             "The project"
             (ro-json-json-field-value sample-project-summary "description" ""))
(assert-true "core projects summary archived false"
             (not (ro-json-json-field-value sample-project-summary "archived" true)))

(define sample-project-list-output
  (ro-projects-projects-list-output (list sample-project sample-project-alpha)))
(define sample-project-list-data
  (output-data sample-project-list-output))

(assert-num= "core projects list count"
             2
             (count sample-project-list-data))
(assert-str= "core projects list first id"
             "proj-0"
             (ro-json-json-field-value (first-entry sample-project-list-data) "id" ""))
(assert-str= "core projects list first name"
             "Annet"
