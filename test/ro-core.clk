(assert-plan-case-table
 "core workspace planner"
 (list
  {:label "status"
   :plan-fn ro-workspace-status-main-plan
   :args '()
   :expected "{:ok? true, :effects [[:status/show {}]]}"}
  {:label "status help"
   :plan-fn ro-workspace-status-main-plan
   :args '("--help")
   :expected "{:ok? true, :effects [[:status/help {}]]}"}
  {:label "workspace current"
   :plan-fn ro-workspace-workspace-main-plan
   :args '("current")
   :expected "{:ok? true, :effects [[:workspace/current {}]]}"}
  {:label "workspace help"
   :plan-fn ro-workspace-workspace-main-plan
   :args '("help")
   :expected "{:ok? true, :effects [[:workspace/help {}]]}"}
  {:label "workspace add"
   :plan-fn ro-workspace-workspace-main-plan
   :args '("add" "alpha" "--dir" "/tmp/alpha" "--use")
   :expected "{:ok? true, :effects [[:workspace/add {:name \"alpha\", :dir \"/tmp/alpha\", :kind \"git\", :use? true}]]}"}
  {:label "workspace add missing dir"
   :plan-fn ro-workspace-workspace-main-plan
   :args '("add" "alpha")
   :expected "{:ok? false, :error \"missing --dir\", :command (\"alpha\")}"}
  {:label "workspace add help"
   :plan-fn ro-workspace-workspace-add-plan
   :args '("--help")
   :expected (string-append "{:ok? true, :effects [[:workspace/subhelp {:usage "
                            (pr-str ro-workspace/workspace-add-usage-output)
                            ", :root? true}]]}")}
  {:label "workspace init"
   :plan-fn ro-workspace-workspace-main-plan
   :args '("init" "beta" "--dir" "/tmp/beta")
   :expected "{:ok? true, :effects [[:workspace/init {:name \"beta\", :dir \"/tmp/beta\", :use? false}]]}"}
  {:label "workspace init help"
   :plan-fn ro-workspace-workspace-init-plan
   :args '("--help")
   :expected (string-append "{:ok? true, :effects [[:workspace/subhelp {:usage "
                            (pr-str ro-workspace/workspace-init-usage-output)
                            ", :root? true}]]}")}
  {:label "workspace use"
   :plan-fn ro-workspace-workspace-main-plan
   :args '("use" "gamma")
   :expected "{:ok? true, :effects [[:workspace/use {:name \"gamma\"}]]}"}
  {:label "workspace use help"
   :plan-fn ro-workspace-workspace-use-plan
   :args '("--help")
   :expected (string-append "{:ok? true, :effects [[:workspace/subhelp {:usage "
                            (pr-str ro-workspace/workspace-use-usage-output)
                            ", :root? false}]]}")}
  {:label "init"
   :plan-fn ro-workspace-init-main-plan
   :args '()
   :expected "{:ok? true, :effects [[:init/run {}]]}"}
  {:label "identity list"
   :plan-fn ro-workspace-identity-main-plan
   :args '("list")
   :expected "{:ok? true, :effects [[:identity/list {}]]}"}
  {:label "identity help"
   :plan-fn ro-workspace-identity-main-plan
   :args '("list" "--help")
   :expected "{:ok? true, :effects [[:identity/help {}]]}"}))

