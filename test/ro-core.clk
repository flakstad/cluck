(defn parse-output
  [output]
  (json/json-read (open-input-string output)))

(defn output-data
  [output]
  (ro-json-json-field-value (parse-output output) "data" '()))

(defn first-entry
  [value]
  (cond
    (vector? value) (vector-ref value 0)
    (pair? value) (car (seq value))
    :else value))

(defn assert-plan-pr-str=
  [label expected plan]
  (let [expected-value (read (open-input-string expected))
        normalized-expected (normalize-json-value expected-value)
        normalized-plan (normalize-json-value plan)
        expected-text (pr-str normalized-expected)
        actual-text (pr-str normalized-plan)]
    (if (string=? expected-text actual-text)
        (pass label)
        (fail label expected-text actual-text))))

(defn assert-plan-case-table
  [prefix cases]
  (let loop ((xs cases))
    (if (empty? xs)
        true
        (let ((entry (first xs)))
          (assert-plan-pr-str=
           (string-append prefix " " (get entry :label ""))
           (get entry :expected "")
           ((get entry :plan-fn) (get entry :args '())))
          (loop (rest xs))))))

(defn json-key-text
  [key]
  (cond
    (string? key) key
    (keyword? key) (name key)
    (symbol? key) (symbol->string key)
    :else (str key)))

(defn json-object-like?
  [value]
  (let [items (cond
                (map? value) (seq value)
                (vector? value) (vector->list value)
                (pair? value) (seq value)
                :else '())]
    (and (not (empty? items))
         (every? pair? items))))

(defn normalize-json-value
  [value]
  (cond
    (json-object-like? value)
    (let [items (cond
                  (map? value) (seq value)
                  (vector? value) (vector->list value)
                  (pair? value) (seq value)
                  :else '())
          sorted (cluck-sort-list items
                                  (lambda (a b)
                                    (string<? (json-key-text (car a))
                                              (json-key-text (car b)))))]
      (map (lambda (entry)
             (let [key (car entry)]
               (cons key (normalize-json-value (cdr entry)))))
           sorted))

    (vector? value)
    (map normalize-json-value (vector->list value))

    (pair? value)
    (map normalize-json-value (seq value))

    :else value))

(defn alist-get
  [entries key]
  (let loop ((xs entries))
    (cond
      (empty? xs) false
      (string=? (car (first xs)) key) (first xs)
      :else (loop (rest xs)))))

(defn assert-json=
  [label expected actual]
  (if (equal? (normalize-json-value expected)
              (normalize-json-value actual))
      (pass label)
      (fail label expected actual)))

(def sample-detail
  (vector (cons 'name "alpha")
          (cons 'path "/tmp/alpha")))

(def sample-workspace-root
  (vector
   (cons 'data
         (vector (cons 'currentWorkspace "alpha")))
   (cons 'meta
         (vector (cons 'details
                       (vector sample-detail))))))

(def sample-agent
  (vector (cons 'id "actor-1")
          (cons 'name "Agent One")
          (cons 'kind "agent")
          (cons 'userId "human-1")
          (cons 'session "sess-1")))

(def sample-human
  (vector (cons 'id "human-1")
          (cons 'name "Human One")
          (cons 'kind "human")
          (cons 'userId "")
          (cons 'session "")))

(def sample-actors
  (list sample-agent sample-human))

